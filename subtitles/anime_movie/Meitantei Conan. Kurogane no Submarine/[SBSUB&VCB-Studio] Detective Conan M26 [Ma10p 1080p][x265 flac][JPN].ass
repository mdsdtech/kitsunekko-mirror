Dialogue: 0,0:00:20.75,0:00:22.85,DefaultSingle-J,,0,0,0,,		ダメ  そっちに逃げないで	
Dialogue: 0,0:00:24.84,0:00:26.91,DefaultSingle-J,,0,0,0,,		せめて  私に捕まって…	
Dialogue: 0,0:00:27.69,0:00:29.35,DefaultSingle-J,,0,0,0,,		ニーナ  何があったの	
Dialogue: 0,0:00:29.35,0:00:30.77,DefaultSingle-J,,0,0,0,,		状況を報告して	
Dialogue: 0,0:00:31.14,0:00:34.11,DefaultSingle-J,,0,0,0,,		センターに侵入した犯人の仲間に追われてるの	
Dialogue: 0,0:00:34.78,0:00:37.05,DefaultSingle-J,,0,0,0,,		侵入？  誰が侵入したの	
Dialogue: 0,0:00:43.25,0:00:44.62,DefaultSingle-J,,0,0,0,,		ニーナ  大丈夫？	
Dialogue: 0,0:00:54.92,0:00:55.70,DefaultSingle-J,,0,0,0,,		ニーナ	
Dialogue: 0,0:01:00.26,0:01:01.50,DefaultSingle-J,,0,0,0,,		ニーナ  今のは何	
Dialogue: 0,0:01:01.83,0:01:02.67,DefaultSingle-J,,0,0,0,,		ニーナ	
Dialogue: 0,0:01:03.17,0:01:05.50,M26-ForeignSpeak-Chi-C,,0,0,0,,			
Dialogue: 1,0:01:03.17,0:01:05.50,M26-ForeignSpeak-Ger-C,,0,0,0,,	
Dialogue: 0,0:01:08.59,0:01:10.26,M26-ForeignSpeak-Chi-C,,0,0,0,,			
Dialogue: 1,0:01:08.59,0:01:10.26,M26-ForeignSpeak-Ger-C,,0,0,0,,	
Dialogue: 0,0:01:32.99,0:01:33.86,DefaultSingle-J,,0,0,0,,		ジン	
Dialogue: 0,0:01:36.04,0:01:38.66,DefaultSingle-J,,0,0,0,,		モタモタしてんじゃねえ  キール	
Dialogue: 0,0:01:39.03,0:01:40.46,DefaultSingle-J,,0,0,0,,		え…  ええ	
Dialogue: 0,0:01:57.95,0:01:59.52,DefaultSingle-J,,0,0,0,,		状況はどうです	
Dialogue: 0,0:01:59.78,0:02:02.70,DefaultSingle-J,,0,0,0,,		今のところ  うまくいってるみたいよ	
Dialogue: 0,0:02:03.39,0:02:04.44,DefaultSingle-J,,0,0,0,,		あとは…	
Dialogue: 0,0:02:04.76,0:02:08.15,DefaultSingle-J,,0,0,0,,		例のシステムで  この男を捜さないとね	
Dialogue: 0,0:02:09.02,0:02:10.58,DefaultSingle-J,,0,0,0,,		時間の問題でしょ	
Dialogue: 0,0:02:10.61,0:02:11.18,DefaultSingle-J,,0,0,0,,		ん？	
Dialogue: 0,0:02:13.72,0:02:15.99,DefaultSingle-J,,0,0,0,,		うわあ  すっげー	
Dialogue: 0,0:02:15.99,0:02:18.63,DefaultSingle-J,,0,0,0,,		1等はホエールウォッチングだってよ	
Dialogue: 0,0:02:18.63,0:02:20.54,DefaultSingle-J,,0,0,0,,		ぜってー当てようぜ	
Dialogue: 0,0:02:20.54,0:02:24.25,DefaultSingle-J,,0,0,0,,		はい  福引は1人1回しか引けませんからね	
Dialogue: 0,0:02:24.25,0:02:25.71,DefaultSingle-J,,0,0,0,,		クジラさんに会いたい	
Dialogue: 0,0:02:25.71,0:02:27.86,DefaultSingle-J,,0,0,0,,		イルカも「いるか」もな	
Dialogue: 0,0:02:28.88,0:02:30.15,DefaultSingle-J,,0,0,0,,		博士かよ	
Dialogue: 0,0:02:31.46,0:02:33.30,DefaultSingle-J,,0,0,0,,		おい  どこ行くんだ	
Dialogue: 0,0:02:33.60,0:02:34.78,DefaultSingle-J,,0,0,0,,		すぐ戻るわ	
Dialogue: 0,0:02:36.31,0:02:37.77,DefaultSingle-J,,0,0,0,,		ありがとうございます	
Dialogue: 0,0:02:39.40,0:02:40.40,DefaultSingle-J,,0,0,0,,		どうぞ	
Dialogue: 0,0:02:40.56,0:02:41.56,DefaultSingle-J,,0,0,0,,		ありがとう	
Dialogue: 0,0:02:41.83,0:02:47.04,DefaultSingle-J,,0,0,0,,		はい  以上で限定ブローチ販売整理券配布は終了となります	
Dialogue: 0,0:02:47.98,0:02:49.91,DefaultSingle-J,,0,0,0,,		やだぁ  残念	
Dialogue: 0,0:02:51.73,0:02:54.30,DefaultSingle-J,,0,0,0,,		本当にどうにもなりませんの	
Dialogue: 0,0:02:54.39,0:02:57.49,DefaultSingle-J,,0,0,0,,		電車で1時間かけて参りましたのに…	
Dialogue: 0,0:02:57.96,0:03:02.76,DefaultSingle-J,,0,0,0,,		誠に申し訳ございません  数量限定のお品となっております	
Dialogue: 0,0:03:03.65,0:03:05.02,DefaultSingle-J,,0,0,0,,		分かりました	
Dialogue: 0,0:03:07.07,0:03:07.92,DefaultSingle-J,,0,0,0,,		待って	
Dialogue: 0,0:03:09.42,0:03:10.37,DefaultSingle-J,,0,0,0,,		どうしたの	
Dialogue: 0,0:03:11.08,0:03:12.30,DefaultSingle-J,,0,0,0,,		これ  どうぞ	
Dialogue: 0,0:03:13.08,0:03:13.47,DefaultSingle-J,,0,0,0,,		えっ？	
Dialogue: 0,0:03:13.94,0:03:16.05,DefaultSingle-J,,0,0,0,,		まあ  いいのよ  そんな	
Dialogue: 0,0:03:17.51,0:03:20.04,DefaultSingle-J,,0,0,0,,		実は値段ちゃんと見てなくて	
Dialogue: 0,0:03:20.23,0:03:21.93,DefaultSingle-J,,0,0,0,,		私には高かったから	
Dialogue: 0,0:03:22.19,0:03:23.09,DefaultSingle-J,,0,0,0,,		まあ	
Dialogue: 0,0:03:28.50,0:03:31.32,DefaultSingle-J,,0,0,0,,		その様子じゃ  どうやら外れたようね	
Dialogue: 0,0:03:31.60,0:03:33.30,DefaultSingle-J,,0,0,0,,		全員もれなくな	
Dialogue: 0,0:03:34.16,0:03:35.58,DefaultSingle-J,,0,0,0,,		ガビョ〜ン	
Dialogue: 0,0:03:35.58,0:03:37.16,DefaultSingle-J,,0,0,0,,		ダメじゃったのか	
Dialogue: 0,0:03:37.51,0:03:39.97,DefaultSingle-J,,0,0,0,,		せっかく間に合わせたんじゃがなぁ	
Dialogue: 0,0:03:39.97,0:03:40.70,DefaultSingle-J,,0,0,0,,		え？	
Dialogue: 0,0:03:40.98,0:03:42.20,DefaultSingle-J,,0,0,0,,		あれじゃよ	
Dialogue: 0,0:03:42.44,0:03:44.16,DefaultSingle-J,,0,0,0,,		水中スクーターじゃ	
Dialogue: 0,0:03:44.16,0:03:47.83,DefaultSingle-J,,0,0,0,,		市販のものとは違って  自動運転機能もあるし	
Dialogue: 0,0:03:47.83,0:03:49.62,DefaultSingle-J,,0,0,0,,		30メートル以上潜れるぞい	
Dialogue: 0,0:03:49.62,0:03:50.46,DefaultSingle-J,,0,0,0,,		すごい	
Dialogue: 0,0:03:50.46,0:03:51.09,DefaultSingle-J,,0,0,0,,		うお	
Dialogue: 0,0:03:51.09,0:03:52.29,DefaultSingle-J,,0,0,0,,		カッコいいですね	
Dialogue: 0,0:03:53.10,0:03:55.65,DefaultSingle-J,,0,0,0,,		おいおい  30メートルは危ねえって	
Dialogue: 0,0:03:55.96,0:03:58.08,DefaultSingle-J,,0,0,0,,		そう言われると思っての	
Dialogue: 0,0:04:02.22,0:04:04.18,DefaultSingle-J,,0,0,0,,		減圧症になりにくいボンベ	
Dialogue: 0,0:04:04.18,0:04:06.68,DefaultSingle-J,,0,0,0,,		と無線を1つにしたすぐれものじゃ	
Dialogue: 0,0:04:07.13,0:04:11.25,DefaultSingle-J,,0,0,0,,		しかも水中スクーターのヘッドは  着せ替え可能なんじゃぞい	
Dialogue: 0,0:04:13.49,0:04:15.22,DefaultSingle-J,,0,0,0,,		博士すげー	
Dialogue: 0,0:04:14.19,0:04:16.16,DefaultSingle-J,,0,0,0,,		イルカさんかわいい	
Dialogue: 0,0:04:17.72,0:04:19.36,DefaultSingle-J,,0,0,0,,		盛り上がってんね	
Dialogue: 0,0:04:19.61,0:04:20.67,DefaultSingle-J,,0,0,0,,		ねえ  みんな	
Dialogue: 0,0:04:20.67,0:04:24.37,DefaultSingle-J,,0,0,0,,		八丈島のホエールウォッチングツアー  行きたいんでしょ	
Dialogue: 0,0:04:24.37,0:04:26.25,DefaultSingle-J,,0,0,0,,		えっ  なんでそれを？	
Dialogue: 0,0:04:26.25,0:04:27.37,DefaultSingle-J,,0,0,0,,		エスパーか	
Dialogue: 0,0:04:28.68,0:04:32.42,DefaultSingle-J,,0,0,0,,		園子のお父さんのホテルが八丈島にあるんだって	
Dialogue: 0,0:04:32.42,0:04:34.87,DefaultSingle-J,,0,0,0,,		来ると思ったぜ  この展開	
Dialogue: 0,0:04:34.87,0:04:36.10,DefaultSingle-J,,0,0,0,,		もしかして	
Dialogue: 0,0:04:36.10,0:04:37.24,DefaultSingle-J,,0,0,0,,		ボク達を	
Dialogue: 0,0:04:37.24,0:04:38.80,DefaultSingle-J,,0,0,0,,		連れてってくれるのか	
Dialogue: 0,0:04:38.80,0:04:42.93,DefaultSingle-J,,0,0,0,,		あのねえ  これは  この子へのごほうびだからね	
Dialogue: 0,0:04:43.28,0:04:43.79,DefaultSingle-J,,0,0,0,,		え	
Dialogue: 0,0:04:44.89,0:04:47.80,DefaultSingle-J,,0,0,0,,		ちょっとすましたガキだと思ってたけど	
Dialogue: 0,0:04:48.12,0:04:49.89,DefaultSingle-J,,0,0,0,,		優しいとこあんじゃん	
Dialogue: 0,0:04:52.90,0:04:56.55,DefaultSingle-J,,0,0,0,,		あの  それは子供達だけのごほうびでしょうか	
Dialogue: 0,0:04:56.55,0:04:59.66,DefaultSingle-J,,0,0,0,,		もちろん博士も引率役として来てもらいます	
Dialogue: 0,0:04:59.66,0:05:00.91,DefaultSingle-J,,0,0,0,,		やった	
Dialogue: 0,0:05:01.40,0:05:02.69,DefaultSingle-J,,0,0,0,,		よかったね  博士	
Dialogue: 0,0:00:00.00,0:00:00.00,DefaultSingle-J,,0,0,0,,		いやあ  園子さん優しいなあ	
Dialogue: 0,0:05:13.92,0:05:16.46,DefaultSingle-J,,0,0,0,,		あっ  見えた  八丈島	
Dialogue: 0,0:05:16.76,0:05:19.62,DefaultSingle-J,,0,0,0,,		すっげー  でっけえ山がある	
Dialogue: 0,0:05:19.62,0:05:23.14,DefaultSingle-J,,0,0,0,,		確か…  八丈富士っていう山ですよ	
Dialogue: 0,0:05:24.20,0:05:25.35,DefaultSingle-J,,0,0,0,,		ほんとだ	
Dialogue: 2,0:05:25.57,0:05:27.14,DefaultSingle-J,,0,0,0,,		楽しみだね	
Dialogue: 2,0:05:27.14,0:05:28.35,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,0:05:36.61,0:05:38.49,DefaultSingle-J,,0,0,0,,		八丈富士でっけー	
Dialogue: 0,0:05:38.49,0:05:39.91,DefaultSingle-J,,0,0,0,,		すごい	
Dialogue: 0,0:05:40.26,0:05:41.47,DefaultSingle-J,,0,0,0,,		何見てんだ	
Dialogue: 0,0:05:42.03,0:05:45.97,DefaultSingle-J,,0,0,0,,		ここの近くにインターポールの新しい施設ができたんだって  はい	
Dialogue: 0,0:05:47.11,0:05:47.61,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,0:05:48.03,0:05:52.37,DefaultSingle-J,,0,0,0,,		世界中の警察が持つ防犯カメラをつないだ世界初の施設	
Dialogue: 0,0:05:52.77,0:05:54.63,DefaultSingle-J,,0,0,0,,		それが「パシフィック・ブイ」です	
Dialogue: 0,0:05:55.08,0:05:57.32,DefaultSingle-J,,0,0,0,,		防犯カメラの画像を元に	
Dialogue: 0,0:05:57.33,0:05:59.68,DefaultSingle-J,,0,0,0,,		世界中で顔認証が可能とか？	
Dialogue: 0,0:05:59.68,0:06:00.55,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,0:06:01.12,0:06:03.15,DefaultSingle-J,,0,0,0,,		その開発者である彼女も	
Dialogue: 0,0:06:03.30,0:06:05.78,DefaultSingle-J,,0,0,0,,		パシフィック・ブイの一員として  参加します	
Dialogue: 0,0:06:05.78,0:06:07.80,DefaultSingle-J,,0,0,0,,		この人  どこかで…	
Dialogue: 0,0:06:13.06,0:06:13.77,DefaultSingle-J,,0,0,0,,		ここじゃ	
Dialogue: 0,0:06:14.82,0:06:15.92,DefaultSingle-J,,0,0,0,,		着いた	
Dialogue: 0,0:06:16.85,0:06:18.75,DefaultSingle-J,,0,0,0,,		いや  でっけえホテル	
Dialogue: 0,0:06:18.75,0:06:20.03,DefaultSingle-J,,0,0,0,,		ステキ	
Dialogue: 0,0:06:20.03,0:06:21.78,DefaultSingle-J,,0,0,0,,		キレイですね	
Dialogue: 0,0:06:26.05,0:06:27.70,DefaultSingle-J,,0,0,0,,		なんで白鳥警部が…	
Dialogue: 0,0:06:30.22,0:06:31.76,DefaultSingle-J,,0,0,0,,		でっけえクジラ	
Dialogue: 0,0:06:31.76,0:06:33.41,DefaultSingle-J,,0,0,0,,		カメもいますね	
Dialogue: 0,0:06:33.41,0:06:35.42,DefaultSingle-J,,0,0,0,,		イルカさんかわいい	
Dialogue: 0,0:06:35.52,0:06:36.73,DefaultSingle-J,,0,0,0,,		じゃあみんな	
Dialogue: 0,0:06:36.73,0:06:40.45,DefaultSingle-J,,0,0,0,,		部屋に荷物置いたら  1時間後にまたここに集合ね	
Dialogue: 0,0:06:40.45,0:06:41.73,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,0:06:42.85,0:06:46.17,DefaultSingle-J,,0,0,0,,		白鳥警部が？  見間違いじゃないの？	
Dialogue: 0,0:06:46.30,0:06:49.43,DefaultSingle-J,,0,0,0,,		ううん  確かに白鳥警部だったよ	
Dialogue: 0,0:06:50.75,0:06:52.10,DefaultSingle-J,,0,0,0,,		何かしらね	
Dialogue: 0,0:06:56.54,0:06:59.75,DefaultSingle-J,,0,0,0,,		そろそろ八丈島に着いた頃だと思ってね	
Dialogue: 0,0:07:00.95,0:07:03.26,DefaultSingle-J,,0,0,0,,		ボウヤはドイツのフランクフルトに	
Dialogue: 0,0:07:03.46,0:07:07.57,DefaultSingle-J,,0,0,0,,		ユーロポール防犯カメラネットワークセンターがあるのを知っているかな	
Dialogue: 0,0:07:07.85,0:07:09.92,DefaultSingle-J,,0,0,0,,		うん  それがどうしたの	
Dialogue: 0,0:07:09.92,0:07:13.08,DefaultSingle-J,,0,0,0,,		そこに最近  何者かが侵入してね	
Dialogue: 0,0:07:13.33,0:07:16.94,DefaultSingle-J,,0,0,0,,		その侵入者を目撃したユーロポールの職員が	
Dialogue: 0,0:07:17.18,0:07:18.75,DefaultSingle-J,,0,0,0,,		ジンに殺された	
Dialogue: 0,0:07:18.90,0:07:19.76,DefaultSingle-J,,0,0,0,,		ジンに？	
Dialogue: 0,0:07:20.11,0:07:23.85,DefaultSingle-J,,0,0,0,,		ヤツらの組織に潜入捜査してるキールからの情報だ	
Dialogue: 0,0:07:24.29,0:07:27.34,DefaultSingle-J,,0,0,0,,		じゃあ  その侵入者って  黒ずくめの…	
Dialogue: 0,0:07:28.24,0:07:29.07,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,0:07:29.55,0:07:32.09,DefaultSingle-J,,0,0,0,,		髪をコーンロウに編み上げたヤツで	
Dialogue: 0,0:07:32.09,0:07:33.39,DefaultSingle-J,,0,0,0,,		コードネームは…	
Dialogue: 0,0:07:34.10,0:07:35.05,DefaultSingle-J,,0,0,0,,		ピンガ	
Dialogue: 0,0:07:35.62,0:07:38.46,DefaultSingle-J,,0,0,0,,		ラムに気に入られてると聞いたことがある	
Dialogue: 0,0:07:38.86,0:07:40.52,DefaultSingle-J,,0,0,0,,		どうしてそれをボクに	
Dialogue: 0,0:07:40.70,0:07:44.55,DefaultSingle-J,,0,0,0,,		今日そのセンターと回線をつないで  本格始動するのが	
Dialogue: 0,0:07:44.78,0:07:47.25,DefaultSingle-J,,0,0,0,,		その近くにあるパシフィック・ブイだ	
Dialogue: 0,0:07:47.97,0:07:49.88,DefaultSingle-J,,0,0,0,,		君なら気になると思ってね	
Dialogue: 0,0:07:50.46,0:07:52.29,DefaultSingle-J,,0,0,0,,		あっ  赤井さん	
Dialogue: 0,0:07:56.33,0:07:59.13,DefaultSingle-J,,0,0,0,,		ジン  ウォッカ  コルン	
Dialogue: 0,0:07:59.49,0:08:02.54,DefaultSingle-J,,0,0,0,,		アイリッシュ  ピスコ  テキーラ	
Dialogue: 0,0:08:02.94,0:08:04.36,DefaultSingle-J,,0,0,0,,		そしてピンガ	
Dialogue: 0,0:08:05.88,0:08:09.29,DefaultSingle-J,,0,0,0,,		蒸留酒の名前がついたメンバーは  すべて男	
Dialogue: 0,0:08:10.43,0:08:13.96,DefaultSingle-J,,0,0,0,,		そしてピンガは  ラムと同じ原料の酒…	
Dialogue: 0,0:08:14.78,0:08:16.34,DefaultSingle-J,,0,0,0,,		イヤな予感がする	
Dialogue: 0,0:08:40.86,0:08:43.67,DefaultSingle-J,,0,0,0,,		オレは高校生探偵工藤新一	
Dialogue: 0,0:08:45.37,0:08:49.70,DefaultSingle-J,,0,0,0,,		幼なじみで同級生の毛利蘭と遊園地に遊びに行って	
Dialogue: 0,0:08:50.04,0:08:53.98,DefaultSingle-J,,0,0,0,,		黒ずくめの男の  あやしげな取引現場を目撃した	
Dialogue: 0,0:08:55.27,0:08:57.66,DefaultSingle-J,,0,0,0,,		取引を見るのに夢中になっていたオレは	
Dialogue: 0,0:08:58.16,0:09:02.26,DefaultSingle-J,,0,0,0,,		背後から近づいてくるもう一人の仲間に気づかなかった	
Dialogue: 0,0:09:05.61,0:09:09.57,DefaultSingle-J,,0,0,0,,		オレはその男に毒薬をのまされ  目が覚めたら…	
Dialogue: 0,0:09:10.97,0:09:13.10,DefaultSingle-J,,0,0,0,,		体が縮んでしまっていた	
Dialogue: 0,0:09:14.16,0:09:16.90,DefaultSingle-J,,0,0,0,,		工藤新一が生きているとヤツらにバレたら	
Dialogue: 0,0:09:17.20,0:09:20.84,DefaultSingle-J,,0,0,0,,		また命が狙われ  周りの人間にも危害がおよぶ	
Dialogue: 0,0:09:24.26,0:09:27.56,DefaultSingle-J,,0,0,0,,		阿笠博士の助言で正体を隠すことにしたオレは	
Dialogue: 0,0:09:28.18,0:09:30.61,DefaultSingle-J,,0,0,0,,		蘭に名前を聞かれて  とっさに	
Dialogue: 0,0:09:31.06,0:09:33.21,DefaultSingle-J,,0,0,0,,		「江戸川コナン」と名乗り	
Dialogue: 0,0:09:34.67,0:09:36.66,DefaultSingle-J,,0,0,0,,		ヤツらの情報をつかむため	
Dialogue: 0,0:09:36.66,0:09:40.10,DefaultSingle-J,,0,0,0,,		父親が探偵をやっている  蘭の家に転がり込んだ	
Dialogue: 0,0:09:42.85,0:09:44.34,DefaultSingle-J,,0,0,0,,		彼女は灰原哀	
Dialogue: 0,0:09:44.87,0:09:47.05,DefaultSingle-J,,0,0,0,,		黒ずくめの組織の科学者で	
Dialogue: 0,0:09:47.10,0:09:50.83,DefaultSingle-J,,0,0,0,,		例の毒薬  APTX4869の開発者	
Dialogue: 0,0:09:52.31,0:09:56.45,DefaultSingle-J,,0,0,0,,		だが  姉を殺害されたことから  組織に反抗	
Dialogue: 0,0:09:57.26,0:10:00.02,DefaultSingle-J,,0,0,0,,		命を絶つため  その薬をのんだところ	
Dialogue: 0,0:10:01.05,0:10:02.98,DefaultSingle-J,,0,0,0,,		体が縮んでしまった	
Dialogue: 0,0:10:04.02,0:10:07.77,DefaultSingle-J,,0,0,0,,		今はヤツらの目を逃れるため  阿笠博士の家に住んでいる	
Dialogue: 0,0:10:10.16,0:10:12.86,DefaultSingle-J,,0,0,0,,		謎に包まれた黒ずくめの組織	
Dialogue: 0,0:10:13.77,0:10:14.52,DefaultSingle-J,,0,0,0,,		ジン	
Dialogue: 0,0:10:14.95,0:10:15.94,DefaultSingle-J,,0,0,0,,		ウォッカ	
Dialogue: 0,0:10:16.15,0:10:17.35,DefaultSingle-J,,0,0,0,,		ベルモット	
Dialogue: 0,0:10:17.44,0:10:18.75,DefaultSingle-J,,0,0,0,,		キャンティ  コルン	
Dialogue: 0,0:10:19.23,0:10:21.67,DefaultSingle-J,,0,0,0,,		そしてバーボン  キール	
Dialogue: 0,0:10:22.76,0:10:25.64,DefaultSingle-J,,0,0,0,,		この2人は  組織に潜入している	
Dialogue: 0,0:10:25.64,0:10:28.26,DefaultSingle-J,,0,0,0,,		公安警察官  降谷零と	
Dialogue: 0,0:10:29.34,0:10:33.26,DefaultSingle-J,,0,0,0,,		アメリカ中央情報局CIAの  水無怜奈	
Dialogue: 0,0:10:35.04,0:10:38.85,DefaultSingle-J,,0,0,0,,		同じくヤツらを追う  アメリカ連邦捜査局	
Dialogue: 0,0:10:38.86,0:10:40.27,DefaultSingle-J,,0,0,0,,		赤井秀一	
Dialogue: 0,0:10:41.32,0:10:43.76,DefaultSingle-J,,0,0,0,,		FBIきっての狙撃の名手だ	
Dialogue: 0,0:10:45.08,0:10:48.17,DefaultSingle-J,,0,0,0,,		今は沖矢昴という大学院生に変装し	
Dialogue: 0,0:10:48.44,0:10:51.49,DefaultSingle-J,,0,0,0,,		かつてオレが住んでいた家に  身を潜めている	
Dialogue: 0,0:10:54.17,0:10:56.22,DefaultSingle-J,,0,0,0,,		小さくなっても頭脳は同じ	
Dialogue: 0,0:10:58.22,0:11:00.06,DefaultSingle-J,,0,0,0,,		迷宮なしの名探偵	
Dialogue: 0,0:11:01.14,0:11:04.56,DefaultSingle-J,,0,0,0,,		真実はいつも1つ	
Dialogue: 0,0:11:09.41,0:11:11.33,DefaultSingle-J,,0,0,0,,		歩美ちゃん  ちょっと待ってくださいね	
Dialogue: 0,0:11:11.53,0:11:13.00,DefaultSingle-J,,0,0,0,,		こうやって…	
Dialogue: 0,0:11:13.98,0:11:14.94,DefaultSingle-J,,0,0,0,,		ありがとう	
Dialogue: 0,0:11:14.94,0:11:16.67,DefaultSingle-J,,0,0,0,,		はい  これで大丈夫	
Dialogue: 0,0:11:16.67,0:11:17.13,DefaultSingle-J,,0,0,0,,		ありがと	
Dialogue: 0,0:11:17.13,0:11:17.99,DefaultSingle-J,,0,0,0,,		あれ	
Dialogue: 0,0:11:18.50,0:11:22.04,DefaultSingle-J,,0,0,0,,		9人と聞いていますが  あと1人は？	
Dialogue: 0,0:11:22.73,0:11:25.09,DefaultSingle-J,,0,0,0,,		欠席でお願いします	
Dialogue: 0,0:11:25.26,0:11:27.20,DefaultSingle-J,,0,0,0,,		酔っぱらいはジャマなんで	
Dialogue: 0,0:11:27.58,0:11:29.06,DefaultSingle-J,,0,0,0,,		えっ  もう？	
Dialogue: 0,0:11:29.06,0:11:30.35,DefaultSingle-J,,0,0,0,,		ベロンベロンじゃ	
Dialogue: 0,0:11:30.35,0:11:31.80,DefaultSingle-J,,0,0,0,,		マジかよ	
Dialogue: 0,0:11:31.92,0:11:34.08,DefaultSingle-J,,0,0,0,,		ったく  お父さんったら	
Dialogue: 0,0:11:32.48,0:11:34.08,DefaultSingle-J,,0,0,0,,		さすがおっちゃん…	
Dialogue: 0,0:11:35.82,0:11:37.57,DefaultSingle-J,,0,0,0,,		では  どうぞ	
Dialogue: 0,0:11:37.57,0:11:39.52,DefaultSingle-J,,0,0,0,,		やった	
Dialogue: 0,0:11:44.01,0:11:44.66,DefaultSingle-J,,0,0,0,,		大丈夫ですか	
Dialogue: 0,0:11:44.66,0:11:45.60,DefaultSingle-J,,0,0,0,,		次の方	
Dialogue: 0,0:11:45.78,0:11:46.47,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,0:11:57.10,0:11:58.99,DefaultSingle-J,,0,0,0,,		ごめん  博士  ごまかしといて	
Dialogue: 0,0:12:00.51,0:12:02.27,DefaultSingle-J,,0,0,0,,		博士  どうしたの	
Dialogue: 0,0:12:02.27,0:12:04.29,DefaultSingle-J,,0,0,0,,		へ？  え…いや…	
Dialogue: 0,0:12:04.48,0:12:07.53,DefaultSingle-J,,0,0,0,,		ク…クジラってどうほえーるのかなって…	
Dialogue: 0,0:12:20.43,0:12:21.62,DefaultSingle-J,,0,0,0,,		え	
Dialogue: 0,0:12:21.62,0:12:24.22,DefaultSingle-J,,0,0,0,,		間違えて別の船に乗っちゃった？	
Dialogue: 0,0:12:24.51,0:12:27.07,DefaultSingle-J,,0,0,0,,		コナンって抜けたとこあるよな	
Dialogue: 0,0:12:27.07,0:12:28.31,DefaultSingle-J,,0,0,0,,		あるかな…	
Dialogue: 0,0:12:28.47,0:12:30.14,DefaultSingle-J,,0,0,0,,		心配ですねえ	
Dialogue: 0,0:12:30.14,0:12:33.69,DefaultSingle-J,,0,0,0,,		ああ  でも白鳥警部が一緒みたいじゃから	
Dialogue: 0,0:12:34.30,0:12:37.28,DefaultSingle-J,,0,0,0,,		ほら  後でホテルに送ってもらうって	
Dialogue: 0,0:12:37.28,0:12:39.99,DefaultSingle-J,,0,0,0,,		もう  コナン君は…	
Dialogue: 0,0:12:41.18,0:12:43.03,DefaultSingle-J,,0,0,0,,		「間違えて」ねえ…	
Dialogue: 0,0:12:53.62,0:12:55.21,DefaultSingle-J,,0,0,0,,		情報が出てない	
Dialogue: 0,0:12:55.77,0:12:57.71,DefaultSingle-J,,0,0,0,,		やっぱり  この船は	
Dialogue: 0,0:12:57.90,0:12:59.95,DefaultSingle-J,,0,0,0,,		パシフィック・ブイに向かってるんだ	
Dialogue: 0,0:13:14.87,0:13:15.72,DefaultSingle-J,,0,0,0,,		マジすげー	
Dialogue: 0,0:13:15.72,0:13:16.87,DefaultSingle-J,,0,0,0,,		冷たいね	
Dialogue: 0,0:13:16.87,0:13:17.90,DefaultSingle-J,,0,0,0,,		ほんとね	
Dialogue: 0,0:13:24.67,0:13:26.45,DefaultSingle-J,,0,0,0,,		足元  お気をつけください	
Dialogue: 0,0:13:26.45,0:13:27.35,DefaultSingle-J,,0,0,0,,		ありがとう	
Dialogue: 0,0:13:31.96,0:13:34.12,DefaultSingle-J,,0,0,0,,		ものすごい大きさですね	
Dialogue: 0,0:13:36.14,0:13:38.35,DefaultSingle-J,,0,0,0,,		そろそろ聞かせてもらえるかな	
Dialogue: 0,0:13:38.35,0:13:39.21,DefaultSingle-J,,0,0,0,,		は？	
Dialogue: 0,0:13:39.81,0:13:42.66,DefaultSingle-J,,0,0,0,,		なぜ  我々と一緒に来たのか	
Dialogue: 0,0:13:44.80,0:13:46.52,DefaultSingle-J,,0,0,0,,		コナン君  なんで…	
Dialogue: 0,0:13:49.04,0:13:51.72,DefaultSingle-J,,0,0,0,,		クジラを見に行くお船と間違えて	
Dialogue: 0,0:13:52.52,0:13:54.44,DefaultSingle-J,,0,0,0,,		なんですぐ言わなかったの	
Dialogue: 0,0:13:54.44,0:13:57.04,DefaultSingle-J,,0,0,0,,		だって怒られると思って	
Dialogue: 0,0:13:57.37,0:13:59.12,DefaultSingle-J,,0,0,0,,		船を呼び戻します	
Dialogue: 0,0:13:59.12,0:14:02.39,DefaultSingle-J,,0,0,0,,		よせ  インターポールを待たせたくない	
Dialogue: 0,0:14:05.99,0:14:08.18,DefaultSingle-J,,0,0,0,,		遠いところ  おつかれさまでした	
Dialogue: 0,0:14:08.97,0:14:10.08,DefaultSingle-J,,0,0,0,,		はじめまして	
Dialogue: 0,0:14:10.39,0:14:12.95,DefaultSingle-J,,0,0,0,,		パシフィック・ブイ局長の  牧野です	
Dialogue: 0,0:14:13.33,0:14:16.01,DefaultSingle-J,,0,0,0,,		エンジニアの  直美・アルジェントです	
Dialogue: 0,0:14:16.54,0:14:19.73,DefaultSingle-J,,0,0,0,,		警視庁の白鳥と  上司の黒田です	
Dialogue: 0,0:14:20.33,0:14:21.55,DefaultSingle-J,,0,0,0,,		はじめまして	
Dialogue: 0,0:14:21.92,0:14:24.20,DefaultSingle-J,,0,0,0,,		本日は  よろしくお願いします	
Dialogue: 0,0:14:24.66,0:14:28.56,DefaultSingle-J,,0,0,0,,		で  この子が  間違えて乗船してしまったという…	
Dialogue: 0,0:14:28.74,0:14:31.47,DefaultSingle-J,,0,0,0,,		こんにちは  お名前なんていうの	
Dialogue: 0,0:14:31.64,0:14:34.47,DefaultSingle-J,,0,0,0,,		ボク  江戸川コナン  よろしくね	
Dialogue: 0,0:14:34.81,0:14:37.56,DefaultSingle-J,,0,0,0,,		コナン君ね  よろしく	
Dialogue: 0,0:14:38.54,0:14:41.83,DefaultSingle-J,,0,0,0,,		この先に  パシフィック・ブイの入り口があるんだよ	
Dialogue: 0,0:14:42.01,0:14:43.28,DefaultSingle-J,,0,0,0,,		へえー	
Dialogue: 0,0:14:45.46,0:14:46.06,DefaultSingle-J,,0,0,0,,		コナン君  待って	
Dialogue: 0,0:14:46.06,0:14:47.45,DefaultSingle-J,,0,0,0,,		広い	
Dialogue: 0,0:14:53.33,0:14:55.33,DefaultSingle-J,,0,0,0,,		おっきい…穴？	
Dialogue: 0,0:14:55.62,0:14:58.08,DefaultSingle-J,,0,0,0,,		ここが入り口なの  見てて	
Dialogue: 0,0:15:11.67,0:15:13.22,DefaultSingle-J,,0,0,0,,		すっげえ	
Dialogue: 0,0:15:15.32,0:15:17.30,DefaultSingle-J,,0,0,0,,		これが  エントランス部分です	
Dialogue: 0,0:15:17.62,0:15:20.78,DefaultSingle-J,,0,0,0,,		実は  施設の大半は  海中にあるんです	
Dialogue: 0,0:15:21.51,0:15:23.75,DefaultSingle-J,,0,0,0,,		バラストタンクで浮き沈みする仕組みで	
Dialogue: 0,0:15:23.75,0:15:25.92,DefaultSingle-J,,0,0,0,,		波の力をコントロールしています	
Dialogue: 0,0:15:27.48,0:15:31.88,DefaultSingle-J,,0,0,0,,		海中にあるのは  膨大な量のサーバーを  冷やすためでもあります	
Dialogue: 0,0:15:32.24,0:15:35.00,DefaultSingle-J,,0,0,0,,		まるで海に浮かぶブイだね	
Dialogue: 0,0:15:35.18,0:15:38.31,DefaultSingle-J,,0,0,0,,		だから  パシフィック・ブイって呼ばれてるのよ	
Dialogue: 0,0:15:43.24,0:15:44.92,DefaultSingle-J,,0,0,0,,		おお  これは…	
Dialogue: 0,0:15:45.11,0:15:47.32,DefaultSingle-J,,0,0,0,,		メインルームはこの下になります	
Dialogue: 0,0:15:49.42,0:15:51.17,DefaultSingle-J,,0,0,0,,		ねえ  あれは？	
Dialogue: 0,0:15:52.30,0:15:53.11,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,0:15:53.12,0:15:55.79,DefaultSingle-J,,0,0,0,,		潮の流れで発電するリングよ	
Dialogue: 0,0:15:56.19,0:15:58.68,DefaultSingle-J,,0,0,0,,		この辺りは黒潮が強くてね	
Dialogue: 0,0:16:02.23,0:16:05.64,DefaultSingle-J,,0,0,0,,		この階は  スタッフ用の居住エリアにもなっています	
Dialogue: 0,0:16:06.28,0:16:08.60,DefaultSingle-J,,0,0,0,,		メインルームは通路の先です	
Dialogue: 0,0:16:10.24,0:16:11.66,DefaultSingle-J,,0,0,0,,		ん？  これは…	
Dialogue: 0,0:16:11.90,0:16:13.71,DefaultSingle-J,,0,0,0,,		クジラの鳴き声です	
Dialogue: 0,0:16:13.90,0:16:16.37,DefaultSingle-J,,0,0,0,,		ザトウクジラは歌うクジラですから	
Dialogue: 0,0:16:17.24,0:16:19.29,DefaultSingle-J,,0,0,0,,		ソナーが探知したの？	
Dialogue: 0,0:16:19.29,0:16:22.84,DefaultSingle-J,,0,0,0,,		すごい  コナン君って物知りなのね	
Dialogue: 0,0:16:25.76,0:16:29.54,DefaultSingle-J,,0,0,0,,		ご足労おかけしました  こちらがメインルームになります	
Dialogue: 0,0:16:35.58,0:16:36.06,DefaultSingle-J,,0,0,0,,		あ…	
Dialogue: 0,0:16:38.31,0:16:40.15,DefaultSingle-J,,0,0,0,,		おお…広い	
Dialogue: 0,0:16:46.95,0:16:49.80,DefaultSingle-J,,0,0,0,,		では  メインスタッフを紹介させてください	
Dialogue: 0,0:16:51.22,0:16:52.96,DefaultSingle-J,,0,0,0,,		フランス出身のグレース	
Dialogue: 0,0:16:53.36,0:16:54.70,DefaultSingle-J,,0,0,0,,		こんにちは	
Dialogue: 0,0:16:55.77,0:16:57.87,DefaultSingle-J,,0,0,0,,		ドイツ出身のレオンハルト	
Dialogue: 0,0:17:03.04,0:17:04.79,DefaultSingle-J,,0,0,0,,		インド出身のエド	
Dialogue: 0,0:17:05.30,0:17:06.50,DefaultSingle-J,,0,0,0,,		よろしく	
Dialogue: 0,0:17:08.60,0:17:11.37,DefaultSingle-J,,0,0,0,,		あとは私  直美・アルジェント	
Dialogue: 0,0:17:11.63,0:17:14.22,DefaultSingle-J,,0,0,0,,		以上のエンジニアが  任務に当たっています	
Dialogue: 0,0:17:14.48,0:17:15.32,DefaultSingle-J,,0,0,0,,		あの	
Dialogue: 0,0:17:15.32,0:17:15.89,DefaultSingle-J,,0,0,0,,		ん？	
Dialogue: 0,0:17:15.89,0:17:20.27,DefaultSingle-J,,0,0,0,,		これは  日本全国にある警察の防犯カメラですか	
Dialogue: 0,0:17:20.48,0:17:21.11,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,0:17:21.59,0:17:25.28,DefaultSingle-J,,0,0,0,,		これに今日  ヨーロッパ中の防犯カメラが  つながれるんです	
Dialogue: 0,0:17:25.97,0:17:29.19,DefaultSingle-J,,0,0,0,,		今後は  世界中のカメラが接続予定です	
Dialogue: 0,0:17:29.30,0:17:31.94,DefaultSingle-J,,0,0,0,,		さすがインターポールの施設だ	
Dialogue: 0,0:17:32.05,0:17:34.73,DefaultSingle-J,,0,0,0,,		そうだ  ここはインターポールだ	
Dialogue: 0,0:17:35.00,0:17:37.29,DefaultSingle-J,,0,0,0,,		なのに  なんで日本の警察がいる	
Dialogue: 0,0:17:37.41,0:17:40.37,DefaultSingle-J,,0,0,0,,		フランクフルトで侵入事件があったからでしょ	
Dialogue: 0,0:17:42.26,0:17:46.41,DefaultSingle-J,,0,0,0,,		うちも何かあった時のために  警視庁に来てもらったんだ	
Dialogue: 0,0:17:47.10,0:17:52.18,DefaultSingle-J,,0,0,0,,		最新技術を日本の警察にだけ公開するなんて  不公平じゃないか	
Dialogue: 0,0:17:52.49,0:17:55.04,DefaultSingle-J,,0,0,0,,		日本はインターポールの加盟国だ	
Dialogue: 0,0:17:55.48,0:17:58.90,DefaultSingle-J,,0,0,0,,		必要があれば  技術を提供するのは当然だ	
Dialogue: 0,0:17:59.27,0:18:03.10,DefaultSingle-J,,0,0,0,,		ここのトップが日本人だから  日本びいきってワケか	
Dialogue: 0,0:18:03.31,0:18:04.10,DefaultSingle-J,,0,0,0,,		なっ…	
Dialogue: 0,0:18:04.10,0:18:05.55,DefaultSingle-J,,0,0,0,,		いい加減にして	
Dialogue: 0,0:18:05.55,0:18:08.54,DefaultSingle-J,,0,0,0,,		それを言うなら  私だって半分日本人よ	
Dialogue: 0,0:18:08.64,0:18:11.11,DefaultSingle-J,,0,0,0,,		どうりでいけ好かない女だと思った	
Dialogue: 0,0:18:11.96,0:18:15.12,DefaultSingle-J,,0,0,0,,		今の言葉は撤回しなさい  人種差別よ	
Dialogue: 0,0:18:15.40,0:18:16.11,DefaultSingle-J,,0,0,0,,		それにあなた…	
Dialogue: 0,0:18:16.11,0:18:17.11,DefaultSingle-J,,0,0,0,,		あのさあ	
Dialogue: 0,0:18:17.28,0:18:18.87,DefaultSingle-J,,0,0,0,,		そろそろ時間じゃない？	
Dialogue: 0,0:18:18.87,0:18:19.63,DefaultSingle-J,,0,0,0,,		あっ	
Dialogue: 0,0:18:19.88,0:18:21.75,DefaultSingle-J,,0,0,0,,		総員  配置につけ	
Dialogue: 0,0:18:26.61,0:18:27.71,DefaultSingle-J,,0,0,0,,		すみません	
Dialogue: 0,0:18:28.08,0:18:29.96,DefaultSingle-J,,0,0,0,,		レオンハルトはここに来るまで	
Dialogue: 0,0:18:29.96,0:18:33.12,DefaultSingle-J,,0,0,0,,		ヨーロッパ各国の警察と  いろいろあったらしくて	
Dialogue: 0,0:18:39.55,0:18:40.89,DefaultSingle-J,,0,0,0,,		ファーストアクセス	
Dialogue: 0,0:18:57.55,0:19:01.64,DefaultSingle-J,,0,0,0,,		これで  ヨーロッパ中の防犯カメラが確認できるというワケですか	
Dialogue: 0,0:19:01.93,0:19:04.37,DefaultSingle-J,,0,0,0,,		それも  顔認証つきでな	
Dialogue: 0,0:19:04.96,0:19:07.50,DefaultSingle-J,,0,0,0,,		他にも  様々な技術が使えます	
Dialogue: 0,0:19:07.93,0:19:12.43,DefaultSingle-J,,0,0,0,,		その1つ  直美が作った「老若認証」を早速テストします	
Dialogue: 0,0:19:15.79,0:19:17.42,DefaultSingle-J,,0,0,0,,		老若認証？	
Dialogue: 0,0:19:18.65,0:19:23.08,DefaultSingle-J,,0,0,0,,		私はイタリア人の父と日本人の母の間に生まれ	
Dialogue: 0,0:19:23.24,0:19:24.83,DefaultSingle-J,,0,0,0,,		アメリカで育ちました	
Dialogue: 0,0:19:25.47,0:19:28.10,DefaultSingle-J,,0,0,0,,		私の子供の頃の写真でテストします	
Dialogue: 0,0:19:35.55,0:19:38.70,DefaultSingle-J,,0,0,0,,		骨格から  老化や若返りを計算し	
Dialogue: 0,0:19:38.77,0:19:40.96,DefaultSingle-J,,0,0,0,,		その顔をCGで作り	
Dialogue: 0,0:19:40.97,0:19:44.16,DefaultSingle-J,,0,0,0,,		それと合致する顔を  顔認証で捜す	
Dialogue: 0,0:19:48.28,0:19:50.46,DefaultSingle-J,,0,0,0,,		これが老若認証です	
Dialogue: 0,0:19:51.27,0:19:53.67,DefaultSingle-J,,0,0,0,,		今日警察庁からここに来るまで	
Dialogue: 0,0:19:53.78,0:19:55.90,DefaultSingle-J,,0,0,0,,		防犯カメラに映った私です	
Dialogue: 0,0:20:00.49,0:20:03.04,DefaultSingle-J,,0,0,0,,		長期の逃亡者や誘拐の被害者を	
Dialogue: 0,0:20:03.05,0:20:05.65,DefaultSingle-J,,0,0,0,,		世界中で追うことができるシステムです	
Dialogue: 0,0:20:06.07,0:20:09.36,DefaultSingle-J,,0,0,0,,		すごい…  すごいシステムだ	
Dialogue: 0,0:20:10.09,0:20:12.01,DefaultSingle-J,,0,0,0,,		確かにすげえけど…	
Dialogue: 0,0:20:13.52,0:20:18.11,DefaultSingle-J,,0,0,0,,		15分の休憩の後  引き続き各設備のテストに入る	
Dialogue: 0,0:20:27.44,0:20:30.35,DefaultSingle-J,,0,0,0,,		みなさん  コーヒーはいかがですか	
Dialogue: 0,0:20:33.96,0:20:35.60,DefaultSingle-J,,0,0,0,,		ボク  聞いてくるね	
Dialogue: 0,0:20:36.21,0:20:37.43,DefaultSingle-J,,0,0,0,,		コナン君  ありがとう	
Dialogue: 0,0:20:44.66,0:20:46.06,DefaultSingle-J,,0,0,0,,		俺はブラックね	
Dialogue: 0,0:20:46.06,0:20:48.60,DefaultSingle-J,,0,0,0,,		エド  自分で行きなよ	
Dialogue: 0,0:20:48.60,0:20:50.94,DefaultSingle-J,,0,0,0,,		いいわ  エド  ブラックね	
Dialogue: 0,0:20:51.95,0:20:53.67,DefaultSingle-J,,0,0,0,,		砂糖入りをこれだけ	
Dialogue: 0,0:20:53.96,0:20:55.80,DefaultSingle-J,,0,0,0,,		オーケー  1つね	
Dialogue: 0,0:20:55.90,0:20:57.11,DefaultSingle-J,,0,0,0,,		2つよ	
Dialogue: 0,0:20:57.55,0:20:59.28,DefaultSingle-J,,0,0,0,,		コナン君はジュースでいい？	
Dialogue: 0,0:20:59.37,0:21:01.40,DefaultSingle-J,,0,0,0,,		んっと  アイスコーヒーってある？	
Dialogue: 0,0:21:01.91,0:21:04.44,DefaultSingle-J,,0,0,0,,		コーヒー好きなの  いいわよ	
Dialogue: 0,0:21:04.44,0:21:05.73,DefaultSingle-J,,0,0,0,,		ありがとう	
Dialogue: 0,0:21:06.41,0:21:08.16,DefaultSingle-J,,0,0,0,,		ボク  お手伝いするね	
Dialogue: 0,0:21:08.24,0:21:09.66,DefaultSingle-J,,0,0,0,,		うん  偉いね	
Dialogue: 0,0:21:32.70,0:21:33.97,DefaultSingle-J,,0,0,0,,		なぜここに	
Dialogue: 0,0:21:34.46,0:21:36.10,DefaultSingle-J,,0,0,0,,		シルバーブレット…	
Dialogue: 0,0:21:37.27,0:21:39.19,DefaultSingle-J,,0,0,0,,		あれ  直美さんは？	
Dialogue: 0,0:21:39.19,0:21:41.72,DefaultSingle-J,,0,0,0,,		トイレよ  先に戻りましょ	
Dialogue: 0,0:21:41.72,0:21:43.34,DefaultSingle-J,,0,0,0,,		あ  はい	
Dialogue: 0,0:21:57.56,0:22:00.47,DefaultSingle-J,,0,0,0,,		いやあ  すごかったです  老若認証	
Dialogue: 0,0:22:00.58,0:22:02.14,DefaultSingle-J,,0,0,0,,		顔の骨格から	
Dialogue: 0,0:22:02.14,0:22:05.97,DefaultSingle-J,,0,0,0,,		成長した顔を予測するというのはどんな方法で？	
Dialogue: 0,0:22:06.31,0:22:07.05,DefaultSingle-J,,0,0,0,,		確か	
Dialogue: 0,0:22:07.38,0:22:12.10,DefaultSingle-J,,0,0,0,,		解剖学と統計データで計算する  AIを使ってるとか…	
Dialogue: 0,0:22:12.80,0:22:14.80,DefaultSingle-J,,0,0,0,,		くわしくは直美に	
Dialogue: 0,0:22:14.94,0:22:19.59,DefaultSingle-J,,0,0,0,,		映像データさえあれば  AI技術で  自動化が可能なんです	
Dialogue: 0,0:22:19.68,0:22:20.78,DefaultSingle-J,,0,0,0,,		なるほど	
Dialogue: 0,0:22:20.78,0:22:22.87,DefaultSingle-J,,0,0,0,,		すばらしい技術ですね	
Dialogue: 0,0:22:23.95,0:22:28.08,DefaultSingle-J,,0,0,0,,		ミスター牧野  休憩時間とっくに終わってるよ	
Dialogue: 0,0:22:28.61,0:22:29.43,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,0:22:29.78,0:22:31.75,DefaultSingle-J,,0,0,0,,		でも  その前に直美は？	
Dialogue: 0,0:22:31.75,0:22:34.00,DefaultSingle-J,,0,0,0,,		え？  そういえば…	
Dialogue: 0,0:22:34.19,0:22:37.25,DefaultSingle-J,,0,0,0,,		ったく  何やってんだ  あの女は	
Dialogue: 0,0:22:37.25,0:22:39.50,DefaultSingle-J,,0,0,0,,		老若認証か…	
Dialogue: 0,0:22:39.60,0:22:40.71,DefaultSingle-J,,0,0,0,,		出たぜ	
Dialogue: 0,0:22:42.01,0:22:43.81,DefaultSingle-J,,0,0,0,,		12分前の映像ね	
Dialogue: 0,0:22:46.78,0:22:49.47,DefaultSingle-J,,0,0,0,,		カメラに映った姿はこれが最後だ	
Dialogue: 0,0:22:50.13,0:22:54.60,DefaultSingle-J,,0,0,0,,		清掃員2人入ってるが  5分後には出てきてる	
Dialogue: 0,0:22:56.04,0:22:58.02,DefaultSingle-J,,0,0,0,,		あのカートなら人が乗れるね	
Dialogue: 0,0:22:59.17,0:23:00.44,DefaultSingle-J,,0,0,0,,		ちょっとこれ見てよ	
Dialogue: 0,0:23:00.95,0:23:02.87,DefaultSingle-J,,0,0,0,,		ドライデッキに同じヤツらだ	
Dialogue: 0,0:23:05.77,0:23:07.37,DefaultSingle-J,,0,0,0,,		誰なんだ  こいつら	
Dialogue: 0,0:23:10.50,0:23:12.70,DefaultSingle-J,,0,0,0,,		ここから  海へ出られるんですね？	
Dialogue: 0,0:23:12.90,0:23:13.66,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,0:23:14.03,0:23:17.76,DefaultSingle-J,,0,0,0,,		部屋を海水で満たして  外と水圧を合わせたら…	
Dialogue: 0,0:23:18.66,0:23:20.82,DefaultSingle-J,,0,0,0,,		でも  この先は海です	
Dialogue: 0,0:23:21.05,0:23:24.12,DefaultSingle-J,,0,0,0,,		一番近い八丈小島でも  5キロ以上はある	
Dialogue: 0,0:23:25.59,0:23:27.30,DefaultSingle-J,,0,0,0,,		直美は一体どこへ…	
Dialogue: 0,0:23:28.28,0:23:30.72,DefaultSingle-J,,0,0,0,,		この扉の制御権限は誰に？	
Dialogue: 0,0:23:33.95,0:23:36.49,DefaultSingle-J,,0,0,0,,		このハッチは  直接開けられますが	
Dialogue: 0,0:23:36.71,0:23:38.65,DefaultSingle-J,,0,0,0,,		海側のハッチを開けられるのは	
Dialogue: 0,0:23:38.80,0:23:43.84,DefaultSingle-J,,0,0,0,,		私と  あとは先ほど紹介したエンジニア達だけです	
Dialogue: 0,0:23:44.21,0:23:48.15,DefaultSingle-J,,0,0,0,,		だとすれば  直美さんを拉致した犯人の共犯が	
Dialogue: 0,0:23:48.40,0:23:50.35,DefaultSingle-J,,0,0,0,,		その中にいることになる	
Dialogue: 0,0:23:50.85,0:23:52.89,DefaultSingle-J,,0,0,0,,		ええ  ですが…	
Dialogue: 0,0:23:54.75,0:23:57.69,DefaultSingle-J,,0,0,0,,		とにかく  警視庁に臨場要請します	
Dialogue: 0,0:23:59.56,0:24:01.43,DefaultSingle-J,,0,0,0,,		あの短時間での拉致…	
Dialogue: 0,0:24:01.64,0:24:05.94,DefaultSingle-J,,0,0,0,,		間違いない  犯人は直美さんがトイレにいることを知っていた	
Dialogue: 0,0:24:06.63,0:24:07.81,DefaultSingle-J,,0,0,0,,		そしてどこへ…	
Dialogue: 0,0:24:22.49,0:24:24.23,DefaultSingle-J,,0,0,0,,		あら  かわいい	
Dialogue: 0,0:24:32.59,0:24:34.24,DefaultSingle-J,,0,0,0,,		画像ファイルみたいね	
Dialogue: 0,0:24:38.92,0:24:39.75,DefaultSingle-J,,0,0,0,,		これは…	
Dialogue: 0,0:24:39.86,0:24:40.88,DefaultSingle-J,,0,0,0,,		シェリー	
Dialogue: 0,0:24:41.51,0:24:43.92,DefaultSingle-J,,0,0,0,,		隣のガキ  似てるな	
Dialogue: 0,0:24:44.19,0:24:46.08,DefaultSingle-J,,0,0,0,,		子供時代のシェリーかしら	
Dialogue: 0,0:24:46.40,0:24:48.67,DefaultSingle-J,,0,0,0,,		いや  最新の画像だ	
Dialogue: 0,0:24:48.94,0:24:52.57,DefaultSingle-J,,0,0,0,,		奥の野郎の手元を見ろ  最近の機種だぜ	
Dialogue: 0,0:24:52.97,0:24:54.36,DefaultSingle-J,,0,0,0,,		なるほどね	
Dialogue: 0,0:24:54.64,0:24:56.81,DefaultSingle-J,,0,0,0,,		つまり  どういうこと？	
Dialogue: 0,0:24:56.81,0:24:59.44,DefaultSingle-J,,0,0,0,,		まさか  このガキがシェリー？	
Dialogue: 0,0:25:03.05,0:25:06.36,DefaultSingle-J,,0,0,0,,		そいつはなんの冗談だ  ウォッカ	
Dialogue: 0,0:25:06.53,0:25:09.63,DefaultSingle-J,,0,0,0,,		シェリーはベルツリー急行で死んだはずだ	
Dialogue: 0,0:25:14.39,0:25:17.75,DefaultSingle-J,,0,0,0,,		だから  子供のナリになって  生き延びてたんですよ	
Dialogue: 0,0:25:18.37,0:25:19.50,DefaultSingle-J,,0,0,0,,		子供？	
Dialogue: 0,0:25:19.86,0:25:22.00,DefaultSingle-J,,0,0,0,,		どんなカラクリかは分かりやせんが	
Dialogue: 0,0:25:22.42,0:25:25.75,DefaultSingle-J,,0,0,0,,		ただヤツは科学者だし  もしかしたら…	
Dialogue: 0,0:25:26.16,0:25:27.89,DefaultSingle-J,,0,0,0,,		なんなら画像を送りやしょうか	
Dialogue: 0,0:25:29.20,0:25:30.04,DefaultSingle-J,,0,0,0,,		いや	
Dialogue: 0,0:25:30.85,0:25:32.01,DefaultSingle-J,,0,0,0,,		直接見る	
Dialogue: 0,0:25:32.61,0:25:35.21,DefaultSingle-J,,0,0,0,,		それまでにそのガキを  拉致しておけ	
Dialogue: 0,0:25:35.21,0:25:38.27,DefaultSingle-J,,0,0,0,,		えっ？  でもどこにいるか分かりやせんぜ	
Dialogue: 0,0:25:39.90,0:25:43.68,DefaultSingle-J,,0,0,0,,		そういうヤツを見つけるのにふさわしいシステムを…	
Dialogue: 0,0:25:47.68,0:25:49.44,DefaultSingle-J,,0,0,0,,		手に入れたばかりだろ？	
Dialogue: 0,0:25:52.79,0:25:54.43,DefaultSingle-J,,0,0,0,,		さすがは兄貴だ	
Dialogue: 0,0:25:54.60,0:25:55.91,DefaultSingle-J,,0,0,0,,		さらうつもり？	
Dialogue: 0,0:25:56.06,0:25:57.62,DefaultSingle-J,,0,0,0,,		私はお断り	
Dialogue: 0,0:25:57.62,0:25:58.37,DefaultSingle-J,,0,0,0,,		ああ？	
Dialogue: 0,0:25:58.69,0:26:01.37,DefaultSingle-J,,0,0,0,,		計画にないことはすべきじゃないわ	
Dialogue: 0,0:26:01.69,0:26:03.79,DefaultSingle-J,,0,0,0,,		老若認証を改ざんして	
Dialogue: 0,0:26:03.79,0:26:08.13,DefaultSingle-J,,0,0,0,,		過去の防犯カメラの記録から  私達の痕跡を消す	
Dialogue: 0,0:26:08.24,0:26:11.13,DefaultSingle-J,,0,0,0,,		それがボスの命令よ	
Dialogue: 0,0:26:11.36,0:26:12.81,DefaultSingle-J,,0,0,0,,		同感ですね	
Dialogue: 0,0:26:13.53,0:26:16.89,DefaultSingle-J,,0,0,0,,		予定外の動きは計画の失敗を招きます	
Dialogue: 0,0:26:17.10,0:26:20.52,DefaultSingle-J,,0,0,0,,		私も遠慮するわ  こんな状態だし	
Dialogue: 0,0:26:20.66,0:26:24.50,DefaultSingle-J,,0,0,0,,		フンッ  最初からお前らと組むつもりはねえよ	
Dialogue: 0,0:26:25.91,0:26:27.65,DefaultSingle-J,,0,0,0,,		これはピンガにやらせる	
Dialogue: 0,0:26:27.90,0:26:32.15,DefaultSingle-J,,0,0,0,,		あのピンガが  あなたの言うことを聞くかしら	
Dialogue: 0,0:26:32.44,0:26:34.70,DefaultSingle-J,,0,0,0,,		ラムの言うことなら聞くはずだ	
Dialogue: 0,0:26:35.56,0:26:38.23,DefaultSingle-J,,0,0,0,,		かつてラムの片腕だったキュラソー	
Dialogue: 0,0:26:38.53,0:26:40.53,DefaultSingle-J,,0,0,0,,		そのキュラソー亡き今	
Dialogue: 0,0:26:40.73,0:26:43.77,DefaultSingle-J,,0,0,0,,		ラムの側近に収まってるのがピンガだからな	
Dialogue: 0,0:26:44.27,0:26:48.15,DefaultSingle-J,,0,0,0,,		ピンガがラムの言いなりになっているのはなぜだと思います？	
Dialogue: 0,0:26:48.46,0:26:52.17,DefaultSingle-J,,0,0,0,,		ラムに気に入られて  もっと上のランクに上がるためね	
Dialogue: 0,0:26:52.37,0:26:53.69,DefaultSingle-J,,0,0,0,,		知ってるよ	
Dialogue: 0,0:26:53.80,0:26:58.27,DefaultSingle-J,,0,0,0,,		人を蹴落としてでも  成り上がりたい野郎ってこともな	
Dialogue: 0,0:27:00.35,0:27:02.30,DefaultSingle-J,,0,0,0,,		じゃあ  これも知ってる？	
Dialogue: 0,0:27:02.62,0:27:06.02,DefaultSingle-J,,0,0,0,,		そのピンガが一番蹴落としたがってるのが	
Dialogue: 0,0:27:06.10,0:27:07.58,DefaultSingle-J,,0,0,0,,		ジンだってこと	
Dialogue: 0,0:27:09.17,0:27:12.65,DefaultSingle-J,,0,0,0,,		それにしても  老若認証システム…	
Dialogue: 0,0:27:13.73,0:27:17.10,DefaultSingle-J,,0,0,0,,		開けてはならない玉手箱かも…	
Dialogue: 0,0:27:17.55,0:27:19.41,DefaultSingle-J,,0,0,0,,		直美が拉致された？	
Dialogue: 0,0:27:19.41,0:27:23.70,DefaultSingle-J,,0,0,0,,		しかも  我々の中に  共犯者がいるかもしれない	
Dialogue: 0,0:27:24.52,0:27:26.67,DefaultSingle-J,,0,0,0,,		なんだ  それは  バカげてる	
Dialogue: 0,0:27:26.67,0:27:29.81,DefaultSingle-J,,0,0,0,,		そう  だが  我々はインターポールだ	
Dialogue: 0,0:27:30.12,0:27:33.47,DefaultSingle-J,,0,0,0,,		自らにかけられた疑いは  自ら晴らす	
Dialogue: 0,0:27:33.55,0:27:37.16,DefaultSingle-J,,0,0,0,,		海中ハッチのログを調べれば  いいだけでしょ	
Dialogue: 0,0:27:40.34,0:27:43.10,DefaultSingle-J,,0,0,0,,		ログは…ないわね	
Dialogue: 0,0:27:43.35,0:27:45.98,DefaultSingle-J,,0,0,0,,		じゃあ  外からハッキングされたってこと？	
Dialogue: 0,0:27:47.64,0:27:48.98,DefaultSingle-J,,0,0,0,,		なんだ  あのガキ	
Dialogue: 0,0:27:49.23,0:27:53.64,DefaultSingle-J,,0,0,0,,		このシステムは  日本の警察やユーロポールとつながってる	
Dialogue: 0,0:27:53.86,0:27:56.99,DefaultSingle-J,,0,0,0,,		そこからならバックドアも仕掛けられるかもな	
Dialogue: 0,0:27:57.29,0:27:58.66,DefaultSingle-J,,0,0,0,,		バックドア…	
Dialogue: 0,0:27:59.08,0:28:01.66,DefaultSingle-J,,0,0,0,,		ハッキングのために仕掛ける裏口ですか	
Dialogue: 0,0:28:02.10,0:28:04.00,DefaultSingle-J,,0,0,0,,		狙われたということか	
Dialogue: 0,0:28:05.21,0:28:06.12,DefaultSingle-J,,0,0,0,,		はい？	
Dialogue: 0,0:28:06.66,0:28:11.29,DefaultSingle-J,,0,0,0,,		フランクフルトの侵入事件  犯人の真の狙いは	
Dialogue: 0,0:28:11.29,0:28:16.01,DefaultSingle-J,,0,0,0,,		パシフィック・ブイがヨーロッパとつなぐ今日だったということだろう	
Dialogue: 0,0:28:16.09,0:28:17.20,DefaultSingle-J,,0,0,0,,		そうか	
Dialogue: 0,0:28:18.01,0:28:22.49,DefaultSingle-J,,0,0,0,,		コンピューターセキュリティは  中からの攻撃には弱いからな	
Dialogue: 0,0:28:23.01,0:28:27.06,DefaultSingle-J,,0,0,0,,		だとしたら  共犯者は今  ユーロポールにいるのでしょうか	
Dialogue: 0,0:28:27.49,0:28:32.98,DefaultSingle-J,,0,0,0,,		いんや  バックドアが一度できたら  世界中どっからでも操作できる	
Dialogue: 0,0:28:33.38,0:28:37.78,DefaultSingle-J,,0,0,0,,		つまり  この中に共犯者がいる可能性も残る…	
Dialogue: 0,0:28:38.28,0:28:40.76,DefaultSingle-J,,0,0,0,,		というワケですな	
Dialogue: 0,0:28:41.21,0:28:45.11,DefaultSingle-J,,0,0,0,,		ヤツらの狙いはおそらく  老若認証システム	
Dialogue: 0,0:28:46.52,0:28:48.55,DefaultSingle-J,,0,0,0,,		コードネームはピンガ	
Dialogue: 0,0:28:49.21,0:28:51.81,DefaultSingle-J,,0,0,0,,		この中にヤツらの仲間がいるのか	
Dialogue: 0,0:28:52.69,0:28:53.75,DefaultSingle-J,,0,0,0,,		それとも…	
Dialogue: 0,0:28:55.30,0:28:58.99,DefaultSingle-J,,0,0,0,,		では  みなさんには  スマホやパソコンなどの任意提出	
Dialogue: 0,0:28:59.12,0:29:01.64,DefaultSingle-J,,0,0,0,,		および事情聴取を受けてもらいます	
Dialogue: 0,0:29:02.20,0:29:04.00,DefaultSingle-J,,0,0,0,,		いいですね  牧野局長	
Dialogue: 0,0:29:04.65,0:29:05.60,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,0:29:16.00,0:29:18.52,DefaultSingle-J,,0,0,0,,		ホエールウォッチングツアー  楽しみだね	
Dialogue: 0,0:29:23.89,0:29:25.06,DefaultSingle-J,,0,0,0,,		ここも行きたい	
Dialogue: 0,0:29:37.44,0:29:40.72,DefaultSingle-J,,0,0,0,,		お待ちしてました  ユーロポールのハンスです	
Dialogue: 0,0:29:41.12,0:29:43.58,DefaultSingle-J,,0,0,0,,		朝早くに  おむかえありがとう	
Dialogue: 0,0:29:43.58,0:29:46.07,DefaultSingle-J,,0,0,0,,		はじめまして  キャメルです	
Dialogue: 0,0:29:46.24,0:29:47.35,DefaultSingle-J,,0,0,0,,		ジェイムズです	
Dialogue: 0,0:29:48.83,0:29:50.59,DefaultSingle-J,,0,0,0,,		ニーナは残念だったわ	
Dialogue: 0,0:29:50.82,0:29:52.25,DefaultSingle-J,,0,0,0,,		親しかったんですか	
Dialogue: 0,0:29:53.20,0:29:54.04,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,0:29:54.50,0:29:56.97,DefaultSingle-J,,0,0,0,,		ユーロポールと捜査協力した時	
Dialogue: 0,0:29:57.17,0:29:59.53,DefaultSingle-J,,0,0,0,,		連絡先を交換したことがあって	
Dialogue: 0,0:30:01.33,0:30:04.99,DefaultSingle-J,,0,0,0,,		行きましょう  ユーロポールネットワークセンターに案内します	
Dialogue: 0,0:30:04.99,0:30:05.74,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,0:30:16.44,0:30:18.75,DefaultSingle-J,,0,0,0,,		グレースさんはいつからこちらに？	
Dialogue: 0,0:30:19.00,0:30:22.85,DefaultSingle-J,,0,0,0,,		私は5年前に  技術職で採用されました	
Dialogue: 0,0:30:23.96,0:30:26.57,DefaultSingle-J,,0,0,0,,		あの  こんなことが起きた以上	
Dialogue: 0,0:30:26.98,0:30:31.29,DefaultSingle-J,,0,0,0,,		システムの運用を  いったん停止すべきなんじゃ…と思うのですが…	
Dialogue: 0,0:30:32.38,0:30:34.88,DefaultSingle-J,,0,0,0,,		ダメだ  それは絶対にできない	
Dialogue: 0,0:30:35.06,0:30:36.49,DefaultSingle-J,,0,0,0,,		いや  しかし…	
Dialogue: 0,0:30:36.49,0:30:40.18,DefaultSingle-J,,0,0,0,,		当日に停止など  インターポールの威信に関わる	
Dialogue: 0,0:30:40.56,0:30:43.07,DefaultSingle-J,,0,0,0,,		なんであんたらが取り調べしてんだよ	
Dialogue: 0,0:30:43.17,0:30:45.67,DefaultSingle-J,,0,0,0,,		インターポールに出向したのは  いつですか	
Dialogue: 0,0:30:47.09,0:30:49.91,DefaultSingle-J,,0,0,0,,		日本警察だって容疑者のうちじゃねえのか	
Dialogue: 0,0:30:50.44,0:30:52.20,DefaultSingle-J,,0,0,0,,		俺も停止は反対	
Dialogue: 0,0:30:52.48,0:30:55.21,DefaultSingle-J,,0,0,0,,		だって  こんなすごいシステムをいじれるんだよ	
Dialogue: 0,0:30:55.33,0:31:00.39,DefaultSingle-J,,0,0,0,,		以前まで  世界的なIT企業におられたそうですが	
Dialogue: 0,0:31:02.23,0:31:04.58,DefaultSingle-J,,0,0,0,,		こっちの方がずっとやりがいあるね	
Dialogue: 0,0:31:04.89,0:31:07.97,DefaultSingle-J,,0,0,0,,		今日みたいに  エキサイティングな事件も見られるし	
Dialogue: 0,0:31:12.00,0:31:13.88,DefaultSingle-J,,0,0,0,,		ママ  おなかすいた	
Dialogue: 0,0:31:13.99,0:31:14.90,DefaultSingle-J,,0,0,0,,		ねー	
Dialogue: 0,0:31:15.55,0:31:17.10,DefaultSingle-J,,0,0,0,,		おいしかったね	
Dialogue: 0,0:31:18.00,0:31:19.39,DefaultSingle-J,,0,0,0,,		ほんとキレイ	
Dialogue: 0,0:31:19.50,0:31:21.23,DefaultSingle-J,,0,0,0,,		お食事もおいしいし	
Dialogue: 0,0:31:21.66,0:31:23.33,DefaultSingle-J,,0,0,0,,		雰囲気もステキだね	
Dialogue: 0,0:31:23.33,0:31:24.74,DefaultSingle-J,,0,0,0,,		うん  夏も…	
Dialogue: 0,0:31:24.74,0:31:26.00,DefaultSingle-J,,0,0,0,,		サイコー	
Dialogue: 0,0:31:27.32,0:31:28.91,DefaultSingle-J,,0,0,0,,		台無しだけど	
Dialogue: 0,0:31:29.11,0:31:30.50,DefaultSingle-J,,0,0,0,,		お父さん	
Dialogue: 0,0:31:30.88,0:31:33.62,DefaultSingle-J,,0,0,0,,		大きい声出さないでよ  はずかしい	
Dialogue: 0,0:31:35.22,0:31:36.53,DefaultSingle-J,,0,0,0,,		うんめー	
Dialogue: 0,0:31:36.77,0:31:38.73,DefaultSingle-J,,0,0,0,,		明日葉って苦ぇんだな	
Dialogue: 0,0:31:38.90,0:31:40.41,DefaultSingle-J,,0,0,0,,		ほんとですねえ	
Dialogue: 0,0:31:40.68,0:31:42.38,DefaultSingle-J,,0,0,0,,		このお寿司  おいしいよ	
Dialogue: 0,0:31:42.57,0:31:44.84,DefaultSingle-J,,0,0,0,,		で  どこ行ってたの	
Dialogue: 0,0:31:44.98,0:31:46.61,DefaultSingle-J,,0,0,0,,		パシフィック・ブイってとこ	
Dialogue: 0,0:31:46.61,0:31:47.81,DefaultSingle-J,,0,0,0,,		やっぱりね	
Dialogue: 0,0:31:48.38,0:31:49.49,DefaultSingle-J,,0,0,0,,		何してたのよ	
Dialogue: 0,0:31:49.85,0:31:51.26,DefaultSingle-J,,0,0,0,,		いや  別に	
Dialogue: 0,0:31:51.43,0:31:56.00,DefaultSingle-J,,0,0,0,,		コナン君  クジラさん  バシャーンってすごかったんだよ	
Dialogue: 0,0:31:56.34,0:31:58.75,DefaultSingle-J,,0,0,0,,		クジラのおじさんが当ててくれるの	
Dialogue: 0,0:31:58.75,0:32:00.77,DefaultSingle-J,,0,0,0,,		タブレットで調べてました	
Dialogue: 0,0:32:00.96,0:32:02.49,DefaultSingle-J,,0,0,0,,		クジラのおじさん？	
Dialogue: 0,0:32:02.80,0:32:03.78,DefaultSingle-J,,0,0,0,,		ほれ	
Dialogue: 0,0:32:04.72,0:32:05.95,DefaultSingle-J,,0,0,0,,		彼じゃよ	
Dialogue: 0,0:32:05.95,0:32:07.60,DefaultSingle-J,,0,0,0,,		なんだよ  この写真…	
Dialogue: 0,0:32:07.60,0:32:10.82,DefaultSingle-J,,0,0,0,,		いや  すっかり意気投合してのう	
Dialogue: 0,0:32:11.09,0:32:16.70,DefaultSingle-J,,0,0,0,,		そうじゃ  ワシが教えてもらったクジラ知識で  腹ごなしの…	
Dialogue: 0,0:32:17.67,0:32:18.71,DefaultSingle-J,,0,0,0,,		まさか…	
Dialogue: 0,0:32:19.71,0:32:21.73,DefaultSingle-J,,0,0,0,,		クジラクイズじゃ	
Dialogue: 0,0:32:21.73,0:32:24.34,DefaultSingle-J,,0,0,0,,		腹ごなしのクイズってなんだよ…	
Dialogue: 0,0:32:24.48,0:32:26.80,DefaultSingle-J,,0,0,0,,		みな大好きクジラさん	
Dialogue: 0,0:32:26.80,0:32:31.40,DefaultSingle-J,,0,0,0,,		ではクジラが怒ったかどうか  どこを見れば分かるかな	
Dialogue: 0,0:32:32.29,0:32:34.00,DefaultSingle-J,,0,0,0,,		1番  耳	
Dialogue: 0,0:32:34.72,0:32:36.52,DefaultSingle-J,,0,0,0,,		2番  鼻	
Dialogue: 0,0:32:37.22,0:32:39.00,DefaultSingle-J,,0,0,0,,		3番  口	
Dialogue: 0,0:32:39.38,0:32:41.11,DefaultSingle-J,,0,0,0,,		4番  目	
Dialogue: 0,0:32:41.87,0:32:44.07,DefaultSingle-J,,0,0,0,,		さあ  どれかのう	
Dialogue: 0,0:32:45.21,0:32:47.99,DefaultSingle-J,,0,0,0,,		え  クジラさんが怒った時？	
Dialogue: 0,0:32:48.08,0:32:50.76,DefaultSingle-J,,0,0,0,,		耳  鼻  口  目…	
Dialogue: 0,0:32:50.76,0:32:52.20,DefaultSingle-J,,0,0,0,,		わかんねーよ	
Dialogue: 0,0:32:52.20,0:32:54.20,DefaultSingle-J,,0,0,0,,		なんかヒントねーのかよ  コナン	
Dialogue: 0,0:32:54.31,0:32:58.21,DefaultSingle-J,,0,0,0,,		そうだな…  「怒る」を別の言い方にするとなんだ？	
Dialogue: 0,0:33:02.17,0:33:04.59,DefaultSingle-J,,0,0,0,,		吉田さん  怒った顔  やってみて	
Dialogue: 0,0:33:04.94,0:33:06.60,DefaultSingle-J,,0,0,0,,		怒った顔？	
Dialogue: 0,0:33:06.78,0:33:08.22,DefaultSingle-J,,0,0,0,,		こーお？	
Dialogue: 0,0:33:08.68,0:33:10.76,DefaultSingle-J,,0,0,0,,		その指は  どこを押さえてる？	
Dialogue: 0,0:33:11.00,0:33:13.25,DefaultSingle-J,,0,0,0,,		目尻…  ですか	
Dialogue: 0,0:33:13.35,0:33:15.89,DefaultSingle-J,,0,0,0,,		目尻は  目くじりとも言うんだぜ	
Dialogue: 0,0:33:16.02,0:33:17.83,DefaultSingle-J,,0,0,0,,		目くじり？	
Dialogue: 0,0:33:17.83,0:33:19.22,DefaultSingle-J,,0,0,0,,		あ  そっか	
Dialogue: 0,0:33:19.22,0:33:22.52,DefaultSingle-J,,0,0,0,,		ああ  あの言葉ってそこから来てるんだ	
Dialogue: 0,0:33:22.84,0:33:24.42,DefaultSingle-J,,0,0,0,,		目くじり…？	
Dialogue: 0,0:33:24.54,0:33:27.00,DefaultSingle-J,,0,0,0,,		ああ  目くじらを立てる	
Dialogue: 0,0:33:27.00,0:33:29.07,DefaultSingle-J,,0,0,0,,		答えは4番の「目」です	
Dialogue: 0,0:33:29.39,0:33:32.57,DefaultSingle-J,,0,0,0,,		ピンポーン  光彦君  正解じゃ	
Dialogue: 0,0:33:32.57,0:33:33.90,DefaultSingle-J,,0,0,0,,		やりました	
Dialogue: 0,0:33:34.50,0:33:37.88,DefaultSingle-J,,0,0,0,,		ほとんど答え教えてもらってたじゃねーかよ	
Dialogue: 0,0:33:37.88,0:33:40.11,DefaultSingle-J,,0,0,0,,		それ  元太君も聞いてたでしょ	
Dialogue: 0,0:33:40.49,0:33:41.80,DefaultSingle-J,,0,0,0,,		でもよ…	
Dialogue: 0,0:33:39.08,0:33:40.11,DefaultSingle-J,,0,0,0,,		なあ  博士	
Dialogue: 0,0:33:40.49,0:33:41.30,DefaultSingle-J,,0,0,0,,		ん？	
Dialogue: 0,0:33:41.48,0:33:42.83,DefaultSingle-J,,0,0,0,,		後で  ちょっといいか	
Dialogue: 0,0:33:43.25,0:33:45.02,DefaultSingle-J,,0,0,0,,		おお  なんか用かの	
Dialogue: 0,0:33:45.14,0:33:46.16,DefaultSingle-J,,0,0,0,,		いや  ちょっと	
Dialogue: 0,0:33:50.11,0:33:51.00,DefaultSingle-J,,0,0,0,,		なんじゃと	
Dialogue: 0,0:33:51.00,0:33:52.34,DefaultSingle-J,,0,0,0,,		声がデケーって	
Dialogue: 0,0:33:54.15,0:33:57.10,DefaultSingle-J,,0,0,0,,		それは黒ずくめの仕業なのか	
Dialogue: 0,0:33:57.23,0:33:58.58,DefaultSingle-J,,0,0,0,,		オレはそう思ってる	
Dialogue: 0,0:33:59.28,0:34:00.73,DefaultSingle-J,,0,0,0,,		なるほど	
Dialogue: 0,0:34:01.10,0:34:02.75,DefaultSingle-J,,0,0,0,,		そういうことだったのね	
Dialogue: 0,0:34:03.79,0:34:05.44,DefaultSingle-J,,0,0,0,,		どっから聞いてた	
Dialogue: 0,0:34:05.44,0:34:08.43,DefaultSingle-J,,0,0,0,,		女性エンジニアがさらわれたってとこから	
Dialogue: 0,0:34:09.10,0:34:10.24,DefaultSingle-J,,0,0,0,,		全部じゃな	
Dialogue: 0,0:34:10.59,0:34:13.61,DefaultSingle-J,,0,0,0,,		さらったのは  本当に組織なの	
Dialogue: 0,0:34:13.81,0:34:15.29,DefaultSingle-J,,0,0,0,,		可能性は高い	
Dialogue: 0,0:34:15.77,0:34:18.99,DefaultSingle-J,,0,0,0,,		だから明日になったら  すぐ子供達と帰ってくれ	
Dialogue: 0,0:34:19.18,0:34:21.63,DefaultSingle-J,,0,0,0,,		ええ  言われなくてもそうするわ	
Dialogue: 0,0:34:22.11,0:34:24.30,DefaultSingle-J,,0,0,0,,		もちろん  あなたも一緒にね	
Dialogue: 0,0:34:32.71,0:34:36.04,DefaultSingle-J,,0,0,0,,		なんのつもり  予備のメガネなら持ってるけど	
Dialogue: 0,0:34:36.41,0:34:39.70,DefaultSingle-J,,0,0,0,,		そのメガネは博士が最初に作った1号機	
Dialogue: 0,0:34:40.49,0:34:45.64,DefaultSingle-J,,0,0,0,,		言ったろ  そいつをかけてると  正体が絶対バレねえって	
Dialogue: 0,0:34:47.89,0:34:52.11,DefaultSingle-J,,0,0,0,,		のわりには  あっさりピスコにバレてさらわれたけど	
Dialogue: 0,0:34:54.49,0:34:56.44,DefaultSingle-J,,0,0,0,,		でもその後  助かったろ？	
Dialogue: 0,0:34:57.09,0:34:59.67,DefaultSingle-J,,0,0,0,,		まあ  お守りみてえなもんだと思って	
Dialogue: 0,0:35:02.01,0:35:04.67,DefaultSingle-J,,0,0,0,,		オメーの予備のメガネと  交換しとこうぜ	
Dialogue: 0,0:35:07.15,0:35:08.99,DefaultSingle-J,,0,0,0,,		さあ  哀君も戻ろう	
Dialogue: 0,0:35:09.19,0:35:10.01,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,0:35:14.98,0:35:16.17,DefaultSingle-J,,0,0,0,,		「お守り」ね…	
Dialogue: 0,0:35:29.74,0:35:32.94,DefaultSingle-J,,0,0,0,,		例のガキをシステムで見つけたそうですぜ	
Dialogue: 0,0:35:41.33,0:35:43.45,DefaultSingle-J,,0,0,0,,		アタイも見つけたよ  ジン	
Dialogue: 0,0:35:43.73,0:35:48.25,DefaultSingle-J,,0,0,0,,		まさか八丈島にいたなんて  運はこっちに向いてるよ	
Dialogue: 0,0:36:26.00,0:36:26.98,DefaultSingle-J,,0,0,0,,		よう	
Dialogue: 0,0:36:32.71,0:36:33.37,DefaultSingle-J,,0,0,0,,		放し…	
Dialogue: 0,0:36:36.72,0:36:37.77,DefaultSingle-J,,0,0,0,,		灰原？	
Dialogue: 0,0:36:38.57,0:36:39.46,DefaultSingle-J,,0,0,0,,		まさか…	
Dialogue: 0,0:36:49.44,0:36:51.34,DefaultSingle-J,,0,0,0,,		博士  灰原がさらわれた	
Dialogue: 0,0:36:51.34,0:36:53.00,DefaultSingle-J,,0,0,0,,		なっ  なんじゃと	
Dialogue: 0,0:36:54.48,0:36:55.48,DefaultSingle-J,,0,0,0,,		ウォッカ	
Dialogue: 0,0:36:55.88,0:36:57.18,DefaultSingle-J,,0,0,0,,		クソッ  間に合わねえ	
Dialogue: 0,0:36:57.64,0:37:01.06,DefaultSingle-J,,0,0,0,,		あの先は非常口  下りたら駐車場だ	
Dialogue: 0,0:37:01.06,0:37:02.87,DefaultSingle-J,,0,0,0,,		博士  車を回してくれ	
Dialogue: 0,0:37:02.87,0:37:03.85,DefaultSingle-J,,0,0,0,,		分かった	
Dialogue: 0,0:37:08.31,0:37:10.25,DefaultSingle-J,,0,0,0,,		コーンロウ  あいつがピンガ	
Dialogue: 0,0:37:12.25,0:37:13.67,DefaultSingle-J,,0,0,0,,		急がねえと…	
Dialogue: 0,0:37:14.62,0:37:15.84,DefaultSingle-J,,0,0,0,,		楽勝だね	
Dialogue: 0,0:37:21.93,0:37:22.85,DefaultSingle-J,,0,0,0,,		蘭	
Dialogue: 0,0:37:28.60,0:37:29.26,DefaultSingle-J,,0,0,0,,		何っ	
Dialogue: 0,0:37:31.86,0:37:33.03,DefaultSingle-J,,0,0,0,,		なんだ  お前は	
Dialogue: 0,0:37:33.03,0:37:34.69,DefaultSingle-J,,0,0,0,,		哀ちゃんを返しなさい	
Dialogue: 0,0:37:37.40,0:37:38.11,DefaultSingle-J,,0,0,0,,		なんだ	
Dialogue: 0,0:37:41.37,0:37:43.07,DefaultSingle-J,,0,0,0,,		クソッ  ウソだろ	
Dialogue: 0,0:38:02.49,0:38:04.01,DefaultSingle-J,,0,0,0,,		構うな  行くぞ	
Dialogue: 0,0:38:04.51,0:38:05.89,DefaultSingle-J,,0,0,0,,		待ちなさい	
Dialogue: 0,0:38:06.33,0:38:07.89,DefaultSingle-J,,0,0,0,,		誰だか知らないけど	
Dialogue: 0,0:38:08.87,0:38:09.75,DefaultSingle-J,,0,0,0,,		死にな	
Dialogue: 0,0:38:09.75,0:38:10.80,DefaultSingle-J,,0,0,0,,		ヤベエ	
Dialogue: 0,0:38:17.52,0:38:19.10,DefaultSingle-J,,0,0,0,,		なんだ  今のは	
Dialogue: 0,0:38:21.78,0:38:23.45,DefaultSingle-J,,0,0,0,,		コナン君  誰か呼んでくる…	
Dialogue: 0,0:38:23.45,0:38:24.30,DefaultSingle-J,,0,0,0,,		ダメだ	
Dialogue: 0,0:38:24.86,0:38:28.27,DefaultSingle-J,,0,0,0,,		オレが合図するまで  そこを動くんじゃねーぞ	
Dialogue: 0,0:38:30.42,0:38:31.83,DefaultSingle-J,,0,0,0,,		う  うん	
Dialogue: 0,0:38:38.74,0:38:40.59,DefaultSingle-J,,0,0,0,,		200メートルってとこか	
Dialogue: 0,0:38:43.30,0:38:44.93,DefaultSingle-J,,0,0,0,,		今だ  走れ	
Dialogue: 0,0:38:47.41,0:38:48.48,DefaultSingle-J,,0,0,0,,		死ね	
Dialogue: 0,0:38:49.13,0:38:49.94,DefaultSingle-J,,0,0,0,,		何っ	
Dialogue: 0,0:38:50.69,0:38:52.10,DefaultSingle-J,,0,0,0,,		クソッ  誰だ	
Dialogue: 0,0:38:52.36,0:38:53.50,DefaultSingle-J,,0,0,0,,		よし	
Dialogue: 0,0:38:55.60,0:38:57.11,DefaultSingle-J,,0,0,0,,		新一  乗れ	
Dialogue: 0,0:38:59.51,0:39:02.61,DefaultSingle-J,,0,0,0,,		お父さん  起きて  大変なの	
Dialogue: 0,0:39:02.83,0:39:04.10,DefaultSingle-J,,0,0,0,,		蘭  頼む	
Dialogue: 0,0:39:04.57,0:39:05.73,DefaultSingle-J,,0,0,0,,		もう1杯	
Dialogue: 0,0:39:09.41,0:39:10.24,DefaultSingle-J,,0,0,0,,		もう	
Dialogue: 0,0:39:14.42,0:39:17.32,DefaultSingle-J,,0,0,0,,		よかった  探偵バッジは持ってるみてえだ	
Dialogue: 0,0:39:18.44,0:39:19.88,DefaultSingle-J,,0,0,0,,		なぜ哀君が…	
Dialogue: 0,0:39:20.49,0:39:24.30,DefaultSingle-J,,0,0,0,,		バレちまったのかもしれねえ  あいつがシェリーだってことが	
Dialogue: 0,0:39:24.42,0:39:25.63,DefaultSingle-J,,0,0,0,,		なんじゃと	
Dialogue: 0,0:39:30.62,0:39:32.39,DefaultSingle-J,,0,0,0,,		ああ  5分後だ	
Dialogue: 0,0:39:32.39,0:39:33.49,DefaultSingle-J,,0,0,0,,		クソッ	
Dialogue: 0,0:39:33.64,0:39:35.39,DefaultSingle-J,,0,0,0,,		とんだジャマが入ったな	
Dialogue: 0,0:39:36.90,0:39:39.19,DefaultSingle-J,,0,0,0,,		次に会ったら殺してやるよ	
Dialogue: 0,0:39:40.45,0:39:41.40,DefaultSingle-J,,0,0,0,,		ん？	
Dialogue: 0,0:39:42.80,0:39:44.39,DefaultSingle-J,,0,0,0,,		なんだ  あの車は	
Dialogue: 0,0:39:46.03,0:39:47.74,DefaultSingle-J,,0,0,0,,		おったぞ  ヤツらじゃ	
Dialogue: 0,0:39:48.20,0:39:49.41,DefaultSingle-J,,0,0,0,,		二手に分かれよう	
Dialogue: 0,0:40:02.90,0:40:05.22,DefaultSingle-J,,0,0,0,,		やっかいな道を走りおって	
Dialogue: 0,0:40:05.22,0:40:08.70,DefaultSingle-J,,0,0,0,,		博士  山道はオトリだ  ムチャすんなよ	
Dialogue: 0,0:40:08.70,0:40:09.69,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,0:40:14.48,0:40:15.64,DefaultSingle-J,,0,0,0,,		おそらくヤツらは	
Dialogue: 0,0:40:15.64,0:40:19.96,DefaultSingle-J,,0,0,0,,		山道を進むと見せかけて  途中で曲がって外周道路に出るはずだ	
Dialogue: 0,0:40:20.24,0:40:22.68,DefaultSingle-J,,0,0,0,,		八丈富士方向に逃げ場はねーしな	
Dialogue: 0,0:40:23.64,0:40:25.68,DefaultSingle-J,,0,0,0,,		先回りしてはさみ込むしかねえ	
Dialogue: 0,0:40:39.54,0:40:43.97,DefaultSingle-J,,0,0,0,,		新一  読みどおりじゃ  ヤツら国道に出おったぞ	
Dialogue: 0,0:40:43.97,0:40:45.60,DefaultSingle-J,,0,0,0,,		ああ  こっちも捉えた	
Dialogue: 0,0:40:46.05,0:40:48.00,DefaultSingle-J,,0,0,0,,		ぶつけてでも止めたるわい	
Dialogue: 0,0:40:51.87,0:40:54.34,DefaultSingle-J,,0,0,0,,		博士より先になんとかしねーと	
Dialogue: 0,0:40:54.59,0:40:56.64,DefaultSingle-J,,0,0,0,,		こいつで眠らせるしかねーか	
Dialogue: 0,0:41:01.77,0:41:02.59,DefaultSingle-J,,0,0,0,,		来た	
Dialogue: 0,0:41:04.95,0:41:07.94,DefaultSingle-J,,0,0,0,,		チャンスは一度きり  イチかバチかだ	
Dialogue: 0,0:41:10.07,0:41:10.70,DefaultSingle-J,,0,0,0,,		なっ…	
Dialogue: 0,0:41:15.30,0:41:16.30,DefaultSingle-J,,0,0,0,,		クソッ	
Dialogue: 0,0:41:20.19,0:41:21.79,DefaultSingle-J,,0,0,0,,		どこに行くつもりだ	
Dialogue: 0,0:41:21.95,0:41:23.31,DefaultSingle-J,,0,0,0,,		そっちに行ったって…	
Dialogue: 0,0:41:24.38,0:41:25.40,DefaultSingle-J,,0,0,0,,		まさか…	
Dialogue: 0,0:41:30.05,0:41:31.34,DefaultSingle-J,,0,0,0,,		ウソだろ	
Dialogue: 0,0:41:31.59,0:41:33.01,DefaultSingle-J,,0,0,0,,		哀君	
Dialogue: 0,0:41:38.98,0:41:39.78,DefaultSingle-J,,0,0,0,,		クソッ	
Dialogue: 0,0:41:40.50,0:41:41.39,DefaultSingle-J,,0,0,0,,		新一	
Dialogue: 0,0:42:27.16,0:42:29.00,DefaultSingle-J,,0,0,0,,		ヤベ…もう息が…	
Dialogue: 0,0:42:33.32,0:42:35.84,DefaultSingle-J,,0,0,0,,		灰原  灰原	
Dialogue: 0,0:42:40.10,0:42:41.69,DefaultSingle-J,,0,0,0,,		この音はなんだ	
Dialogue: 0,0:43:01.85,0:43:03.10,DefaultSingle-J,,0,0,0,,		マジかよ	
Dialogue: 0,0:43:05.47,0:43:06.67,DefaultSingle-J,,0,0,0,,		ヤベエ	
Dialogue: 0,0:43:31.09,0:43:33.13,DefaultSingle-J,,0,0,0,,		そ…そんな…	
Dialogue: 0,0:43:33.53,0:43:36.05,DefaultSingle-J,,0,0,0,,		どうして…哀君…	
Dialogue: 0,0:43:49.09,0:43:50.12,DefaultSingle-J,,0,0,0,,		博士	
Dialogue: 0,0:43:51.00,0:43:52.13,DefaultSingle-J,,0,0,0,,		灰原は…	
Dialogue: 0,0:43:54.36,0:43:56.52,DefaultSingle-J,,0,0,0,,		オレがぜってー連れ戻す	
Dialogue: 0,0:44:00.76,0:44:02.12,DefaultSingle-J,,0,0,0,,		潜水艦？	
Dialogue: 0,0:44:02.12,0:44:02.90,DefaultSingle-J,,0,0,0,,		うん	
Dialogue: 0,0:44:03.26,0:44:04.38,DefaultSingle-J,,0,0,0,,		まさか	
Dialogue: 0,0:44:05.20,0:44:06.79,DefaultSingle-J,,0,0,0,,		阿笠さんも見たんですか	
Dialogue: 0,0:44:07.03,0:44:09.72,DefaultSingle-J,,0,0,0,,		いや  ワシは暗くて…	
Dialogue: 0,0:44:11.94,0:44:14.15,DefaultSingle-J,,0,0,0,,		怖い思いをしたから  勘違いしたのかも…	
Dialogue: 0,0:44:14.15,0:44:15.13,DefaultSingle-J,,0,0,0,,		違う	
Dialogue: 0,0:44:15.38,0:44:17.88,DefaultSingle-J,,0,0,0,,		オレはほんとに潜水艦を見たんだ	
Dialogue: 0,0:44:19.83,0:44:20.99,DefaultSingle-J,,0,0,0,,		落ち着くんじゃ	
Dialogue: 0,0:44:27.28,0:44:28.29,DefaultSingle-J,,0,0,0,,		コナン君	
Dialogue: 0,0:44:29.26,0:44:30.75,DefaultSingle-J,,0,0,0,,		どの辺りかな	
Dialogue: 0,0:44:34.48,0:44:36.28,DefaultSingle-J,,0,0,0,,		この辺  間違いない	
Dialogue: 0,0:44:37.48,0:44:38.49,DefaultSingle-J,,0,0,0,,		灯台があります	
Dialogue: 0,0:44:39.15,0:44:42.10,DefaultSingle-J,,0,0,0,,		警察や海保の防犯カメラがあるはずだ	
Dialogue: 0,0:44:42.93,0:44:43.99,DefaultSingle-J,,0,0,0,,		調べてみよう	
Dialogue: 0,0:44:43.99,0:44:44.72,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,0:44:47.84,0:44:51.10,DefaultSingle-J,,0,0,0,,		哀君…  無事だといいんじゃが	
Dialogue: 0,0:44:51.47,0:44:52.46,DefaultSingle-J,,0,0,0,,		そうだ	
Dialogue: 0,0:44:54.16,0:44:56.30,DefaultSingle-J,,0,0,0,,		灰原  灰原	
Dialogue: 0,0:44:56.62,0:44:58.39,DefaultSingle-J,,0,0,0,,		さすがに無理じゃ	
Dialogue: 0,0:45:00.17,0:45:03.27,DefaultSingle-J,,0,0,0,,		それにヤツらに聞かれてしまうかもしれんぞ	
Dialogue: 0,0:45:05.39,0:45:06.50,DefaultSingle-J,,0,0,0,,		だよな	
Dialogue: 0,0:45:08.00,0:45:09.58,DefaultSingle-J,,0,0,0,,		ピンガを捜し出さねーと	
Dialogue: 0,0:45:10.18,0:45:10.95,DefaultSingle-J,,0,0,0,,		ピンガ？	
Dialogue: 0,0:45:11.22,0:45:13.58,DefaultSingle-J,,0,0,0,,		ああ  組織のメンバーの1人だ	
Dialogue: 0,0:45:15.86,0:45:20.03,DefaultSingle-J,,0,0,0,,		潜水艦か…ライフルでは歯が立たないな	
Dialogue: 0,0:45:20.57,0:45:21.73,DefaultSingle-J,,0,0,0,,		どうすればいい	
Dialogue: 0,0:45:22.63,0:45:24.69,DefaultSingle-J,,0,0,0,,		こちらで対処法を考える	
Dialogue: 0,0:45:25.02,0:45:26.53,DefaultSingle-J,,0,0,0,,		その子の奪還は…	
Dialogue: 0,0:45:27.00,0:45:28.66,DefaultSingle-J,,0,0,0,,		それはこっちでなんとかすっから	
Dialogue: 0,0:45:29.13,0:45:31.19,DefaultSingle-J,,0,0,0,,		赤井さんは潜水艦に専念して	
Dialogue: 0,0:45:31.71,0:45:33.68,DefaultSingle-J,,0,0,0,,		ああ  分かった	
Dialogue: 0,0:45:36.93,0:45:41.97,DefaultSingle-J,,0,0,0,,		心配すんなって  オレもいろいろ探って  博士に連絡すっから	
Dialogue: 0,0:45:42.41,0:45:45.13,DefaultSingle-J,,0,0,0,,		新一  こっちに来られないの	
Dialogue: 0,0:45:45.79,0:45:48.21,DefaultSingle-J,,0,0,0,,		知り合いの子がさらわれちゃったんだよ	
Dialogue: 0,0:45:48.44,0:45:49.48,DefaultSingle-J,,0,0,0,,		分かってる	
Dialogue: 0,0:45:50.31,0:45:53.05,DefaultSingle-J,,0,0,0,,		いざとなったら  そっちに行ってやっからよ	
Dialogue: 0,0:45:53.61,0:45:55.90,DefaultSingle-J,,0,0,0,,		ほんと？  約束だからね	
Dialogue: 0,0:45:56.25,0:45:57.15,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,0:46:01.02,0:46:04.31,DefaultSingle-J,,0,0,0,,		いざとなったら…  な…	
Dialogue: 0,0:46:58.99,0:47:03.50,DefaultSingle-J,,0,0,0,,		私と同じく  幼児化した可能性が高い工藤新一…	
Dialogue: 0,0:47:09.37,0:47:10.85,DefaultSingle-J,,0,0,0,,		工藤新一なら…	
Dialogue: 0,0:47:15.44,0:47:16.67,DefaultSingle-J,,0,0,0,,		あ  あの…	
Dialogue: 0,0:47:27.41,0:47:29.03,DefaultSingle-J,,0,0,0,,		会いたかったぜ	
Dialogue: 0,0:47:29.27,0:47:30.37,DefaultSingle-J,,0,0,0,,		シェリー	
Dialogue: 0,0:47:44.65,0:47:45.70,DefaultSingle-J,,0,0,0,,		よかった	
Dialogue: 0,0:47:48.13,0:47:49.05,DefaultSingle-J,,0,0,0,,		だ  誰	
Dialogue: 0,0:47:51.03,0:47:52.32,DefaultSingle-J,,0,0,0,,		怖かったよね	
Dialogue: 0,0:47:55.26,0:47:57.81,DefaultSingle-J,,0,0,0,,		あなた  確かニュース…	
Dialogue: 0,0:47:57.95,0:47:59.39,DefaultSingle-J,,0,0,0,,		え  なんて？	
Dialogue: 0,0:47:59.79,0:48:02.42,DefaultSingle-J,,0,0,0,,		いえ  ここはどこ	
Dialogue: 0,0:48:02.59,0:48:05.07,DefaultSingle-J,,0,0,0,,		たぶん潜水艦だと思うんだけど	
Dialogue: 0,0:48:05.39,0:48:06.96,DefaultSingle-J,,0,0,0,,		私も分からなくて	
Dialogue: 0,0:48:11.92,0:48:12.82,DefaultSingle-J,,0,0,0,,		誰が…	
Dialogue: 0,0:48:13.52,0:48:14.59,DefaultSingle-J,,0,0,0,,		何	
Dialogue: 0,0:48:15.66,0:48:19.54,DefaultSingle-J,,0,0,0,,		あなた  本当に似てる  志保に	
Dialogue: 0,0:48:20.97,0:48:23.09,DefaultSingle-J,,0,0,0,,		いや  志保はもう大人だから	
Dialogue: 0,0:48:23.09,0:48:25.18,DefaultSingle-J,,0,0,0,,		志保の小さい時にってことね	
Dialogue: 0,0:48:25.77,0:48:27.70,DefaultSingle-J,,0,0,0,,		へえ  そうなんだ	
Dialogue: 0,0:48:31.49,0:48:34.61,DefaultSingle-J,,0,0,0,,		おい  何だ  縛ってねえじゃねえか	
Dialogue: 0,0:48:34.81,0:48:36.89,DefaultSingle-J,,0,0,0,,		こんな子供に必要ないわ	
Dialogue: 0,0:48:37.08,0:48:38.98,DefaultSingle-J,,0,0,0,,		念には念をだ	
Dialogue: 0,0:48:38.98,0:48:40.89,DefaultSingle-J,,0,0,0,,		貸して  私がやるわ	
Dialogue: 0,0:48:41.09,0:48:44.00,DefaultSingle-J,,0,0,0,,		あなたは  これを確認したいんでしょ？	
Dialogue: 0,0:48:44.08,0:48:45.28,DefaultSingle-J,,0,0,0,,		まあな	
Dialogue: 0,0:48:46.61,0:48:47.61,DefaultSingle-J,,0,0,0,,		足からね	
Dialogue: 0,0:48:56.41,0:48:57.14,DefaultSingle-J,,0,0,0,,		腕を	
Dialogue: 0,0:49:10.04,0:49:12.91,DefaultSingle-J,,0,0,0,,		しっかし  信じらんねえな	
Dialogue: 0,0:49:14.95,0:49:17.18,DefaultSingle-J,,0,0,0,,		お前  シェリーなんだろ？	
Dialogue: 0,0:49:20.58,0:49:21.10,DefaultSingle-J,,0,0,0,,		フンッ	
Dialogue: 0,0:49:21.98,0:49:25.57,DefaultSingle-J,,0,0,0,,		おい  このガキがこの女ってことだよな？	
Dialogue: 0,0:49:25.68,0:49:26.81,DefaultSingle-J,,0,0,0,,		これって…	
Dialogue: 0,0:49:30.69,0:49:32.94,DefaultSingle-J,,0,0,0,,		チッ  まあいい	
Dialogue: 0,0:49:33.21,0:49:35.81,DefaultSingle-J,,0,0,0,,		黙っていられるのも  今のうちだ	
Dialogue: 0,0:49:35.81,0:49:39.08,DefaultSingle-J,,0,0,0,,		生かしたまま  ラムに会わせるしかないわね	
Dialogue: 0,0:49:39.40,0:49:41.63,DefaultSingle-J,,0,0,0,,		ジンの兄貴に会わすのが先だ	
Dialogue: 0,0:49:50.52,0:49:52.09,DefaultSingle-J,,0,0,0,,		えっ  哀ちゃんが？	
Dialogue: 0,0:49:52.09,0:49:54.52,DefaultSingle-J,,0,0,0,,		昨日は元気だったのになあ	
Dialogue: 0,0:49:54.52,0:49:57.27,DefaultSingle-J,,0,0,0,,		それなら  ボク達お見舞いに行きます	
Dialogue: 0,0:49:57.27,0:49:58.22,DefaultSingle-J,,0,0,0,,		だな	
Dialogue: 0,0:49:57.79,0:49:58.22,DefaultSingle-J,,0,0,0,,		うん	
Dialogue: 0,0:49:58.39,0:50:00.56,DefaultSingle-J,,0,0,0,,		うな重差し入れしよーぜ	
Dialogue: 0,0:50:00.93,0:50:03.77,DefaultSingle-J,,0,0,0,,		ダメ  カゼがうつっちゃうでしょ	
Dialogue: 0,0:50:04.12,0:50:06.45,DefaultSingle-J,,0,0,0,,		哀ちゃん  そんなに悪いの	
Dialogue: 0,0:50:06.45,0:50:09.44,DefaultSingle-J,,0,0,0,,		病院で診てもらってる  大丈夫だ	
Dialogue: 0,0:50:09.58,0:50:10.69,DefaultSingle-J,,0,0,0,,		でも…	
Dialogue: 0,0:50:10.84,0:50:14.78,DefaultSingle-J,,0,0,0,,		クルーザーを手配したから  みんな支度して  いいわね	
Dialogue: 0,0:50:14.93,0:50:16.57,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,0:50:16.67,0:50:17.62,DefaultSingle-J,,0,0,0,,		毛利君	
Dialogue: 0,0:50:17.82,0:50:18.82,DefaultSingle-J,,0,0,0,,		警部殿	
Dialogue: 0,0:50:18.94,0:50:22.30,DefaultSingle-J,,0,0,0,,		すまないが  コナン君と一緒に来てくれないか	
Dialogue: 0,0:50:22.42,0:50:22.89,DefaultSingle-J,,0,0,0,,		えっ？	
Dialogue: 0,0:50:22.61,0:50:23.38,DefaultSingle-J,,0,0,0,,		えーっ？	
Dialogue: 0,0:50:30.97,0:50:33.23,DefaultSingle-J,,0,0,0,,		ごめん  ちょっと待って  すぐ終わらせる	
Dialogue: 0,0:50:33.70,0:50:35.35,DefaultSingle-J,,0,0,0,,		何やってんだ  あいつ	
Dialogue: 0,0:50:35.35,0:50:39.43,DefaultSingle-J,,0,0,0,,		あれ  いっ  いたたっ…	
Dialogue: 0,0:50:40.77,0:50:41.68,DefaultSingle-J,,0,0,0,,		もしもし	
Dialogue: 0,0:50:42.61,0:50:43.38,DefaultSingle-J,,0,0,0,,		安室さん	
Dialogue: 0,0:50:43.79,0:50:47.17,DefaultSingle-J,,0,0,0,,		ホテルでさらわれた少女は  君の知り合いだよね	
Dialogue: 0,0:50:47.21,0:50:49.17,DefaultSingle-J,,0,0,0,,		まさか  昨日の電話って…	
Dialogue: 0,0:50:49.34,0:50:51.29,DefaultSingle-J,,0,0,0,,		夕方にはジンが合流する	
Dialogue: 0,0:50:52.13,0:50:54.00,DefaultSingle-J,,0,0,0,,		潜水艦に乗り込むってこと？	
Dialogue: 0,0:50:54.34,0:50:57.00,DefaultSingle-J,,0,0,0,,		知ってたのか  さすがだね	
Dialogue: 0,0:50:57.58,0:50:59.57,DefaultSingle-J,,0,0,0,,		ヤツは空から合流する	
Dialogue: 0,0:50:59.70,0:51:00.95,DefaultSingle-J,,0,0,0,,		つまり  その時…	
Dialogue: 0,0:51:01.74,0:51:04.35,DefaultSingle-J,,0,0,0,,		潜水艦は浮上せざるを得ない	
Dialogue: 0,0:51:04.51,0:51:05.30,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,0:51:06.19,0:51:07.96,DefaultSingle-J,,0,0,0,,		おい  行くぞ	
Dialogue: 0,0:51:09.76,0:51:12.41,DefaultSingle-J,,0,0,0,,		彼女を助けるなら  そこしかない	
Dialogue: 0,0:51:15.61,0:51:17.97,DefaultSingle-J,,0,0,0,,		確認してもらいたいことがある	
Dialogue: 0,0:51:18.37,0:51:21.27,DefaultSingle-J,,0,0,0,,		灯台の防犯カメラを調べてみたんだが	
Dialogue: 0,0:51:21.27,0:51:24.15,DefaultSingle-J,,0,0,0,,		潜水艦は映っていなかった	
Dialogue: 0,0:51:24.81,0:51:25.35,DefaultSingle-J,,0,0,0,,		えっ	
Dialogue: 0,0:51:26.26,0:51:28.09,DefaultSingle-J,,0,0,0,,		夜だからってワケじゃないよね	
Dialogue: 0,0:51:28.53,0:51:30.48,DefaultSingle-J,,0,0,0,,		警察の高解像度カメラよ	
Dialogue: 0,0:51:30.85,0:51:35.48,DefaultSingle-J,,0,0,0,,		すいません  こいつのせいで  余計な手間かけさせてしまって	
Dialogue: 0,0:51:35.95,0:51:38.18,DefaultSingle-J,,0,0,0,,		このシステムにつなげてるカメラって	
Dialogue: 0,0:51:38.31,0:51:40.83,DefaultSingle-J,,0,0,0,,		警察が管理してる物だけだったよね	
Dialogue: 0,0:51:41.16,0:51:42.25,DefaultSingle-J,,0,0,0,,		そうだけど	
Dialogue: 0,0:51:42.79,0:51:43.79,DefaultSingle-J,,0,0,0,,		ちょっといい？	
Dialogue: 1,0:51:46.31,0:51:48.04,DefaultSingle-J,,0,0,0,,		犯人が逃げたルートだよ	
Dialogue: 0,0:51:48.19,0:51:49.06,DefaultSingle-J,,0,0,0,,		えっ	
Dialogue: 0,0:51:49.17,0:51:51.58,DefaultSingle-J,,0,0,0,,		この道にある警察のカメラを調べて	
Dialogue: 0,0:51:51.84,0:51:53.01,DefaultSingle-J,,0,0,0,,		おい  いい加減に…	
Dialogue: 0,0:51:53.01,0:51:55.38,DefaultSingle-J,,0,0,0,,		昨夜の11時頃です	
Dialogue: 0,0:51:56.35,0:51:57.20,DefaultSingle-J,,0,0,0,,		うん	
Dialogue: 0,0:51:57.90,0:52:00.01,DefaultSingle-J,,0,0,0,,		レオンハルト  A－6のカメラだ	
Dialogue: 0,0:52:00.84,0:52:03.02,DefaultSingle-J,,0,0,0,,		今度はガキの言いなりかよ	
Dialogue: 0,0:52:08.39,0:52:09.56,DefaultSingle-J,,0,0,0,,		ここのカメラです	
Dialogue: 0,0:52:13.41,0:52:16.27,DefaultSingle-J,,0,0,0,,		変ですね  犯人の車が映ってない	
Dialogue: 0,0:52:16.98,0:52:20.38,DefaultSingle-J,,0,0,0,,		阿笠さんの車もない  どういうことだ	
Dialogue: 0,0:52:21.08,0:52:23.12,DefaultSingle-J,,0,0,0,,		まさか  書き換えられてる？	
Dialogue: 0,0:52:24.00,0:52:25.61,DefaultSingle-J,,0,0,0,,		間違いない	
Dialogue: 0,0:52:30.23,0:52:33.12,DefaultSingle-J,,0,0,0,,		もしかして  あなた  志保の娘？	
Dialogue: 0,0:52:33.51,0:52:37.06,DefaultSingle-J,,0,0,0,,		だから  宮野志保なんて知らないって言ったでしょ	
Dialogue: 0,0:52:38.01,0:52:39.42,DefaultSingle-J,,0,0,0,,		そうよね	
Dialogue: 0,0:52:39.71,0:52:42.60,DefaultSingle-J,,0,0,0,,		志保にこんな大きな子供がいるはずないし	
Dialogue: 0,0:52:43.70,0:52:47.39,DefaultSingle-J,,0,0,0,,		でもあなたは  私が出会った頃の彼女にそっくり	
Dialogue: 0,0:52:48.37,0:52:50.70,DefaultSingle-J,,0,0,0,,		出会った？  どこで？	
Dialogue: 0,0:52:51.66,0:52:54.74,DefaultSingle-J,,0,0,0,,		私  小さい頃アメリカにいたの	
Dialogue: 0,0:52:56.64,0:53:01.37,DefaultSingle-J,,0,0,0,,		東洋系が珍しかったからか  毎日いじめに遭ってて…	
Dialogue: 0,0:53:16.15,0:53:19.69,DefaultSingle-J,,0,0,0,,		そんな時  私をかばってくれたのが	
Dialogue: 0,0:53:21.40,0:53:23.39,DefaultSingle-J,,0,0,0,,		日本人の志保だった	
Dialogue: 0,0:53:24.18,0:53:25.63,DefaultSingle-J,,0,0,0,,		ここ座って	
Dialogue: 0,0:53:29.72,0:53:35.09,DefaultSingle-J,,0,0,0,,		その日から  いじめの標的が  彼女に変わってしまって…	
Dialogue: 0,0:53:38.03,0:53:44.07,DefaultSingle-J,,0,0,0,,		私…  助けられなかった  またいじめられるのが怖くて	
Dialogue: 0,0:53:46.34,0:53:50.88,DefaultSingle-J,,0,0,0,,		だから  人種によって憎しみ合わない世の中にしたいって…	
Dialogue: 0,0:53:51.90,0:53:53.20,DefaultSingle-J,,0,0,0,,		分からないよね	
Dialogue: 0,0:53:53.51,0:53:55.90,DefaultSingle-J,,0,0,0,,		だから  老若認証を作ったの？	
Dialogue: 0,0:53:56.58,0:54:00.34,DefaultSingle-J,,0,0,0,,		ええ  人類学とAIを学んでいるうちに	
Dialogue: 0,0:54:00.90,0:54:05.34,DefaultSingle-J,,0,0,0,,		人種や年齢を問わずに  認証できるプログラムを思いついたの	
Dialogue: 0,0:54:05.97,0:54:09.28,DefaultSingle-J,,0,0,0,,		そしたら  インターポールから声が掛かって	
Dialogue: 0,0:54:09.68,0:54:11.73,DefaultSingle-J,,0,0,0,,		老若認証をテストするために	
Dialogue: 0,0:54:12.12,0:54:15.36,DefaultSingle-J,,0,0,0,,		日本の防犯カメラにアクセスする許可をもらったの	
Dialogue: 0,0:54:16.46,0:54:20.49,DefaultSingle-J,,0,0,0,,		その時  最初に思いついたのが  志保だった	
Dialogue: 0,0:54:21.99,0:54:23.89,DefaultSingle-J,,0,0,0,,		志保にまた会いたかった	
Dialogue: 0,0:54:24.28,0:54:28.23,DefaultSingle-J,,0,0,0,,		ずっと…ずっと謝りたかったから	
Dialogue: 0,0:54:42.19,0:54:45.51,DefaultSingle-J,,0,0,0,,		そしたら  なぜかあなたもヒットして…	
Dialogue: 0,0:54:47.45,0:54:51.36,DefaultSingle-J,,0,0,0,,		それがどういうことなのか  今でも分からないんだけど	
Dialogue: 0,0:54:52.82,0:54:56.32,DefaultSingle-J,,0,0,0,,		でもきっと  私のせいで巻き込まれたんだと思う	
Dialogue: 0,0:54:57.35,0:55:00.88,DefaultSingle-J,,0,0,0,,		いいえ  巻き込んだのは  私の方…	
Dialogue: 0,0:55:13.99,0:55:16.00,DefaultSingle-J,,0,0,0,,		そう言うと思ったわ	
Dialogue: 0,0:55:33.90,0:55:36.16,DefaultSingle-J,,0,0,0,,		あん  ジャマしないの	
Dialogue: 0,0:55:46.44,0:55:48.24,DefaultSingle-J,,0,0,0,,		あれはどういうことだ	
Dialogue: 0,0:55:49.33,0:55:50.94,DefaultSingle-J,,0,0,0,,		なんとか言ったらどうなんだ	
Dialogue: 0,0:55:53.40,0:55:56.89,DefaultSingle-J,,0,0,0,,		あのログはゆうべ  お前がメインルームにいた時の…	
Dialogue: 0,0:55:58.25,0:55:59.79,DefaultSingle-J,,0,0,0,,		何やってんだ  お前	
Dialogue: 0,0:56:21.33,0:56:23.21,DefaultSingle-J,,0,0,0,,		蘭は本当に残るの？	
Dialogue: 0,0:56:23.65,0:56:25.50,DefaultSingle-J,,0,0,0,,		哀ちゃんが心配だし	
Dialogue: 0,0:56:25.62,0:56:26.69,DefaultSingle-J,,0,0,0,,		だよね	
Dialogue: 0,0:56:26.98,0:56:30.44,DefaultSingle-J,,0,0,0,,		でも大丈夫  博士も残ってくれるし	
Dialogue: 0,0:56:30.64,0:56:33.61,DefaultSingle-J,,0,0,0,,		すまんが  子供達を頼むわい	
Dialogue: 0,0:56:33.61,0:56:38.45,DefaultSingle-J,,0,0,0,,		まあ  あのガキんちょどもの世話は  わたしに任しといて	
Dialogue: 0,0:56:38.60,0:56:39.92,DefaultSingle-J,,0,0,0,,		慣れたもんよ	
Dialogue: 0,0:56:40.00,0:56:42.25,DefaultSingle-J,,0,0,0,,		園子…  ありがと	
Dialogue: 0,0:56:42.92,0:56:44.43,DefaultSingle-J,,0,0,0,,		じゃーなー	
Dialogue: 0,0:56:42.92,0:56:44.43,DefaultSingle-J,,0,0,0,,		バイバーイ	
Dialogue: 0,0:56:44.13,0:56:44.57,DefaultSingle-J,,0,0,0,,		また	
Dialogue: 0,0:56:44.57,0:56:47.78,DefaultSingle-J,,0,0,0,,		お土産いっぱい買ってきてくれよ	
Dialogue: 0,0:56:48.08,0:56:49.15,DefaultSingle-J,,0,0,0,,		絶対だぞ	
Dialogue: 0,0:56:49.15,0:56:50.45,DefaultSingle-J,,0,0,0,,		こら  危ないって	
Dialogue: 0,0:56:50.45,0:56:51.85,DefaultSingle-J,,0,0,0,,		ああっ  元太君	
Dialogue: 0,0:56:54.18,0:56:57.06,DefaultSingle-J,,0,0,0,,		えっ？  ちょっと  みんな  これ見てよ	
Dialogue: 0,0:56:57.36,0:56:58.86,DefaultSingle-J,,0,0,0,,		レオンハルトからだわ	
Dialogue: 0,0:57:02.45,0:57:04.28,DefaultSingle-J,,0,0,0,,		そんな  どうして…	
Dialogue: 0,0:57:04.28,0:57:06.29,DefaultSingle-J,,0,0,0,,		えっ  何  何	
Dialogue: 0,0:57:06.29,0:57:09.20,DefaultSingle-J,,0,0,0,,		直美さんを拉致した犯人を手引きするため	
Dialogue: 0,0:57:09.45,0:57:11.69,DefaultSingle-J,,0,0,0,,		システムにバックドアを仕掛けたって	
Dialogue: 0,0:57:11.79,0:57:12.48,DefaultSingle-J,,0,0,0,,		ええっ？	
Dialogue: 0,0:57:12.23,0:57:12.70,DefaultSingle-J,,0,0,0,,		えっ？	
Dialogue: 0,0:57:13.14,0:57:13.68,DefaultSingle-J,,0,0,0,,		え？	
Dialogue: 0,0:57:13.68,0:57:16.00,DefaultSingle-J,,0,0,0,,		拉致の実行犯については…	
Dialogue: 0,0:57:16.15,0:57:18.85,DefaultSingle-J,,0,0,0,,		金で雇われたから不明だそうだ	
Dialogue: 0,0:57:19.72,0:57:22.88,DefaultSingle-J,,0,0,0,,		レオンハルトを見つけました  カフェにいます	
Dialogue: 0,0:57:28.58,0:57:30.63,DefaultSingle-J,,0,0,0,,		あれは…薬か	
Dialogue: 0,0:57:31.00,0:57:31.85,DefaultSingle-J,,0,0,0,,		なんだ	
Dialogue: 0,0:57:36.46,0:57:38.39,DefaultSingle-J,,0,0,0,,		ねえ  なんか…	
Dialogue: 0,0:57:38.51,0:57:39.88,DefaultSingle-J,,0,0,0,,		様子が変だぞ	
Dialogue: 0,0:57:45.65,0:57:46.80,DefaultSingle-J,,0,0,0,,		レオンハルト	
Dialogue: 0,0:57:46.80,0:57:48.78,DefaultSingle-J,,0,0,0,,		違うカメラを  早く	
Dialogue: 0,0:57:53.88,0:57:54.88,DefaultSingle-J,,0,0,0,,		何っ	
Dialogue: 0,0:57:56.04,0:57:57.12,DefaultSingle-J,,0,0,0,,		えっ  レオンハルトが？	
Dialogue: 0,0:57:57.12,0:57:57.97,DefaultSingle-J,,0,0,0,,		ウソ	
Dialogue: 0,0:57:59.59,0:58:01.75,DefaultSingle-J,,0,0,0,,		誰か  見てたスタッフはいないか	
Dialogue: 0,0:58:01.75,0:58:04.29,DefaultSingle-J,,0,0,0,,		定例の清掃時間でしたから	
Dialogue: 0,0:58:04.54,0:58:07.29,DefaultSingle-J,,0,0,0,,		ああ  そういえばそうだったか	
Dialogue: 0,0:58:12.04,0:58:15.60,DefaultSingle-J,,0,0,0,,		口の周り  ただれてる  毒物かしら	
Dialogue: 0,0:58:16.22,0:58:17.83,DefaultSingle-J,,0,0,0,,		じゃ  このにおいって…	
Dialogue: 0,0:58:18.19,0:58:19.74,DefaultSingle-J,,0,0,0,,		コーヒーのにおいだね	
Dialogue: 0,0:58:20.07,0:58:24.10,DefaultSingle-J,,0,0,0,,		それもするけど  ほんのかすかにシンナーみたいなにおいしない？	
Dialogue: 0,0:58:25.12,0:58:29.15,DefaultSingle-J,,0,0,0,,		またいつもいつも現場を惑わせるようなことばっかり言って	
Dialogue: 0,0:58:29.46,0:58:31.84,DefaultSingle-J,,0,0,0,,		どう見ても服毒自殺だろーが	
Dialogue: 0,0:58:31.84,0:58:33.05,DefaultSingle-J,,0,0,0,,		まあまあ	
Dialogue: 0,0:58:33.05,0:58:34.64,DefaultSingle-J,,0,0,0,,		でも変じゃない？	
Dialogue: 0,0:58:34.64,0:58:35.49,DefaultSingle-J,,0,0,0,,		何が	
Dialogue: 0,0:58:35.70,0:58:39.07,DefaultSingle-J,,0,0,0,,		レオンハルトさんは  自分のお部屋があるんでしょ？	
Dialogue: 0,0:58:39.72,0:58:42.25,DefaultSingle-J,,0,0,0,,		なんでカフェで死んじゃったのかなあ	
Dialogue: 0,0:58:43.51,0:58:45.00,DefaultSingle-J,,0,0,0,,		確かにそうよね	
Dialogue: 0,0:58:45.20,0:58:47.13,DefaultSingle-J,,0,0,0,,		そんなの決まってんだろ	
Dialogue: 0,0:58:47.54,0:58:50.51,DefaultSingle-J,,0,0,0,,		死ぬ前にうまいコーヒーが飲みたかったんだよ	
Dialogue: 0,0:58:50.68,0:58:51.81,DefaultSingle-J,,0,0,0,,		オイオイ	
Dialogue: 0,0:58:52.60,0:58:55.55,DefaultSingle-J,,0,0,0,,		遺体はヘリで運び  解剖を依頼する	
Dialogue: 0,0:58:55.55,0:58:56.38,DefaultSingle-J,,0,0,0,,		はっ	
Dialogue: 0,0:58:57.29,0:59:01.41,DefaultSingle-J,,0,0,0,,		日本の警察は  自殺の遺体は司法解剖しないはずでは？	
Dialogue: 0,0:59:02.76,0:59:04.56,DefaultSingle-J,,0,0,0,,		念のためですよ	
Dialogue: 0,0:59:08.77,0:59:11.10,DefaultSingle-J,,0,0,0,,		拉致された理由に心当たりは？	
Dialogue: 0,0:59:12.09,0:59:16.64,DefaultSingle-J,,0,0,0,,		老若認証が完成した時  接触してきた人物がいたの	
Dialogue: 0,0:59:17.38,0:59:18.32,DefaultSingle-J,,0,0,0,,		会ったの？	
Dialogue: 0,0:59:18.49,0:59:21.07,DefaultSingle-J,,0,0,0,,		ううん  メールだったから	
Dialogue: 0,0:59:21.07,0:59:23.41,DefaultSingle-J,,0,0,0,,		でも  ピンガって名乗ってた	
Dialogue: 0,0:59:23.52,0:59:24.52,DefaultSingle-J,,0,0,0,,		ピンガ…	
Dialogue: 0,0:59:25.11,0:59:27.04,DefaultSingle-J,,0,0,0,,		ブラジル原産の蒸留酒ね	
Dialogue: 0,0:59:27.47,0:59:33.34,DefaultSingle-J,,0,0,0,,		莫大な報酬を提示されて  システムの独占使用と改良を打診されたけど	
Dialogue: 0,0:59:33.39,0:59:34.23,DefaultSingle-J,,0,0,0,,		断った	
Dialogue: 0,0:59:34.74,0:59:39.23,DefaultSingle-J,,0,0,0,,		その時にはもう  インターポールのために使うシステムだと決めてたから	
Dialogue: 0,0:59:40.18,0:59:45.12,DefaultSingle-J,,0,0,0,,		つまり  老若認証は  それだけ彼らにとって価値がある	
Dialogue: 0,0:59:45.12,0:59:45.81,DefaultSingle-J,,0,0,0,,		「彼ら」？	
Dialogue: 0,0:59:47.58,0:59:51.51,DefaultSingle-J,,0,0,0,,		その「彼ら」って言い方  ほんとにシェリーみたいだぜ	
Dialogue: 0,0:59:52.23,0:59:55.74,DefaultSingle-J,,0,0,0,,		昔からあいつは  なじんでなかったからな	
Dialogue: 0,0:59:57.14,1:00:01.99,DefaultSingle-J,,0,0,0,,		で  俺達のために  システムを改良する決心はついたか	
Dialogue: 0,1:00:03.58,1:00:05.65,DefaultSingle-J,,0,0,0,,		チッ  しょうがねえな	
Dialogue: 0,1:00:06.11,1:00:06.96,DefaultSingle-J,,0,0,0,,		やめて	
Dialogue: 0,1:00:06.96,1:00:07.50,DefaultSingle-J,,0,0,0,,		立て	
Dialogue: 0,1:00:07.50,1:00:08.42,DefaultSingle-J,,0,0,0,,		いやっ	
Dialogue: 0,1:00:09.56,1:00:10.49,DefaultSingle-J,,0,0,0,,		入れ	
Dialogue: 0,1:00:11.91,1:00:12.92,DefaultSingle-J,,0,0,0,,		ウォッカ	
Dialogue: 0,1:00:13.87,1:00:15.05,DefaultSingle-J,,0,0,0,,		始末したって	
Dialogue: 0,1:00:15.21,1:00:16.02,DefaultSingle-J,,0,0,0,,		何？	
Dialogue: 0,1:00:16.52,1:00:20.13,DefaultSingle-J,,0,0,0,,		ピンガのヤツ  計画にない行動しやがって	
Dialogue: 0,1:00:21.07,1:00:22.25,DefaultSingle-J,,0,0,0,,		計画にない？	
Dialogue: 0,1:00:22.25,1:00:23.28,DefaultSingle-J,,0,0,0,,		さっさと来い	
Dialogue: 0,1:00:24.31,1:00:25.39,DefaultSingle-J,,0,0,0,,		これを見ろ	
Dialogue: 0,1:00:28.23,1:00:29.46,DefaultSingle-J,,0,0,0,,		父さん	
Dialogue: 0,1:00:30.22,1:00:31.61,DefaultSingle-J,,0,0,0,,		父をどうする気	
Dialogue: 0,1:00:31.93,1:00:35.04,DefaultSingle-J,,0,0,0,,		頭のいいお前なら  想像できるだろ？	
Dialogue: 0,1:00:36.20,1:00:41.95,DefaultSingle-J,,0,0,0,,		あれは  私の父が  世界平和に生かしたいと言って実現してくれたシステムよ	
Dialogue: 0,1:00:41.95,1:00:45.73,DefaultSingle-J,,0,0,0,,		そんなステキな父親を見殺しにするってのか	
Dialogue: 0,1:00:45.73,1:00:47.46,DefaultSingle-J,,0,0,0,,		ひでえ娘だな	
Dialogue: 0,1:00:48.65,1:00:51.26,DefaultSingle-J,,0,0,0,,		あなた達には絶対に渡さない	
Dialogue: 0,1:00:51.71,1:00:52.32,DefaultSingle-J,,0,0,0,,		ほう	
Dialogue: 0,1:00:52.99,1:00:56.31,DefaultSingle-J,,0,0,0,,		それじゃ  お楽しみタイムといくか	
Dialogue: 0,1:00:59.76,1:01:00.68,DefaultSingle-J,,0,0,0,,		バックドアだ	
Dialogue: 0,1:01:01.74,1:01:02.81,DefaultSingle-J,,0,0,0,,		どういうことだ	
Dialogue: 0,1:01:02.81,1:01:07.40,DefaultSingle-J,,0,0,0,,		関係者が検索されたら  引っかかるようにトラップを仕掛けておいたんです	
Dialogue: 0,1:01:08.69,1:01:09.90,DefaultSingle-J,,0,0,0,,		誰ですか  彼は	
Dialogue: 0,1:01:10.18,1:01:11.51,DefaultSingle-J,,0,0,0,,		マリオ・アルジェント	
Dialogue: 0,1:01:12.22,1:01:15.70,DefaultSingle-J,,0,0,0,,		EU議会の議員で  直美の父親です	
Dialogue: 0,1:01:17.00,1:01:18.26,DefaultSingle-J,,0,0,0,,		なんだって	
Dialogue: 0,1:01:18.97,1:01:23.12,DefaultSingle-J,,0,0,0,,		彼のおかげで  ここがユーロポールの防犯カメラとつなげられたんです	
Dialogue: 0,1:01:23.94,1:01:26.24,DefaultSingle-J,,0,0,0,,		エド  今なら割り出せるはずよ	
Dialogue: 0,1:01:26.75,1:01:28.62,DefaultSingle-J,,0,0,0,,		ああ  もうやってるよ	
Dialogue: 0,1:01:28.94,1:01:31.54,DefaultSingle-J,,0,0,0,,		ユーロポールに  議員の保護を要請	
Dialogue: 0,1:01:34.74,1:01:36.59,DefaultSingle-J,,0,0,0,,		マリオ議員の所在地が判明	
Dialogue: 0,1:01:37.08,1:01:40.85,DefaultSingle-J,,0,0,0,,		エッシェンハイマータワー近くの  シティホテル401号室です	
Dialogue: 0,1:01:41.59,1:01:42.81,DefaultSingle-J,,0,0,0,,		キャメル  出して	
Dialogue: 0,1:01:43.02,1:01:43.76,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,1:01:46.77,1:01:48.45,DefaultSingle-J,,0,0,0,,		マリオ議員に連絡を入れます	
Dialogue: 0,1:01:48.45,1:01:49.28,DefaultSingle-J,,0,0,0,,		うむ	
Dialogue: 0,1:01:50.12,1:01:52.24,DefaultSingle-J,,0,0,0,,		あとは時間との闘い…	
Dialogue: 0,1:01:55.58,1:01:57.81,DefaultSingle-J,,0,0,0,,		コルン  そっちは任せたよ	
Dialogue: 0,1:01:58.22,1:01:59.29,DefaultSingle-J,,0,0,0,,		分かった	
Dialogue: 0,1:02:10.76,1:02:12.96,DefaultSingle-J,,0,0,0,,		見つけた  マリオ	
Dialogue: 0,1:02:14.18,1:02:15.31,DefaultSingle-J,,0,0,0,,		いつでもいい	
Dialogue: 0,1:02:15.95,1:02:18.38,DefaultSingle-J,,0,0,0,,		父さん  早く逃げて	
Dialogue: 0,1:02:18.38,1:02:20.85,DefaultSingle-J,,0,0,0,,		早いとこ決心した方がいいぜ	
Dialogue: 0,1:02:20.85,1:02:24.09,DefaultSingle-J,,0,0,0,,		父さん  逃げて	
Dialogue: 0,1:02:26.66,1:02:28.47,DefaultSingle-J,,0,0,0,,		あきらめるなよ  瑛海	
Dialogue: 0,1:02:29.61,1:02:32.31,DefaultSingle-J,,0,0,0,,		待ち続ければ必ず味方が現れる	
Dialogue: 0,1:02:33.76,1:02:36.20,DefaultSingle-J,,0,0,0,,		俺の代わりに任務を全うしろ	
Dialogue: 0,1:02:41.07,1:02:42.06,DefaultSingle-J,,0,0,0,,		父さん…	
Dialogue: 0,1:02:49.91,1:02:51.14,DefaultSingle-J,,0,0,0,,		気づかれた	
Dialogue: 0,1:02:53.36,1:02:55.24,DefaultSingle-J,,0,0,0,,		でも  逃さない	
Dialogue: 0,1:03:26.04,1:03:29.16,DefaultSingle-J,,0,0,0,,		いやあああっ	
Dialogue: 0,1:03:29.53,1:03:31.75,DefaultSingle-J,,0,0,0,,		次はお前の母親だ	
Dialogue: 0,1:03:32.40,1:03:35.86,DefaultSingle-J,,0,0,0,,		それでも俺達との取引を断る気か	
Dialogue: 0,1:03:36.52,1:03:39.20,DefaultSingle-J,,0,0,0,,		よく考えた方がいいぜ	
Dialogue: 0,1:03:43.45,1:03:44.51,DefaultSingle-J,,0,0,0,,		クソッ	
Dialogue: 0,1:03:47.30,1:03:50.30,DefaultSingle-J,,0,0,0,,		私が…私が父を殺した	
Dialogue: 0,1:03:51.55,1:03:53.46,DefaultSingle-J,,0,0,0,,		あの時と同じように	
Dialogue: 0,1:03:53.60,1:03:55.73,DefaultSingle-J,,0,0,0,,		今度は父さんを見捨てた	
Dialogue: 0,1:03:55.91,1:03:57.55,DefaultSingle-J,,0,0,0,,		違う  あなたは…	
Dialogue: 0,1:03:57.55,1:04:00.00,DefaultSingle-J,,0,0,0,,		このままじゃ  あなたも殺されちゃう	
Dialogue: 0,1:04:00.27,1:04:02.64,DefaultSingle-J,,0,0,0,,		私のせいで  みんな…	
Dialogue: 0,1:04:25.91,1:04:27.74,DefaultSingle-J,,0,0,0,,		丑尾さん  すみません	
Dialogue: 0,1:04:27.89,1:04:32.60,DefaultSingle-J,,0,0,0,,		気にするな  パシフィック・ブイは俺も近くで見てみたかったんだ	
Dialogue: 0,1:04:33.14,1:04:35.63,DefaultSingle-J,,0,0,0,,		それに  彼の頼みだしな	
Dialogue: 0,1:04:35.63,1:04:36.39,DefaultSingle-J,,0,0,0,,		えっ？	
Dialogue: 0,1:04:36.64,1:04:39.59,DefaultSingle-J,,0,0,0,,		彼が作った発明品を見せてもらった	
Dialogue: 0,1:04:40.04,1:04:43.01,DefaultSingle-J,,0,0,0,,		大した男だよ  阿笠さんは	
Dialogue: 0,1:04:44.42,1:04:45.35,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,1:04:48.07,1:04:50.03,DefaultSingle-J,,0,0,0,,		分かった  サーバー特定	
Dialogue: 0,1:04:50.26,1:04:51.78,DefaultSingle-J,,0,0,0,,		どのくらいで閉じられる	
Dialogue: 0,1:04:51.78,1:04:54.04,DefaultSingle-J,,0,0,0,,		2～3時間ってとこかな	
Dialogue: 0,1:04:55.00,1:04:56.32,DefaultSingle-J,,0,0,0,,		頼むぞ  エド	
Dialogue: 0,1:04:57.17,1:04:59.56,DefaultSingle-J,,0,0,0,,		局長  ソナーが反応しています	
Dialogue: 0,1:04:59.74,1:05:00.46,DefaultSingle-J,,0,0,0,,		何っ	
Dialogue: 0,1:05:00.63,1:05:03.13,DefaultSingle-J,,0,0,0,,		ここから2キロ以内  スクリュー音です	
Dialogue: 0,1:05:03.37,1:05:04.47,DefaultSingle-J,,0,0,0,,		スクリュー音…	
Dialogue: 0,1:05:06.23,1:05:08.17,DefaultSingle-J,,0,0,0,,		ヤツは空から合流する	
Dialogue: 0,1:05:08.41,1:05:09.70,DefaultSingle-J,,0,0,0,,		つまり  その時…	
Dialogue: 0,1:05:18.41,1:05:19.56,DefaultSingle-J,,0,0,0,,		浮上してる？	
Dialogue: 0,1:05:19.94,1:05:22.65,DefaultSingle-J,,0,0,0,,		灰原  灰原  聞こえるか	
Dialogue: 0,1:05:22.65,1:05:23.52,DefaultSingle-J,,0,0,0,,		江戸川君	
Dialogue: 0,1:05:23.88,1:05:25.39,DefaultSingle-J,,0,0,0,,		灰原  聞こえるか	
Dialogue: 0,1:05:25.61,1:05:27.53,DefaultSingle-J,,0,0,0,,		江戸川君  聞こえるわ	
Dialogue: 0,1:05:27.73,1:05:29.45,DefaultSingle-J,,0,0,0,,		今  潜水艦の中か	
Dialogue: 0,1:05:29.85,1:05:30.98,DefaultSingle-J,,0,0,0,,		どうしてそれを…	
Dialogue: 0,1:05:31.37,1:05:32.98,DefaultSingle-J,,0,0,0,,		灰原  よく聞け	
Dialogue: 0,1:05:33.31,1:05:37.00,DefaultSingle-J,,0,0,0,,		お前を拉致した後  ヤツらは車ごと海に飛び込んだ	
Dialogue: 0,1:05:37.40,1:05:39.59,DefaultSingle-J,,0,0,0,,		艦橋から乗り込んだ様子はなかった	
Dialogue: 0,1:05:39.92,1:05:43.58,DefaultSingle-J,,0,0,0,,		海中で車から脱出し  そのまま乗り込んだんだ	
Dialogue: 0,1:05:44.21,1:05:48.36,DefaultSingle-J,,0,0,0,,		つまり  その潜水艦は  水中から出入りできるはずなんだ	
Dialogue: 0,1:05:48.76,1:05:51.60,DefaultSingle-J,,0,0,0,,		拉致された時  私は眠らされていたの	
Dialogue: 0,1:05:52.05,1:05:54.72,DefaultSingle-J,,0,0,0,,		どこから潜水艦に乗ったかなんて  覚えてない	
Dialogue: 0,1:06:00.55,1:06:03.03,DefaultSingle-J,,0,0,0,,		そういえば  ちょっと気になったんだけど	
Dialogue: 0,1:06:03.19,1:06:04.00,DefaultSingle-J,,0,0,0,,		ああ？	
Dialogue: 0,1:06:04.00,1:06:06.18,DefaultSingle-J,,0,0,0,,		ジンはどこから乗り込むの？	
Dialogue: 0,1:06:06.41,1:06:09.07,DefaultSingle-J,,0,0,0,,		昨日みたいに  魚雷発射管から？	
Dialogue: 0,1:06:10.41,1:06:11.63,DefaultSingle-J,,0,0,0,,		魚雷発射管	
Dialogue: 0,1:06:11.63,1:06:12.44,DefaultSingle-J,,0,0,0,,		えっ？	
Dialogue: 0,1:06:13.05,1:06:15.16,DefaultSingle-J,,0,0,0,,		私は  そこから乗ったみたい	
Dialogue: 0,1:06:15.40,1:06:18.12,DefaultSingle-J,,0,0,0,,		ダイバーが出入りできる魚雷発射管…	
Dialogue: 0,1:06:18.85,1:06:20.00,DefaultSingle-J,,0,0,0,,		聞いたことがある	
Dialogue: 0,1:06:20.69,1:06:23.76,DefaultSingle-J,,0,0,0,,		兄貴には艦橋から安全に乗ってもらうさ	
Dialogue: 0,1:06:24.07,1:06:25.88,DefaultSingle-J,,0,0,0,,		そのために浮上してんだ	
Dialogue: 0,1:06:26.32,1:06:30.80,DefaultSingle-J,,0,0,0,,		あそこから出入りするのは  もうこりごりだ  肝が冷えるぜ	
Dialogue: 0,1:06:31.12,1:06:32.49,DefaultSingle-J,,0,0,0,,		あら  どうして	
Dialogue: 0,1:06:32.76,1:06:35.90,DefaultSingle-J,,0,0,0,,		黄色のボタンを押せば  発射管に入れるでしょ？	
Dialogue: 0,1:06:36.09,1:06:41.82,DefaultSingle-J,,0,0,0,,		あとは自動で海水が流れ込み  扉も自動で開く  簡単じゃない	
Dialogue: 0,1:06:42.44,1:06:43.63,DefaultSingle-J,,0,0,0,,		自動で海に…	
Dialogue: 0,1:06:43.85,1:06:47.38,DefaultSingle-J,,0,0,0,,		バーカ  普段は魚雷を発射してんだぞ	
Dialogue: 0,1:06:47.75,1:06:50.77,DefaultSingle-J,,0,0,0,,		誰かが間違えて  あのレバーを引いたら…	
Dialogue: 0,1:06:51.19,1:06:51.99,DefaultSingle-J,,0,0,0,,		パッ	
Dialogue: 0,1:06:52.19,1:06:53.11,DefaultSingle-J,,0,0,0,,		レバー？	
Dialogue: 0,1:06:53.11,1:06:56.69,DefaultSingle-J,,0,0,0,,		何  そんなことも知らねーで乗ってたのかよ	
Dialogue: 0,1:06:57.28,1:06:58.00,DefaultSingle-J,,0,0,0,,		来い	
Dialogue: 0,1:06:59.79,1:07:05.39,DefaultSingle-J,,0,0,0,,		この緑のレバーを引くと  発射管内に圧縮空気が撃ち出される	
Dialogue: 0,1:07:05.63,1:07:08.57,DefaultSingle-J,,0,0,0,,		もしその時  中に人がいようもんなら…	
Dialogue: 0,1:07:08.94,1:07:11.96,DefaultSingle-J,,0,0,0,,		命を落とす  忘れてたわ	
Dialogue: 0,1:07:12.28,1:07:14.00,DefaultSingle-J,,0,0,0,,		大丈夫かよ  お前	
Dialogue: 0,1:07:15.33,1:07:17.01,DefaultSingle-J,,0,0,0,,		脱出の方法が分かった	
Dialogue: 0,1:07:17.01,1:07:17.99,DefaultSingle-J,,0,0,0,,		ほんとか	
Dialogue: 0,1:07:18.14,1:07:22.17,DefaultSingle-J,,0,0,0,,		よし  お前も直美さんも  ぜってー助けてやっかんな	
Dialogue: 0,1:07:23.77,1:07:25.59,DefaultSingle-J,,0,0,0,,		あとはこれを動かせれば…	
Dialogue: 0,1:07:26.93,1:07:28.84,DefaultSingle-J,,0,0,0,,		コナン君	
Dialogue: 0,1:07:31.11,1:07:31.82,DefaultSingle-J,,0,0,0,,		蘭	
Dialogue: 0,1:07:34.54,1:07:36.35,DefaultSingle-J,,0,0,0,,		ヘリがまもなく到着します	
Dialogue: 0,1:07:36.59,1:07:37.51,DefaultSingle-J,,0,0,0,,		よし	
Dialogue: 0,1:07:38.15,1:07:40.09,DefaultSingle-J,,0,0,0,,		ジンの兄貴と合流だ	
Dialogue: 0,1:07:48.14,1:07:48.97,DefaultSingle-J,,0,0,0,,		来る	
Dialogue: 0,1:07:50.58,1:07:51.69,DefaultSingle-J,,0,0,0,,		脱出するわよ	
Dialogue: 0,1:07:53.20,1:07:54.13,DefaultSingle-J,,0,0,0,,		無理よ	
Dialogue: 0,1:07:57.72,1:07:58.19,DefaultSingle-J,,0,0,0,,		え	
Dialogue: 0,1:07:58.90,1:08:01.32,DefaultSingle-J,,0,0,0,,		解きやすいポーズで縛られていただけ	
Dialogue: 0,1:08:01.79,1:08:03.76,DefaultSingle-J,,0,0,0,,		マジシャンがよく使う手よ	
Dialogue: 0,1:08:04.12,1:08:05.59,DefaultSingle-J,,0,0,0,,		あなた  一体…	
Dialogue: 0,1:08:05.99,1:08:07.82,DefaultSingle-J,,0,0,0,,		時間がない  行くわよ	
Dialogue: 0,1:08:08.03,1:08:10.61,DefaultSingle-J,,0,0,0,,		ムチャ言わないで  絶対に無理	
Dialogue: 0,1:08:11.24,1:08:16.69,DefaultSingle-J,,0,0,0,,		人種を超えた世界平和  それが  あなたとお父さんの夢なんでしょ？	
Dialogue: 0,1:08:16.80,1:08:18.90,DefaultSingle-J,,0,0,0,,		その父だって  もう…	
Dialogue: 0,1:08:19.57,1:08:21.91,DefaultSingle-J,,0,0,0,,		あなたには生きる義務があるの	
Dialogue: 0,1:08:22.26,1:08:25.59,DefaultSingle-J,,0,0,0,,		哀ちゃんやコナン君みたいな子供に何ができるの？	
Dialogue: 0,1:08:26.79,1:08:28.68,DefaultSingle-J,,0,0,0,,		何ができるっていうの	
Dialogue: 0,1:08:31.92,1:08:33.05,DefaultSingle-J,,0,0,0,,		あら  そう	
Dialogue: 0,1:08:34.16,1:08:35.50,DefaultSingle-J,,0,0,0,,		子供だから何	
Dialogue: 0,1:08:36.07,1:08:39.74,DefaultSingle-J,,0,0,0,,		あなた  世代間の差別もなくしたいんじゃなかったの？	
Dialogue: 0,1:08:43.20,1:08:47.18,DefaultSingle-J,,0,0,0,,		子供の言葉や行動で  人生が変わることもある	
Dialogue: 0,1:08:51.43,1:08:52.45,DefaultSingle-J,,0,0,0,,		私は…	
Dialogue: 0,1:08:53.92,1:08:55.75,DefaultSingle-J,,0,0,0,,		それを体験して変われた	
Dialogue: 0,1:08:56.45,1:08:59.57,DefaultSingle-J,,0,0,0,,		だから  私を信じて  直美	
Dialogue: 0,1:09:05.17,1:09:06.37,DefaultSingle-J,,0,0,0,,		今のうちじゃ	
Dialogue: 0,1:09:06.77,1:09:07.55,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,1:09:09.68,1:09:12.28,DefaultSingle-J,,0,0,0,,		哀君を頼んだぞ  新一	
Dialogue: 0,1:09:12.88,1:09:14.87,DefaultSingle-J,,0,0,0,,		ああ  行ってくる	
Dialogue: 0,1:09:51.40,1:09:53.20,DefaultSingle-J,,0,0,0,,		お待ちしてやした	
Dialogue: 0,1:09:53.64,1:09:58.96,DefaultSingle-J,,0,0,0,,		さあ  お前がシェリーだというガキのツラを  拝ませてもらおうか	
Dialogue: 0,1:10:03.69,1:10:05.75,DefaultSingle-J,,0,0,0,,		何っ  クソッ	
Dialogue: 0,1:10:06.24,1:10:07.52,DefaultSingle-J,,0,0,0,,		こ  これは…	
Dialogue: 0,1:10:09.08,1:10:10.39,DefaultSingle-J,,0,0,0,,		おい  ウォッカ	
Dialogue: 0,1:10:11.44,1:10:12.89,DefaultSingle-J,,0,0,0,,		どういうことだ	
Dialogue: 0,1:10:12.89,1:10:14.80,DefaultSingle-J,,0,0,0,,		これは…その…	
Dialogue: 0,1:10:16.19,1:10:19.69,DefaultSingle-J,,0,0,0,,		発射管室で誰かが  ダイバー排出の操作をしています	
Dialogue: 0,1:10:31.67,1:10:34.17,DefaultSingle-J,,0,0,0,,		クソッ  あいつらいつの間に…	
Dialogue: 0,1:10:34.63,1:10:35.58,DefaultSingle-J,,0,0,0,,		こっちです	
Dialogue: 0,1:10:35.91,1:10:37.80,DefaultSingle-J,,0,0,0,,		おい  出てこい	
Dialogue: 0,1:10:38.09,1:10:39.59,DefaultSingle-J,,0,0,0,,		おい  お前ら	
Dialogue: 0,1:10:40.46,1:10:42.90,DefaultSingle-J,,0,0,0,,		すでに海水が注入され  開きません	
Dialogue: 0,1:10:43.34,1:10:46.32,DefaultSingle-J,,0,0,0,,		残り70秒で  中の人間が海へ出ます	
Dialogue: 0,1:10:46.89,1:10:50.35,DefaultSingle-J,,0,0,0,,		それなら  2人とも殺すまでだ	
Dialogue: 0,1:10:54.71,1:10:57.28,DefaultSingle-J,,0,0,0,,		いる…  すぐそばに	
Dialogue: 0,1:11:01.10,1:11:02.16,DefaultSingle-J,,0,0,0,,		ダメよ  ジン	
Dialogue: 0,1:11:02.57,1:11:03.53,DefaultSingle-J,,0,0,0,,		キール…	
Dialogue: 0,1:11:03.82,1:11:06.87,DefaultSingle-J,,0,0,0,,		組織は直美のシステムを必要としてる	
Dialogue: 0,1:11:07.07,1:11:08.49,DefaultSingle-J,,0,0,0,,		生きて捕らえないと	
Dialogue: 0,1:11:09.35,1:11:12.00,DefaultSingle-J,,0,0,0,,		その組織に刃向かおうとするヤツは	
Dialogue: 0,1:11:12.59,1:11:14.69,DefaultSingle-J,,0,0,0,,		誰であろうと容赦しねえ	
Dialogue: 0,1:11:16.65,1:11:18.12,DefaultSingle-J,,0,0,0,,		その手をどけろ	
Dialogue: 0,1:11:26.04,1:11:27.30,DefaultSingle-J,,0,0,0,,		キール  てめえ	
Dialogue: 0,1:11:27.60,1:11:30.42,DefaultSingle-J,,0,0,0,,		さっきからお前の行動は尋常じゃねえ	
Dialogue: 0,1:11:31.11,1:11:34.06,DefaultSingle-J,,0,0,0,,		まさか  「ネズミ」じゃないだろうな	
Dialogue: 0,1:11:34.71,1:11:38.32,DefaultSingle-J,,0,0,0,,		尋常じゃないのはジン  あなたの方よ	
Dialogue: 0,1:11:39.04,1:11:40.08,DefaultSingle-J,,0,0,0,,		何？	
Dialogue: 0,1:11:40.41,1:11:43.77,DefaultSingle-J,,0,0,0,,		あの少女がベルツリー急行で死んだシェリーなら	
Dialogue: 0,1:11:43.78,1:11:45.07,DefaultSingle-J,,0,0,0,,		なぜ生きてるの	
Dialogue: 0,1:11:45.28,1:11:47.09,DefaultSingle-J,,0,0,0,,		なぜ少女になってるの	
Dialogue: 0,1:11:47.64,1:11:51.01,DefaultSingle-J,,0,0,0,,		そのワケを  彼女の口から聞きたくないの	
Dialogue: 0,1:11:51.63,1:11:55.23,DefaultSingle-J,,0,0,0,,		あ…兄貴  確かに一理ありやすぜ	
Dialogue: 0,1:11:55.23,1:11:56.60,DefaultSingle-J,,0,0,0,,		生きて捕らえて…	
Dialogue: 0,1:11:58.66,1:12:00.03,DefaultSingle-J,,0,0,0,,		発射口  開きました	
Dialogue: 0,1:12:02.21,1:12:03.29,DefaultSingle-J,,0,0,0,,		兄貴…	
Dialogue: 0,1:12:24.81,1:12:26.95,DefaultSingle-J,,0,0,0,,		小さなスクリュー音をキャッチしました	
Dialogue: 0,1:12:26.95,1:12:29.66,DefaultSingle-J,,0,0,0,,		おそらく水中スクーターかと思われます	
Dialogue: 0,1:12:29.66,1:12:32.02,DefaultSingle-J,,0,0,0,,		10時方向に  5ノットで移動中	
Dialogue: 0,1:12:34.50,1:12:36.65,DefaultSingle-J,,0,0,0,,		よし  そいつを追え	
Dialogue: 0,1:13:03.91,1:13:05.53,DefaultSingle-J,,0,0,0,,		2人とも  大丈夫？	
Dialogue: 0,1:13:05.86,1:13:06.82,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,1:13:07.34,1:13:08.33,DefaultSingle-J,,0,0,0,,		ありがとう	
Dialogue: 0,1:13:09.10,1:13:12.90,DefaultSingle-J,,0,0,0,,		でも  あなた一体  何者	
Dialogue: 0,1:13:13.58,1:13:15.02,DefaultSingle-J,,0,0,0,,		江戸川コナン	
Dialogue: 0,1:13:15.16,1:13:16.38,DefaultSingle-J,,0,0,0,,		探偵よ	
Dialogue: 0,1:13:21.69,1:13:22.81,DefaultSingle-J,,0,0,0,,		そっか	
Dialogue: 0,1:13:28.02,1:13:29.11,DefaultSingle-J,,0,0,0,,		早く  これ	
Dialogue: 0,1:13:31.11,1:13:32.02,DefaultSingle-J,,0,0,0,,		ありがと…	
Dialogue: 0,1:13:33.21,1:13:34.62,DefaultSingle-J,,0,0,0,,		よかった…	
Dialogue: 0,1:13:35.27,1:13:38.91,DefaultSingle-J,,0,0,0,,		哀ちゃんが無事で  本当によかった	
Dialogue: 0,1:13:39.87,1:13:41.61,DefaultSingle-J,,0,0,0,,		もう大丈夫だからね	
Dialogue: 0,1:13:44.76,1:13:46.09,DefaultSingle-J,,0,0,0,,		大丈夫だから	
Dialogue: 0,1:13:49.27,1:13:50.50,DefaultSingle-J,,0,0,0,,		お姉ちゃん…	
Dialogue: 0,1:13:52.91,1:13:54.81,DefaultSingle-J,,0,0,0,,		水中スクーターを見つけた？	
Dialogue: 0,1:13:55.09,1:13:57.98,DefaultSingle-J,,0,0,0,,		はい  充電切れで停止したようです	
Dialogue: 0,1:13:58.57,1:13:59.88,DefaultSingle-J,,0,0,0,,		回収させますか	
Dialogue: 0,1:14:00.40,1:14:02.10,DefaultSingle-J,,0,0,0,,		いいえ  必要ないわ	
Dialogue: 0,1:14:02.83,1:14:04.62,DefaultSingle-J,,0,0,0,,		やはりオトリだったか	
Dialogue: 0,1:14:05.11,1:14:08.14,DefaultSingle-J,,0,0,0,,		漁船のスクリュー音もキャッチしてます  追いますか	
Dialogue: 0,1:14:08.38,1:14:10.88,DefaultSingle-J,,0,0,0,,		待て  行き先は分かってる	
Dialogue: 0,1:14:11.36,1:14:13.66,DefaultSingle-J,,0,0,0,,		兄貴  これを見てください	
Dialogue: 0,1:14:18.39,1:14:19.64,DefaultSingle-J,,0,0,0,,		何？	
Dialogue: 0,1:14:21.53,1:14:23.17,DefaultSingle-J,,0,0,0,,		これはどういうことだ	
Dialogue: 0,1:14:24.10,1:14:26.32,DefaultSingle-J,,0,0,0,,		ベルモットから  送られてきました	
Dialogue: 0,1:14:27.60,1:14:30.37,DefaultSingle-J,,0,0,0,,		直美が持っていたシェリーの一致画像は	
Dialogue: 0,1:14:30.38,1:14:32.41,DefaultSingle-J,,0,0,0,,		テストってファイル名だったから	
Dialogue: 0,1:14:32.69,1:14:37.51,DefaultSingle-J,,0,0,0,,		念のためにもう一度シェリーの顔を  老若認証で検索してみたの	
Dialogue: 0,1:14:37.92,1:14:40.27,DefaultSingle-J,,0,0,0,,		そしたらなんとこの有り様	
Dialogue: 0,1:14:40.85,1:14:46.78,DefaultSingle-J,,0,0,0,,		どうやらよく似た人間を同一人物と判断しちゃう欠陥システムみたいね	
Dialogue: 0,1:14:48.25,1:14:52.35,DefaultSingle-J,,0,0,0,,		何が老若認証だ  とんだクソシステムじゃねえか	
Dialogue: 0,1:14:56.95,1:14:59.11,DefaultSingle-J,,0,0,0,,		あの方の計画どおり	
Dialogue: 0,1:14:59.11,1:15:03.19,DefaultSingle-J,,0,0,0,,		万が一の時の最終手段を使う時が来たようですね	
Dialogue: 0,1:15:03.41,1:15:05.72,DefaultSingle-J,,0,0,0,,		老若認証はあきらめるんですか	
Dialogue: 0,1:15:06.00,1:15:10.07,DefaultSingle-J,,0,0,0,,		どうやら  使い物にならないシステムのようですから	
Dialogue: 0,1:15:11.05,1:15:12.20,DefaultSingle-J,,0,0,0,,		分かりました	
Dialogue: 0,1:15:13.60,1:15:15.01,DefaultSingle-J,,0,0,0,,		老若認証…	
Dialogue: 0,1:15:15.52,1:15:18.63,DefaultSingle-J,,0,0,0,,		つき止めるのに使えると思ったんだがな	
Dialogue: 0,1:15:19.48,1:15:23.43,DefaultSingle-J,,0,0,0,,		最近姿を見せないあの方の所在を…	
Dialogue: 0,1:15:28.07,1:15:30.75,DefaultSingle-J,,0,0,0,,		兄貴  ここにいたんですかい	
Dialogue: 0,1:15:31.20,1:15:32.27,DefaultSingle-J,,0,0,0,,		なんだ	
Dialogue: 0,1:15:32.27,1:15:36.15,DefaultSingle-J,,0,0,0,,		万が一のための最後の手を使ってくれとのことですぜ	
Dialogue: 0,1:15:37.29,1:15:39.25,DefaultSingle-J,,0,0,0,,		ああ  分かった	
Dialogue: 0,1:15:39.56,1:15:42.27,DefaultSingle-J,,0,0,0,,		クソシステムもろとも沈めてやるよ	
Dialogue: 0,1:15:42.83,1:15:45.90,DefaultSingle-J,,0,0,0,,		黒鉄色の海底に…	
Dialogue: 0,1:15:50.61,1:15:51.80,DefaultSingle-J,,0,0,0,,		やっぱりか	
Dialogue: 0,1:15:52.11,1:15:54.11,DefaultSingle-J,,0,0,0,,		ええ  バレてるわ	
Dialogue: 0,1:15:54.78,1:15:57.49,DefaultSingle-J,,0,0,0,,		このまま行方をくらますしかないわね	
Dialogue: 0,1:15:59.13,1:16:00.89,DefaultSingle-J,,0,0,0,,		まだこっちには切り札がある	
Dialogue: 0,1:16:02.13,1:16:03.25,DefaultSingle-J,,0,0,0,,		切り札？	
Dialogue: 0,1:16:03.72,1:16:04.77,DefaultSingle-J,,0,0,0,,		ピンガだ	
Dialogue: 0,1:16:05.16,1:16:07.40,DefaultSingle-J,,0,0,0,,		パシフィック・ブイにいるのは間違いない	
Dialogue: 0,1:16:08.23,1:16:10.09,DefaultSingle-J,,0,0,0,,		ヤツに取引を持ちかける	
Dialogue: 0,1:16:10.59,1:16:11.86,DefaultSingle-J,,0,0,0,,		誰か分かったの	
Dialogue: 0,1:16:12.33,1:16:14.74,DefaultSingle-J,,0,0,0,,		いや  もうちょっとなんだけど…	
Dialogue: 0,1:16:16.92,1:16:18.35,DefaultSingle-J,,0,0,0,,		それにしても	
Dialogue: 0,1:16:18.76,1:16:23.14,DefaultSingle-J,,0,0,0,,		まさかこのボウズの言うとおり  ほんとに潜水艦がいたなんて	
Dialogue: 0,1:16:23.14,1:16:26.70,DefaultSingle-J,,0,0,0,,		海上自衛隊の出動を政府に要請した	
Dialogue: 0,1:16:27.18,1:16:29.31,DefaultSingle-J,,0,0,0,,		さっ  医務室へ向かいましょう	
Dialogue: 0,1:16:30.81,1:16:32.03,DefaultSingle-J,,0,0,0,,		寒かったでしょう	
Dialogue: 0,1:16:32.33,1:16:35.26,DefaultSingle-J,,0,0,0,,		着替えと  温まるものを用意するわね	
Dialogue: 0,1:16:36.28,1:16:37.21,DefaultSingle-J,,0,0,0,,		手伝います	
Dialogue: 0,1:16:39.10,1:16:41.53,DefaultSingle-J,,0,0,0,,		さらわれた時の状況は覚えてるか	
Dialogue: 0,1:16:41.81,1:16:44.63,DefaultSingle-J,,0,0,0,,		ええ  エーテルで眠らされたわ	
Dialogue: 0,1:16:44.63,1:16:45.66,DefaultSingle-J,,0,0,0,,		エーテル？	
Dialogue: 0,1:16:45.97,1:16:49.68,DefaultSingle-J,,0,0,0,,		それをベースに  ピンガが作った麻酔薬だと思う	
Dialogue: 0,1:16:50.06,1:16:52.10,DefaultSingle-J,,0,0,0,,		シンナーみたいなにおいするか	
Dialogue: 0,1:16:52.20,1:16:54.68,DefaultSingle-J,,0,0,0,,		ああ…  まあ似てるわね	
Dialogue: 0,1:16:55.24,1:16:59.77,DefaultSingle-J,,0,0,0,,		だとすると  レオンハルトさんは死亡する前に眠らされていた	
Dialogue: 0,1:17:01.34,1:17:02.96,DefaultSingle-J,,0,0,0,,		他には何か聞いてないか	
Dialogue: 0,1:17:04.55,1:17:08.31,DefaultSingle-J,,0,0,0,,		なんか  計画にない行動について怒ってた	
Dialogue: 0,1:17:08.79,1:17:10.30,DefaultSingle-J,,0,0,0,,		計画にない…	
Dialogue: 0,1:17:11.19,1:17:12.61,DefaultSingle-J,,0,0,0,,		殺人？	
Dialogue: 0,1:17:13.12,1:17:14.10,DefaultSingle-J,,0,0,0,,		お待たせ	
Dialogue: 0,1:17:14.77,1:17:15.84,DefaultSingle-J,,0,0,0,,		はい  どうぞ	
Dialogue: 0,1:17:16.32,1:17:17.40,DefaultSingle-J,,0,0,0,,		ありがとう	
Dialogue: 0,1:17:18.17,1:17:19.44,DefaultSingle-J,,0,0,0,,		あったまる	
Dialogue: 0,1:17:18.71,1:17:20.32,DefaultSingle-J,,0,0,0,,		着替え  ここに置くわね	
Dialogue: 0,1:17:23.93,1:17:24.97,DefaultSingle-J,,0,0,0,,		おいしい	
Dialogue: 0,1:17:30.14,1:17:32.69,DefaultSingle-J,,0,0,0,,		そうか  そういうことか	
Dialogue: 0,1:17:35.02,1:17:37.42,DefaultSingle-J,,0,0,0,,		灰原  ここで待ってろ	
Dialogue: 0,1:17:37.71,1:17:39.47,DefaultSingle-J,,0,0,0,,		ぜってーなんとかしてやっからよ	
Dialogue: 0,1:17:39.47,1:17:40.93,DefaultSingle-J,,0,0,0,,		ちょっと  コナン君	
Dialogue: 0,1:17:42.14,1:17:45.20,DefaultSingle-J,,0,0,0,,		ったく  待たせるの好きよねぇ	
Dialogue: 0,1:17:46.07,1:17:47.19,DefaultSingle-J,,0,0,0,,		新一君	
Dialogue: 0,1:17:50.00,1:17:50.94,DefaultSingle-J,,0,0,0,,		これは？	
Dialogue: 0,1:17:51.68,1:17:54.77,DefaultSingle-J,,0,0,0,,		レオンハルトさんの血液検査結果です	
Dialogue: 0,1:17:56.41,1:17:57.53,DefaultSingle-J,,0,0,0,,		それで？	
Dialogue: 0,1:17:57.73,1:18:00.77,DefaultSingle-J,,0,0,0,,		強アルカリ系の毒物が  検出されてます	
Dialogue: 0,1:18:01.03,1:18:04.12,DefaultSingle-J,,0,0,0,,		たぶん  洗剤か何かだろうと言っていた	
Dialogue: 0,1:18:04.37,1:18:07.65,DefaultSingle-J,,0,0,0,,		だから口がただれてたんだな  やはり…	
Dialogue: 0,1:18:10.17,1:18:12.27,DefaultSingle-J,,0,0,0,,		お  お父さん	
Dialogue: 0,1:18:12.69,1:18:14.36,DefaultSingle-J,,0,0,0,,		ただれて  ただれて…	
Dialogue: 0,1:18:16.38,1:18:17.38,DefaultSingle-J,,0,0,0,,		何	
Dialogue: 0,1:18:17.38,1:18:18.88,DefaultSingle-J,,0,0,0,,		こ  これは…	
Dialogue: 0,1:18:18.88,1:18:20.53,DefaultSingle-J,,0,0,0,,		眠りの小五郎	
Dialogue: 0,1:18:21.52,1:18:22.67,DefaultSingle-J,,0,0,0,,		えー  みなさん	
Dialogue: 0,1:18:23.38,1:18:26.89,DefaultSingle-J,,0,0,0,,		やはり直美さんの拉致を手引きし  哀君をさらい	
Dialogue: 0,1:18:27.30,1:18:31.11,DefaultSingle-J,,0,0,0,,		レオンハルトさんを殺害した犯人が  この中にいます	
Dialogue: 0,1:18:31.11,1:18:32.80,DefaultSingle-J,,0,0,0,,		彼は自殺では？	
Dialogue: 0,1:18:32.95,1:18:38.40,DefaultSingle-J,,0,0,0,,		いえ  麻酔薬で眠らされた後  毒物で殺害されたのです	
Dialogue: 0,1:18:38.61,1:18:41.41,DefaultSingle-J,,0,0,0,,		なんでそんな回りくどい方法を…	
Dialogue: 0,1:18:41.80,1:18:46.94,DefaultSingle-J,,0,0,0,,		今回の殺害は計画的ではなく  突発的犯行だったからです	
Dialogue: 0,1:18:47.21,1:18:47.77,DefaultSingle-J,,0,0,0,,		は？	
Dialogue: 0,1:18:47.34,1:18:48.08,DefaultSingle-J,,0,0,0,,		えっ？	
Dialogue: 0,1:18:48.33,1:18:54.17,DefaultSingle-J,,0,0,0,,		だから  哀君を拉致した時に使ったのと同じ麻酔薬を使うしかなかった	
Dialogue: 0,1:18:54.80,1:18:57.40,DefaultSingle-J,,0,0,0,,		エーテルのにおいのする薬だよね	
Dialogue: 0,1:18:58.09,1:18:58.81,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,1:18:59.32,1:19:03.93,DefaultSingle-J,,0,0,0,,		そのにおいをごまかすために  遺体をコーヒーまみれにしたんです	
Dialogue: 0,1:19:04.20,1:19:06.35,DefaultSingle-J,,0,0,0,,		しかし  あの映像は？	
Dialogue: 0,1:19:06.68,1:19:08.79,DefaultSingle-J,,0,0,0,,		自殺に偽装するための…	
Dialogue: 0,1:19:09.65,1:19:11.10,DefaultSingle-J,,0,0,0,,		「ディープフェイク」です	
Dialogue: 0,1:19:11.10,1:19:11.84,DefaultSingle-J,,0,0,0,,		はぁ？	
Dialogue: 0,1:19:11.21,1:19:12.09,DefaultSingle-J,,0,0,0,,		あれが？	
Dialogue: 0,1:19:12.48,1:19:13.87,DefaultSingle-J,,0,0,0,,		ディープフェイク？	
Dialogue: 0,1:19:14.07,1:19:16.55,DefaultSingle-J,,0,0,0,,		簡単に言うと  ニセ動画のことよ	
Dialogue: 0,1:19:16.55,1:19:17.94,DefaultSingle-J,,0,0,0,,		えっ  ウソ	
Dialogue: 0,1:19:18.26,1:19:21.11,DefaultSingle-J,,0,0,0,,		なるほど  だからカフェだったのか	
Dialogue: 0,1:19:21.31,1:19:22.07,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,1:19:22.47,1:19:24.81,DefaultSingle-J,,0,0,0,,		個室には監視カメラがありませんから	
Dialogue: 0,1:19:25.22,1:19:29.22,DefaultSingle-J,,0,0,0,,		定例となっているカフェの清掃時間を利用したんです	
Dialogue: 0,1:19:29.22,1:19:33.50,DefaultSingle-J,,0,0,0,,		だが  実際には清掃は行われていないということか	
Dialogue: 0,1:19:33.50,1:19:34.28,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,1:19:34.69,1:19:37.12,DefaultSingle-J,,0,0,0,,		キャンセルの連絡を入れているはずです	
Dialogue: 0,1:19:37.72,1:19:40.88,DefaultSingle-J,,0,0,0,,		そして  その後の犯人の動きは  こうです	
Dialogue: 0,1:19:41.55,1:19:43.31,DefaultSingle-J,,0,0,0,,		直美さん拉致と同様に	
Dialogue: 0,1:19:43.95,1:19:46.97,DefaultSingle-J,,0,0,0,,		清掃カートに眠らせたレオンハルトさんを入れ	
Dialogue: 0,1:19:47.50,1:19:49.86,DefaultSingle-J,,0,0,0,,		清掃員の姿でカフェに行き	
Dialogue: 0,1:19:50.38,1:19:52.21,DefaultSingle-J,,0,0,0,,		誰も入れないようにした	
Dialogue: 0,1:19:53.46,1:19:56.13,DefaultSingle-J,,0,0,0,,		もちろん監視カメラはループ映像にしてね	
Dialogue: 0,1:19:57.35,1:20:01.48,DefaultSingle-J,,0,0,0,,		そこで犯人はレオンハルトさんに  毒物をのませて殺害	
Dialogue: 0,1:20:02.44,1:20:04.83,DefaultSingle-J,,0,0,0,,		息絶えるまでその場にいたはずです	
Dialogue: 0,1:20:05.92,1:20:08.23,DefaultSingle-J,,0,0,0,,		死に様を観察するためにね	
Dialogue: 0,1:20:09.16,1:20:10.25,DefaultSingle-J,,0,0,0,,		ひどい	
Dialogue: 0,1:20:10.86,1:20:12.91,DefaultSingle-J,,0,0,0,,		先に映像を作ってしまうと	
Dialogue: 0,1:20:13.18,1:20:15.95,DefaultSingle-J,,0,0,0,,		どんな死に方をされるか分からないですからね	
Dialogue: 0,1:20:16.95,1:20:20.69,DefaultSingle-J,,0,0,0,,		その後  犯人は  レオンハルトさんに似た服に着替え	
Dialogue: 0,1:20:21.00,1:20:23.33,DefaultSingle-J,,0,0,0,,		毒薬に苦しむ芝居をしたんです	
Dialogue: 0,1:20:24.40,1:20:26.67,DefaultSingle-J,,0,0,0,,		テーブルに隠れるように倒れたのは	
Dialogue: 0,1:20:27.11,1:20:31.65,DefaultSingle-J,,0,0,0,,		実際カフェにある監視カメラの映像とリアルタイムで切り替える時に	
Dialogue: 0,1:20:31.93,1:20:34.65,DefaultSingle-J,,0,0,0,,		齟齬が生じないようにするためです	
Dialogue: 0,1:20:34.93,1:20:36.53,DefaultSingle-J,,0,0,0,,		似た服っていうのは？	
Dialogue: 0,1:20:36.77,1:20:39.28,DefaultSingle-J,,0,0,0,,		ああ  何しろこの映像は	
Dialogue: 0,1:20:39.80,1:20:43.32,DefaultSingle-J,,0,0,0,,		顔だけがCGで  体は犯人ですから	
Dialogue: 0,1:20:43.32,1:20:44.09,DefaultSingle-J,,0,0,0,,		え	
Dialogue: 0,1:20:43.32,1:20:44.51,DefaultSingle-J,,0,0,0,,		なんだって？	
Dialogue: 0,1:20:45.29,1:20:49.17,DefaultSingle-J,,0,0,0,,		体までCGで作るには  時間が足りなかったんでしょう	
Dialogue: 0,1:20:50.07,1:20:52.31,DefaultSingle-J,,0,0,0,,		しかし  どうやってそんなことを…	
Dialogue: 0,1:20:52.98,1:20:57.68,DefaultSingle-J,,0,0,0,,		直美さんが開発した老若認証の技術を使ったんです	
Dialogue: 0,1:20:58.17,1:21:00.87,DefaultSingle-J,,0,0,0,,		CGで顔を作る技術か	
Dialogue: 0,1:21:01.35,1:21:05.61,DefaultSingle-J,,0,0,0,,		職員のデータなら  事前に取っていた可能性も高いな	
Dialogue: 0,1:21:05.92,1:21:09.78,DefaultSingle-J,,0,0,0,,		しかし毛利君  ワシには本物にしか見えん	
Dialogue: 0,1:21:10.23,1:21:12.85,DefaultSingle-J,,0,0,0,,		これがニセ動画だっていう根拠は？	
Dialogue: 0,1:21:13.50,1:21:18.54,DefaultSingle-J,,0,0,0,,		私が初めにこの映像を見た時  強い違和感を覚えました	
Dialogue: 0,1:21:18.83,1:21:20.23,DefaultSingle-J,,0,0,0,,		違和感？	
Dialogue: 0,1:21:20.69,1:21:23.12,DefaultSingle-J,,0,0,0,,		彼の手元をよく見てください	
Dialogue: 0,1:21:30.45,1:21:31.51,DefaultSingle-J,,0,0,0,,		あれって…	
Dialogue: 0,1:21:31.84,1:21:34.60,DefaultSingle-J,,0,0,0,,		口紅をしてる女性特有の仕草	
Dialogue: 0,1:21:35.18,1:21:36.95,DefaultSingle-J,,0,0,0,,		お母さんもよくやってた	
Dialogue: 0,1:21:37.20,1:21:38.50,DefaultSingle-J,,0,0,0,,		そうなんです	
Dialogue: 0,1:21:38.83,1:21:41.63,DefaultSingle-J,,0,0,0,,		このカップのふちを拭く仕草	
Dialogue: 0,1:21:42.61,1:21:45.67,DefaultSingle-J,,0,0,0,,		あなたはここで  よくそうしてましたよね	
Dialogue: 0,1:21:46.91,1:21:48.17,DefaultSingle-J,,0,0,0,,		グレースさん	
Dialogue: 0,1:21:50.61,1:21:53.74,DefaultSingle-J,,0,0,0,,		きっとその仕草が  クセになっていたんでしょう	
Dialogue: 0,1:21:54.82,1:21:57.22,DefaultSingle-J,,0,0,0,,		女性であろうとするあまりに	
Dialogue: 0,1:21:57.39,1:21:59.23,DefaultSingle-J,,0,0,0,,		女性であろうとした？	
Dialogue: 0,1:21:59.23,1:21:59.93,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,1:22:00.39,1:22:02.18,DefaultSingle-J,,0,0,0,,		私の勘が正しければ	
Dialogue: 0,1:22:02.60,1:22:06.79,DefaultSingle-J,,0,0,0,,		この人はおそらく  女性ではないと思いますよ	
Dialogue: 0,1:22:07.07,1:22:07.60,DefaultSingle-J,,0,0,0,,		えっ	
Dialogue: 0,1:22:07.70,1:22:08.36,DefaultSingle-J,,0,0,0,,		えっ	
Dialogue: 0,1:22:08.47,1:22:09.22,DefaultSingle-J,,0,0,0,,		えっ	
Dialogue: 0,1:22:09.41,1:22:13.12,DefaultSingle-J,,0,0,0,,		反論しないということは  やはりあなたは…	
Dialogue: 0,1:22:14.57,1:22:16.58,DefaultSingle-J,,0,0,0,,		おどろいて声が出ないのよ	
Dialogue: 0,1:22:16.97,1:22:19.32,DefaultSingle-J,,0,0,0,,		女じゃないなんて言われると思ってなかっ…	
Dialogue: 0,1:22:19.32,1:22:20.75,DefaultSingle-J,,0,0,0,,		コナンから聞いたんだが	
Dialogue: 0,1:22:21.14,1:22:21.94,DefaultSingle-J,,0,0,0,,		蘭	
Dialogue: 0,1:22:22.23,1:22:22.88,DefaultSingle-J,,0,0,0,,		えっ？	
Dialogue: 0,1:22:23.26,1:22:25.64,DefaultSingle-J,,0,0,0,,		哀君を拉致した2人組の1人は	
Dialogue: 0,1:22:25.88,1:22:28.34,DefaultSingle-J,,0,0,0,,		お前の蹴りで首を負傷してるとか	
Dialogue: 0,1:22:28.65,1:22:30.09,DefaultSingle-J,,0,0,0,,		あ…  うん	
Dialogue: 0,1:22:30.40,1:22:31.26,DefaultSingle-J,,0,0,0,,		何を	
Dialogue: 0,1:22:32.64,1:22:33.87,DefaultSingle-J,,0,0,0,,		そのアザ	
Dialogue: 0,1:22:34.61,1:22:37.22,DefaultSingle-J,,0,0,0,,		て…てか  のどぼとけがある	
Dialogue: 0,1:22:37.44,1:22:38.65,DefaultSingle-J,,0,0,0,,		マジかよ	
Dialogue: 0,1:22:50.66,1:22:52.39,DefaultSingle-J,,0,0,0,,		コーンロウの男	
Dialogue: 0,1:22:52.83,1:22:56.49,DefaultSingle-J,,0,0,0,,		フランクフルトの施設に侵入したのも  お前か	
Dialogue: 0,1:22:57.14,1:22:57.87,DefaultSingle-J,,0,0,0,,		ああ	
Dialogue: 0,1:22:57.87,1:23:01.73,DefaultSingle-J,,0,0,0,,		その時  ユーロポールの職員に見つかったワケか	
Dialogue: 0,1:23:02.03,1:23:05.87,DefaultSingle-J,,0,0,0,,		帰ったはずだったんだが  間の悪い女だよな	
Dialogue: 0,1:23:09.88,1:23:10.63,DefaultSingle-J,,0,0,0,,		ん？	
Dialogue: 0,1:23:12.63,1:23:13.59,DefaultSingle-J,,0,0,0,,		よし	
Dialogue: 0,1:23:15.46,1:23:17.72,DefaultSingle-J,,0,0,0,,		誰  そこで何してるの	
Dialogue: 0,1:23:24.83,1:23:26.92,DefaultSingle-J,,0,0,0,,		キールか  1人逃げた	
Dialogue: 0,1:23:27.48,1:23:29.68,DefaultSingle-J,,0,0,0,,		ああ  見られた  始末しろ	
Dialogue: 0,1:23:33.41,1:23:36.41,DefaultSingle-J,,0,0,0,,		レオンハルトさんを殺害した動機は？	
Dialogue: 0,1:23:37.75,1:23:40.14,DefaultSingle-J,,0,0,0,,		予定外の拉致のせいでな	
Dialogue: 0,1:23:40.70,1:23:44.15,DefaultSingle-J,,0,0,0,,		防犯カメラの映像を改ざんする必要が出てきた	
Dialogue: 0,1:23:45.09,1:23:49.58,DefaultSingle-J,,0,0,0,,		仮で処理した後  完全に痕跡を消そうとしたんだが…	
Dialogue: 1,1:23:50.13,1:23:55.14,DefaultSingle-J,,0,0,0,,		あのガキがついきゅうしたおかげで  ヤツが痕跡に感づきやがったんだ	
Dialogue: 0,1:23:57.03,1:23:58.71,DefaultSingle-J,,0,0,0,,		あれはどういうことだ	
Dialogue: 0,1:23:59.81,1:24:01.47,DefaultSingle-J,,0,0,0,,		なんとか言ったらどうなんだ	
Dialogue: 0,1:24:03.56,1:24:07.12,DefaultSingle-J,,0,0,0,,		あのログはゆうべ  お前がメインルームにいた時の…	
Dialogue: 0,1:24:08.46,1:24:09.78,DefaultSingle-J,,0,0,0,,		何やってんだ  お前	
Dialogue: 0,1:24:20.69,1:24:22.90,DefaultSingle-J,,0,0,0,,		改ざんした記録は消した	
Dialogue: 0,1:24:23.20,1:24:24.90,DefaultSingle-J,,0,0,0,,		俺がやった証拠はない	
Dialogue: 0,1:24:25.87,1:24:29.92,DefaultSingle-J,,0,0,0,,		あとはヤツさえ消せば  万事うまくいく	
Dialogue: 0,1:24:29.92,1:24:31.89,DefaultSingle-J,,0,0,0,,		はずだったんだがな	
Dialogue: 0,1:24:34.66,1:24:35.80,DefaultSingle-J,,0,0,0,,		逃すな	
Dialogue: 0,1:24:35.80,1:24:36.38,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,1:24:36.38,1:24:37.36,DefaultSingle-J,,0,0,0,,		待て	
Dialogue: 0,1:24:44.10,1:24:45.22,DefaultSingle-J,,0,0,0,,		またお前か	
Dialogue: 0,1:24:56.24,1:24:56.99,DefaultSingle-J,,0,0,0,,		蘭	
Dialogue: 0,1:25:03.34,1:25:04.40,DefaultSingle-J,,0,0,0,,		大丈夫か	
Dialogue: 0,1:25:04.62,1:25:06.11,DefaultSingle-J,,0,0,0,,		あ…あっ  はい	
Dialogue: 0,1:25:06.41,1:25:10.99,DefaultSingle-J,,0,0,0,,		右の正拳を出した後  体が左に流れるクセがある	
Dialogue: 0,1:25:11.28,1:25:12.20,DefaultSingle-J,,0,0,0,,		気をつけなさい	
Dialogue: 0,1:25:12.20,1:25:13.60,DefaultSingle-J,,0,0,0,,		は…はい	
Dialogue: 0,1:25:14.72,1:25:16.08,DefaultSingle-J,,0,0,0,,		どこに行くつもりなんだ	
Dialogue: 0,1:25:16.95,1:25:18.39,DefaultSingle-J,,0,0,0,,		逃げられるワケがない	
Dialogue: 0,1:25:27.31,1:25:28.46,DefaultSingle-J,,0,0,0,,		右に曲がったぞ	
Dialogue: 0,1:25:28.46,1:25:29.27,DefaultSingle-J,,0,0,0,,		了解	
Dialogue: 0,1:25:32.03,1:25:34.08,DefaultSingle-J,,0,0,0,,		いや  そうじゃない	
Dialogue: 0,1:25:34.61,1:25:35.68,DefaultSingle-J,,0,0,0,,		あれは…	
Dialogue: 0,1:25:44.00,1:25:45.12,DefaultSingle-J,,0,0,0,,		ごめんなさい	
Dialogue: 0,1:25:55.37,1:25:56.21,DefaultSingle-J,,0,0,0,,		待て	
Dialogue: 0,1:25:57.86,1:25:59.30,DefaultSingle-J,,0,0,0,,		またお前か	
Dialogue: 0,1:25:59.58,1:26:00.81,DefaultSingle-J,,0,0,0,,		なぜ分かった	
Dialogue: 0,1:26:01.31,1:26:04.80,DefaultSingle-J,,0,0,0,,		廊下の監視カメラを一部反転したんでしょ？	
Dialogue: 0,1:26:08.48,1:26:10.37,DefaultSingle-J,,0,0,0,,		ピアスが逆になってたよ	
Dialogue: 0,1:26:12.55,1:26:15.19,DefaultSingle-J,,0,0,0,,		いつからグレースがあやしいとにらんでた？	
Dialogue: 0,1:26:15.40,1:26:17.38,DefaultSingle-J,,0,0,0,,		コーヒーを頼んだ時だよ	
Dialogue: 0,1:26:17.67,1:26:22.79,DefaultSingle-J,,0,0,0,,		フランス人なら  これが2つを表すってことを知らないワケないからね	
Dialogue: 0,1:26:23.33,1:26:25.00,DefaultSingle-J,,0,0,0,,		オーケー  1つね	
Dialogue: 0,1:26:26.11,1:26:28.17,DefaultSingle-J,,0,0,0,,		オメーはそれが分からなかった	
Dialogue: 0,1:26:28.75,1:26:30.35,DefaultSingle-J,,0,0,0,,		その時  思ったんだ	
Dialogue: 0,1:26:30.61,1:26:35.09,DefaultSingle-J,,0,0,0,,		この人  何かの理由でウソついてる  得体の知れない人だってね	
Dialogue: 0,1:26:35.50,1:26:36.85,DefaultSingle-J,,0,0,0,,		さすがだな	
Dialogue: 0,1:26:38.17,1:26:39.76,DefaultSingle-J,,0,0,0,,		工藤新一	
Dialogue: 0,1:26:39.76,1:26:40.47,DefaultSingle-J,,0,0,0,,		なっ…	
Dialogue: 0,1:26:41.13,1:26:42.26,DefaultSingle-J,,0,0,0,,		何	
Dialogue: 0,1:26:42.47,1:26:44.89,DefaultSingle-J,,0,0,0,,		俺もお前が気になって調べたよ	
Dialogue: 0,1:26:45.54,1:26:49.23,DefaultSingle-J,,0,0,0,,		まさか  小さくなって生きていたとはな	
Dialogue: 0,1:26:49.23,1:26:52.09,DefaultSingle-J,,0,0,0,,		ヤベエ  どうする  どうする	
Dialogue: 0,1:26:52.62,1:26:55.24,DefaultSingle-J,,0,0,0,,		直美とシェリーは逃しちまったが	
Dialogue: 0,1:26:55.24,1:26:58.54,DefaultSingle-J,,0,0,0,,		これをラムに見せれば  俺は組織でのし上がり	
Dialogue: 0,1:26:58.54,1:27:03.56,DefaultSingle-J,,0,0,0,,		お前を始末したと思っているジンの顔をつぶすことができるってワケだ	
Dialogue: 0,1:27:05.95,1:27:11.09,DefaultSingle-J,,0,0,0,,		通常  殺人を犯してしまった人は  平常心ではいられない	
Dialogue: 0,1:27:12.47,1:27:15.12,DefaultSingle-J,,0,0,0,,		だから普通と違う行動をとってしまう	
Dialogue: 0,1:27:15.88,1:27:17.20,DefaultSingle-J,,0,0,0,,		あんたは逆だ	
Dialogue: 0,1:27:18.21,1:27:20.70,DefaultSingle-J,,0,0,0,,		慣れすぎてんだよ  人の死に	
Dialogue: 0,1:27:22.41,1:27:26.05,DefaultSingle-J,,0,0,0,,		あんた  ジンにそっくりだよ  って言いたいところだけど	
Dialogue: 0,1:27:26.43,1:27:28.50,DefaultSingle-J,,0,0,0,,		ヤツならこんなヘマはやらねえ	
Dialogue: 0,1:27:29.16,1:27:32.56,DefaultSingle-J,,0,0,0,,		ジンもどきのただのチンピラってところかな	
Dialogue: 0,1:27:34.26,1:27:36.86,DefaultSingle-J,,0,0,0,,		ムカつくヤツの名前を出すんじゃねえ	
Dialogue: 0,1:27:40.86,1:27:45.86,DefaultSingle-J,,0,0,0,,		ジンの野郎と似てるってだけでも  虫唾が走るっつうのによ	
Dialogue: 0,1:27:45.86,1:27:49.65,DefaultSingle-J,,0,0,0,,		あのクソ野郎より下の  「もどき」だと？	
Dialogue: 0,1:27:51.38,1:27:55.28,DefaultSingle-J,,0,0,0,,		工藤新一  もちろんお前は連れていく	
Dialogue: 0,1:27:55.29,1:27:56.93,DefaultSingle-J,,0,0,0,,		いい土産になるぜ	
Dialogue: 0,1:27:56.93,1:28:00.45,DefaultSingle-J,,0,0,0,,		体が縮んだカラクリをラムの前で吐かせてやる	
Dialogue: 0,1:28:07.81,1:28:08.86,DefaultSingle-J,,0,0,0,,		この野郎	
Dialogue: 0,1:28:09.39,1:28:10.56,DefaultSingle-J,,0,0,0,,		コナン君	
Dialogue: 0,1:28:10.56,1:28:12.93,DefaultSingle-J,,0,0,0,,		チッ  クソッ	
Dialogue: 0,1:28:12.93,1:28:14.07,DefaultSingle-J,,0,0,0,,		いって…	
Dialogue: 0,1:28:14.70,1:28:15.69,DefaultSingle-J,,0,0,0,,		コナン君	
Dialogue: 0,1:28:15.88,1:28:17.95,DefaultSingle-J,,0,0,0,,		あいつ  なんてことを…	
Dialogue: 0,1:28:17.11,1:28:18.52,DefaultSingle-J,,0,0,0,,		おい  開けろ	
Dialogue: 0,1:28:18.03,1:28:19.09,DefaultSingle-J,,0,0,0,,		早く医務室に	
Dialogue: 0,1:28:19.09,1:28:20.16,DefaultSingle-J,,0,0,0,,		大丈夫	
Dialogue: 0,1:28:20.16,1:28:21.04,DefaultSingle-J,,0,0,0,,		ダメよ	
Dialogue: 0,1:28:21.04,1:28:24.77,DefaultSingle-J,,0,0,0,,		それより  あの時どなってごめんなさい	
Dialogue: 0,1:28:25.12,1:28:26.39,DefaultSingle-J,,0,0,0,,		コナン君…	
Dialogue: 0,1:28:26.96,1:28:30.21,DefaultSingle-J,,0,0,0,,		いいのよ  私も信じてあげられなくてごめんね	
Dialogue: 0,1:28:30.95,1:28:32.23,DefaultSingle-J,,0,0,0,,		おい  開けろ	
Dialogue: 0,1:28:32.95,1:28:33.50,DefaultSingle-J,,0,0,0,,		おい	
Dialogue: 0,1:28:33.50,1:28:34.51,DefaultSingle-J,,0,0,0,,		開けなさい	
Dialogue: 0,1:28:35.93,1:28:37.20,DefaultSingle-J,,0,0,0,,		逃がすかよ	
Dialogue: 0,1:28:39.41,1:28:40.43,DefaultSingle-J,,0,0,0,,		安室さん？	
Dialogue: 0,1:28:40.92,1:28:42.87,DefaultSingle-J,,0,0,0,,		まだパシフィック・ブイにいるのか	
Dialogue: 0,1:28:42.87,1:28:44.14,DefaultSingle-J,,0,0,0,,		え？うん	
Dialogue: 0,1:28:44.34,1:28:46.67,DefaultSingle-J,,0,0,0,,		何やってる  すぐに逃げるんだ	
Dialogue: 0,1:28:47.10,1:28:48.34,DefaultSingle-J,,0,0,0,,		もうすぐそこに…	
Dialogue: 0,1:28:50.60,1:28:52.00,DefaultSingle-J,,0,0,0,,		なんだって？	
Dialogue: 0,1:28:52.00,1:28:53.68,DefaultSingle-J,,0,0,0,,		早くみんなに知らせないと	
Dialogue: 0,1:28:54.09,1:28:54.60,DefaultSingle-J,,0,0,0,,		いや	
Dialogue: 0,1:28:55.56,1:28:57.08,DefaultSingle-J,,0,0,0,,		それはもう済んだ	
Dialogue: 0,1:28:57.77,1:28:59.17,DefaultSingle-J,,0,0,0,,		くり返す	
Dialogue: 0,1:28:59.17,1:29:03.99,DefaultSingle-J,,0,0,0,,		民間人は至急退避  魚雷に狙われている可能性がある	
Dialogue: 0,1:29:05.02,1:29:08.66,DefaultSingle-J,,0,0,0,,		ここにいる人間を  システムごと葬るつもりか	
Dialogue: 0,1:29:08.92,1:29:11.10,DefaultSingle-J,,0,0,0,,		目暮  陣頭指揮を頼む	
Dialogue: 0,1:29:11.31,1:29:11.92,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,1:29:13.33,1:29:15.73,DefaultSingle-J,,0,0,0,,		退避命令が発令されました	
Dialogue: 0,1:29:15.73,1:29:19.39,DefaultSingle-J,,0,0,0,,		ただちに一般職員の方々は退避してください	
Dialogue: 0,1:29:19.61,1:29:20.67,DefaultSingle-J,,0,0,0,,		くり返します…	
Dialogue: 0,1:29:20.93,1:29:23.13,DefaultSingle-J,,0,0,0,,		お父さん  起きてよ	
Dialogue: 0,1:29:23.27,1:29:24.21,DefaultSingle-J,,0,0,0,,		は？	
Dialogue: 0,1:29:26.19,1:29:27.38,DefaultSingle-J,,0,0,0,,		お父さん	
Dialogue: 0,1:29:27.69,1:29:30.24,DefaultSingle-J,,0,0,0,,		相手はたかが潜水艦1隻	
Dialogue: 0,1:29:30.45,1:29:32.03,DefaultSingle-J,,0,0,0,,		装備の数が違う	
Dialogue: 0,1:29:32.47,1:29:33.79,DefaultSingle-J,,0,0,0,,		デコイの準備だ	
Dialogue: 0,1:29:33.79,1:29:34.52,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,1:29:34.82,1:29:35.93,DefaultSingle-J,,0,0,0,,		デコイ？	
Dialogue: 0,1:29:36.13,1:29:37.97,DefaultSingle-J,,0,0,0,,		魚雷を誘導するオトリだ	
Dialogue: 0,1:29:38.30,1:29:40.00,DefaultSingle-J,,0,0,0,,		それより  早くそこから…	
Dialogue: 0,1:29:40.00,1:29:41.12,DefaultSingle-J,,0,0,0,,		あっ  ちょっと待って	
Dialogue: 0,1:29:43.88,1:29:44.83,DefaultSingle-J,,0,0,0,,		赤井さん？	
Dialogue: 0,1:29:46.08,1:29:47.19,DefaultSingle-J,,0,0,0,,		赤井だと？	
Dialogue: 0,1:29:48.90,1:29:51.03,DefaultSingle-J,,0,0,0,,		どんな状況だ  ボウヤ	
Dialogue: 0,1:29:51.37,1:29:52.36,DefaultSingle-J,,0,0,0,,		待って	
Dialogue: 0,1:29:53.86,1:29:56.41,DefaultSingle-J,,0,0,0,,		ピンガは潜水艦に逃げ込むつもりだよ	
Dialogue: 0,1:29:56.90,1:30:01.07,DefaultSingle-J,,0,0,0,,		潜水艦にダメージをあたえる武器を  米軍から手に入れてある	
Dialogue: 0,1:30:01.58,1:30:04.28,DefaultSingle-J,,0,0,0,,		米軍の武器を日本国内で使う気か	
Dialogue: 0,1:30:04.70,1:30:06.11,DefaultSingle-J,,0,0,0,,		その声は安室…	
Dialogue: 0,1:30:06.53,1:30:08.56,DefaultSingle-J,,0,0,0,,		いや  降谷零君か	
Dialogue: 0,1:30:09.02,1:30:11.50,DefaultSingle-J,,0,0,0,,		日本に迫る脅威を打ちはらうのも	
Dialogue: 0,1:30:11.59,1:30:14.90,DefaultSingle-J,,0,0,0,,		在日米軍の役割の1つじゃなかったかな	
Dialogue: 0,1:30:15.72,1:30:16.21,DefaultSingle-J,,0,0,0,,		フン	
Dialogue: 0,1:30:16.59,1:30:20.59,DefaultSingle-J,,0,0,0,,		日本で勝手に活動しているFBIのセリフとは思えんが	
Dialogue: 0,1:30:21.31,1:30:23.17,DefaultSingle-J,,0,0,0,,		今は一刻の猶予もない	
Dialogue: 0,1:30:24.05,1:30:26.48,DefaultSingle-J,,0,0,0,,		止められるんだろうな  その武器で	
Dialogue: 0,1:30:26.95,1:30:30.30,DefaultSingle-J,,0,0,0,,		ああ  潜水艦の位置さえ分かればな	
Dialogue: 0,1:30:30.70,1:30:32.34,DefaultSingle-J,,0,0,0,,		できるか  ボウヤ	
Dialogue: 0,1:30:32.95,1:30:35.03,DefaultSingle-J,,0,0,0,,		うん  やってみる	
Dialogue: 0,1:30:35.83,1:30:38.11,DefaultSingle-J,,0,0,0,,		組織随一のスナイパー…	
Dialogue: 0,1:30:38.89,1:30:41.91,DefaultSingle-J,,0,0,0,,		海自が来る前に済ませろよ  ライ	
Dialogue: 0,1:30:42.21,1:30:45.37,DefaultSingle-J,,0,0,0,,		もちろん  そのつもりだよ  バーボン	
Dialogue: 0,1:30:50.12,1:30:53.59,DefaultSingle-J,,0,0,0,,		降谷さん  あと2分で容疑者が到着します	
Dialogue: 0,1:30:54.80,1:30:55.80,DefaultSingle-J,,0,0,0,,		降谷さん？	
Dialogue: 0,1:30:56.46,1:30:57.86,DefaultSingle-J,,0,0,0,,		ああ  分かった	
Dialogue: 0,1:31:03.19,1:31:05.57,DefaultSingle-J,,0,0,0,,		もうすぐ警備艇が到着します	
Dialogue: 0,1:31:05.57,1:31:07.86,DefaultSingle-J,,0,0,0,,		みなさんはそれで避難してください	
Dialogue: 0,1:31:07.86,1:31:09.56,DefaultSingle-J,,0,0,0,,		俺は自分の船がある	
Dialogue: 0,1:31:09.56,1:31:11.01,DefaultSingle-J,,0,0,0,,		ああっ  頼みます	
Dialogue: 0,1:31:22.23,1:31:24.83,DefaultSingle-J,,0,0,0,,		あっ  また遠隔操作されている	
Dialogue: 0,1:31:24.94,1:31:25.86,DefaultSingle-J,,0,0,0,,		何？	
Dialogue: 0,1:31:26.09,1:31:27.38,DefaultSingle-J,,0,0,0,,		閉じたはずだろう	
Dialogue: 0,1:31:27.82,1:31:29.56,DefaultSingle-J,,0,0,0,,		新たなバックドア	
Dialogue: 0,1:31:29.56,1:31:30.97,DefaultSingle-J,,0,0,0,,		グレースのヤツ	
Dialogue: 0,1:31:31.95,1:31:33.13,DefaultSingle-J,,0,0,0,,		いつの間に…	
Dialogue: 0,1:31:35.47,1:31:37.25,DefaultSingle-J,,0,0,0,,		止めてやる  止めてやる	
Dialogue: 0,1:31:37.79,1:31:40.68,DefaultSingle-J,,0,0,0,,		ヤツらの潜水艦を  止めてやる	
Dialogue: 0,1:31:41.22,1:31:42.08,DefaultSingle-J,,0,0,0,,		ていっ	
Dialogue: 0,1:31:47.48,1:31:48.57,DefaultSingle-J,,0,0,0,,		魚雷を探知	
Dialogue: 0,1:31:49.69,1:31:50.88,DefaultSingle-J,,0,0,0,,		デコイ発射	
Dialogue: 0,1:31:50.88,1:31:52.58,DefaultSingle-J,,0,0,0,,		デコイ発射  了解	
Dialogue: 0,1:32:08.88,1:32:10.40,DefaultSingle-J,,0,0,0,,		魚雷  進路変更	
Dialogue: 0,1:32:11.10,1:32:12.55,DefaultSingle-J,,0,0,0,,		デコイにかかりました	
Dialogue: 0,1:32:27.51,1:32:29.78,DefaultSingle-J,,0,0,0,,		クソッ  デコイに引っ張られた	
Dialogue: 0,1:32:29.78,1:32:32.11,DefaultSingle-J,,0,0,0,,		構わん  撃ち続けろ	
Dialogue: 0,1:32:32.11,1:32:32.74,DefaultSingle-J,,0,0,0,,		はい	
Dialogue: 0,1:32:43.25,1:32:44.66,DefaultSingle-J,,0,0,0,,		サンキュー  博士	
Dialogue: 0,1:32:56.93,1:32:58.01,DefaultSingle-J,,0,0,0,,		ダメよ	
Dialogue: 0,1:32:58.48,1:33:03.96,DefaultSingle-J,,0,0,0,,		玉手箱は  海の底に  沈んでないとね	
Dialogue: 0,1:33:10.56,1:33:12.07,DefaultSingle-J,,0,0,0,,		デコイの発射口が…	
Dialogue: 0,1:33:12.07,1:33:12.97,DefaultSingle-J,,0,0,0,,		何？	
Dialogue: 0,1:33:13.14,1:33:13.86,DefaultSingle-J,,0,0,0,,		エド	
Dialogue: 0,1:33:14.99,1:33:15.97,DefaultSingle-J,,0,0,0,,		ダメだ	
Dialogue: 0,1:33:16.65,1:33:19.60,DefaultSingle-J,,0,0,0,,		防御システムも  遠隔操作されてる	
Dialogue: 0,1:33:19.99,1:33:21.12,DefaultSingle-J,,0,0,0,,		なんだとっ	
Dialogue: 0,1:33:24.37,1:33:25.65,DefaultSingle-J,,0,0,0,,		魚雷を捕捉	
Dialogue: 0,1:33:26.12,1:33:28.37,DefaultSingle-J,,0,0,0,,		牧野局長  決断を	
Dialogue: 0,1:33:28.78,1:33:30.35,DefaultSingle-J,,0,0,0,,		90秒で着弾	
Dialogue: 0,1:33:33.13,1:33:35.05,DefaultSingle-J,,0,0,0,,		総員  至急退避	
Dialogue: 0,1:33:35.57,1:33:37.82,DefaultSingle-J,,0,0,0,,		施設内すべてに  避難指示を	
Dialogue: 0,1:33:37.88,1:33:38.71,DefaultSingle-J,,0,0,0,,		急げ	
Dialogue: 0,1:33:42.97,1:33:45.56,DefaultSingle-J,,0,0,0,,		水は空気に比べて圧縮されないから	
Dialogue: 0,1:33:45.94,1:33:49.40,DefaultSingle-J,,0,0,0,,		水中の衝撃波は秒速1500メートルにもなる	
Dialogue: 0,1:33:50.64,1:33:54.39,DefaultSingle-J,,0,0,0,,		魚雷の衝撃を避けるには  岩礁帯しかねえ	
Dialogue: 0,1:33:59.09,1:34:00.53,DefaultSingle-J,,0,0,0,,		デコイが出てねえ	
Dialogue: 0,1:34:00.99,1:34:02.50,DefaultSingle-J,,0,0,0,,		避難は間に合ったのか	
Dialogue: 0,1:34:03.08,1:34:04.95,DefaultSingle-J,,0,0,0,,		着弾まで10  9…	
Dialogue: 0,1:34:04.95,1:34:07.95,DefaultSingle-J,,0,0,0,,		これで  パシフィック・ブイはしまいだ	
Dialogue: 0,1:34:05.07,1:34:07.94,DefaultSingle-J,,0,0,0,,		8  7	
Dialogue: 0,1:34:07.95,1:34:10.51,DefaultSingle-J,,0,0,0,,		6  5  4	
Dialogue: 0,1:34:10.86,1:34:13.65,DefaultSingle-J,,0,0,0,,		3  2  1…	
Dialogue: 0,1:34:14.21,1:34:15.09,DefaultSingle-J,,0,0,0,,		ゼロ	
Dialogue: 0,1:34:26.98,1:34:28.30,DefaultSingle-J,,0,0,0,,		なんてことだ	
Dialogue: 0,1:34:28.41,1:34:30.65,DefaultSingle-J,,0,0,0,,		ああ  パシフィック・ブイが…	
Dialogue: 0,1:34:35.05,1:34:38.38,DefaultSingle-J,,0,0,0,,		あのシステムはいくらでも悪用できただろうに	
Dialogue: 0,1:34:38.38,1:34:40.07,DefaultSingle-J,,0,0,0,,		まさか破壊するとは	
Dialogue: 0,1:34:40.49,1:34:45.13,DefaultSingle-J,,0,0,0,,		それともヤツらに破壊せざるを得ない事情が何かあったのか	
Dialogue: 0,1:34:49.68,1:34:51.51,DefaultSingle-J,,0,0,0,,		兄貴  ピンガからです	
Dialogue: 0,1:34:51.51,1:34:52.50,DefaultSingle-J,,0,0,0,,		貸せ	
Dialogue: 0,1:34:53.43,1:34:55.79,DefaultSingle-J,,0,0,0,,		最後の仕上げが終わったようだな	
Dialogue: 0,1:34:56.34,1:34:59.89,DefaultSingle-J,,0,0,0,,		早く合流しろ  お前に見せたいもんがある	
Dialogue: 0,1:35:00.13,1:35:01.92,DefaultSingle-J,,0,0,0,,		そいつは奇遇だな	
Dialogue: 0,1:35:02.01,1:35:03.98,DefaultSingle-J,,0,0,0,,		こっちはお前が二度と組織で	
Dialogue: 0,1:35:03.98,1:35:07.69,DefaultSingle-J,,0,0,0,,		偉そうなツラができねえような  土産を持ってるぜ	
Dialogue: 0,1:35:08.01,1:35:09.94,DefaultSingle-J,,0,0,0,,		合流するのが楽しみだ	
Dialogue: 0,1:35:10.14,1:35:12.14,DefaultSingle-J,,0,0,0,,		ああ  後でな	
Dialogue: 0,1:35:14.34,1:35:15.90,DefaultSingle-J,,0,0,0,,		聞こえる？  赤井さん	
Dialogue: 0,1:35:16.09,1:35:17.56,DefaultSingle-J,,0,0,0,,		潜水艦を見つけたよ	
Dialogue: 0,1:35:18.00,1:35:20.04,DefaultSingle-J,,0,0,0,,		岩礁帯の中腹辺りにいる	
Dialogue: 0,1:35:20.89,1:35:23.89,DefaultSingle-J,,0,0,0,,		岩礁帯の位置は海図で確認済みだが	
Dialogue: 0,1:35:25.00,1:35:26.50,DefaultSingle-J,,0,0,0,,		範囲が広すぎる	
Dialogue: 0,1:35:27.14,1:35:29.97,DefaultSingle-J,,0,0,0,,		潜水艦の形が見えたら  狙撃できる？	
Dialogue: 0,1:35:31.05,1:35:32.85,DefaultSingle-J,,0,0,0,,		できるが  どうする気だ	
Dialogue: 0,1:35:33.19,1:35:34.21,DefaultSingle-J,,0,0,0,,		なんとかするよ	
Dialogue: 0,1:35:35.16,1:35:36.26,DefaultSingle-J,,0,0,0,,		工藤君…	
Dialogue: 0,1:35:40.72,1:35:41.68,DefaultSingle-J,,0,0,0,,		哀君	
Dialogue: 0,1:35:43.62,1:35:46.09,DefaultSingle-J,,0,0,0,,		何してんのよ  あのバカ	
Dialogue: 0,1:35:46.51,1:35:49.82,DefaultSingle-J,,0,0,0,,		哀君  それはダメじゃ  バッテリーが…	
Dialogue: 0,1:35:49.14,1:35:50.66,DefaultSingle-J,,0,0,0,,		博士  危ない	
Dialogue: 0,1:35:55.16,1:35:57.89,DefaultSingle-J,,0,0,0,,		パシフィック・ブイはもう沈みやすぜ	
Dialogue: 0,1:35:58.26,1:36:01.65,DefaultSingle-J,,0,0,0,,		よし  ピンガとの合流地点に急げ	
Dialogue: 0,1:36:36.67,1:36:37.90,DefaultSingle-J,,0,0,0,,		まだだ	
Dialogue: 0,1:36:38.64,1:36:40.89,DefaultSingle-J,,0,0,0,,		もっと引きつけてから…	
Dialogue: 0,1:36:45.30,1:36:48.18,DefaultSingle-J,,0,0,0,,		ヤベエ…  手がしびれて…	
Dialogue: 0,1:36:54.57,1:36:55.85,DefaultSingle-J,,0,0,0,,		今だ	
Dialogue: 0,1:37:07.34,1:37:09.25,DefaultSingle-J,,0,0,0,,		う…海が光っています	
Dialogue: 0,1:37:09.25,1:37:10.20,DefaultSingle-J,,0,0,0,,		何	
Dialogue: 0,1:37:15.25,1:37:16.52,DefaultSingle-J,,0,0,0,,		捕捉した	
Dialogue: 0,1:37:16.60,1:37:17.15,DefaultSingle-J,,0,0,0,,		んっ？	
Dialogue: 0,1:37:18.90,1:37:20.10,DefaultSingle-J,,0,0,0,,		沈め	
Dialogue: 0,1:37:25.65,1:37:26.82,DefaultSingle-J,,0,0,0,,		エンジン出火	
Dialogue: 0,1:37:26.82,1:37:28.64,DefaultSingle-J,,0,0,0,,		なんだ  何が起きた	
Dialogue: 0,1:37:28.64,1:37:31.50,DefaultSingle-J,,0,0,0,,		発電機から浸水  速力低下	
Dialogue: 0,1:37:32.45,1:37:33.42,DefaultSingle-J,,0,0,0,,		モーター停止	
Dialogue: 0,1:37:33.42,1:37:35.20,DefaultSingle-J,,0,0,0,,		サブ電力に切り替えろ	
Dialogue: 0,1:37:35.20,1:37:37.10,DefaultSingle-J,,0,0,0,,		ダメです  つながりません	
Dialogue: 0,1:37:37.65,1:37:39.67,DefaultSingle-J,,0,0,0,,		ボウヤ  よくやったぞ	
Dialogue: 0,1:38:05.06,1:38:06.03,DefaultSingle-J,,0,0,0,,		工藤君…	
Dialogue: 0,1:38:24.72,1:38:28.21,DefaultSingle-J,,0,0,0,,		ウソ  ウソ  工藤君	
Dialogue: 0,1:38:41.62,1:38:43.74,DefaultSingle-J,,0,0,0,,		ダメ  ダメ	
Dialogue: 0,1:39:03.68,1:39:05.25,DefaultSingle-J,,0,0,0,,		あっぶねえ	
Dialogue: 0,1:39:05.74,1:39:07.59,DefaultSingle-J,,0,0,0,,		助かったぜ  灰原	
Dialogue: 0,1:39:08.82,1:39:11.57,DefaultSingle-J,,0,0,0,,		さあ  ゆっくり浮上しようぜ	
Dialogue: 0,1:39:12.60,1:39:15.75,DefaultSingle-J,,0,0,0,,		急浮上すると  減圧症になっちまうからな	
Dialogue: 0,1:39:24.66,1:39:25.41,DefaultSingle-J,,0,0,0,,		ん？	
Dialogue: 0,1:39:28.41,1:39:30.31,DefaultSingle-J,,0,0,0,,		中に入れない気か	
Dialogue: 0,1:39:30.57,1:39:31.89,DefaultSingle-J,,0,0,0,,		あの野郎	
Dialogue: 0,1:39:32.79,1:39:34.86,DefaultSingle-J,,0,0,0,,		ねえ  工藤君…	
Dialogue: 0,1:39:35.95,1:39:36.91,DefaultSingle-J,,0,0,0,,		分かってる？	
Dialogue: 0,1:39:37.74,1:39:40.27,DefaultSingle-J,,0,0,0,,		組織に私がシェリーだとバレた以上	
Dialogue: 0,1:39:40.95,1:39:44.26,DefaultSingle-J,,0,0,0,,		このまま帰ったら  みんなを巻き込むことになる	
Dialogue: 0,1:39:45.21,1:39:46.05,DefaultSingle-J,,0,0,0,,		そう…	
Dialogue: 0,1:39:46.87,1:39:50.42,DefaultSingle-J,,0,0,0,,		私にはもう  帰る場所はどこにもないの	
Dialogue: 0,1:39:51.59,1:39:55.55,DefaultSingle-J,,0,0,0,,		だから  あなたといられるのは  これが最後	
Dialogue: 0,1:39:57.53,1:40:01.91,DefaultSingle-J,,0,0,0,,		バイバイだね  江戸川コナン君	
Dialogue: 0,1:40:05.89,1:40:08.06,DefaultSingle-J,,0,0,0,,		そんな顔してんじゃねえよ	
Dialogue: 0,1:40:08.70,1:40:12.01,DefaultSingle-J,,0,0,0,,		言ったろ  オレがぜってーなんとかしてやるってよ	
Dialogue: 0,1:40:17.61,1:40:21.44,DefaultSingle-J,,0,0,0,,		まあ  この後  すっげーいろいろ大変そうだけど	
Dialogue: 0,1:40:23.41,1:40:24.40,DefaultSingle-J,,0,0,0,,		どうして	
Dialogue: 0,1:40:26.06,1:40:29.34,DefaultSingle-J,,0,0,0,,		どうしてあなたはいつも…いつも…	
Dialogue: 0,1:40:30.27,1:40:32.07,DefaultSingle-J,,0,0,0,,		そんな顔ができるのよ	
Dialogue: 0,1:40:35.44,1:40:36.56,DefaultSingle-J,,0,0,0,,		工藤君…	
Dialogue: 0,1:40:37.45,1:40:39.59,DefaultSingle-J,,0,0,0,,		あなたは知らないでしょうけど	
Dialogue: 0,1:40:40.67,1:40:41.95,DefaultSingle-J,,0,0,0,,		私達さっき…	
Dialogue: 0,1:40:43.49,1:40:45.12,DefaultSingle-J,,0,0,0,,		キスしちゃったのよ	
Dialogue: 0,1:40:55.27,1:40:56.83,DefaultSingle-J,,0,0,0,,		潜水艇がねえ	
Dialogue: 0,1:41:06.00,1:41:08.35,DefaultSingle-J,,0,0,0,,		そういうことかよ  ジン	
Dialogue: 0,1:41:29.50,1:41:30.57,DefaultSingle-J,,0,0,0,,		マズい	
Dialogue: 0,1:41:40.60,1:41:45.02,DefaultSingle-J,,0,0,0,,		いっけえええーっ	
Dialogue: 0,1:42:06.55,1:42:08.34,DefaultSingle-J,,0,0,0,,		破壊したんですかい	
Dialogue: 0,1:42:08.69,1:42:12.78,DefaultSingle-J,,0,0,0,,		あの潜水艦には  組織の秘密が詰まってるからな	
Dialogue: 0,1:42:13.36,1:42:15.16,DefaultSingle-J,,0,0,0,,		ピンガには伝えたのよね？	
Dialogue: 0,1:42:16.02,1:42:18.34,DefaultSingle-J,,0,0,0,,		さあ  どうだったかな	
Dialogue: 0,1:42:26.50,1:42:28.78,DefaultSingle-J,,0,0,0,,		コナン君	
Dialogue: 0,1:42:29.28,1:42:30.13,DefaultSingle-J,,0,0,0,,		蘭	
Dialogue: 0,1:42:30.50,1:42:32.75,DefaultSingle-J,,0,0,0,,		無事でよかった	
Dialogue: 0,1:42:30.96,1:42:32.75,DefaultSingle-J,,0,0,0,,		おい	
Dialogue: 0,1:42:33.81,1:42:35.47,DefaultSingle-J,,0,0,0,,		助かったぞ  灰原	
Dialogue: 0,1:42:39.89,1:42:41.08,DefaultSingle-J,,0,0,0,,		おい  灰原	
Dialogue: 0,1:42:45.36,1:42:47.39,DefaultSingle-J,,0,0,0,,		灰原  おい  灰原	
Dialogue: 0,1:42:48.19,1:42:49.81,DefaultSingle-J,,0,0,0,,		クソッ  減圧症か	
Dialogue: 0,1:42:55.15,1:42:57.40,DefaultSingle-J,,0,0,0,,		大変  哀ちゃん	
Dialogue: 0,1:42:56.15,1:42:57.40,DefaultSingle-J,,0,0,0,,		哀君	
Dialogue: 0,1:42:57.40,1:42:58.38,DefaultSingle-J,,0,0,0,,		コナン君  どいて	
Dialogue: 0,1:42:58.95,1:43:00.61,DefaultSingle-J,,0,0,0,,		ウソ  どうしよう	
Dialogue: 0,1:43:10.42,1:43:11.28,DefaultSingle-J,,0,0,0,,		え？	
Dialogue: 0,1:43:12.02,1:43:14.87,DefaultSingle-J,,0,0,0,,		ね…寝ぼけてるのかなあ	
Dialogue: 0,1:43:16.87,1:43:18.53,DefaultSingle-J,,0,0,0,,		ちゃんと返したわよ	
Dialogue: 0,1:43:19.30,1:43:20.80,DefaultSingle-J,,0,0,0,,		あなたの唇	
Dialogue: 0,1:46:48.63,1:46:52.67,DefaultSingle-J,,0,0,0,,		八丈島近海にあるパシフィック・ブイの復旧を断念し	
Dialogue: 0,1:46:52.67,1:46:56.59,DefaultSingle-J,,0,0,0,,		世界中の防犯カメラをつなぐ  インターポールの施設は	
Dialogue: 0,1:46:56.59,1:47:00.08,DefaultSingle-J,,0,0,0,,		日本以外の国に置くことになると発表しました	
Dialogue: 0,1:46:58.63,1:47:01.52,DefaultSingle-J,,0,0,0,,		行くのね  新たなパシフィック・ブイに	
Dialogue: 0,1:47:02.31,1:47:03.70,DefaultSingle-J,,0,0,0,,		今度はどこの国？	
Dialogue: 0,1:47:04.23,1:47:06.94,DefaultSingle-J,,0,0,0,,		ごめんね  話しちゃいけないの	
Dialogue: 0,1:47:07.20,1:47:08.31,DefaultSingle-J,,0,0,0,,		そうよね	
Dialogue: 0,1:47:08.31,1:47:09.31,DefaultSingle-J,,0,0,0,,		ごめんなさい	
Dialogue: 0,1:47:09.81,1:47:12.96,DefaultSingle-J,,0,0,0,,		いいわよ  言っちゃいけない決まりなんでしょ？	
Dialogue: 0,1:47:14.29,1:47:18.28,DefaultSingle-J,,0,0,0,,		子供の言葉や行動で  人生が変わることもある	
Dialogue: 0,1:47:19.84,1:47:21.27,DefaultSingle-J,,0,0,0,,		あれ  本当ね	
Dialogue: 0,1:47:21.94,1:47:25.58,DefaultSingle-J,,0,0,0,,		今のあなたのおかげで  これからの私がある	
Dialogue: 0,1:47:26.74,1:47:27.68,DefaultSingle-J,,0,0,0,,		ありがとう	
Dialogue: 0,1:47:30.17,1:47:31.60,DefaultSingle-J,,0,0,0,,		じゃあ  行くね	
Dialogue: 0,1:47:31.75,1:47:32.50,DefaultSingle-J,,0,0,0,,		ええ	
Dialogue: 0,1:47:42.03,1:47:43.93,DefaultSingle-J,,0,0,0,,		また会えてうれしかったわ	
Dialogue: 0,1:47:45.50,1:47:46.30,DefaultSingle-J,,0,0,0,,		志保	
Dialogue: 0,1:47:57.02,1:47:58.51,DefaultSingle-J,,0,0,0,,		えっ？ベルモットが？	
Dialogue: 0,1:47:59.15,1:48:02.96,DefaultSingle-J,,0,0,0,,		ああ  おそらくベルモットがいろんなシェリーに化けて	
Dialogue: 0,1:48:03.30,1:48:06.64,DefaultSingle-J,,0,0,0,,		各地の防犯カメラに  その姿を残したんだ	
Dialogue: 0,1:48:07.72,1:48:11.50,DefaultSingle-J,,0,0,0,,		おかげで  組織は老若認証への興味をなくしたよ	
Dialogue: 0,1:48:11.87,1:48:13.49,DefaultSingle-J,,0,0,0,,		でも  どうしてベルモットが…	
Dialogue: 0,1:48:13.79,1:48:14.74,DefaultSingle-J,,0,0,0,,		さあね	
Dialogue: 0,1:48:15.20,1:48:18.22,DefaultSingle-J,,0,0,0,,		君なら心当たりがあると思ったんだけどな	
Dialogue: 0,1:48:19.33,1:48:21.88,DefaultSingle-J,,0,0,0,,		ちなみに  ピンガという組織のメンバーが	
Dialogue: 0,1:48:21.88,1:48:24.18,DefaultSingle-J,,0,0,0,,		帰還せずに消息を絶ったらしいけど	
Dialogue: 0,1:48:24.71,1:48:26.34,DefaultSingle-J,,0,0,0,,		君は何か知ってるかい	
Dialogue: 0,1:48:27.01,1:48:27.96,DefaultSingle-J,,0,0,0,,		さあ…	
Dialogue: 0,1:48:29.55,1:48:32.53,DefaultSingle-J,,0,0,0,,		あの後  ヤツらの動きがねえなと思ってたけど	
Dialogue: 0,1:48:33.22,1:48:36.53,DefaultSingle-J,,0,0,0,,		やっぱりあの潜水艦の爆発に巻き込まれて…	
Dialogue: 0,1:48:37.34,1:48:38.27,DefaultSingle-J,,0,0,0,,		どうしたの	
Dialogue: 0,1:48:38.52,1:48:40.61,DefaultSingle-J,,0,0,0,,		あっ  いや  別に	
Dialogue: 0,1:48:40.85,1:48:44.44,DefaultSingle-J,,0,0,0,,		じゃあ  腹ごしらえでもして帰るとするかの	
Dialogue: 0,1:48:44.68,1:48:45.98,DefaultSingle-J,,0,0,0,,		揚げ物はダメよ	
Dialogue: 0,1:48:45.98,1:48:46.96,DefaultSingle-J,,0,0,0,,		アゲアゲ	
Dialogue: 0,1:48:46.96,1:48:49.56,DefaultSingle-J,,0,0,0,,		哀君の愛は手厳しいの	
Dialogue: 0,1:48:49.56,1:48:50.62,DefaultSingle-J,,0,0,0,,		当たり前じゃない	
Dialogue: 0,1:48:50.62,1:48:52.39,DefaultSingle-J,,0,0,0,,		隠れて食べてるの知ってるんだから	
Dialogue: 0,1:48:52.03,1:48:52.90,DefaultSingle-J,,0,0,0,,		ええー	
Dialogue: 0,1:48:52.39,1:48:54.41,DefaultSingle-J,,0,0,0,,		博士  バレてんぞ	
Dialogue: 0,1:48:56.38,1:48:58.08,DefaultSingle-J,,0,0,0,,		助けたワケ？	
Dialogue: 0,1:48:58.24,1:49:01.32,DefaultSingle-J,,0,0,0,,		それを探るのがあなたの仕事でしょ？	
Dialogue: 0,1:49:01.90,1:49:03.78,DefaultSingle-J,,0,0,0,,		シルバーブレット君	
