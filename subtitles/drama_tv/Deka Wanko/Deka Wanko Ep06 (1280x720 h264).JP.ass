Dialogue: 0,0:00:01.37,0:00:03.38,Japanese SUB,,0,0,0,,（花森一子の声）　大都会　東京。
Dialogue: 0,0:00:03.38,0:00:05.88,Japanese SUB,,0,0,0,,殺人事件は\N毎日のように起きている。
Dialogue: 0,0:00:05.88,0:00:09.90,Japanese SUB,,0,0,0,,しかし　全ての事件に\N私達　本庁の捜査一課が→
Dialogue: 0,0:00:09.90,0:00:11.87,Japanese SUB,,0,0,0,,出動するわけではない。
Dialogue: 0,0:00:11.87,0:00:14.87,Japanese SUB,,0,0,0,,捜査一課は\N１から１３係まであり→
Dialogue: 0,0:00:14.87,0:00:17.94,Japanese SUB,,0,0,0,,事件は　順番に振り分けられる。
Dialogue: 0,0:00:17.94,0:00:22.44,Japanese SUB,,0,0,0,,…というわけで\N相も変わらず在庁番です。
Dialogue: 0,0:00:23.88,0:00:26.40,Japanese SUB,,0,0,0,,お茶くみ　なう。
Dialogue: 0,0:00:26.40,0:00:30.39,Japanese SUB,,0,0,0,,ボス　お茶です　はい　どうぞ。
Dialogue: 0,0:00:30.39,0:00:34.37,Japanese SUB,,0,0,0,,（門馬）　あぁ～　間違えた！\N皆さん　お茶で～す。
Dialogue: 0,0:00:34.37,0:00:36.89,Japanese SUB,,0,0,0,,（小松原）　今日のボス　どうしたんだ。\N（重村）　さぁ？
Dialogue: 0,0:00:36.89,0:00:38.91,Japanese SUB,,0,0,0,,（門馬）　あぁ～！　電池が切れた！
Dialogue: 0,0:00:38.91,0:00:42.48,Japanese SUB,,0,0,0,,（和田）\N何だろな　いつもの５割増しで\Nムシャクシャしてんな。
Dialogue: 0,0:00:42.48,0:00:44.87,Japanese SUB,,0,0,0,,（デューク）　まぁ　いいんじゃないすか。\N（桐島竜太）　誰が原因だよ。
Dialogue: 0,0:00:44.87,0:00:48.89,Japanese SUB,,0,0,0,,（デューク）　Ｎｏｔ　ｍｅ．\Nデーク　ちょっと聞いて来い。
Dialogue: 0,0:00:48.89,0:00:50.87,Japanese SUB,,0,0,0,,お前が行けよ。\Nあぁ？
Dialogue: 0,0:00:50.87,0:00:52.89,Japanese SUB,,0,0,0,,ジョークです。\N分かってるよ　この野郎。
Dialogue: 0,0:00:52.89,0:00:55.88,Japanese SUB,,0,0,0,,余りものです。\N（柳）　その小っちゃいピンクの帽子→
Dialogue: 0,0:00:55.88,0:00:58.92,Japanese SUB,,0,0,0,,かわいいじゃねえかよ。\Nん？　いいですか？
Dialogue: 0,0:00:58.92,0:01:00.95,Japanese SUB,,0,0,0,,かわいいですか？\N（門馬）　ワンコ　ちょっと来い！
Dialogue: 0,0:01:00.95,0:01:03.90,Japanese SUB,,0,0,0,,後でにしてもらって　いいですか？\N何様!?
Dialogue: 0,0:01:03.90,0:01:05.40,Japanese SUB,,0,0,0,,いいから来い！
Dialogue: 0,0:01:06.89,0:01:08.39,Japanese SUB,,0,0,0,,は～い。
Dialogue: 0,0:01:10.89,0:01:13.88,Japanese SUB,,0,0,0,,昨日　「まともな格好をして来い」と\Nいったよな？
Dialogue: 0,0:01:13.88,0:01:16.38,Japanese SUB,,0,0,0,,はい！\Nそれが　まともな格好か!?
Dialogue: 0,0:01:16.38,0:01:18.94,Japanese SUB,,0,0,0,,えっ　ダメですか？\Nダメみたいよ。
Dialogue: 0,0:01:18.94,0:01:22.37,Japanese SUB,,0,0,0,,（門馬）　何なんだ　その帽子は！\Nえっ　かわいくないですか？
Dialogue: 0,0:01:22.37,0:01:26.39,Japanese SUB,,0,0,0,,刑事が　かわいい必要があるのか！\Nかわいいほうが　よくないですか？
Dialogue: 0,0:01:26.39,0:01:31.38,Japanese SUB,,0,0,0,,制服を着ろ！　制服を！\N刑事って　私服ＯＫですよね？
Dialogue: 0,0:01:31.38,0:01:34.38,Japanese SUB,,0,0,0,,だから　頑張って\N刑事になったんです！
Dialogue: 0,0:01:34.38,0:01:36.90,Japanese SUB,,0,0,0,,あぁ　そういう動機か！
Dialogue: 0,0:01:36.90,0:01:39.96,Japanese SUB,,0,0,0,,だからだ～。\Nなるほどな　やっと分かったよ。
Dialogue: 0,0:01:39.96,0:01:42.39,Japanese SUB,,0,0,0,,警察官は　警察官らしくだ！
Dialogue: 0,0:01:42.39,0:01:44.39,Japanese SUB,,0,0,0,,らしいです！
Dialogue: 0,0:01:44.39,0:01:46.38,Japanese SUB,,0,0,0,,ワンコ　頑張るね～。
Dialogue: 0,0:01:46.38,0:01:48.38,Japanese SUB,,0,0,0,,はい！
Dialogue: 0,0:01:48.38,0:01:50.88,Japanese SUB,,0,0,0,,ったく　そっくりだな　ホントに。
Dialogue: 0,0:01:50.88,0:01:53.40,Japanese SUB,,0,0,0,,はい？\Nはぁ…。
Dialogue: 0,0:01:53.40,0:01:56.41,Japanese SUB,,0,0,0,,とにかく　フリフリじゃ　ないのを\N着て来い！
Dialogue: 0,0:01:56.41,0:01:59.46,Japanese SUB,,0,0,0,,フリフリじゃ　ないのは　部屋着か\Nパジャマしかありません！
Dialogue: 0,0:01:59.46,0:02:02.40,Japanese SUB,,0,0,0,,だったら買って来い！\N勤務中ですよ？
Dialogue: 0,0:02:02.40,0:02:05.88,Japanese SUB,,0,0,0,,勤務中に　行ってもいいんですか？\Nああ行け　今行け　すぐに行け！
Dialogue: 0,0:02:05.88,0:02:08.40,Japanese SUB,,0,0,0,,１週間　出社には及ばん！
Dialogue: 0,0:02:08.40,0:02:11.40,Japanese SUB,,0,0,0,,その間に　事件が起きたら\Nどうするんですか！
Dialogue: 0,0:02:11.40,0:02:15.90,Japanese SUB,,0,0,0,,お前が心配しなくても　うちには\N優秀な刑事が　たくさんいるんだ！
Dialogue: 0,0:02:20.40,0:02:22.88,Japanese SUB,,0,0,0,,不安です。\N（小松原）　何つった　この野郎。
Dialogue: 0,0:02:22.88,0:02:25.89,Japanese SUB,,0,0,0,,（小松原）　回せ　回せ。\N（柳）　クルクルしましょう。
Dialogue: 0,0:02:25.89,0:02:28.39,Japanese SUB,,0,0,0,,（門馬）　まぁまぁ…　ここは…。
Dialogue: 0,0:02:28.39,0:02:30.91,Japanese SUB,,0,0,0,,はいはい…　早く　服　買って来い！
Dialogue: 0,0:02:30.91,0:02:32.88,Japanese SUB,,0,0,0,,分かりました。
Dialogue: 0,0:02:32.88,0:02:36.96,Japanese SUB,,0,0,0,,シゲさん　領収書　落ちますか？\N落ちるか！
Dialogue: 0,0:02:36.96,0:02:38.88,Japanese SUB,,0,0,0,,やっぱり。
Dialogue: 0,0:02:38.88,0:02:42.39,Japanese SUB,,0,0,0,,（小松原）　回せ　もう一回。\Nもう一回　行きましょう。
Dialogue: 0,0:02:42.39,0:02:44.40,Japanese SUB,,0,0,0,,何で？
Dialogue: 0,0:02:44.40,0:02:46.37,Japanese SUB,,0,0,0,,何で？　何で？　おぉ～。
Dialogue: 0,0:02:46.37,0:03:00.37,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:03:03.91,0:03:05.88,Japanese SUB,,0,0,0,,かわいい～！
Dialogue: 0,0:03:05.88,0:03:07.38,Japanese SUB,,0,0,0,,えぇ～！
Dialogue: 0,0:03:07.38,0:03:09.40,Japanese SUB,,0,0,0,,あっ　かわいい～！
Dialogue: 0,0:03:09.40,0:03:12.90,Japanese SUB,,0,0,0,,（ミーちゃん）　花森様\Nいつも　ありがとうございます。
Dialogue: 0,0:03:12.90,0:03:16.89,Japanese SUB,,0,0,0,,どうも\Nミーちゃん　今日も　かわいい～！
Dialogue: 0,0:03:16.89,0:03:18.94,Japanese SUB,,0,0,0,,一子ちゃんも　かわいい！
Dialogue: 0,0:03:18.94,0:03:20.97,Japanese SUB,,0,0,0,,かわいい～。\Nかわいい～。
Dialogue: 0,0:03:20.97,0:03:23.88,Japanese SUB,,0,0,0,,もう　ホントに　かわいい～！
Dialogue: 0,0:03:23.88,0:03:26.40,Japanese SUB,,0,0,0,,かわいい新作が入荷してます。
Dialogue: 0,0:03:26.40,0:03:28.38,Japanese SUB,,0,0,0,,一番地味なの　ください。
Dialogue: 0,0:03:28.38,0:03:31.38,Japanese SUB,,0,0,0,,えっ　どうしたんですか？
Dialogue: 0,0:03:31.38,0:03:35.88,Japanese SUB,,0,0,0,,ん～　いろいろ？\Nお待ちください。
Dialogue: 0,0:03:40.96,0:03:42.88,Japanese SUB,,0,0,0,,あっ　すいません。\N（ちえみ）　すいません。
Dialogue: 0,0:03:42.88,0:03:45.87,Japanese SUB,,0,0,0,,どうぞ？\Nあっ　いいです　どうせ買えないし。
Dialogue: 0,0:03:45.87,0:03:49.89,Japanese SUB,,0,0,0,,あら。\Nそれより　花森さんですよね。
Dialogue: 0,0:03:49.89,0:03:53.37,Japanese SUB,,0,0,0,,お店で　噂を聞いてました\N会えて　ビックリです。
Dialogue: 0,0:03:53.37,0:03:55.89,Japanese SUB,,0,0,0,,そう。
Dialogue: 0,0:03:55.89,0:03:58.93,Japanese SUB,,0,0,0,,ホントに　かわいい！
Dialogue: 0,0:03:58.93,0:04:00.43,Japanese SUB,,0,0,0,,そう？
Dialogue: 0,0:04:01.98,0:04:04.38,Japanese SUB,,0,0,0,,よっ　ほっ。
Dialogue: 0,0:04:04.38,0:04:07.88,Japanese SUB,,0,0,0,,ほっ　もういっちょ。
Dialogue: 0,0:04:09.39,0:04:11.89,Japanese SUB,,0,0,0,,チョコ　あげたの？\Nう～ん→
Dialogue: 0,0:04:11.89,0:04:15.39,Japanese SUB,,0,0,0,,あげたい子は　いるんだけど\Nその子　いっぱい貰ってたから→
Dialogue: 0,0:04:15.39,0:04:17.39,Japanese SUB,,0,0,0,,あげなかった。\Nふ～ん。
Dialogue: 0,0:04:18.90,0:04:20.90,Japanese SUB,,0,0,0,,（店員）　はい　毎度！
Dialogue: 0,0:04:25.39,0:04:29.38,Japanese SUB,,0,0,0,,ここの　たこ焼き　おいしいの。\Nへぇ～　知らなかった。
Dialogue: 0,0:04:29.38,0:04:31.38,Japanese SUB,,0,0,0,,いいにおい！
Dialogue: 0,0:04:33.88,0:04:35.88,Japanese SUB,,0,0,0,,あ…。\Nあっ。
Dialogue: 0,0:04:38.47,0:04:41.89,Japanese SUB,,0,0,0,,ちょっと　すいません。\N（工藤）　あぁ？
Dialogue: 0,0:04:41.89,0:04:44.37,Japanese SUB,,0,0,0,,みんな\Nちゃ～んと並んでるんですけど。
Dialogue: 0,0:04:44.37,0:04:46.89,Japanese SUB,,0,0,0,,花森さん\Nケガしたら　バカみたいだよ。
Dialogue: 0,0:04:46.89,0:04:50.38,Japanese SUB,,0,0,0,,何いってんだよ。\N割り込んだでしょ!?
Dialogue: 0,0:04:50.38,0:04:51.88,Japanese SUB,,0,0,0,,うるせぇよ！
Dialogue: 0,0:04:51.88,0:04:53.88,Japanese SUB,,0,0,0,,ほっ　ほっ　ほっ！
Dialogue: 0,0:04:58.95,0:05:01.39,Japanese SUB,,0,0,0,,もういいよ。
Dialogue: 0,0:05:01.39,0:05:04.38,Japanese SUB,,0,0,0,,「もういいよ」じゃ　ないでしょ！
Dialogue: 0,0:05:04.38,0:05:07.38,Japanese SUB,,0,0,0,,大人が\N恥ずかしくないんですか？
Dialogue: 0,0:05:07.38,0:05:09.88,Japanese SUB,,0,0,0,,お前らの格好のほうが\Nよっぽど恥ずかしいわ！
Dialogue: 0,0:05:09.88,0:05:12.40,Japanese SUB,,0,0,0,,小学生は\N勉強だけしてりゃいいんだよ！
Dialogue: 0,0:05:12.40,0:05:15.90,Japanese SUB,,0,0,0,,私は大人です！\Nウソつけ　ガキが。
Dialogue: 0,0:05:19.48,0:05:22.38,Japanese SUB,,0,0,0,,ちょっと待ちなさい。
Dialogue: 0,0:05:22.38,0:05:26.88,Japanese SUB,,0,0,0,,私は　警視庁捜査一課の刑事です。
Dialogue: 0,0:05:28.90,0:05:32.37,Japanese SUB,,0,0,0,,あ？　お前じゃねえじゃねぇか！
Dialogue: 0,0:05:32.37,0:05:34.89,Japanese SUB,,0,0,0,,えっ!?　えっ　いや　これ　私です。
Dialogue: 0,0:05:34.89,0:05:37.41,Japanese SUB,,0,0,0,,ちょちょ…！　待ってください！
Dialogue: 0,0:05:37.41,0:05:41.38,Japanese SUB,,0,0,0,,しつこいな　どけ！\Nうぉ～　ほっ！
Dialogue: 0,0:05:41.38,0:05:43.38,Japanese SUB,,0,0,0,,ほっ！　おぉ…。
Dialogue: 0,0:05:43.38,0:05:45.89,Japanese SUB,,0,0,0,,わぁ～！\Nあっ！
Dialogue: 0,0:05:45.89,0:05:49.39,Japanese SUB,,0,0,0,,痛～！　何すんだよ！
Dialogue: 0,0:05:51.39,0:05:54.88,Japanese SUB,,0,0,0,,誰か！　お巡りさん\Nお巡りさん　呼んでください！
Dialogue: 0,0:05:54.88,0:05:56.38,Japanese SUB,,0,0,0,,覚えてろよ！
Dialogue: 0,0:05:57.93,0:05:59.93,Japanese SUB,,0,0,0,,花森さん？
Dialogue: 0,0:06:04.39,0:06:07.89,Japanese SUB,,0,0,0,,たこ焼き…　食べようか。
Dialogue: 0,0:06:13.40,0:06:17.38,Japanese SUB,,0,0,0,,お巡りさん呼んでくれた　お礼！\Nありがとう。
Dialogue: 0,0:06:17.38,0:06:19.94,Japanese SUB,,0,0,0,,こちらこそ。
Dialogue: 0,0:06:19.94,0:06:22.94,Japanese SUB,,0,0,0,,花森さん　ホントに刑事なの？
Dialogue: 0,0:06:26.89,0:06:30.88,Japanese SUB,,0,0,0,,ほら　ちゃんと見て。
Dialogue: 0,0:06:30.88,0:06:35.89,Japanese SUB,,0,0,0,,実は　私　捜査一課第八強行犯捜査\N殺人捜査１３係ってとこに→
Dialogue: 0,0:06:35.89,0:06:37.90,Japanese SUB,,0,0,0,,所属してるの。
Dialogue: 0,0:06:37.90,0:06:39.87,Japanese SUB,,0,0,0,,シ～！
Dialogue: 0,0:06:39.87,0:06:43.96,Japanese SUB,,0,0,0,,えっ　１３係？\Nそうだよ。
Dialogue: 0,0:06:43.96,0:06:47.38,Japanese SUB,,0,0,0,,あ…　何人ぐらい　いるんですか？
Dialogue: 0,0:06:47.38,0:06:50.88,Japanese SUB,,0,0,0,,え～っと　私の他に→
Dialogue: 0,0:06:50.88,0:06:53.89,Japanese SUB,,0,0,0,,コマさん　シゲさん　ヤナさん→
Dialogue: 0,0:06:53.89,0:06:55.91,Japanese SUB,,0,0,0,,チャンコさん　キリさん\Nデューク…。
Dialogue: 0,0:06:55.91,0:06:58.91,Japanese SUB,,0,0,0,,あ？　誰か忘れてるな。
Dialogue: 0,0:06:58.91,0:07:01.89,Japanese SUB,,0,0,0,,あれを手配して\N賞味期限が切れちまうから…。
Dialogue: 0,0:07:01.89,0:07:04.45,Japanese SUB,,0,0,0,,お疲れさまです。\Nはい　お疲れさん。
Dialogue: 0,0:07:04.45,0:07:08.88,Japanese SUB,,0,0,0,,あぁ　ボスだ～！\Nボス？
Dialogue: 0,0:07:08.88,0:07:13.39,Japanese SUB,,0,0,0,,そう　門馬係長　現場　出ないから\N印象　薄いんだよね～。
Dialogue: 0,0:07:13.39,0:07:17.38,Japanese SUB,,0,0,0,,現場に出ないんだ。\N経理畑出身だからね。
Dialogue: 0,0:07:17.38,0:07:19.88,Japanese SUB,,0,0,0,,逮捕したりしないの？
Dialogue: 0,0:07:19.88,0:07:23.42,Japanese SUB,,0,0,0,,「俺は　一人も逮捕しないで\N捜査一課の係長になったんだ」→
Dialogue: 0,0:07:23.42,0:07:25.97,Japanese SUB,,0,0,0,,…っていうのが自慢でさ。
Dialogue: 0,0:07:25.97,0:07:29.89,Japanese SUB,,0,0,0,,ホントに　こういう格好　嫌いでさ\N今日もさ　朝からさ→
Dialogue: 0,0:07:29.89,0:07:34.39,Japanese SUB,,0,0,0,,ブツブツブツブツ…\Nうるさくてさ。
Dialogue: 0,0:07:34.39,0:07:40.40,Japanese SUB,,0,0,0,,さぁ　今日は　はんこデーだ\N押しまくりますよ～。
Dialogue: 0,0:07:40.40,0:07:42.37,Japanese SUB,,0,0,0,,はい　ポン！
Dialogue: 0,0:07:42.37,0:07:44.40,Japanese SUB,,0,0,0,,よっしゃ～。
Dialogue: 0,0:07:44.40,0:07:46.40,Japanese SUB,,0,0,0,,ポン！
Dialogue: 0,0:07:49.88,0:07:53.38,Japanese SUB,,0,0,0,,あっ　ストラップ　かわいい～！
Dialogue: 0,0:07:53.38,0:07:54.88,Japanese SUB,,0,0,0,,フフっ！
Dialogue: 0,0:07:54.88,0:07:57.88,Japanese SUB,,0,0,0,,あっ…　よし！
Dialogue: 0,0:07:57.88,0:08:00.37,Japanese SUB,,0,0,0,,「花森一子」？
Dialogue: 0,0:08:00.37,0:08:03.37,Japanese SUB,,0,0,0,,「いちこ」だよ　みんなからは\N「ワンコ」って呼ばれてんの。
Dialogue: 0,0:08:03.37,0:08:04.91,Japanese SUB,,0,0,0,,ふ～ん。
Dialogue: 0,0:08:04.91,0:08:07.96,Japanese SUB,,0,0,0,,ちえみちゃんだよね？\Nはい！
Dialogue: 0,0:08:07.96,0:08:10.88,Japanese SUB,,0,0,0,,帽子　ありがとうございました。\Nどういたしまして。
Dialogue: 0,0:08:10.88,0:08:13.38,Japanese SUB,,0,0,0,,じゃ　さよなら。\Nバイバイ。
Dialogue: 0,0:08:16.39,0:08:20.39,Japanese SUB,,0,0,0,,どっかで　嗅いだことのある\Nにおいだなぁ。
Dialogue: 0,0:08:20.39,0:08:22.39,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:08:24.88,0:08:26.88,Japanese SUB,,0,0,0,,はぁ…。
Dialogue: 0,0:08:28.96,0:08:31.40,Japanese SUB,,0,0,0,,（チャイム）
Dialogue: 0,0:08:31.40,0:08:32.90,Japanese SUB,,0,0,0,,私だ。
Dialogue: 0,0:08:32.90,0:08:34.87,Japanese SUB,,0,0,0,,（インターホン：門馬の妻）\Nおかえりなさい。
Dialogue: 0,0:08:34.87,0:08:37.87,Japanese SUB,,0,0,0,,（鍵が開く音）\N（門馬）　ただいま。
Dialogue: 0,0:08:41.89,0:08:43.88,Japanese SUB,,0,0,0,,ちえみ。
Dialogue: 0,0:08:43.88,0:08:45.91,Japanese SUB,,0,0,0,,勝手に開けないでよ！
Dialogue: 0,0:08:45.91,0:08:48.47,Japanese SUB,,0,0,0,,ノックしただろ。\N返事してない。
Dialogue: 0,0:08:48.47,0:08:50.90,Japanese SUB,,0,0,0,,どっかで\N聞いたことあるような言葉を…。
Dialogue: 0,0:08:50.90,0:08:53.40,Japanese SUB,,0,0,0,,また　そんな\Nフリフリの服　着てんのか。
Dialogue: 0,0:08:55.39,0:08:58.39,Japanese SUB,,0,0,0,,この帽子…。\Nやめてよ！
Dialogue: 0,0:09:00.88,0:09:03.38,Japanese SUB,,0,0,0,,どうして\Nパパが買ってあげた服を→
Dialogue: 0,0:09:03.38,0:09:05.42,Japanese SUB,,0,0,0,,着ないんだ？\Nやめてってば！
Dialogue: 0,0:09:05.42,0:09:08.99,Japanese SUB,,0,0,0,,何だ　このフリフリ　ダサい。\Nパパ　ホントに嫌い　勝手に開けないで！
Dialogue: 0,0:09:08.99,0:09:11.89,Japanese SUB,,0,0,0,,親が　どうして…。\N私は　パパのお人形じゃ　ない！
Dialogue: 0,0:09:11.89,0:09:13.88,Japanese SUB,,0,0,0,,ちえみ…。
Dialogue: 0,0:09:13.88,0:09:16.88,Japanese SUB,,0,0,0,,パパだって　何　その格好…\N臭い。
Dialogue: 0,0:09:16.88,0:09:19.40,Japanese SUB,,0,0,0,,臭い？
Dialogue: 0,0:09:19.40,0:09:23.90,Japanese SUB,,0,0,0,,臭い!?　何が臭い!?　どこが…。\Nどいて。
Dialogue: 0,0:09:23.90,0:09:26.42,Japanese SUB,,0,0,0,,塾なの！\Nちえみ！
Dialogue: 0,0:09:26.42,0:09:30.42,Japanese SUB,,0,0,0,,おい　ちえみ！\N待ちなさい　ちえみ！
Dialogue: 0,0:09:32.90,0:09:34.40,Japanese SUB,,0,0,0,,はぁ…。
Dialogue: 0,0:09:43.39,0:09:45.89,Japanese SUB,,0,0,0,,ボス　これじゃ　ダメですか？
Dialogue: 0,0:09:45.89,0:09:47.93,Japanese SUB,,0,0,0,,はぁ…　ダメだ。
Dialogue: 0,0:09:47.93,0:09:49.96,Japanese SUB,,0,0,0,,地味です　これ…。
Dialogue: 0,0:09:49.96,0:09:53.38,Japanese SUB,,0,0,0,,そういう問題じゃ　ない。\Nどういう問題ですか？
Dialogue: 0,0:09:53.38,0:09:56.39,Japanese SUB,,0,0,0,,（門馬）　お前と話してると\N頭が痛くなる　もう帰れ！
Dialogue: 0,0:09:56.39,0:09:58.87,Japanese SUB,,0,0,0,,それ　部下に向かって\Nいう言葉ですか!?
Dialogue: 0,0:09:58.87,0:10:00.89,Japanese SUB,,0,0,0,,もう　うるさい！
Dialogue: 0,0:10:00.89,0:10:04.39,Japanese SUB,,0,0,0,,（においを嗅ぐ音）\Nん？
Dialogue: 0,0:10:04.39,0:10:06.91,Japanese SUB,,0,0,0,,何だ？　何だ？　ん…？\N（においを嗅ぐ音）
Dialogue: 0,0:10:06.91,0:10:09.98,Japanese SUB,,0,0,0,,あっ　ちえみちゃん！
Dialogue: 0,0:10:09.98,0:10:12.89,Japanese SUB,,0,0,0,,あぁ！　帽子！
Dialogue: 0,0:10:12.89,0:10:15.37,Japanese SUB,,0,0,0,,お前だったのか！\Nボスだったんですか～。
Dialogue: 0,0:10:15.37,0:10:17.39,Japanese SUB,,0,0,0,,お前　会ったのか？\Nはい！
Dialogue: 0,0:10:17.39,0:10:19.88,Japanese SUB,,0,0,0,,お前…　お前　あぁ…。
Dialogue: 0,0:10:19.88,0:10:22.88,Japanese SUB,,0,0,0,,ボスだったのか～。
Dialogue: 0,0:10:22.88,0:10:25.88,Japanese SUB,,0,0,0,,娘には近づくな。\Nどうしてですか？
Dialogue: 0,0:10:25.88,0:10:27.92,Japanese SUB,,0,0,0,,分かるだろ！\N分かりません！
Dialogue: 0,0:10:27.92,0:10:30.47,Japanese SUB,,0,0,0,,あのな！\N（重村）　あっ　あぁ　そうだ→
Dialogue: 0,0:10:30.47,0:10:33.89,Japanese SUB,,0,0,0,,ちょっと　出かけて来ます。\Nおい　シゲ　行くな！
Dialogue: 0,0:10:33.89,0:10:37.38,Japanese SUB,,0,0,0,,２人にするな。\Nはい。
Dialogue: 0,0:10:37.38,0:10:40.88,Japanese SUB,,0,0,0,,えぇ？　シゲさん\N「はい」って　それは…。
Dialogue: 0,0:10:40.88,0:10:44.38,Japanese SUB,,0,0,0,,あれ？\Nみんなは　どうしたんですか？
Dialogue: 0,0:10:44.38,0:10:46.89,Japanese SUB,,0,0,0,,事件ですか？\N現場は　どこですか!?
Dialogue: 0,0:10:46.89,0:10:49.42,Japanese SUB,,0,0,0,,お前は　いいから。\N教えてください！
Dialogue: 0,0:10:49.42,0:10:52.37,Japanese SUB,,0,0,0,,お前は　犯人よりも　服を探せ！
Dialogue: 0,0:10:52.37,0:10:54.89,Japanese SUB,,0,0,0,,シゲ　行こう。\Nどこにですか？
Dialogue: 0,0:10:54.89,0:10:56.39,Japanese SUB,,0,0,0,,え？
Dialogue: 0,0:10:58.40,0:11:00.88,Japanese SUB,,0,0,0,,行こう　うん　うん…　行こう　早く。
Dialogue: 0,0:11:00.88,0:11:03.88,Japanese SUB,,0,0,0,,ボス！　シゲさん！
Dialogue: 0,0:11:09.44,0:11:11.48,Japanese SUB,,0,0,0,,（刑事）　≪警部補≫\Nおう。
Dialogue: 0,0:11:11.48,0:11:12.90,Japanese SUB,,0,0,0,,どうも。
Dialogue: 0,0:11:12.90,0:11:15.38,Japanese SUB,,0,0,0,,（刑事）　免許証から\N被害者の身元が分かりました。
Dialogue: 0,0:11:15.38,0:11:19.89,Japanese SUB,,0,0,0,,東京渋谷銀行センター街支店の\N工藤淳一さんです。
Dialogue: 0,0:11:19.89,0:11:22.37,Japanese SUB,,0,0,0,,凶器は　この…。\Nうん　何だ？
Dialogue: 0,0:11:22.37,0:11:25.87,Japanese SUB,,0,0,0,,何つうんすか？　この…\Nコンクリート製の　このやつで→
Dialogue: 0,0:11:25.87,0:11:27.93,Japanese SUB,,0,0,0,,後頭部を一撃ですね。
Dialogue: 0,0:11:27.93,0:11:29.44,Japanese SUB,,0,0,0,,よし。
Dialogue: 0,0:11:29.44,0:11:33.38,Japanese SUB,,0,0,0,,おい　ワンコ！　におい嗅げ！\Nコマさん　ワンコ　いません。
Dialogue: 0,0:11:33.38,0:11:34.88,Japanese SUB,,0,0,0,,そうか　困ったな…。
Dialogue: 0,0:11:34.88,0:11:37.38,Japanese SUB,,0,0,0,,よ～し　付近捜索！\N（一同）　うい！
Dialogue: 0,0:11:39.39,0:11:42.89,Japanese SUB,,0,0,0,,（田村）　ミハイルを忘れてませんか？\Nあぁ　そうか。
Dialogue: 0,0:11:42.89,0:11:45.38,Japanese SUB,,0,0,0,,コマさん\Nそれは　ないんじゃないですか？
Dialogue: 0,0:11:45.38,0:11:47.90,Japanese SUB,,0,0,0,,最近　ミハイルを\Nないがしろに　し過ぎです！
Dialogue: 0,0:11:47.90,0:11:50.45,Japanese SUB,,0,0,0,,ハハ　申し訳ない。\Nあっ　ちょっと→
Dialogue: 0,0:11:50.45,0:11:53.39,Japanese SUB,,0,0,0,,（田村）　和田さん　お願いします。\Nあっ　はい。
Dialogue: 0,0:11:53.39,0:11:56.39,Japanese SUB,,0,0,0,,コマさん　コマさん！\Nミハイルが　どれだけ→
Dialogue: 0,0:11:56.39,0:11:58.87,Japanese SUB,,0,0,0,,事件解決に貢献してるか\Nご存じでしょう？
Dialogue: 0,0:11:58.87,0:12:01.88,Japanese SUB,,0,0,0,,はいはい　すいません。\N「はいはい」って→
Dialogue: 0,0:12:01.88,0:12:04.38,Japanese SUB,,0,0,0,,そういう返事の仕方\Nないでしょう？
Dialogue: 0,0:12:04.38,0:12:08.43,Japanese SUB,,0,0,0,,ミハイルが　連日出動してるの…\N疲れてるんですよ。
Dialogue: 0,0:12:08.43,0:12:11.49,Japanese SUB,,0,0,0,,（ミハイルの吠え声）\Nでも１３係のヤマだっていうし…。
Dialogue: 0,0:12:11.49,0:12:13.37,Japanese SUB,,0,0,0,,（和田）　ミハイルが…！\Nあっ　ちょっ　ちょっと！
Dialogue: 0,0:12:13.37,0:12:15.37,Japanese SUB,,0,0,0,,おう　キリ　行くぞ～。\Nはい。
Dialogue: 0,0:12:15.37,0:12:19.88,Japanese SUB,,0,0,0,,[TEL]（着信音）
Dialogue: 0,0:12:19.88,0:12:21.38,Japanese SUB,,0,0,0,,チッ。
Dialogue: 0,0:12:21.38,0:12:22.88,Japanese SUB,,0,0,0,,もしもし？
Dialogue: 0,0:12:22.88,0:12:25.88,Japanese SUB,,0,0,0,,キリさん\Nちょっと待ってくださいね。
Dialogue: 0,0:12:25.88,0:12:28.40,Japanese SUB,,0,0,0,,ほっ　ほっ。
Dialogue: 0,0:12:28.40,0:12:31.97,Japanese SUB,,0,0,0,,キリさん　現場は　どこですか？
Dialogue: 0,0:12:31.97,0:12:34.38,Japanese SUB,,0,0,0,,コマさん\Nワンコが来たがってます。
Dialogue: 0,0:12:34.38,0:12:35.88,Japanese SUB,,0,0,0,,ハウスだ。
Dialogue: 0,0:12:35.88,0:12:38.88,Japanese SUB,,0,0,0,,…っつうことで　お疲れ。
Dialogue: 0,0:12:45.89,0:12:48.39,Japanese SUB,,0,0,0,,コマさ～ん。\Nあぁ？
Dialogue: 0,0:12:50.93,0:12:52.98,Japanese SUB,,0,0,0,,何だ？
Dialogue: 0,0:12:52.98,0:12:54.90,Japanese SUB,,0,0,0,,こんなものが。
Dialogue: 0,0:12:54.90,0:12:57.40,Japanese SUB,,0,0,0,,ケータイストラップか。\Nですね。
Dialogue: 0,0:13:00.89,0:13:03.89,Japanese SUB,,0,0,0,,（署長）\N≪続いて　本庁　和田巡査部長≫
Dialogue: 0,0:13:03.89,0:13:05.87,Japanese SUB,,0,0,0,,（和田）　はい。
Dialogue: 0,0:13:05.87,0:13:08.91,Japanese SUB,,0,0,0,,ミハイルの\N追跡結果を報告します。
Dialogue: 0,0:13:08.91,0:13:10.95,Japanese SUB,,0,0,0,,ミハイルに　凶器と思われる→
Dialogue: 0,0:13:10.95,0:13:13.88,Japanese SUB,,0,0,0,,コンクリート製のブロックの\Nにおいを嗅がせたところ→
Dialogue: 0,0:13:13.88,0:13:16.88,Japanese SUB,,0,0,0,,ある建物に　たどり着きました。
Dialogue: 0,0:13:20.87,0:13:24.91,Japanese SUB,,0,0,0,,((ここですね))\N((何だ？　ここは))
Dialogue: 0,0:13:24.91,0:13:26.96,Japanese SUB,,0,0,0,,((「サロン・ド・ヤマテ」))
Dialogue: 0,0:13:26.96,0:13:29.90,Japanese SUB,,0,0,0,,((レストランや　バー\Nイベント会場などがあります))
Dialogue: 0,0:13:29.90,0:13:32.90,Japanese SUB,,0,0,0,,((デューク　行け))\N((はい))
Dialogue: 0,0:13:34.40,0:13:37.87,Japanese SUB,,0,0,0,,（和田の声）　店には　不特定多数の\N人間が出入りしており→
Dialogue: 0,0:13:37.87,0:13:40.94,Japanese SUB,,0,0,0,,それ以上の捜索は\Nできませんでした　以上です。
Dialogue: 0,0:13:40.94,0:13:43.88,Japanese SUB,,0,0,0,,マジっすか？\N遺留品のケータイストラップ→
Dialogue: 0,0:13:43.88,0:13:46.40,Japanese SUB,,0,0,0,,その『サロン・ド・ヤマテ』が\N発注して作らせたもんで→
Dialogue: 0,0:13:46.40,0:13:48.38,Japanese SUB,,0,0,0,,限定１００個です。
Dialogue: 0,0:13:48.38,0:13:52.87,Japanese SUB,,0,0,0,,イニシャル「Ｃ．Ｍ」か…。\N「Ｍ」が名字だとすると…。
Dialogue: 0,0:13:52.87,0:13:57.41,Japanese SUB,,0,0,0,,マツダ　マツイ　ミカミ　ムトウ→
Dialogue: 0,0:13:57.41,0:13:59.96,Japanese SUB,,0,0,0,,モリタ…　たくさんいるな。
Dialogue: 0,0:13:59.96,0:14:02.38,Japanese SUB,,0,0,0,,「Ｃ」だと　「チ」しかないですね。
Dialogue: 0,0:14:02.38,0:14:05.38,Japanese SUB,,0,0,0,,チアキ　チヒロ　チサト　チカコ→
Dialogue: 0,0:14:05.38,0:14:07.87,Japanese SUB,,0,0,0,,チハル…。\N女の名前ばっかりだな　お前。
Dialogue: 0,0:14:07.87,0:14:09.37,Japanese SUB,,0,0,0,,男だと…。
Dialogue: 0,0:14:09.37,0:14:11.39,Japanese SUB,,0,0,0,,忠太郎！\Nあぁ？
Dialogue: 0,0:14:11.39,0:14:15.38,Japanese SUB,,0,0,0,,知りませんか？　『番場の忠太郎』。
Dialogue: 0,0:14:15.38,0:14:17.41,Japanese SUB,,0,0,0,,『瞼の母』。
Dialogue: 0,0:14:17.41,0:14:19.46,Japanese SUB,,0,0,0,,『番場の忠太郎』？\N『瞼の母』？
Dialogue: 0,0:14:19.46,0:14:22.40,Japanese SUB,,0,0,0,,帰国子女のお前が　何で知ってる？
Dialogue: 0,0:14:22.40,0:14:25.40,Japanese SUB,,0,0,0,,「おいら　淋しくなったら→
Dialogue: 0,0:14:25.40,0:14:28.40,Japanese SUB,,0,0,0,,上の瞼と　下の瞼を　あわせやす」。
Dialogue: 0,0:14:30.38,0:14:33.90,Japanese SUB,,0,0,0,,「お袋さんに逢いたくなったら→
Dialogue: 0,0:14:33.90,0:14:36.92,Japanese SUB,,0,0,0,,逢いたくなったら　おいら→
Dialogue: 0,0:14:36.92,0:14:41.90,Japanese SUB,,0,0,0,,瞼をとじ合わせ　じっと眼を\Nつむりやす。
Dialogue: 0,0:14:41.90,0:14:44.89,Japanese SUB,,0,0,0,,マミー！
Dialogue: 0,0:14:44.89,0:14:47.39,Japanese SUB,,0,0,0,,忠太郎って呼んでくだせぇ！
Dialogue: 0,0:14:47.39,0:14:49.88,Japanese SUB,,0,0,0,,忠太郎って呼んでくだせぇ」。
Dialogue: 0,0:14:49.88,0:14:52.40,Japanese SUB,,0,0,0,,誰か止めろ。\N（柳）　シャット　アップ。
Dialogue: 0,0:14:52.40,0:14:54.88,Japanese SUB,,0,0,0,,シャット　アップ　デューク。\Nいつ覚えた？　そんなこと…。
Dialogue: 0,0:14:54.88,0:14:57.95,Japanese SUB,,0,0,0,,（ドアが開く音）\N目撃者がいました！
Dialogue: 0,0:14:57.95,0:15:00.89,Japanese SUB,,0,0,0,,近所の寿司屋の店員が\N公園から走り去る人物を→
Dialogue: 0,0:15:00.89,0:15:02.87,Japanese SUB,,0,0,0,,目撃しています。\N人相は？
Dialogue: 0,0:15:02.87,0:15:05.86,Japanese SUB,,0,0,0,,走っている車から\N後ろ姿を見たので→
Dialogue: 0,0:15:05.86,0:15:08.86,Japanese SUB,,0,0,0,,人相は分からないとのこと\Nただ→
Dialogue: 0,0:15:08.86,0:15:12.38,Japanese SUB,,0,0,0,,女性だったそうです。\N何？
Dialogue: 0,0:15:12.38,0:15:17.46,Japanese SUB,,0,0,0,,それも　いわゆる　ゴシック＆ロリータ\Nゴスロリです。
Dialogue: 0,0:15:17.46,0:15:19.37,Japanese SUB,,0,0,0,,ゴスロリか…。\Nはい。
Dialogue: 0,0:15:19.37,0:15:21.38,Japanese SUB,,0,0,0,,ワンコが着ている　あれです。
Dialogue: 0,0:15:21.38,0:15:25.36,Japanese SUB,,0,0,0,,ワンコが着ている　あれか…。
Dialogue: 0,0:15:25.36,0:15:28.88,Japanese SUB,,0,0,0,,（署長）　本庁さん　さっきから\N話に　ついて行けないんだが→
Dialogue: 0,0:15:28.88,0:15:31.37,Japanese SUB,,0,0,0,,「ワンコ」とは？\N署長　ちょっと黙っててください。
Dialogue: 0,0:15:31.37,0:15:33.39,Japanese SUB,,0,0,0,,それで？\Nなぁ　デューク→
Dialogue: 0,0:15:33.39,0:15:35.92,Japanese SUB,,0,0,0,,ワンコみたいなのが\Nたくさん　いたんだろ？
Dialogue: 0,0:15:35.92,0:15:37.42,Japanese SUB,,0,0,0,,Ｙｅｓ．
Dialogue: 0,0:15:43.88,0:15:45.88,Japanese SUB,,0,0,0,,((ワ～オ…))
Dialogue: 0,0:15:50.87,0:15:52.87,Japanese SUB,,0,0,0,,お茶会　なう。
Dialogue: 0,0:15:52.87,0:15:54.93,Japanese SUB,,0,0,0,,（一同）　「お茶会　なう」。\NＹｅｓ．
Dialogue: 0,0:15:54.93,0:15:57.48,Japanese SUB,,0,0,0,,お前　今回　よく喋ってんな。\Nだな。
Dialogue: 0,0:15:57.48,0:15:59.87,Japanese SUB,,0,0,0,,どうも。\N「お茶会　なう」とは？
Dialogue: 0,0:15:59.87,0:16:02.87,Japanese SUB,,0,0,0,,ミハイルの　におい追跡\N遺留品　目撃情報→
Dialogue: 0,0:16:02.87,0:16:05.39,Japanese SUB,,0,0,0,,全てが　『サロン・ド・ヤマテ』に\Nつながってるな。
Dialogue: 0,0:16:05.39,0:16:08.39,Japanese SUB,,0,0,0,,重点的に調べるぞ\N従来の地取り捜査も続けてくれ。
Dialogue: 0,0:16:08.39,0:16:10.39,Japanese SUB,,0,0,0,,（一同）　はい！
Dialogue: 0,0:16:15.41,0:16:17.97,Japanese SUB,,0,0,0,,（重村）　あ…。
Dialogue: 0,0:16:17.97,0:16:20.97,Japanese SUB,,0,0,0,,所轄の皆さんも\Nよろしくお願いします。
Dialogue: 0,0:16:22.37,0:16:24.87,Japanese SUB,,0,0,0,,（釣り鐘の音）
Dialogue: 0,0:16:26.39,0:16:28.88,Japanese SUB,,0,0,0,,マグロ…。
Dialogue: 0,0:16:28.88,0:16:31.88,Japanese SUB,,0,0,0,,これだ　私。\N（山田彦左衛門）　あ…？
Dialogue: 0,0:16:31.88,0:16:35.87,Japanese SUB,,0,0,0,,ねぇ　おじいちゃん　マグロって\N泳いでないと死んじゃうでしょ？
Dialogue: 0,0:16:35.87,0:16:38.42,Japanese SUB,,0,0,0,,（山田）　それは　サメだよ\Nなぁ？　ばあさん。
Dialogue: 0,0:16:38.42,0:16:40.97,Japanese SUB,,0,0,0,,（山田小梅）　それ　イルカでしょ。\N（山田）　あっ　カマスか。
Dialogue: 0,0:16:40.97,0:16:43.38,Japanese SUB,,0,0,0,,はぁ…。
Dialogue: 0,0:16:43.38,0:16:47.40,Japanese SUB,,0,0,0,,一子ちゃん　どうしたんだい\N彼氏にでもフラれたのかい？
Dialogue: 0,0:16:47.40,0:16:49.38,Japanese SUB,,0,0,0,,違うよ。
Dialogue: 0,0:16:49.38,0:16:51.90,Japanese SUB,,0,0,0,,一子ちゃんの彼は\Nパトラッシュだもんね～。
Dialogue: 0,0:16:51.90,0:16:53.87,Japanese SUB,,0,0,0,,パトラッシュは犬！
Dialogue: 0,0:16:53.87,0:16:56.39,Japanese SUB,,0,0,0,,さっ\N『スッキリ!!』でも見よ～っと。
Dialogue: 0,0:16:56.39,0:17:00.96,Japanese SUB,,0,0,0,,[TV]　殺害されたのは　東京渋谷銀行\Nセンター街支店に勤務する→
Dialogue: 0,0:17:00.96,0:17:02.88,Japanese SUB,,0,0,0,,工藤淳一さん　４１歳で…。
Dialogue: 0,0:17:02.88,0:17:05.38,Japanese SUB,,0,0,0,,((何いってんだよ))
Dialogue: 0,0:17:06.90,0:17:08.90,Japanese SUB,,0,0,0,,あの人…。
Dialogue: 0,0:17:10.89,0:17:13.41,Japanese SUB,,0,0,0,,ちょっと出て来る！
Dialogue: 0,0:17:13.41,0:17:16.41,Japanese SUB,,0,0,0,,一子の彼氏　あれかい？\N（小梅）　あれ？
Dialogue: 0,0:17:43.36,0:17:45.36,Japanese SUB,,0,0,0,,（主任）　え～っと…。
Dialogue: 0,0:17:46.89,0:17:48.94,Japanese SUB,,0,0,0,,君　合格。
Dialogue: 0,0:17:48.94,0:17:51.85,Japanese SUB,,0,0,0,,（主任）　あんた　不合格　以上。
Dialogue: 0,0:17:51.85,0:17:56.35,Japanese SUB,,0,0,0,,てめぇ　どこ見て選んでんだ…!!\Nヤナさん！　ヤナさん　ヤナさん…。
Dialogue: 0,0:17:56.35,0:17:59.85,Japanese SUB,,0,0,0,,ヤナさん　ちょっと…。\Nふざけやがって　この野郎。
Dialogue: 0,0:17:59.85,0:18:03.86,Japanese SUB,,0,0,0,,ヤナさん！　募集要項に\N「イケメンに限る」って。
Dialogue: 0,0:18:03.86,0:18:05.86,Japanese SUB,,0,0,0,,しょうがないっすよ。
Dialogue: 0,0:18:17.36,0:18:19.36,Japanese SUB,,0,0,0,,やっぱり顔か。
Dialogue: 0,0:18:19.36,0:18:21.86,Japanese SUB,,0,0,0,,ブフフ…。
Dialogue: 0,0:18:24.85,0:18:27.85,Japanese SUB,,0,0,0,,（戸田）　≪桐島君≫
Dialogue: 0,0:18:27.85,0:18:29.87,Japanese SUB,,0,0,0,,はい。
Dialogue: 0,0:18:29.87,0:18:32.92,Japanese SUB,,0,0,0,,（戸田）　桐島君　接客業の経験は？
Dialogue: 0,0:18:32.92,0:18:35.86,Japanese SUB,,0,0,0,,カラオケボックス　居酒屋\N焼き鳥屋で少々。
Dialogue: 0,0:18:35.86,0:18:38.36,Japanese SUB,,0,0,0,,常連の皆さんが集まってるから\N紹介します。
Dialogue: 0,0:18:38.36,0:18:39.86,Japanese SUB,,0,0,0,,はい。
Dialogue: 0,0:18:39.86,0:18:44.35,Japanese SUB,,0,0,0,,あ　あ　マイクチェック　ワンツー　ワンツー\N聞こえてますか？　マイクチェック…。
Dialogue: 0,0:18:44.35,0:18:46.37,Japanese SUB,,0,0,0,,うるせぇ　聞こえてんだよ　バ～カ。
Dialogue: 0,0:18:46.37,0:19:03.85,Japanese SUB,,0,0,0,,♪～
Dialogue: 0,0:19:03.85,0:19:08.86,Japanese SUB,,0,0,0,,皆さん　今日からスタッフに\N加わりました　桐島です。
Dialogue: 0,0:19:08.86,0:19:10.88,Japanese SUB,,0,0,0,,よ…　よろしくお願いします。
Dialogue: 0,0:19:10.88,0:19:13.36,Japanese SUB,,0,0,0,,よろしくお願いしま～す。
Dialogue: 0,0:19:13.36,0:19:16.40,Japanese SUB,,0,0,0,,よろしくね～。\Nこちらこそ　よろしくね～。
Dialogue: 0,0:19:16.40,0:19:19.97,Japanese SUB,,0,0,0,,それじゃあ　挨拶代わりに何か。
Dialogue: 0,0:19:19.97,0:19:22.37,Japanese SUB,,0,0,0,,はい？　何を…。
Dialogue: 0,0:19:22.37,0:19:24.37,Japanese SUB,,0,0,0,,ダンスとか　いろいろ？
Dialogue: 0,0:19:26.36,0:19:27.86,Japanese SUB,,0,0,0,,はい。
Dialogue: 0,0:19:31.36,0:19:32.86,Japanese SUB,,0,0,0,,（指を鳴らす音）
Dialogue: 0,0:19:32.86,0:19:35.87,Japanese SUB,,0,0,0,,整いました。
Dialogue: 0,0:19:35.87,0:19:40.46,Japanese SUB,,0,0,0,,お茶会とかけまして\N学校の避難訓練と解きます。
Dialogue: 0,0:19:40.46,0:19:42.37,Japanese SUB,,0,0,0,,おっ　その心は？
Dialogue: 0,0:19:42.37,0:19:45.86,Japanese SUB,,0,0,0,,どちらも　オカシが大切です。
Dialogue: 0,0:19:45.86,0:19:49.36,Japanese SUB,,0,0,0,,（一同）　すご～い！\N（拍手）
Dialogue: 0,0:19:49.36,0:19:53.35,Japanese SUB,,0,0,0,,フフ…\Nうまいこと　いうじゃないかよ。
Dialogue: 0,0:19:53.35,0:19:55.37,Japanese SUB,,0,0,0,,どういう意味だ？
Dialogue: 0,0:19:55.37,0:19:57.92,Japanese SUB,,0,0,0,,「押さない　駆けない\N喋らない」ですね。
Dialogue: 0,0:19:57.92,0:19:59.92,Japanese SUB,,0,0,0,,整ってんのか？
Dialogue: 0,0:20:02.36,0:20:04.36,Japanese SUB,,0,0,0,,いいね。\Nはい。
Dialogue: 0,0:20:04.36,0:20:06.38,Japanese SUB,,0,0,0,,踊って。
Dialogue: 0,0:20:06.38,0:20:08.38,Japanese SUB,,0,0,0,,はい。
Dialogue: 0,0:20:16.37,0:20:17.89,Japanese SUB,,0,0,0,,ご苦労さまです。
Dialogue: 0,0:20:17.89,0:20:30.86,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:20:30.86,0:20:32.86,Japanese SUB,,0,0,0,,何ですか？　あなたは。
Dialogue: 0,0:20:34.36,0:20:38.86,Japanese SUB,,0,0,0,,ボス…\N捜査一課の門馬係長はいますか？
Dialogue: 0,0:20:38.86,0:20:41.86,Japanese SUB,,0,0,0,,いらっしゃってませんが\Nおたくは？
Dialogue: 0,0:20:44.92,0:20:48.37,Japanese SUB,,0,0,0,,この辺を見ていただければ\N一緒です。
Dialogue: 0,0:20:48.37,0:20:50.88,Japanese SUB,,0,0,0,,（刑事）　あ…　ご苦労さまです。
Dialogue: 0,0:20:50.88,0:20:59.38,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:21:00.85,0:21:03.40,Japanese SUB,,0,0,0,,あっ　ウソ…。
Dialogue: 0,0:21:03.40,0:21:09.38,Japanese SUB,,0,0,0,,[TEL]♪～　『太陽にほえろ！メインテーマ』
Dialogue: 0,0:21:09.38,0:21:10.88,Japanese SUB,,0,0,0,,あっ…。\N[TEL]♪～　『太陽にほえろ！メインテーマ』
Dialogue: 0,0:21:10.88,0:21:13.88,Japanese SUB,,0,0,0,,[TEL]♪～　『太陽にほえろ！メインテーマ』
Dialogue: 0,0:21:13.88,0:21:15.87,Japanese SUB,,0,0,0,,もしもし？
Dialogue: 0,0:21:15.87,0:21:20.37,Japanese SUB,,0,0,0,,ちえみちゃん？\Nうん…　うんうん…。
Dialogue: 0,0:21:21.37,0:21:22.91,Japanese SUB,,0,0,0,,（ちえみ）　≪どうぞ≫
Dialogue: 0,0:21:22.91,0:21:26.36,Japanese SUB,,0,0,0,,あっ　奥さん　お構いなく～。
Dialogue: 0,0:21:26.36,0:21:31.08,Japanese SUB,,0,0,0,,そっかぁ　私がパパの娘だって\N分かったんだ。
Dialogue: 0,0:21:31.08,0:21:32.40,Japanese SUB,,0,0,0,,においで。
Dialogue: 0,0:21:32.40,0:21:38.37,Japanese SUB,,0,0,0,,私が「ワンコ」って呼ばれてるのは\Nちょいとばかし　鼻が利くんでね。
Dialogue: 0,0:21:38.37,0:21:41.38,Japanese SUB,,0,0,0,,えっ　パパと一緒の　におい？\Nそうでやんす。
Dialogue: 0,0:21:41.38,0:21:43.34,Japanese SUB,,0,0,0,,えぇ～　ショックなんですけど。
Dialogue: 0,0:21:43.34,0:21:46.35,Japanese SUB,,0,0,0,,あっ　変な　においじゃ　ないよ？\Nカレーのにおい。
Dialogue: 0,0:21:46.35,0:21:49.35,Japanese SUB,,0,0,0,,あぁ　ウチ　みんな\Nカレー好きだから。
Dialogue: 0,0:21:49.35,0:21:51.35,Japanese SUB,,0,0,0,,私も好き。
Dialogue: 0,0:21:51.35,0:21:54.92,Japanese SUB,,0,0,0,,それより　電話くれたの\Nケータイストラップのことだよね？
Dialogue: 0,0:21:54.92,0:21:56.42,Japanese SUB,,0,0,0,,うん。
Dialogue: 0,0:21:59.38,0:22:03.87,Japanese SUB,,0,0,0,,イニシャルの　「Ｃ．Ｍ」\NＣｈｉｅｍｉ　Ｍｏｎｍａ。
Dialogue: 0,0:22:03.87,0:22:06.87,Japanese SUB,,0,0,0,,あっ…\Nでも　殺人事件には関係ないよ。
Dialogue: 0,0:22:06.87,0:22:09.35,Japanese SUB,,0,0,0,,私　落としただけだから。
Dialogue: 0,0:22:09.35,0:22:11.86,Japanese SUB,,0,0,0,,「落としただけ」って→
Dialogue: 0,0:22:11.86,0:22:14.91,Japanese SUB,,0,0,0,,みんな犯人のものだと思って\N大騒ぎなんだよ？
Dialogue: 0,0:22:14.91,0:22:16.44,Japanese SUB,,0,0,0,,そうなの？
Dialogue: 0,0:22:16.44,0:22:17.85,Japanese SUB,,0,0,0,,うん。
Dialogue: 0,0:22:17.85,0:22:20.85,Japanese SUB,,0,0,0,,一昨日の夜　何があったの？
Dialogue: 0,0:22:23.85,0:22:29.86,Japanese SUB,,0,0,0,,（ちえみの声）　塾の帰り\N割り込み男に偶然　会ったの。
Dialogue: 0,0:22:29.86,0:22:32.38,Japanese SUB,,0,0,0,,しつこく追われて…。
Dialogue: 0,0:22:32.38,0:22:35.43,Japanese SUB,,0,0,0,,（工藤）((おい！　待て　おい！))
Dialogue: 0,0:22:35.43,0:22:37.35,Japanese SUB,,0,0,0,,((はっ　離して…！))\N((何やってんだよ！))
Dialogue: 0,0:22:37.35,0:22:39.37,Japanese SUB,,0,0,0,,（ちえみ）((離してって…！))
Dialogue: 0,0:22:39.37,0:22:41.37,Japanese SUB,,0,0,0,,それで？
Dialogue: 0,0:22:41.37,0:22:45.36,Japanese SUB,,0,0,0,,振り切って逃げた後　叫び声が…。
Dialogue: 0,0:22:45.36,0:22:46.86,Japanese SUB,,0,0,0,,（工藤）((うわっ！))
Dialogue: 0,0:22:51.96,0:22:54.87,Japanese SUB,,0,0,0,,（ちえみの声）\N女の人が走ってくのが見えた。
Dialogue: 0,0:22:54.87,0:22:57.37,Japanese SUB,,0,0,0,,女の人…。
Dialogue: 0,0:22:57.37,0:23:00.36,Japanese SUB,,0,0,0,,うん　暗くて\Nよく見えなかったけど→
Dialogue: 0,0:23:00.36,0:23:02.86,Japanese SUB,,0,0,0,,私達と同じような格好してた。
Dialogue: 0,0:23:04.86,0:23:07.36,Japanese SUB,,0,0,0,,分かった　ありがとう。
Dialogue: 0,0:23:07.36,0:23:11.95,Japanese SUB,,0,0,0,,え？　信用してくれるの？\Nもちろん。
Dialogue: 0,0:23:11.95,0:23:14.85,Japanese SUB,,0,0,0,,パパは絶対　信用してくれない。
Dialogue: 0,0:23:14.85,0:23:18.36,Japanese SUB,,0,0,0,,だから　ボスに話さなかったの？
Dialogue: 0,0:23:18.36,0:23:19.86,Japanese SUB,,0,0,0,,うん。
Dialogue: 0,0:23:21.36,0:23:25.35,Japanese SUB,,0,0,0,,口うるさくて　頭ごなしに\N自分の価値観　押しつけるし。
Dialogue: 0,0:23:25.35,0:23:28.87,Japanese SUB,,0,0,0,,私が欲しくもない洋服　買って来て\N着ろって。
Dialogue: 0,0:23:28.87,0:23:30.87,Japanese SUB,,0,0,0,,これよ？　これ。
Dialogue: 0,0:23:32.94,0:23:35.86,Japanese SUB,,0,0,0,,確かに　地味～。
Dialogue: 0,0:23:35.86,0:23:38.86,Japanese SUB,,0,0,0,,それに　パパ\N現場の人じゃないんでしょ？
Dialogue: 0,0:23:38.86,0:23:41.38,Japanese SUB,,0,0,0,,いっても　しょうがないでしょ？
Dialogue: 0,0:23:41.38,0:23:47.37,Japanese SUB,,0,0,0,,そうか…\N「現場の人じゃ　ない」か…。
Dialogue: 0,0:23:47.37,0:23:49.37,Japanese SUB,,0,0,0,,う～ん…。
Dialogue: 0,0:23:54.46,0:23:55.96,Japanese SUB,,0,0,0,,はぁ…。
Dialogue: 0,0:24:00.88,0:24:03.37,Japanese SUB,,0,0,0,,よし。
Dialogue: 0,0:24:03.37,0:24:06.37,Japanese SUB,,0,0,0,,（においを嗅ぐ音）\N来てる　来てる　来てる…！
Dialogue: 0,0:24:06.37,0:24:08.37,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:24:08.37,0:24:10.36,Japanese SUB,,0,0,0,,確かに。
Dialogue: 0,0:24:10.36,0:24:15.40,Japanese SUB,,0,0,0,,（においを嗅ぐ音）\Nなるほど…　なるほど　なるほど。
Dialogue: 0,0:24:15.40,0:24:17.95,Japanese SUB,,0,0,0,,なるほど。
Dialogue: 0,0:24:17.95,0:24:19.95,Japanese SUB,,0,0,0,,分かった。
Dialogue: 0,0:24:21.64,0:24:24.36,Japanese SUB,,0,0,0,,ただいま～。\N（アリサ）　あぁ　おかえり～。
Dialogue: 0,0:24:24.36,0:24:25.86,Japanese SUB,,0,0,0,,ただいま～。\N（山田）　おかえり～。
Dialogue: 0,0:24:25.86,0:24:29.85,Japanese SUB,,0,0,0,,一子ちゃん　お客様。
Dialogue: 0,0:24:29.85,0:24:32.35,Japanese SUB,,0,0,0,,あっ！　ボス…。
Dialogue: 0,0:24:34.35,0:24:37.39,Japanese SUB,,0,0,0,,これ　使います？\Nああ。
Dialogue: 0,0:24:37.39,0:24:39.92,Japanese SUB,,0,0,0,,ボス　どうしたんですか？
Dialogue: 0,0:24:39.92,0:24:43.34,Japanese SUB,,0,0,0,,ん？　あぁ　うん…　ほれ。
Dialogue: 0,0:24:43.34,0:24:45.85,Japanese SUB,,0,0,0,,私に？\Nあぁ。
Dialogue: 0,0:24:45.85,0:24:48.85,Japanese SUB,,0,0,0,,明日から着て来い。\Nえぇ～！
Dialogue: 0,0:24:50.33,0:24:52.87,Japanese SUB,,0,0,0,,マジっすか？\Nうん。
Dialogue: 0,0:24:52.87,0:24:56.34,Japanese SUB,,0,0,0,,ちえみちゃんの気持\Nよく分かります。
Dialogue: 0,0:24:56.34,0:24:58.38,Japanese SUB,,0,0,0,,お前　また　ちえみと\N会ってるんじゃないだろうな？
Dialogue: 0,0:24:58.38,0:25:00.43,Japanese SUB,,0,0,0,,会いました　お家で。
Dialogue: 0,0:25:00.43,0:25:02.35,Japanese SUB,,0,0,0,,家に来たのか？
Dialogue: 0,0:25:02.35,0:25:05.85,Japanese SUB,,0,0,0,,素敵な奥さんで。\Nカミさんにも会ったのか。
Dialogue: 0,0:25:05.85,0:25:08.85,Japanese SUB,,0,0,0,,いらん\Nお前達　どうして　そうやって…。
Dialogue: 0,0:25:08.85,0:25:11.34,Japanese SUB,,0,0,0,,まぁまぁ　ボス　座ってください。
Dialogue: 0,0:25:11.34,0:25:12.84,Japanese SUB,,0,0,0,,座ってるよ。
Dialogue: 0,0:25:12.84,0:25:15.88,Japanese SUB,,0,0,0,,一子ちゃん\Nもんじゃは　食べるかい？
Dialogue: 0,0:25:15.88,0:25:18.93,Japanese SUB,,0,0,0,,あ～　お腹ペコペコ！\Nボスも食べますよね？
Dialogue: 0,0:25:18.93,0:25:20.85,Japanese SUB,,0,0,0,,いや　お構いなく。
Dialogue: 0,0:25:20.85,0:25:23.35,Japanese SUB,,0,0,0,,今すぐ用意します。
Dialogue: 0,0:25:23.35,0:25:25.35,Japanese SUB,,0,0,0,,さてと…。
Dialogue: 0,0:25:25.35,0:25:28.36,Japanese SUB,,0,0,0,,あぁ　なぁ　ワンコ。
Dialogue: 0,0:25:28.36,0:25:32.86,Japanese SUB,,0,0,0,,どう　ちえみの気持が分かるんだ？
Dialogue: 0,0:25:32.86,0:25:36.90,Japanese SUB,,0,0,0,,自分の価値観を否定されるのが\N嫌なんですよ。
Dialogue: 0,0:25:36.90,0:25:38.95,Japanese SUB,,0,0,0,,しかし　どう考えても\Nこの格好は…。
Dialogue: 0,0:25:38.95,0:25:42.37,Japanese SUB,,0,0,0,,私　ボスの髪形　変だと思ってます。
Dialogue: 0,0:25:42.37,0:25:45.84,Japanese SUB,,0,0,0,,怪しいとも思ってますよ。
Dialogue: 0,0:25:45.84,0:25:49.86,Japanese SUB,,0,0,0,,だけど　いったこと\Nないじゃないですか！
Dialogue: 0,0:25:49.86,0:25:52.86,Japanese SUB,,0,0,0,,当たり前だ！　これは地毛だ！
Dialogue: 0,0:25:52.86,0:25:56.88,Japanese SUB,,0,0,0,,いや　服装の話をしてるんだ\N髪形は　どうでもいい。
Dialogue: 0,0:25:56.88,0:25:58.92,Japanese SUB,,0,0,0,,だって…。
Dialogue: 0,0:25:58.92,0:26:00.86,Japanese SUB,,0,0,0,,いただきま～す。
Dialogue: 0,0:26:00.86,0:26:04.36,Japanese SUB,,0,0,0,,はぁ…　私は何で普通に\N花森の家で→
Dialogue: 0,0:26:04.36,0:26:05.86,Japanese SUB,,0,0,0,,もんじゃを食べてるんだ。
Dialogue: 0,0:26:05.86,0:26:09.36,Japanese SUB,,0,0,0,,うん　そうだ！　ボス。\N何だ？
Dialogue: 0,0:26:09.36,0:26:13.87,Japanese SUB,,0,0,0,,『太陽にほえろ！』で\Nボスは時々　大活躍します。
Dialogue: 0,0:26:13.87,0:26:15.39,Japanese SUB,,0,0,0,,それが　どうした？
Dialogue: 0,0:26:15.39,0:26:18.46,Japanese SUB,,0,0,0,,ボスも活躍しましょうよ\N犯人逮捕。
Dialogue: 0,0:26:18.46,0:26:22.86,Japanese SUB,,0,0,0,,コマ達が　やってくれてる\N私には私の役割がある。
Dialogue: 0,0:26:22.86,0:26:25.36,Japanese SUB,,0,0,0,,刑事なのに　つまんなくないすか？
Dialogue: 0,0:26:25.36,0:26:27.37,Japanese SUB,,0,0,0,,お前と話してると\N頭がウニになるよ。
Dialogue: 0,0:26:27.37,0:26:29.35,Japanese SUB,,0,0,0,,おっ　昭和のフレーズ。
Dialogue: 0,0:26:29.35,0:26:31.87,Japanese SUB,,0,0,0,,うるさい！\N私は　ちえみの気持をだな…。
Dialogue: 0,0:26:31.87,0:26:33.84,Japanese SUB,,0,0,0,,（アリサ）　お代わり　どうすか？
Dialogue: 0,0:26:33.84,0:26:36.37,Japanese SUB,,0,0,0,,ん！　彼女　高校生だから→
Dialogue: 0,0:26:36.37,0:26:38.91,Japanese SUB,,0,0,0,,私より　ちえみちゃんの気持\N分かると思います。
Dialogue: 0,0:26:38.91,0:26:40.96,Japanese SUB,,0,0,0,,アリサちゃん　座って　座って。
Dialogue: 0,0:26:40.96,0:26:42.85,Japanese SUB,,0,0,0,,え～　私に相談してもムダっす。
Dialogue: 0,0:26:42.85,0:26:44.35,Japanese SUB,,0,0,0,,何で？
Dialogue: 0,0:26:44.35,0:26:48.35,Japanese SUB,,0,0,0,,いや～　今どきの若いもんの気持は\N分かんないね。
Dialogue: 0,0:26:50.35,0:26:52.36,Japanese SUB,,0,0,0,,アリサちゃんだって\N今どきじゃん。
Dialogue: 0,0:26:52.36,0:26:54.84,Japanese SUB,,0,0,0,,１０歳違えば　エイリアンです。
Dialogue: 0,0:26:54.84,0:26:57.88,Japanese SUB,,0,0,0,,うん　アリサちゃんもエイリアン。
Dialogue: 0,0:26:57.88,0:27:01.95,Japanese SUB,,0,0,0,,一子ちゃん\N一子ちゃんと話　通じないのは→
Dialogue: 0,0:27:01.95,0:27:04.35,Japanese SUB,,0,0,0,,ジェネレーションギャップじゃ\Nない気がする。
Dialogue: 0,0:27:04.35,0:27:05.85,Japanese SUB,,0,0,0,,どういう意味？
Dialogue: 0,0:27:05.85,0:27:08.86,Japanese SUB,,0,0,0,,だってさ　一子ちゃんって\Nトリッキーじゃん。
Dialogue: 0,0:27:08.86,0:27:11.86,Japanese SUB,,0,0,0,,トリッキー？\N私から見たら３人とも変わらんよ。
Dialogue: 0,0:27:11.86,0:27:13.86,Japanese SUB,,0,0,0,,ん？\Nあぁ　いや…。
Dialogue: 0,0:27:13.86,0:27:17.87,Japanese SUB,,0,0,0,,まぁ　話　通じない前提で\N喋ったほうが　いいんじゃないの？
Dialogue: 0,0:27:17.87,0:27:20.40,Japanese SUB,,0,0,0,,おじさんも　おばさんも。
Dialogue: 0,0:27:20.40,0:27:23.85,Japanese SUB,,0,0,0,,（アリサ）　ってことで　私は帰ります\Nお疲れさま～。
Dialogue: 0,0:27:23.85,0:27:25.87,Japanese SUB,,0,0,0,,（門馬）　お疲れさまでした。\Nお疲れさま。
Dialogue: 0,0:27:25.87,0:27:28.36,Japanese SUB,,0,0,0,,はい　おばあちゃん。\N（小梅）　はい　ご苦労さん。
Dialogue: 0,0:27:28.36,0:27:31.36,Japanese SUB,,0,0,0,,私も　そろそろ…。\Nボス　まだ食べてないです。
Dialogue: 0,0:27:31.36,0:27:33.36,Japanese SUB,,0,0,0,,あ～　もう胸が　いっぱいで。
Dialogue: 0,0:27:33.36,0:27:38.86,Japanese SUB,,0,0,0,,ボス　ちえみちゃんの服\N自由にさせてあげてください。
Dialogue: 0,0:27:40.42,0:27:43.92,Japanese SUB,,0,0,0,,せめて　洋服　一緒に\N買いに行ってください。
Dialogue: 0,0:27:45.84,0:27:47.34,Japanese SUB,,0,0,0,,考えてみる。
Dialogue: 0,0:27:47.34,0:27:48.85,Japanese SUB,,0,0,0,,ついでに　私も。
Dialogue: 0,0:27:48.85,0:27:51.33,Japanese SUB,,0,0,0,,小学生と刑事は別だ　ダメだ！
Dialogue: 0,0:27:51.33,0:27:53.83,Japanese SUB,,0,0,0,,え～　ケチ～。
Dialogue: 0,0:27:55.84,0:27:59.86,Japanese SUB,,0,0,0,,何でワンコなんかに\N相談しようと思ったんだ？
Dialogue: 0,0:27:59.86,0:28:02.41,Japanese SUB,,0,0,0,,どう話したらいいんだろうな。
Dialogue: 0,0:28:02.41,0:28:05.35,Japanese SUB,,0,0,0,,（重村）　お嬢さんですか？\Nいたのか　シゲ。
Dialogue: 0,0:28:05.35,0:28:07.83,Japanese SUB,,0,0,0,,鍋島松涛公園殺人事件の\N捜査資料です。
Dialogue: 0,0:28:07.83,0:28:09.33,Japanese SUB,,0,0,0,,目　通しておいてください。
Dialogue: 0,0:28:09.33,0:28:11.85,Japanese SUB,,0,0,0,,会議　出られなくて　すまんな。\Nいえ。
Dialogue: 0,0:28:11.85,0:28:14.86,Japanese SUB,,0,0,0,,小学校５年生でしたっけ？\Nちえみちゃん。
Dialogue: 0,0:28:14.86,0:28:18.88,Japanese SUB,,0,0,0,,ああ　言うこと聞かないんだ\Nこれが。
Dialogue: 0,0:28:18.88,0:28:20.91,Japanese SUB,,0,0,0,,一緒に　お風呂に入ってくれない。
Dialogue: 0,0:28:20.91,0:28:22.85,Japanese SUB,,0,0,0,,それもある。
Dialogue: 0,0:28:22.85,0:28:26.35,Japanese SUB,,0,0,0,,あれだけ　「パパ大好き！」\N「大きくなったら→
Dialogue: 0,0:28:26.35,0:28:29.35,Japanese SUB,,0,0,0,,パパのお嫁さんになる」なんて\Nいってたのにな→
Dialogue: 0,0:28:29.35,0:28:33.34,Japanese SUB,,0,0,0,,最近は　ろくに口もききやしない\N反発ばっかりしやがる。
Dialogue: 0,0:28:33.34,0:28:38.84,Japanese SUB,,0,0,0,,それは　反発じゃなくて\N自立なんじゃないですか？
Dialogue: 0,0:28:41.95,0:28:45.85,Japanese SUB,,0,0,0,,そうやって　だんだん大人になって\N行くんじゃないでしょうかね。
Dialogue: 0,0:28:45.85,0:28:47.85,Japanese SUB,,0,0,0,,そんなもんかな。
Dialogue: 0,0:28:49.84,0:28:55.85,Japanese SUB,,0,0,0,,まぁ　温か～く　見守るしか\Nないんでしょうねぇ　大人は。
Dialogue: 0,0:28:55.85,0:28:58.37,Japanese SUB,,0,0,0,,なるほど。
Dialogue: 0,0:28:58.37,0:29:02.92,Japanese SUB,,0,0,0,,ん？　シゲ　子供いたっけ？
Dialogue: 0,0:29:02.92,0:29:04.84,Japanese SUB,,0,0,0,,どうでしょう？
Dialogue: 0,0:29:04.84,0:29:06.86,Japanese SUB,,0,0,0,,じゃ　お先に。
Dialogue: 0,0:29:06.86,0:29:19.37,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:29:19.37,0:29:22.94,Japanese SUB,,0,0,0,,（ちえみ）　≪おかえりなさい≫
Dialogue: 0,0:29:22.94,0:29:24.86,Japanese SUB,,0,0,0,,ただいま。
Dialogue: 0,0:29:24.86,0:29:26.86,Japanese SUB,,0,0,0,,（ちえみ）　≪パパ？≫
Dialogue: 0,0:29:28.85,0:29:30.35,Japanese SUB,,0,0,0,,何だ？
Dialogue: 0,0:29:30.35,0:29:33.35,Japanese SUB,,0,0,0,,（ちえみ）　≪一応　いっとくけど\Nあのケータイのストラップ→
Dialogue: 0,0:29:33.35,0:29:35.35,Japanese SUB,,0,0,0,,私のだから≫
Dialogue: 0,0:29:37.84,0:29:39.34,Japanese SUB,,0,0,0,,ちえみ！
Dialogue: 0,0:29:43.84,0:29:45.85,Japanese SUB,,0,0,0,,（門馬）　そのように\N問いただしたところ→
Dialogue: 0,0:29:45.85,0:29:52.37,Japanese SUB,,0,0,0,,私の娘は　その場を走り去る女を\N一瞬しか見ていない。
Dialogue: 0,0:29:52.37,0:29:55.84,Japanese SUB,,0,0,0,,その女が\Nマルヒかどうかも不明だ。
Dialogue: 0,0:29:55.84,0:29:58.36,Japanese SUB,,0,0,0,,デューク　報告を。
Dialogue: 0,0:29:58.36,0:30:01.93,Japanese SUB,,0,0,0,,他の目撃情報から考えて\N間違いないな。
Dialogue: 0,0:30:01.93,0:30:03.35,Japanese SUB,,0,0,0,,ボスの娘か～。
Dialogue: 0,0:30:03.35,0:30:06.35,Japanese SUB,,0,0,0,,驚いたな。\Nええ。
Dialogue: 0,0:30:06.35,0:30:08.87,Japanese SUB,,0,0,0,,所轄に　女性捜査官なんか\Nいましたっけ？
Dialogue: 0,0:30:08.87,0:30:10.37,Japanese SUB,,0,0,0,,今は　そんなこと関係ねえだろ。
Dialogue: 0,0:30:10.37,0:30:14.37,Japanese SUB,,0,0,0,,『サロン・ド・ヤマテ』に潜入中の\N桐島から連絡があり…。
Dialogue: 0,0:30:16.36,0:30:18.38,Japanese SUB,,0,0,0,,デューク　続けて。\Nはい。
Dialogue: 0,0:30:18.38,0:30:22.85,Japanese SUB,,0,0,0,,え～　今日　大規模な\Nお茶会が開かれるそうです。
Dialogue: 0,0:30:22.85,0:30:25.37,Japanese SUB,,0,0,0,,お～　フリフリ連中　大集合か。\Nうわ～！
Dialogue: 0,0:30:25.37,0:30:29.36,Japanese SUB,,0,0,0,,正午から夜の８時まで\Nパーティー会場は開放され→
Dialogue: 0,0:30:29.36,0:30:31.36,Japanese SUB,,0,0,0,,スリースリーゴーゴー\N集まります。
Dialogue: 0,0:30:31.36,0:30:33.34,Japanese SUB,,0,0,0,,「スリースリーゴーゴー」？\N三々五々だろ。
Dialogue: 0,0:30:33.34,0:30:34.85,Japanese SUB,,0,0,0,,Ｔｈａｔ’ｓ　ｌｉｇｈｔ！
Dialogue: 0,0:30:34.85,0:30:36.86,Japanese SUB,,0,0,0,,「ゴーゴー」ってのは\N日本語じゃねえか！
Dialogue: 0,0:30:36.86,0:30:38.90,Japanese SUB,,0,0,0,,「ファイブ　ファイブ」だろ。\NＯｈ　ｍｙ　Ｇｏｄ！
Dialogue: 0,0:30:38.90,0:30:40.94,Japanese SUB,,0,0,0,,（和田）　誰だ？\N中途半端なこと教えたのは。
Dialogue: 0,0:30:40.94,0:30:43.37,Japanese SUB,,0,0,0,,（柳）　バカか！　お前は。
Dialogue: 0,0:30:43.37,0:30:44.87,Japanese SUB,,0,0,0,,（せき払い）
Dialogue: 0,0:30:44.87,0:30:46.37,Japanese SUB,,0,0,0,,会場で張ろう。
Dialogue: 0,0:30:47.86,0:30:49.84,Japanese SUB,,0,0,0,,出席者には\N服装チェックがあります。
Dialogue: 0,0:30:49.84,0:30:53.83,Japanese SUB,,0,0,0,,『サロン・ド・ヤマテ』は\N我々に協力的ではありません。
Dialogue: 0,0:30:53.83,0:30:56.35,Japanese SUB,,0,0,0,,そうなると潜入できんのは→
Dialogue: 0,0:30:56.35,0:30:58.90,Japanese SUB,,0,0,0,,ワンコしか　いねえじゃねぇかよ。\Nワンコかよ。
Dialogue: 0,0:30:58.90,0:31:01.40,Japanese SUB,,0,0,0,,ワンコねぇ。\Nワンコなぁ。
Dialogue: 0,0:31:07.34,0:31:08.83,Japanese SUB,,0,0,0,,ワンコです！
Dialogue: 0,0:31:08.83,0:31:10.85,Japanese SUB,,0,0,0,,あっ！
Dialogue: 0,0:31:10.85,0:31:14.35,Japanese SUB,,0,0,0,,ボス　今こそ\N私の出番じゃありませんか！
Dialogue: 0,0:31:14.35,0:31:17.35,Japanese SUB,,0,0,0,,この私を使わないで\Nどうするんですか！
Dialogue: 0,0:31:17.35,0:31:20.36,Japanese SUB,,0,0,0,,皆さん\Nゴスロリパーティーですよ！
Dialogue: 0,0:31:20.36,0:31:23.86,Japanese SUB,,0,0,0,,フリフリですよ！\Nクレバーですよ！　クールですよ！
Dialogue: 0,0:31:25.93,0:31:29.35,Japanese SUB,,0,0,0,,本庁さん！\N真面目にやりませんか！　本当に。
Dialogue: 0,0:31:29.35,0:31:31.85,Japanese SUB,,0,0,0,,いや～\Nこれには　いろいろありまして。
Dialogue: 0,0:31:31.85,0:31:35.36,Japanese SUB,,0,0,0,,所轄の皆さん\N私に期待していてください。
Dialogue: 0,0:31:35.36,0:31:37.34,Japanese SUB,,0,0,0,,ふざけんなよ！
Dialogue: 0,0:31:37.34,0:31:40.34,Japanese SUB,,0,0,0,,警察　ナメてんだろ！
Dialogue: 0,0:31:40.34,0:31:42.86,Japanese SUB,,0,0,0,,デューク　ワンコに嗅がしてやれ。
Dialogue: 0,0:31:42.86,0:31:45.92,Japanese SUB,,0,0,0,,はい　ワンコ　来い。
Dialogue: 0,0:31:45.92,0:31:47.92,Japanese SUB,,0,0,0,,嗅げ。
Dialogue: 0,0:31:50.84,0:31:54.34,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:31:54.34,0:31:57.34,Japanese SUB,,0,0,0,,どうだ？　行けそうか？
Dialogue: 0,0:31:57.34,0:31:58.85,Japanese SUB,,0,0,0,,楽勝っす。
Dialogue: 0,0:31:58.85,0:32:00.86,Japanese SUB,,0,0,0,,よし　行くぞ。\N（一同）　はい！
Dialogue: 0,0:32:00.86,0:32:02.36,Japanese SUB,,0,0,0,,はい！
Dialogue: 0,0:32:04.34,0:32:07.40,Japanese SUB,,0,0,0,,（門馬）　よし　みんな！　頼んだぞ！
Dialogue: 0,0:32:07.40,0:32:19.85,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:32:19.85,0:32:23.35,Japanese SUB,,0,0,0,,キリが従業員として潜入している\N連携して犯人を見つけろ。
Dialogue: 0,0:32:23.35,0:32:25.86,Japanese SUB,,0,0,0,,何かあったら無線で連絡。
Dialogue: 0,0:32:25.86,0:32:28.36,Japanese SUB,,0,0,0,,了解　なう。
Dialogue: 0,0:32:31.35,0:32:32.85,Japanese SUB,,0,0,0,,ミーちゃん！\N一子ちゃん！
Dialogue: 0,0:32:32.85,0:32:36.87,Japanese SUB,,0,0,0,,今日も　かわいい！　かわいい！\N今日も　かわいい！　かわいい！
Dialogue: 0,0:32:36.87,0:32:40.34,Japanese SUB,,0,0,0,,ごゆっくりしてってくださいね。\Nはい。
Dialogue: 0,0:32:40.34,0:32:45.36,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:32:45.36,0:32:46.88,Japanese SUB,,0,0,0,,琴美！
Dialogue: 0,0:32:46.88,0:32:49.43,Japanese SUB,,0,0,0,,（琴美）　あっ　一子～！\Nやっぱり来てたんだ。
Dialogue: 0,0:32:49.43,0:32:52.85,Japanese SUB,,0,0,0,,このイベントは　外せないわよね！
Dialogue: 0,0:32:52.85,0:32:55.36,Japanese SUB,,0,0,0,,ちょっと　どこ行くのよ？
Dialogue: 0,0:32:55.36,0:32:57.88,Japanese SUB,,0,0,0,,離れてくれない？\N琴美と一緒だと目立つ！
Dialogue: 0,0:32:57.88,0:33:00.36,Japanese SUB,,0,0,0,,何でよ　一緒に楽しもうよ！\Nあれ？
Dialogue: 0,0:33:00.36,0:33:01.86,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:33:01.86,0:33:04.87,Japanese SUB,,0,0,0,,あっ！　ちえみちゃん！\Nあっ　ワンコさん。
Dialogue: 0,0:33:04.87,0:33:06.87,Japanese SUB,,0,0,0,,やっぱり\Nいらっしゃってたんですね。
Dialogue: 0,0:33:06.87,0:33:08.90,Japanese SUB,,0,0,0,,いや　だから…。
Dialogue: 0,0:33:08.90,0:33:13.34,Japanese SUB,,0,0,0,,あっ　２人とも　私のお友達\Nだから仲良くしててね。
Dialogue: 0,0:33:13.34,0:33:16.86,Japanese SUB,,0,0,0,,そうなの？　よろしくね。\Nチャンスだ。
Dialogue: 0,0:33:16.86,0:33:19.35,Japanese SUB,,0,0,0,,（においを嗅ぐ音）\Nちえみです。
Dialogue: 0,0:33:19.35,0:33:20.85,Japanese SUB,,0,0,0,,犯人のにおい。
Dialogue: 0,0:33:20.85,0:33:26.85,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:33:26.85,0:33:29.41,Japanese SUB,,0,0,0,,キリさん！\N何？　あっ…。
Dialogue: 0,0:33:29.41,0:33:31.44,Japanese SUB,,0,0,0,,何？　その格好…！
Dialogue: 0,0:33:31.44,0:33:34.34,Japanese SUB,,0,0,0,,ちょ…　ちょっと　いらっしゃい。
Dialogue: 0,0:33:34.34,0:33:37.87,Japanese SUB,,0,0,0,,流れでですよ。\Nどんな流れですか!?
Dialogue: 0,0:33:37.87,0:33:40.35,Japanese SUB,,0,0,0,,ちょっと　いらっしゃい。\N知り合いばっかじゃん。
Dialogue: 0,0:33:40.35,0:33:42.35,Japanese SUB,,0,0,0,,あぁ!?
Dialogue: 0,0:33:42.35,0:33:44.37,Japanese SUB,,0,0,0,,撮りましょう。
Dialogue: 0,0:33:44.37,0:33:47.37,Japanese SUB,,0,0,0,,やめろよ。\Nはい　うわっ　かわいい！
Dialogue: 0,0:33:47.37,0:33:50.39,Japanese SUB,,0,0,0,,てか　お前\N流出させたら　ぶっ殺すからな。
Dialogue: 0,0:33:50.39,0:33:53.46,Japanese SUB,,0,0,0,,ぶっ殺す？　キリさん　殺しました？\Nあぁ？
Dialogue: 0,0:33:53.46,0:33:55.87,Japanese SUB,,0,0,0,,工藤さんです。\N何で俺が殺すんだよ！
Dialogue: 0,0:33:55.87,0:33:58.85,Japanese SUB,,0,0,0,,だって　犯人の　においがします。
Dialogue: 0,0:33:58.85,0:34:00.87,Japanese SUB,,0,0,0,,俺？\Nはい。
Dialogue: 0,0:34:00.87,0:34:02.37,Japanese SUB,,0,0,0,,（においを嗅ぐ音）\N（においを嗅ぐ音）
Dialogue: 0,0:34:02.37,0:34:04.86,Japanese SUB,,0,0,0,,服か。\Nそうですね。
Dialogue: 0,0:34:04.86,0:34:07.34,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:34:07.34,0:34:10.38,Japanese SUB,,0,0,0,,店のものだよ。\Nって　どういうこと？
Dialogue: 0,0:34:10.38,0:34:12.42,Japanese SUB,,0,0,0,,犯人は\Nこの店の従業員の中にいる。
Dialogue: 0,0:34:12.42,0:34:14.85,Japanese SUB,,0,0,0,,キリさんみたいに\N女装して殺した？
Dialogue: 0,0:34:14.85,0:34:17.85,Japanese SUB,,0,0,0,,「俺みたいに」は　余計だよ！\Nくそ！　盲点　突かれた！
Dialogue: 0,0:34:17.85,0:34:21.88,Japanese SUB,,0,0,0,,…ってか　殺人に使った服\N着せんなよ！
Dialogue: 0,0:34:21.88,0:34:25.35,Japanese SUB,,0,0,0,,ワンコ　嗅いで来い！\Nはい。
Dialogue: 0,0:34:25.35,0:34:30.42,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:34:30.42,0:34:33.87,Japanese SUB,,0,0,0,,（戸田）　ティーは　いかがですか？\Nあぁ　どうぞ。
Dialogue: 0,0:34:33.87,0:34:39.36,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:34:39.36,0:34:42.36,Japanese SUB,,0,0,0,,どうかなさいました？
Dialogue: 0,0:34:42.36,0:34:45.86,Japanese SUB,,0,0,0,,戸田さん　工藤さん…。
Dialogue: 0,0:34:47.88,0:34:49.92,Japanese SUB,,0,0,0,,何でもありません！
Dialogue: 0,0:34:49.92,0:34:51.92,Japanese SUB,,0,0,0,,楽しんでってください。
Dialogue: 0,0:34:59.85,0:35:02.37,Japanese SUB,,0,0,0,,どうだ　あいつ怪しいのか？\Nいえ。
Dialogue: 0,0:35:02.37,0:35:05.37,Japanese SUB,,0,0,0,,厨房や庭にも従業員\Nたくさんいるから　嗅いで来い。
Dialogue: 0,0:35:05.37,0:35:06.87,Japanese SUB,,0,0,0,,はい。
Dialogue: 0,0:35:09.87,0:35:12.36,Japanese SUB,,0,0,0,,えっ？　何で？\Nいいから　調べて。
Dialogue: 0,0:35:12.36,0:35:14.91,Japanese SUB,,0,0,0,,お願い！\N分かった。
Dialogue: 0,0:35:14.91,0:35:16.95,Japanese SUB,,0,0,0,,どうしたんですか？
Dialogue: 0,0:35:16.95,0:35:19.87,Japanese SUB,,0,0,0,,ううん　何でもない　楽しんで。
Dialogue: 0,0:35:19.87,0:35:25.86,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:35:25.86,0:35:29.86,Japanese SUB,,0,0,0,,[TEL]（ベル）
Dialogue: 0,0:35:31.36,0:35:34.38,Japanese SUB,,0,0,0,,おぉ　ワンコか？\N犯人　逮捕したか？
Dialogue: 0,0:35:34.38,0:35:36.93,Japanese SUB,,0,0,0,,ボス　今どこですか？
Dialogue: 0,0:35:36.93,0:35:39.37,Japanese SUB,,0,0,0,,１３係だよ\N…って　お前　かけて来てんだろ。
Dialogue: 0,0:35:39.37,0:35:40.87,Japanese SUB,,0,0,0,,あっ　そっか。
Dialogue: 0,0:35:40.87,0:35:44.34,Japanese SUB,,0,0,0,,じゃあ　逮捕状を取って\Nすぐに　こっちに来てください！
Dialogue: 0,0:35:44.34,0:35:45.84,Japanese SUB,,0,0,0,,逮捕状って誰の？
Dialogue: 0,0:35:45.84,0:35:48.85,Japanese SUB,,0,0,0,,戸田健太\N『サロン・ド・ヤマテ』の従業員です。
Dialogue: 0,0:35:48.85,0:35:50.85,Japanese SUB,,0,0,0,,えっ　男なの？
Dialogue: 0,0:35:50.85,0:35:52.87,Japanese SUB,,0,0,0,,急いでください！
Dialogue: 0,0:35:52.87,0:35:55.42,Japanese SUB,,0,0,0,,何で　お前に\N命令されなきゃいけないんだよ。
Dialogue: 0,0:35:55.42,0:35:57.45,Japanese SUB,,0,0,0,,っていうか\N逮捕状って　そんな簡単に…。
Dialogue: 0,0:35:57.45,0:35:59.34,Japanese SUB,,0,0,0,,そんなこといってる\N場合じゃ　ない！
Dialogue: 0,0:35:59.34,0:36:01.36,Japanese SUB,,0,0,0,,[TEL]（通話が切れた音）
Dialogue: 0,0:36:01.36,0:36:02.86,Japanese SUB,,0,0,0,,怒られた。\N[TEL]（通話が切れた音）
Dialogue: 0,0:36:02.86,0:36:04.86,Japanese SUB,,0,0,0,,[TEL]（通話が切れた音）
Dialogue: 0,0:36:06.85,0:36:09.85,Japanese SUB,,0,0,0,,デューク　アンパン買って来い。
Dialogue: 0,0:36:09.85,0:36:11.85,Japanese SUB,,0,0,0,,ヤナ　お前が行って来い。
Dialogue: 0,0:36:11.85,0:36:14.40,Japanese SUB,,0,0,0,,お前は\N調子に乗ってんじゃねえよ。
Dialogue: 0,0:36:14.40,0:36:17.34,Japanese SUB,,0,0,0,,デーク…　何だ？　それは。\Nデュークで～す。
Dialogue: 0,0:36:17.34,0:36:19.86,Japanese SUB,,0,0,0,,分かってるよ　この野郎\Nヤナ　やっぱり買って来い。
Dialogue: 0,0:36:19.86,0:36:21.85,Japanese SUB,,0,0,0,,えぇ～！\N俺　メロンパン。
Dialogue: 0,0:36:21.85,0:36:25.35,Japanese SUB,,0,0,0,,いいよ　俺もメロンパンな。\Nえぇ!?\N早く行け。
Dialogue: 0,0:36:30.37,0:36:32.89,Japanese SUB,,0,0,0,,あれ　ボスっす\Nボスっす！　あれ。
Dialogue: 0,0:36:32.89,0:36:34.93,Japanese SUB,,0,0,0,,（デューク）　ワ～オ！
Dialogue: 0,0:36:34.93,0:36:37.86,Japanese SUB,,0,0,0,,おう　ワンコ　ボスが中に\N入って行ったぞ　どういうことだ？
Dialogue: 0,0:36:37.86,0:36:42.85,Japanese SUB,,0,0,0,,[無線]　了解しました！\Nおい　切るなよ　おい！　ワンコ！
Dialogue: 0,0:36:42.85,0:36:45.37,Japanese SUB,,0,0,0,,行きますか？\Nコマさん。
Dialogue: 0,0:36:45.37,0:36:48.37,Japanese SUB,,0,0,0,,ちょっと待った　ちょっと待った\Nちょっと待ってろ…。
Dialogue: 0,0:36:48.37,0:37:05.34,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:37:05.34,0:37:07.84,Japanese SUB,,0,0,0,,あっちで座って飲もっか。\Nあっ　はい。
Dialogue: 0,0:37:09.36,0:37:13.36,Japanese SUB,,0,0,0,,ワンコ　どうした？\Nん？　ううん。
Dialogue: 0,0:37:16.38,0:37:18.94,Japanese SUB,,0,0,0,,いただきま～す。\Nいただきま～す。
Dialogue: 0,0:37:18.94,0:37:22.36,Japanese SUB,,0,0,0,,お紅茶は　こうやって…。
Dialogue: 0,0:37:22.36,0:37:24.84,Japanese SUB,,0,0,0,,ボス…。
Dialogue: 0,0:37:24.84,0:37:28.36,Japanese SUB,,0,0,0,,ボス！\Nおぉ　コマ達は　どうした？
Dialogue: 0,0:37:28.36,0:37:30.33,Japanese SUB,,0,0,0,,ボス　こっちです。
Dialogue: 0,0:37:30.33,0:37:32.85,Japanese SUB,,0,0,0,,ボス。\Nお前　キリか？
Dialogue: 0,0:37:32.85,0:37:35.35,Japanese SUB,,0,0,0,,キリです。\N何なんだ？
Dialogue: 0,0:37:35.35,0:37:36.89,Japanese SUB,,0,0,0,,キリなのか？\Nキリです！
Dialogue: 0,0:37:36.89,0:37:40.89,Japanese SUB,,0,0,0,,犯人は　あの男です\Nボス　逮捕してください。
Dialogue: 0,0:37:42.34,0:37:44.86,Japanese SUB,,0,0,0,,お前は　何で　さっきは\Nいわなかったんだよ!?
Dialogue: 0,0:37:44.86,0:37:47.35,Japanese SUB,,0,0,0,,おい　どうなってんだ？　これは！\Nいろいろあったんです　流れが。
Dialogue: 0,0:37:47.35,0:37:50.85,Japanese SUB,,0,0,0,,どんな　いろいろだ？\N話したら長くなっちゃうんです！
Dialogue: 0,0:37:50.85,0:37:53.35,Japanese SUB,,0,0,0,,僕だって　こんなの好きで\N着てるわけじゃないんです！
Dialogue: 0,0:37:53.35,0:37:54.86,Japanese SUB,,0,0,0,,ボス！
Dialogue: 0,0:37:54.86,0:37:57.87,Japanese SUB,,0,0,0,,あぁ　コマ！　チャンコ！\Nシ～！
Dialogue: 0,0:37:57.87,0:37:59.41,Japanese SUB,,0,0,0,,（小松原）　何が　「シ～」なんだよ。
Dialogue: 0,0:37:59.41,0:38:01.45,Japanese SUB,,0,0,0,,（和田：小松原）　おぉ。
Dialogue: 0,0:38:01.45,0:38:03.35,Japanese SUB,,0,0,0,,お前　キリか!?\Nキリです！
Dialogue: 0,0:38:03.35,0:38:05.87,Japanese SUB,,0,0,0,,この服を着ていた人が\N犯人なんです！
Dialogue: 0,0:38:05.87,0:38:07.83,Japanese SUB,,0,0,0,,犯人は　男なんです！\Nえ!?
Dialogue: 0,0:38:07.83,0:38:09.33,Japanese SUB,,0,0,0,,男！
Dialogue: 0,0:38:12.86,0:38:14.36,Japanese SUB,,0,0,0,,（ドアが開く音）
Dialogue: 0,0:38:14.36,0:38:17.34,Japanese SUB,,0,0,0,,ん？　こいつ？\Nヤナさん！
Dialogue: 0,0:38:17.34,0:38:19.40,Japanese SUB,,0,0,0,,工藤さん殺しの犯人です！
Dialogue: 0,0:38:19.40,0:38:21.43,Japanese SUB,,0,0,0,,♪♪～\Nおい！　この野郎！
Dialogue: 0,0:38:21.43,0:38:23.35,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:38:23.35,0:38:28.36,Japanese SUB,,0,0,0,,♪♪～\N≪キャ～！≫
Dialogue: 0,0:38:28.36,0:38:29.86,Japanese SUB,,0,0,0,,♪♪～\N（戸田）　離せ！
Dialogue: 0,0:38:29.86,0:38:33.84,Japanese SUB,,0,0,0,,（戸田）　キリ！　キリ！\N♪♪～\Nくそ～！
Dialogue: 0,0:38:33.84,0:38:35.86,Japanese SUB,,0,0,0,,あぁ！\N♪♪～\Nあぁ～！
Dialogue: 0,0:38:35.86,0:38:38.88,Japanese SUB,,0,0,0,,離せよ！\N動くんじゃねえよ！
Dialogue: 0,0:38:38.88,0:38:41.95,Japanese SUB,,0,0,0,,１３時４５分　確保！
Dialogue: 0,0:38:41.95,0:38:45.34,Japanese SUB,,0,0,0,,あぁ！　ちょっとヤナさん\N外して！　外して！
Dialogue: 0,0:38:45.34,0:38:48.34,Japanese SUB,,0,0,0,,は？\N早く！　外して！
Dialogue: 0,0:38:48.34,0:38:50.86,Japanese SUB,,0,0,0,,何でだよ…　何で？
Dialogue: 0,0:38:50.86,0:38:52.85,Japanese SUB,,0,0,0,,すいません　すいません…。
Dialogue: 0,0:38:52.85,0:38:54.35,Japanese SUB,,0,0,0,,ボス！
Dialogue: 0,0:38:57.85,0:39:00.37,Japanese SUB,,0,0,0,,ボス！　警視庁刑事部捜査一課→
Dialogue: 0,0:39:00.37,0:39:04.86,Japanese SUB,,0,0,0,,第八強行犯捜査殺人捜査\N１３係所属の門馬係長→
Dialogue: 0,0:39:04.86,0:39:07.34,Japanese SUB,,0,0,0,,容疑者を逮捕しま～す！
Dialogue: 0,0:39:07.34,0:39:09.35,Japanese SUB,,0,0,0,,ボス！　手錠を！
Dialogue: 0,0:39:09.35,0:39:12.35,Japanese SUB,,0,0,0,,俺　手錠　持って来てないぞ！
Dialogue: 0,0:39:12.35,0:39:14.83,Japanese SUB,,0,0,0,,いいから早く！\Nいいからっつったって　おい…。
Dialogue: 0,0:39:14.83,0:39:17.35,Japanese SUB,,0,0,0,,いや　よかったら…。
Dialogue: 0,0:39:17.35,0:39:19.85,Japanese SUB,,0,0,0,,すまんな。\Nここに。
Dialogue: 0,0:39:21.93,0:39:23.43,Japanese SUB,,0,0,0,,じゃあ。
Dialogue: 0,0:39:24.86,0:39:28.85,Japanese SUB,,0,0,0,,１３時４６分　確保。
Dialogue: 0,0:39:28.85,0:39:31.33,Japanese SUB,,0,0,0,,やった～！
Dialogue: 0,0:39:31.33,0:39:33.35,Japanese SUB,,0,0,0,,ちえみちゃん　ちえみちゃん…。\N（拍手）
Dialogue: 0,0:39:33.35,0:39:35.36,Japanese SUB,,0,0,0,,（拍手）
Dialogue: 0,0:39:35.36,0:39:37.86,Japanese SUB,,0,0,0,,ちえみちゃん！　見てたよね!?
Dialogue: 0,0:39:37.86,0:39:39.36,Japanese SUB,,0,0,0,,あれ？
Dialogue: 0,0:39:42.45,0:39:44.33,Japanese SUB,,0,0,0,,あ　ボ　ボス…。\N（門馬）　なぁ　コマ→
Dialogue: 0,0:39:44.33,0:39:46.35,Japanese SUB,,0,0,0,,俺　逮捕状　出さなかったけど\Nいいよな？
Dialogue: 0,0:39:46.35,0:39:49.85,Japanese SUB,,0,0,0,,（小松原）　持ってるんすか？\Nちえみちゃん？　どこ？
Dialogue: 0,0:39:51.84,0:39:53.34,Japanese SUB,,0,0,0,,あ！
Dialogue: 0,0:39:57.36,0:39:59.36,Japanese SUB,,0,0,0,,見てないじゃん！
Dialogue: 0,0:40:02.42,0:40:10.86,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:40:10.86,0:40:14.84,Japanese SUB,,0,0,0,,はぁ…\N♪♪～\N何年ぶりだ　この達成感。
Dialogue: 0,0:40:14.84,0:40:18.35,Japanese SUB,,0,0,0,,♪♪～\Nいいもんだなぁ…　なぁ！
Dialogue: 0,0:40:18.35,0:40:27.92,Japanese SUB,,0,0,0,,♪♪～
Dialogue: 0,0:40:27.92,0:40:29.34,Japanese SUB,,0,0,0,,（ドアが開く音）
Dialogue: 0,0:40:29.34,0:40:32.34,Japanese SUB,,0,0,0,,シゲさん　お願いします。
Dialogue: 0,0:40:37.35,0:40:39.35,Japanese SUB,,0,0,0,,お待たせしました。
Dialogue: 0,0:40:41.34,0:40:44.87,Japanese SUB,,0,0,0,,（重村）　ちょっと\N目をつむっていただけませんか？
Dialogue: 0,0:40:44.87,0:40:47.37,Japanese SUB,,0,0,0,,え？\Nいいから。
Dialogue: 0,0:40:50.85,0:40:53.85,Japanese SUB,,0,0,0,,上の瞼と下の瞼を合わせると→
Dialogue: 0,0:40:53.85,0:40:55.85,Japanese SUB,,0,0,0,,見えて来るものがないですか？
Dialogue: 0,0:40:57.84,0:40:59.84,Japanese SUB,,0,0,0,,いや　別に…。
Dialogue: 0,0:41:01.34,0:41:05.88,Japanese SUB,,0,0,0,,僕はね…→
Dialogue: 0,0:41:05.88,0:41:09.45,Japanese SUB,,0,0,0,,ず～っと会えないでいる→
Dialogue: 0,0:41:09.45,0:41:12.90,Japanese SUB,,0,0,0,,お袋の姿が浮かんで来る。
Dialogue: 0,0:41:12.90,0:41:17.34,Japanese SUB,,0,0,0,,会いたくなったら\N瞼を閉じ合わせ→
Dialogue: 0,0:41:17.34,0:41:22.34,Japanese SUB,,0,0,0,,じ～っと目を閉じるんです。
Dialogue: 0,0:41:26.92,0:41:29.42,Japanese SUB,,0,0,0,,誰が見えますか？
Dialogue: 0,0:41:31.35,0:41:36.84,Japanese SUB,,0,0,0,,お袋…。
Dialogue: 0,0:41:36.84,0:41:38.86,Japanese SUB,,0,0,0,,（泣き声）
Dialogue: 0,0:41:38.86,0:41:40.36,Japanese SUB,,0,0,0,,お袋…。
Dialogue: 0,0:41:40.36,0:41:42.85,Japanese SUB,,0,0,0,,（泣き声）
Dialogue: 0,0:41:42.85,0:41:46.90,Japanese SUB,,0,0,0,,おかあさんものか…。
Dialogue: 0,0:41:46.90,0:41:48.94,Japanese SUB,,0,0,0,,王道だな。
Dialogue: 0,0:41:48.94,0:41:50.94,Japanese SUB,,0,0,0,,マミー…。
Dialogue: 0,0:41:55.33,0:41:56.83,Japanese SUB,,0,0,0,,（門馬）　殺人の動機は？
Dialogue: 0,0:41:56.83,0:41:59.35,Japanese SUB,,0,0,0,,（重村）　戸田は以前　工藤さんと\N同じ銀行に勤めていたんですが→
Dialogue: 0,0:41:59.35,0:42:00.85,Japanese SUB,,0,0,0,,リストラに遭ったそうです。
Dialogue: 0,0:42:00.85,0:42:03.85,Japanese SUB,,0,0,0,,その時に　クビを切ったのが\N工藤さんだったと。
Dialogue: 0,0:42:03.85,0:42:06.34,Japanese SUB,,0,0,0,,逆恨みか。\Nで　戸田は　女装が趣味？
Dialogue: 0,0:42:06.34,0:42:08.83,Japanese SUB,,0,0,0,,いや　あれは単なる変装だ。
Dialogue: 0,0:42:08.83,0:42:11.90,Japanese SUB,,0,0,0,,その趣味があるのは　キリだよな？
Dialogue: 0,0:42:11.90,0:42:14.83,Japanese SUB,,0,0,0,,え？　ちょっと待ってください\N違いますよ！
Dialogue: 0,0:42:14.83,0:42:18.85,Japanese SUB,,0,0,0,,ムキになるのが怪しいな！　おい。\Nチャンコさん！
Dialogue: 0,0:42:18.85,0:42:20.84,Japanese SUB,,0,0,0,,今　普通じゃないですか\Nスーツです。
Dialogue: 0,0:42:20.84,0:42:22.84,Japanese SUB,,0,0,0,,（柳）　かわいい！\Nスーツです！
Dialogue: 0,0:42:22.84,0:42:25.84,Japanese SUB,,0,0,0,,（柳）　かわいい！\N何がですか　おかしくないですか？
Dialogue: 0,0:42:25.84,0:42:28.34,Japanese SUB,,0,0,0,,ワオ！　ワンコ？
Dialogue: 0,0:42:30.88,0:42:32.92,Japanese SUB,,0,0,0,,お疲れさまでした。
Dialogue: 0,0:42:32.92,0:42:34.83,Japanese SUB,,0,0,0,,お前　気持悪ぃな。
Dialogue: 0,0:42:34.83,0:42:37.34,Japanese SUB,,0,0,0,,顔色　悪いぞ。\N誰？　お前。
Dialogue: 0,0:42:37.34,0:42:40.32,Japanese SUB,,0,0,0,,ずっと　それで行くつもりか？\Nやめたほうがいいんじゃないかな。
Dialogue: 0,0:42:40.32,0:42:41.83,Japanese SUB,,0,0,0,,誰？　お前。
Dialogue: 0,0:42:41.83,0:42:44.34,Japanese SUB,,0,0,0,,普通の格好もダメ\Nフリフリもダメ。
Dialogue: 0,0:42:44.34,0:42:46.84,Japanese SUB,,0,0,0,,私　どうしたらいいんですか？
Dialogue: 0,0:42:48.35,0:42:51.94,Japanese SUB,,0,0,0,,ワンコ　明日から→
Dialogue: 0,0:42:51.94,0:42:53.94,Japanese SUB,,0,0,0,,フリフリで来い。
Dialogue: 0,0:42:55.34,0:42:58.84,Japanese SUB,,0,0,0,,やった！\Nもう取り消さないでくださいよ。
Dialogue: 0,0:42:58.84,0:43:01.85,Japanese SUB,,0,0,0,,他の服　着ませんからね！\Nああ　好きにしろ！
Dialogue: 0,0:43:01.85,0:43:03.85,Japanese SUB,,0,0,0,,それにしても　シゲ　コマ。
Dialogue: 0,0:43:03.85,0:43:08.35,Japanese SUB,,0,0,0,,逮捕って…　いいなぁ。
Dialogue: 0,0:43:08.35,0:43:10.35,Japanese SUB,,0,0,0,,どこ見て　いってんだろ。
Dialogue: 0,0:43:10.35,0:43:13.42,Japanese SUB,,0,0,0,,まぁ　とりあえず\N飲みに行きましょっか。
Dialogue: 0,0:43:13.42,0:43:17.34,Japanese SUB,,0,0,0,,よし！　今夜は俺の　おごりだ！
Dialogue: 0,0:43:17.34,0:43:19.85,Japanese SUB,,0,0,0,,おぉ～！
Dialogue: 0,0:43:19.85,0:43:21.85,Japanese SUB,,0,0,0,,（門馬）　よし　行こうぜ！
Dialogue: 0,0:43:21.85,0:43:23.83,Japanese SUB,,0,0,0,,おぉ～！
Dialogue: 0,0:43:23.83,0:43:26.84,Japanese SUB,,0,0,0,,（門馬）　遠慮すんな。\N（一同）　おぉ～！
Dialogue: 0,0:43:26.84,0:43:32.38,Japanese SUB,,0,0,0,,（松田洋雄）　そうか　門馬係長\Nヒーロー作戦は　大失敗か。
Dialogue: 0,0:43:32.38,0:43:34.43,Japanese SUB,,0,0,0,,はい。
Dialogue: 0,0:43:34.43,0:43:36.35,Japanese SUB,,0,0,0,,何だ　嬉しそうだな。
Dialogue: 0,0:43:36.35,0:43:39.85,Japanese SUB,,0,0,0,,私の誤解だったんです。\Nえ？
Dialogue: 0,0:43:40.85,0:43:44.35,Japanese SUB,,0,0,0,,((現場に出ないんだ))\N((経理畑出身だからね))
Dialogue: 0,0:43:44.35,0:43:46.34,Japanese SUB,,0,0,0,,((逮捕したりしないの？))
Dialogue: 0,0:43:46.34,0:43:48.34,Japanese SUB,,0,0,0,,…っていってたから→
Dialogue: 0,0:43:48.34,0:43:51.38,Japanese SUB,,0,0,0,,現場に出ないボスが不満なんだ\Nって思ったんですけど→
Dialogue: 0,0:43:51.38,0:43:53.93,Japanese SUB,,0,0,0,,ところが　どっこい。\N「ところが　どっこい」？
Dialogue: 0,0:43:53.93,0:43:57.85,Japanese SUB,,0,0,0,,((逆だよ～　現場に出ない立場で\Nよかったって思ったの))
Dialogue: 0,0:43:57.85,0:43:59.84,Japanese SUB,,0,0,0,,((え？　そうなの？))
Dialogue: 0,0:43:59.84,0:44:01.84,Japanese SUB,,0,0,0,,((うん　だって　危ないでしょ？))
Dialogue: 0,0:44:01.84,0:44:04.84,Japanese SUB,,0,0,0,,((ケガしたり　下手したら\N殉職の可能性だってあるよね？))
Dialogue: 0,0:44:04.84,0:44:06.34,Japanese SUB,,0,0,0,,((まぁね))
Dialogue: 0,0:44:06.34,0:44:08.90,Japanese SUB,,0,0,0,,((私　お金とか\N管理が　ちゃんとできるパパ→
Dialogue: 0,0:44:08.90,0:44:10.93,Japanese SUB,,0,0,0,,尊敬してるんだ))
Dialogue: 0,0:44:10.93,0:44:13.33,Japanese SUB,,0,0,0,,ハハっ　そうだったの。
Dialogue: 0,0:44:13.33,0:44:16.84,Japanese SUB,,0,0,0,,今どきの子が考えてることは\N分かりません。
Dialogue: 0,0:44:16.84,0:44:19.34,Japanese SUB,,0,0,0,,そうだねぇ。
Dialogue: 0,0:44:19.34,0:44:21.83,Japanese SUB,,0,0,0,,じゃ　失礼しま～す。
Dialogue: 0,0:44:21.83,0:44:23.83,Japanese SUB,,0,0,0,,花森君は→
Dialogue: 0,0:44:23.83,0:44:28.36,Japanese SUB,,0,0,0,,洋服　その感じで　まだ行くのね？
Dialogue: 0,0:44:28.36,0:44:30.40,Japanese SUB,,0,0,0,,はい　何か？
Dialogue: 0,0:44:30.40,0:44:32.32,Japanese SUB,,0,0,0,,「何か」？
Dialogue: 0,0:44:32.32,0:44:33.82,Japanese SUB,,0,0,0,,エヘ！
Dialogue: 0,0:44:33.82,0:44:36.82,Japanese SUB,,0,0,0,,パパが　「待ち合わせしよう」って。
Dialogue: 0,0:44:36.82,0:44:40.33,Japanese SUB,,0,0,0,,そう　あっ　私と会ってることは\N内緒だよ？
Dialogue: 0,0:44:40.33,0:44:44.33,Japanese SUB,,0,0,0,,うん　何か　パパと買い物って\N気が重いなぁ。
Dialogue: 0,0:44:44.33,0:44:46.33,Japanese SUB,,0,0,0,,今日は　一緒に行ったほうが\Nいいよ。
Dialogue: 0,0:44:46.33,0:44:47.87,Japanese SUB,,0,0,0,,どうして？
Dialogue: 0,0:44:47.87,0:44:51.44,Japanese SUB,,0,0,0,,ボス　私のゴスロリも\NＯＫしてくれたから→
Dialogue: 0,0:44:51.44,0:44:54.34,Japanese SUB,,0,0,0,,ちえみちゃんのロリータも\N大丈夫だって。
Dialogue: 0,0:44:54.34,0:44:57.34,Japanese SUB,,0,0,0,,そうかなぁ。\Nうん　大丈夫　大丈夫。
Dialogue: 0,0:45:02.33,0:45:04.33,Japanese SUB,,0,0,0,,（ちえみ）　パパ。\Nうん。
Dialogue: 0,0:45:07.34,0:45:09.37,Japanese SUB,,0,0,0,,どう？　似合う？
Dialogue: 0,0:45:09.37,0:45:12.44,Japanese SUB,,0,0,0,,世界一！　フフ！
Dialogue: 0,0:45:12.44,0:45:16.33,Japanese SUB,,0,0,0,,おとう様ですか？\Nあ…　父です。
Dialogue: 0,0:45:16.33,0:45:19.83,Japanese SUB,,0,0,0,,パパ　ありがと。
Dialogue: 0,0:45:23.32,0:45:26.84,Japanese SUB,,0,0,0,,（においを嗅ぐ音）
Dialogue: 0,0:45:26.84,0:45:29.84,Japanese SUB,,0,0,0,,親子の　においがします。
Dialogue: 0,0:45:29.84,0:45:34.34,Japanese SUB,,0,0,0,,♪♪～
