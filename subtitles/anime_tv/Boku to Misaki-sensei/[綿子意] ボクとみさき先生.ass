Dialogue: 0,0:00:11.49,0:00:13.80,Default,,0,0,0,,僕には憧れの人がいる
Dialogue: 0,0:00:14.56,0:00:16.49,Default,,0,0,0,,いや、憧れではない
Dialogue: 0,0:00:17.28,0:00:18.51,Default,,0,0,0,,愛しているのだ
Dialogue: 0,0:00:18.93,0:00:20.91,Default,,0,0,0,,僕の人生の中で
Dialogue: 0,0:00:20.91,0:00:22.57,Default,,0,0,0,,こんなに恋いこがれ
Dialogue: 0,0:00:22.57,0:00:26.00,Default,,0,0,0,,愛しく切なくさせる\N人が出てこようとは
Dialogue: 0,0:00:30.79,0:00:33.47,Default,,0,0,0,,一人きりの部屋で\N窓越しに夜空を見上げ
Dialogue: 0,0:00:33.47,0:00:36.21,Default,,0,0,0,,ため息、またため息
Dialogue: 0,0:00:42.30,0:00:45.38,Default,,0,0,0,,いたずら、禁止ですよ
Dialogue: 0,0:00:46.97,0:00:48.76,Default,,0,0,0,,なんてキュート
Dialogue: 0,0:00:48.76,0:00:50.48,Default,,0,0,0,,なんて可憐
Dialogue: 0,0:00:50.48,0:00:52.58,Default,,0,0,0,,なんてセクシー
Dialogue: 0,0:00:53.36,0:00:58.37,Default,,0,0,0,,そんな彼女を見ているだけでは\Nとうとう我慢できなくなり
Dialogue: 0,0:00:58.37,0:01:02.20,Default,,0,0,0,,僕のリビドーが\N大爆発を起こしてしまったんだ
Dialogue: 0,0:01:07.49,0:01:09.53,Default,,0,0,0,,ボクとみさき先生
Dialogue: 0,0:01:16.33,0:01:18.21,Default,,0,0,0,,はい！
Dialogue: 0,0:01:24.72,0:01:26.03,Default,,0,0,0,,かざまくん？
Dialogue: 0,0:01:28.02,0:01:30.78,Default,,0,0,0,,どうしたの?\N こんな遅くてに
Dialogue: 0,0:01:33.81,0:01:35.20,Default,,0,0,0,,先生
Dialogue: 0,0:01:35.20,0:01:36.94,Default,,0,0,0,,女性の体を
Dialogue: 0,0:01:36.94,0:01:38.94,Default,,0,0,0,,女性の体を
Dialogue: 0,0:01:38.94,0:01:41.82,Default,,0,0,0,,僕に教えてください
Dialogue: 0,0:01:44.83,0:01:46.73,Default,,0,0,0,,お願いします
Dialogue: 0,0:02:01.21,0:02:03.39,Default,,0,0,0,,りんごジュース
Dialogue: 0,0:02:04.64,0:02:07.88,Default,,0,0,0,,えと、りんごジュースでも飲む？
Dialogue: 0,0:02:13.31,0:02:15.40,Default,,0,0,0,,それとも、シャワーあげる？
Dialogue: 0,0:02:15.40,0:02:18.40,Default,,0,0,0,,はい！シャワーをいただきます
Dialogue: 0,0:02:39.92,0:02:41.16,Default,,0,0,0,,脱がせて
Dialogue: 0,0:02:58.35,0:03:01.36,Default,,0,0,0,,見て、女性の身体よ
Dialogue: 0,0:03:15.09,0:03:16.80,Default,,0,0,0,,焦らないよ
Dialogue: 0,0:03:16.81,0:03:19.97,Default,,0,0,0,,まだ下着の2枚が残ってるわよ
Dialogue: 0,0:03:26.64,0:03:29.73,Default,,0,0,0,,おっぱいが、おっぱいに、おっぱいに
Dialogue: 0,0:03:42.69,0:03:45.58,Default,,0,0,0,,だめ！\Nシャワー浴びてから
Dialogue: 0,0:04:07.38,0:04:08.66,Default,,0,0,0,,優しくね
Dialogue: 0,0:04:33.21,0:04:36.99,Default,,0,0,0,,かざまくん、女性の大事なところよ
Dialogue: 0,0:04:37.89,0:04:39.61,Default,,0,0,0,,よく見て
Dialogue: 0,0:04:40.58,0:04:43.86,Default,,0,0,0,,先生、もっと広げてよく見えない
Dialogue: 0,0:04:44.42,0:04:47.01,Default,,0,0,0,,先生、かなり恥ずかしいんだから
Dialogue: 0,0:04:47.01,0:04:49.22,Default,,0,0,0,,もっと
Dialogue: 0,0:04:56.34,0:04:58.00,Default,,0,0,0,,触ってみて
Dialogue: 0,0:05:05.02,0:05:06.86,Default,,0,0,0,,ぬるぬるしてる
Dialogue: 0,0:05:07.40,0:05:10.41,Default,,0,0,0,,男性を受け入れる
Dialogue: 0,0:05:12.13,0:05:14.10,Default,,0,0,0,,押しているところよ
Dialogue: 0,0:05:30.09,0:05:31.50,Default,,0,0,0,,大き
Dialogue: 0,0:05:57.95,0:05:59.34,Default,,0,0,0,,気持ちいい？
Dialogue: 0,0:06:06.12,0:06:07.22,Default,,0,0,0,,来て
Dialogue: 0,0:06:07.72,0:06:09.21,Default,,0,0,0,,ここ？
Dialogue: 0,0:06:09.21,0:06:11.24,Default,,0,0,0,,そう、そこ
Dialogue: 0,0:06:11.24,0:06:13.18,Default,,0,0,0,,ゆっくり
Dialogue: 0,0:06:19.01,0:06:20.48,Default,,0,0,0,,入った
Dialogue: 0,0:06:21.09,0:06:23.54,Default,,0,0,0,,ゆっくり動かしてみて
Dialogue: 0,0:06:36.16,0:06:37.92,Default,,0,0,0,,暖かい
Dialogue: 0,0:06:37.92,0:06:39.77,Default,,0,0,0,,これがおまんこ
Dialogue: 0,0:06:41.75,0:06:46.86,Default,,0,0,0,,私の身体の奥の\N奥深くのぬくもりよ
Dialogue: 0,0:06:47.29,0:06:49.95,Default,,0,0,0,,かざまくんのおちんちんも暖かい
Dialogue: 0,0:06:50.79,0:06:52.14,Default,,0,0,0,,熱いくらい
Dialogue: 0,0:07:08.10,0:07:11.32,Default,,0,0,0,,気持ちいい\Nちんちんがおかしくなっちゃう
Dialogue: 0,0:07:11.32,0:07:12.84,Default,,0,0,0,,だめ！
Dialogue: 0,0:07:15.98,0:07:17.22,Default,,0,0,0,,出る！
Dialogue: 0,0:07:17.22,0:07:18.77,Default,,0,0,0,,中はだめ
Dialogue: 0,0:07:20.25,0:07:22.01,Default,,0,0,0,,だめ！
Dialogue: 0,0:08:04.52,0:08:06.34,Default,,0,0,0,,もう一回してもいい?
Dialogue: 0,0:08:06.95,0:08:08.57,Default,,0,0,0,,気持ち良かった?
Dialogue: 0,0:08:09.53,0:08:11.26,Default,,0,0,0,,すっごく良かった
Dialogue: 0,0:08:12.63,0:08:14.77,Default,,0,0,0,,じゃあ行くときは外にね
Dialogue: 0,0:08:57.55,0:09:00.51,Default,,0,0,0,,入った
Dialogue: 0,0:10:09.20,0:10:11.60,Default,,0,0,0,,かざまくん！かざまくん！
Dialogue: 0,0:10:12.46,0:10:14.77,Default,,0,0,0,,先生、行く！
Dialogue: 0,0:10:17.83,0:10:19.95,Default,,0,0,0,,みさき先生
Dialogue: 0,0:10:19.95,0:10:23.47,Default,,0,0,0,,どうして僕にエッチさせてくれたの
Dialogue: 0,0:10:23.47,0:10:27.00,Default,,0,0,0,,みんなに先生が\Nいたずらされてるの
Dialogue: 0,0:10:27.00,0:10:28.82,Default,,0,0,0,,いつも見てたでしょ
Dialogue: 0,0:10:29.64,0:10:32.48,Default,,0,0,0,,みんなに加わりた\Nそうにしてるのが
Dialogue: 0,0:10:32.49,0:10:35.47,Default,,0,0,0,,とっても可愛くって
Dialogue: 0,0:10:38.20,0:10:39.96,Default,,0,0,0,,こうして
Dialogue: 0,0:10:39.96,0:10:44.05,Default,,0,0,0,,ボクとみさき先生との\N秘密の関係が始まったんだ
Dialogue: 0,0:11:59.39,0:12:00.78,Default,,0,0,0,,着てくれたんだ
Dialogue: 0,0:12:00.78,0:12:02.81,Default,,0,0,0,,みさき先生、すごく似合うよ
Dialogue: 0,0:12:02.81,0:12:04.39,Default,,0,0,0,,エッチだよ！
Dialogue: 0,0:12:05.89,0:12:08.59,Default,,0,0,0,,先生の学生時代のものなんで
Dialogue: 0,0:12:08.83,0:12:09.71,Default,,0,0,0,,もう
Dialogue: 0,0:12:09.71,0:12:11.41,Default,,0,0,0,,ピチピチになっちゃう
Dialogue: 0,0:12:11.41,0:12:14.50,Default,,0,0,0,,ゆうくんのリクエスト\Nだから着てみたけど
Dialogue: 0,0:12:14.50,0:12:16.75,Default,,0,0,0,,やっぱり恥ずかしいな
Dialogue: 0,0:12:35.35,0:12:37.61,Default,,0,0,0,,そんなところ舐めないで
Dialogue: 0,0:12:44.36,0:12:46.88,Default,,0,0,0,,先生もしかして水着
Dialogue: 0,0:12:49.03,0:12:52.66,Default,,0,0,0,,ゆうくんが喜んで\Nくれるかなって思って
Dialogue: 0,0:13:08.21,0:13:11.39,Default,,0,0,0,,これでもプロポーション\Nには自信があるんだから
Dialogue: 0,0:13:16.01,0:13:18.54,Default,,0,0,0,,どう？ゆうくん
Dialogue: 0,0:13:50.55,0:13:51.81,Default,,0,0,0,,美味しい？
Dialogue: 0,0:13:51.81,0:13:53.10,Default,,0,0,0,,美味しい！
Dialogue: 0,0:14:23.20,0:14:24.65,Default,,0,0,0,,入れて
Dialogue: 0,0:14:27.55,0:14:31.76,Default,,0,0,0,,みさき先生もう少し\N遊びしてからね
Dialogue: 0,0:14:32.09,0:14:33.70,Default,,0,0,0,,いや！
Dialogue: 0,0:14:51.44,0:14:52.58,Default,,0,0,0,,お待たせ
Dialogue: 0,0:14:52.58,0:14:54.21,Default,,0,0,0,,そろそろ入れるね
Dialogue: 0,0:15:00.20,0:15:01.41,Default,,0,0,0,,お願い
Dialogue: 0,0:15:01.93,0:15:03.56,Default,,0,0,0,,思いっきりください
Dialogue: 0,0:15:03.56,0:15:05.62,Default,,0,0,0,,ゆうくんのちん
Dialogue: 0,0:15:18.55,0:15:19.89,Default,,0,0,0,,気持ちいい
Dialogue: 0,0:15:36.83,0:15:39.68,Default,,0,0,0,,ゆうくんのおちん、すごい
Dialogue: 0,0:16:07.02,0:16:10.53,Default,,0,0,0,,また、またおちん気持ちいいよ
Dialogue: 0,0:16:10.53,0:16:13.02,Default,,0,0,0,,気持ちいいよ
Dialogue: 0,0:16:18.80,0:16:23.53,Default,,0,0,0,,行く！
Dialogue: 0,0:16:51.10,0:16:52.88,Default,,0,0,0,,今日はバニーちゃんだぞ
Dialogue: 0,0:16:56.57,0:16:58.77,Default,,0,0,0,,すぐエッチになっちゃうんだから
Dialogue: 0,0:17:12.82,0:17:17.18,Default,,0,0,0,,みさき先生\N紐使っていい?
Dialogue: 0,0:17:19.01,0:17:20.47,Default,,0,0,0,,紐？
Dialogue: 0,0:17:35.77,0:17:37.61,Default,,0,0,0,,もういい ゆうくん
Dialogue: 0,0:17:37.61,0:17:39.12,Default,,0,0,0,,ちょっと痛い
Dialogue: 0,0:17:39.12,0:17:41.57,Default,,0,0,0,,先生こういうの\Nあんまり好きじゃないな
Dialogue: 0,0:17:42.04,0:17:44.75,Default,,0,0,0,,みさき先生の大きな\Nおっぱいとお尻を
Dialogue: 0,0:17:44.75,0:17:47.87,Default,,0,0,0,,最大限に楽しむために\N必要なんですよ
Dialogue: 0,0:17:47.87,0:17:50.09,Default,,0,0,0,,今日はこれでいきます
Dialogue: 0,0:17:50.52,0:17:52.64,Default,,0,0,0,,すごくいいですよ先生
Dialogue: 0,0:17:52.64,0:17:54.10,Default,,0,0,0,,我慢できない
Dialogue: 0,0:18:29.80,0:18:31.13,Default,,0,0,0,,気持ちいいだろう？
Dialogue: 0,0:18:31.13,0:18:32.23,Default,,0,0,0,,感じてるだろう？
Dialogue: 0,0:18:33.26,0:18:36.24,Default,,0,0,0,,感じてるなら、\N感じてるって言え！
Dialogue: 0,0:18:39.25,0:18:41.47,Default,,0,0,0,,楽しい一日ましょう
Dialogue: 0,0:18:41.47,0:18:42.76,Default,,0,0,0,,こんなじゃ嫌だ
Dialogue: 0,0:18:42.76,0:18:44.45,Default,,0,0,0,,ゆうくん！
Dialogue: 0,0:19:11.37,0:19:14.27,Default,,0,0,0,,みさき先生、ごめんなさい
Dialogue: 0,0:19:18.06,0:19:21.21,Default,,0,0,0,,- ごめんなさい！ごめんなさい！\N - いい！すごいよ！
Dialogue: 0,0:19:23.13,0:19:25.79,Default,,0,0,0,,出して！\Nいっぱい出して！
Dialogue: 0,0:19:29.81,0:19:32.15,Default,,0,0,0,,行く！
Dialogue: 0,0:19:50.78,0:19:52.46,Default,,0,0,0,,気持ちよかった?
Dialogue: 0,0:19:53.22,0:19:54.76,Default,,0,0,0,,気持ちよかった
Dialogue: 0,0:20:10.31,0:20:11.26,Default,,0,0,0,,好き
