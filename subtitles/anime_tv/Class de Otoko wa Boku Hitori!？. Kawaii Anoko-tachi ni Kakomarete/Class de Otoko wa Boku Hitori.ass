Comment: 0,0:00:00.00,0:00:00.00,Sx-jp,,0,0,0,code once,function relf() local eff = relf_kr() relf_margin() relf_layer() return eff end function relf_kr() for i = 1, #characters, 1 do if line.actor == characters[i] then return characters_eff[i] end end return "" end function relf_margin() if string.find(line.raw,"%{\\an8%}") ~= nil then if line.styleref.name == "Sx-jp" then line.margin_t = margin_t_jp else line.margin_t = margin_t_zh end end local tmp = strsub(line.text_stripped,strlen(line.text_stripped)-1,1) if tmp == "…" or tmp == "！" or tmp == "？" then if line.styleref.name == "Sx-jp" then line.margin_l = line.margin_l + 42 else line.margin_l = line.margin_l + 55 end end end function relf_layer() if line.styleref.name == "Sx-zh" then line.layer = 1 end end
