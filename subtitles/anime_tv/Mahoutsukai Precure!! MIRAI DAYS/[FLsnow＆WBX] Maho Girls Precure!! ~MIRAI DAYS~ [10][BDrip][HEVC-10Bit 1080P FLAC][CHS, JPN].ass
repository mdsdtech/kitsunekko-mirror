Dialogue: 0,0:00:06.19,0:00:07.47,Miracle_JP,,0,0,0,,校長先生
Dialogue: 0,0:00:06.19,0:00:07.47,Miracle_CN,,0,0,0,,校长
Dialogue: 0,0:00:15.11,0:00:15.92,Miracle_JP,,0,0,0,,あっ...
Dialogue: 0,0:00:15.11,0:00:15.92,Miracle_CN,,0,0,0,,啊...
Dialogue: 0,0:00:24.25,0:00:24.90,Ha_Chan_JP,,0,0,0,,ハッ...
Dialogue: 0,0:00:24.25,0:00:24.90,Ha_Chan_CN,,0,0,0,,啊...
Dialogue: 0,0:00:26.77,0:00:29.69,Miracle_JP,,0,0,0,,魔法界のみんなが 石に
Dialogue: 0,0:00:26.77,0:00:29.69,Miracle_CN,,0,0,0,,魔法界的大家 都变成石像了
Dialogue: 0,0:00:30.27,0:00:31.68,Mofurun_JP,,0,0,0,,モフ...
Dialogue: 0,0:00:30.27,0:00:31.68,Mofurun_CN,,0,0,0,,mofu...
Dialogue: 0,0:00:38.34,0:00:39.54,Magical_JP,,0,0,0,,お父様...
Dialogue: 0,0:00:38.34,0:00:39.54,Magical_CN,,0,0,0,,爸爸...
Dialogue: 0,0:00:44.19,0:00:46.72,Magical_JP,,0,0,0,,あなたみたいに みんなが
Dialogue: 0,0:00:44.19,0:00:46.72,Magical_CN,,0,0,0,,大家都和你一样 变成石像了
Dialogue: 0,0:00:48.78,0:00:50.99,Magical_JP,,0,0,0,,行きましょう ナシマホウ界に
Dialogue: 0,0:00:48.78,0:00:50.99,Magical_CN,,0,0,0,,我们走吧 去无魔界
Dialogue: 0,0:00:51.95,0:00:54.25,Magical_JP,,0,0,0,,ナシマホウ界が こうなる前に！
Dialogue: 0,0:00:51.95,0:00:54.25,Magical_CN,,0,0,0,,要赶在无魔界变成这样之前！
Dialogue: 0,0:00:54.52,0:00:55.34,Miracle_JP,,0,0,0,,うん！
Dialogue: 0,0:00:54.52,0:00:55.34,Miracle_CN,,0,0,0,,嗯！
Dialogue: 0,0:01:01.87,0:01:03.03,Miracle_JP,,0,0,0,,嘘でしょ！
Dialogue: 0,0:01:01.87,0:01:03.03,Miracle_CN,,0,0,0,,不是吧！
Dialogue: 0,0:01:03.75,0:01:04.81,Ha_Chan_JP,,0,0,0,,これって...
Dialogue: 0,0:01:03.75,0:01:04.81,Ha_Chan_CN,,0,0,0,,这是...
Dialogue: 0,0:01:05.15,0:01:07.94,Mofurun_JP,,0,0,0,,ジュン ケイ エミリーモフ
Dialogue: 0,0:01:05.15,0:01:07.94,Mofurun_CN,,0,0,0,,是俊 凯 还有艾米丽
Dialogue: 0,0:01:09.46,0:01:11.33,Miracle_JP,,0,0,0,,なんでジュン達が...
Dialogue: 0,0:01:09.46,0:01:11.33,Miracle_CN,,0,0,0,,为什么俊她们会...
Dialogue: 0,0:01:11.46,0:01:13.28,Magical_JP,,0,0,0,,どうしてこっちにいたの
Dialogue: 0,0:01:11.46,0:01:13.28,Magical_CN,,0,0,0,,她们怎么会在这里
Dialogue: 0,0:01:14.48,0:01:15.83,Ha_Chan_JP,,0,0,0,,カタツムリニアも...
Dialogue: 0,0:01:14.48,0:01:15.83,Ha_Chan_CN,,0,0,0,,连蜗牛列车都...
Dialogue: 0,0:01:17.96,0:01:20.03,Mofurun_JP,,0,0,0,,石になってるモフ
Dialogue: 0,0:01:17.96,0:01:20.03,Mofurun_CN,,0,0,0,,变成石像了
Dialogue: 0,0:01:20.89,0:01:23.09,Mofurun_JP,,0,0,0,,これじゃ帰れないモフ
Dialogue: 0,0:01:20.89,0:01:23.09,Mofurun_CN,,0,0,0,,这样就没法回去了
Dialogue: 0,0:01:23.47,0:01:25.37,Default_JP,,0,0,0,,いいえ 帰れますよ
Dialogue: 0,0:01:23.47,0:01:25.37,Default_CN,,0,0,0,,不 能回去的
Dialogue: 0,0:01:27.12,0:01:28.70,Default_JP,,0,0,0,,ナシマホウ界に
Dialogue: 0,0:01:27.12,0:01:28.70,Default_CN,,0,0,0,,能回无魔界
Dialogue: 0,0:01:28.91,0:01:29.78,Magical_JP,,0,0,0,,ヤモー！
Dialogue: 0,0:01:28.91,0:01:29.78,Magical_CN,,0,0,0,,邪蟆！
Dialogue: 0,0:01:31.04,0:01:34.14,Miracle_JP,,0,0,0,,今...帰れるって言いました！
Dialogue: 0,0:01:31.04,0:01:34.14,Miracle_CN,,0,0,0,,刚才你说...可以回去！
Dialogue: 0,0:01:34.14,0:01:36.14,Miracle_CN,,0,0,0,,
Dialogue: 0,0:03:07.66,0:03:12.58,Default_CN,,0,0,300,,{\fad(500,0)}追赶时间
Dialogue: 0,0:03:12.32,0:03:13.48,Default_CN,,0,0,0,,
Dialogue: 0,0:03:13.62,0:03:16.57,Mofurun_JP,,0,0,0,,本当にナシマホウ界に帰れるモフ？
Dialogue: 0,0:03:13.62,0:03:16.57,Mofurun_CN,,0,0,0,,真的能回无魔界？
Dialogue: 0,0:03:16.81,0:03:21.45,Default_JP,,0,0,0,,ええ 造作もない事 私の闇の魔法があればね
Dialogue: 0,0:03:16.81,0:03:21.45,Default_CN,,0,0,0,,是的 轻而易举 只需有我的黑暗魔法
Dialogue: 0,0:03:22.41,0:03:25.86,Default_JP,,0,0,0,,かつての同志を過去に閉じ込め あろう事か
Dialogue: 0,0:03:22.41,0:03:25.86,Default_CN,,0,0,0,,它将我以前的同事 困在了过去 岂有此理
Dialogue: 0,0:03:26.92,0:03:31.31,Default_JP,,0,0,0,,在りし日のドクロクシー様をエサに 私を利用した
Dialogue: 0,0:03:26.92,0:03:31.31,Default_CN,,0,0,0,,更将某个时期的毒骷髅库西大人作为诱饵 利用了我
Dialogue: 0,0:03:32.70,0:03:36.06,Default_JP,,0,0,0,,許せません 共に刻の魔獣を止めましょう
Dialogue: 0,0:03:32.70,0:03:36.06,Default_CN,,0,0,0,,我饶不了它 一起去阻止时间魔兽吧
Dialogue: 0,0:03:36.42,0:03:37.06,Magical_JP,,0,0,0,,うん
Dialogue: 0,0:03:36.42,0:03:37.06,Miracle_CN,,0,0,0,,嗯
Dialogue: 0,0:03:37.49,0:03:38.37,Default_JP,,0,0,0,,イードウ
Dialogue: 0,0:03:37.49,0:03:38.37,Default_CN,,0,0,0,,移动
Dialogue: 0,0:03:38.52,0:03:39.17,Magical_JP,,0,0,0,,えっ？
Dialogue: 0,0:03:38.52,0:03:39.17,Miracle_CN,,0,0,0,,诶？
Dialogue: 0,0:03:43.70,0:03:44.88,Magical_JP,,0,0,0,,いきなり 何
Dialogue: 0,0:03:43.70,0:03:44.88,Magical_CN,,0,0,0,,你突然干什么啊
Dialogue: 0,0:03:44.92,0:03:45.98,Default_JP,,0,0,0,,エッ！
Dialogue: 0,0:03:44.92,0:03:45.98,Default_CN,,0,0,0,,呀！
Dialogue: 0,0:03:46.77,0:03:47.39,Ha_Chan_JP,,0,0,0,,リコ
Dialogue: 0,0:03:46.77,0:03:47.39,Ha_Chan_CN,,0,0,0,,李可
Dialogue: 0,0:03:50.53,0:03:51.12,Magical_JP,,0,0,0,,ハッ...
Dialogue: 0,0:03:50.53,0:03:51.12,Magical_CN,,0,0,0,,啊...
Dialogue: 0,0:03:53.58,0:03:54.66,Magical_JP,,0,0,0,,津成木町
Dialogue: 0,0:03:53.58,0:03:54.66,Magical_CN,,0,0,0,,津成木镇
Dialogue: 0,0:03:54.83,0:03:56.24,Miracle_JP,,0,0,0,,津成木駅だよ
Dialogue: 0,0:03:54.83,0:03:56.24,Miracle_CN,,0,0,0,,是津成木站
Dialogue: 0,0:03:56.78,0:03:57.87,Miracle_JP,,0,0,0,,帰ってきたんだ
Dialogue: 0,0:03:56.78,0:03:57.87,Miracle_CN,,0,0,0,,我们回来了
Dialogue: 0,0:03:58.17,0:03:59.30,Miracle_JP,,0,0,0,,みんな無事だ
Dialogue: 0,0:03:58.17,0:03:59.30,Miracle_CN,,0,0,0,,大家都没事
Dialogue: 0,0:03:59.36,0:04:00.60,Magical_JP,,0,0,0,,でも どうして？
Dialogue: 0,0:03:59.36,0:04:00.60,Magical_CN,,0,0,0,,可是 为什么呢？
Dialogue: 0,0:04:00.86,0:04:05.71,Ha_Chan_JP,,0,0,0,,うん 魔法界みたいに 一気にバーッて襲わないんだろう
Dialogue: 0,0:04:00.86,0:04:05.71,Ha_Chan_CN,,0,0,0,,嗯 是因为没像魔法界那样 一下子攻过来吧
Dialogue: 0,0:04:06.24,0:04:11.84,Mofurun_JP,,0,0,0,,モフ お昼までいっぱい来てたモフ 助けて魔法つかいのお願い
Dialogue: 0,0:04:06.24,0:04:11.84,Mofurun_CN,,0,0,0,,mofu 白天发过来好多 帮帮我 魔法师 的请愿
Dialogue: 0,0:04:07.10,0:04:12.36,Default_CN,,30,0,30,,{\an7}{\fs50}哥哥不见了！\N朋友变成石像了！
Dialogue: 0,0:04:12.64,0:04:15.08,Default_JP,,0,0,0,,助けて魔法つかい？お願い？
Dialogue: 0,0:04:12.64,0:04:15.08,Default_CN,,0,0,0,,帮帮我 魔法师？请愿？
Dialogue: 0,0:04:15.42,0:04:19.90,Miracle_JP,,0,0,0,,友達が石になったとか ママがいなくなったとか いっぱい来てる
Dialogue: 0,0:04:15.42,0:04:19.90,Miracle_CN,,0,0,0,,好多都是“朋友变成石像了”“妈妈不见了”之类的
Dialogue: 0,0:04:20.24,0:04:24.08,Magical_JP,,0,0,0,,この依頼って ちょうど魔法界が襲われた時間帯じゃない？
Dialogue: 0,0:04:20.24,0:04:24.08,Magical_CN,,0,0,0,,这些委托是不是都是魔法界被袭击的时间段？
Dialogue: 0,0:04:24.67,0:04:25.36,Ha_Chan_JP,,0,0,0,,ホントに？
Dialogue: 0,0:04:24.67,0:04:25.36,Ha_Chan_CN,,0,0,0,,真的吗？
Dialogue: 0,0:04:25.53,0:04:27.36,Miracle_JP,,0,0,0,,でも 今はピタッとなくなってる
Dialogue: 0,0:04:25.53,0:04:27.36,Miracle_CN,,0,0,0,,可是 现在啪的一下就断档了
Dialogue: 0,0:04:27.70,0:04:28.98,Magical_JP,,0,0,0,,どういう事なの？
Dialogue: 0,0:04:27.70,0:04:28.98,Magical_CN,,0,0,0,,怎么回事？
Dialogue: 0,0:04:29.17,0:04:30.52,Default_JP,,0,0,0,,私にも見せて
Dialogue: 0,0:04:29.17,0:04:30.52,Default_CN,,0,0,0,,让我也看看
Dialogue: 0,0:04:30.88,0:04:33.70,Default_JP,,0,0,0,,連れてきたのに 扱いがぞんざい過ぎます
Dialogue: 0,0:04:30.88,0:04:33.70,Default_CN,,0,0,0,,是我带你们来的 你们待我也太冷淡了
Dialogue: 0,0:04:34.12,0:04:35.37,Default_CN,,0,0,30,,{\an8}20条未接留言
Dialogue: 0,0:04:35.76,0:04:38.04,Miracle_JP,,0,0,0,,電波が繋がって 一気に来たんだ
Dialogue: 0,0:04:35.76,0:04:38.04,Miracle_CN,,0,0,0,,信号联通后 一下子进来好多
Dialogue: 0,0:04:38.13,0:04:40.84,Default_CN,,0,0,30,,{\an8}妈妈留言
Dialogue: 0,0:04:39.03,0:04:40.84,Default_JP,,0,0,0,,もしもし 大丈夫？
Dialogue: 0,0:04:39.03,0:04:40.84,Default_CN,,0,0,0,,喂喂 没事吧？
Dialogue: 0,0:04:41.42,0:04:43.47,Default_JP,,0,0,0,,何度電話しても出ないんだから
Dialogue: 0,0:04:41.42,0:04:43.47,Default_CN,,0,0,0,,打了你好多电话 都不接
Dialogue: 0,0:04:44.02,0:04:45.68,Miracle_JP,,0,0,0,,お母さんからの留守電
Dialogue: 0,0:04:44.02,0:04:45.68,Miracle_CN,,0,0,0,,是妈妈的留言
Dialogue: 0,0:04:45.87,0:04:47.32,Mofurun_JP,,0,0,0,,カンカンモフ
Dialogue: 0,0:04:45.87,0:04:47.32,Mofurun_CN,,0,0,0,,很大的火气
Dialogue: 0,0:04:51.90,0:04:52.84,Miracle_JP,,0,0,0,,ケイからだ
Dialogue: 0,0:04:51.90,0:04:52.84,Miracle_CN,,0,0,0,,是凯打来的
Dialogue: 0,0:04:54.96,0:04:57.95,Default_JP,,0,0,0,,みらい 何度も電話かけたんだけど
Dialogue: 0,0:04:54.96,0:04:57.95,Default_CN,,0,0,0,,未来 打了你好多电话了
Dialogue: 0,0:04:58.76,0:05:05.10,Default_JP,,0,0,0,,津成木町界隈の失踪事件と あちこちに出てくる石像の事を聞きたかったんだよね
Dialogue: 0,0:04:58.76,0:05:05.10,Default_CN,,0,0,0,,我想跟你打听一下 津成木镇周围的失踪事件 以及各处出现的石像
Dialogue: 0,0:05:05.88,0:05:06.89,Default_JP,,0,0,0,,また連絡する
Dialogue: 0,0:05:05.88,0:05:06.89,Default_CN,,0,0,0,,还会再联系你的
Dialogue: 0,0:05:07.36,0:05:12.10,Default_JP,,0,0,0,,そうそう 魔法ガールも失踪事件の事で疑われているから気を付けて
Dialogue: 0,0:05:07.36,0:05:12.10,Default_CN,,0,0,0,,对了 有人怀疑魔法少女跟失踪事件有关 你当心一点
Dialogue: 0,0:05:12.93,0:05:17.46,Default_JP,,0,0,0,,これからジュン達と カタツムリニアに乗るから スマホ繋がらなくなるね
Dialogue: 0,0:05:12.93,0:05:17.46,Default_CN,,0,0,0,,等会儿就要跟俊她们坐蜗牛列车了 手机会没信号的
Dialogue: 0,0:05:18.04,0:05:21.29,Default_JP,,0,0,0,,みらいは魔法界にいるかもだけど 一応連絡
Dialogue: 0,0:05:18.04,0:05:21.29,Default_CN,,0,0,0,,虽然未来可能已经去了魔法界 总归先联系一下
Dialogue: 0,0:05:21.95,0:05:25.92,Default_JP,,0,0,0,,アタイ ジュン 聞いたぜ はーちゃんも一緒なんだろ？
Dialogue: 0,0:05:21.95,0:05:25.92,Default_CN,,0,0,0,,你们俊姐在此 姐听说了 小哈也在吧？
Dialogue: 0,0:05:26.13,0:05:28.81,Default_JP,,0,0,0,,エミリーだよ  会うの楽しみ
Dialogue: 0,0:05:26.13,0:05:28.81,Default_CN,,0,0,0,,我是艾米丽 很期待见到你们
Dialogue: 0,0:05:29.12,0:05:30.74,Default_JP,,0,0,0,,じゃあ また後でね
Dialogue: 0,0:05:29.12,0:05:30.74,Default_CN,,0,0,0,,走了 等会再见
Dialogue: 0,0:05:41.77,0:05:43.28,Miracle_JP,,0,0,0,,た ただいま
Dialogue: 0,0:05:41.77,0:05:43.28,Miracle_CN,,0,0,0,,我们回来了
Dialogue: 0,0:05:43.79,0:05:45.61,Default_JP,,0,0,0,,なんで連絡くれないの！
Dialogue: 0,0:05:43.79,0:05:45.61,Default_CN,,0,0,0,,为什么不回电话！
Dialogue: 0,0:05:45.96,0:05:48.77,Miracle_JP,,0,0,0,,ごめん スマホの充電切れてて
Dialogue: 0,0:05:45.96,0:05:48.77,Miracle_CN,,0,0,0,,抱歉 手机没电了
Dialogue: 0,0:05:48.84,0:05:52.66,Default_JP,,0,0,0,,心配したよ 失踪事件に巻き込まれたのかと思って
Dialogue: 0,0:05:48.84,0:05:52.66,Default_CN,,0,0,0,,我们很担心 怕你被卷入失踪事件
Dialogue: 0,0:05:52.85,0:05:53.97,Miracle_JP,,0,0,0,,本当 ごめん
Dialogue: 0,0:05:52.85,0:05:53.97,Miracle_CN,,0,0,0,,真的很抱歉
Dialogue: 0,0:05:54.37,0:05:55.96,Default_JP,,0,0,0,,一安心ね
Dialogue: 0,0:05:54.37,0:05:55.96,Default_CN,,0,0,0,,这下能松口气了
Dialogue: 0,0:05:57.12,0:05:57.82,Default_JP,,0,0,0,,あっ！
Dialogue: 0,0:05:57.12,0:05:57.82,Default_CN,,0,0,0,,啊！
Dialogue: 0,0:05:59.60,0:06:00.59,Ha_Chan_JP,,0,0,0,,はー！
Dialogue: 0,0:05:59.60,0:06:00.59,Ha_Chan_CN,,0,0,0,,哈！
Dialogue: 0,0:06:01.02,0:06:02.44,Ha_Chan_JP,,0,0,0,,みんな 久しぶり
Dialogue: 0,0:06:01.02,0:06:02.44,Ha_Chan_CN,,0,0,0,,大家 好久不见
Dialogue: 0,0:06:02.72,0:06:03.72,Default_JP,,0,0,0,,はーちゃん！
Dialogue: 0,0:06:02.72,0:06:03.72,Default_CN,,0,0,0,,小哈！
Dialogue: 0,0:06:06.20,0:06:07.90,Ha_Chan_JP,,0,0,0,,会いたかった！
Dialogue: 0,0:06:06.20,0:06:07.90,Ha_Chan_CN,,0,0,0,,好想你们！
Dialogue: 0,0:06:09.29,0:06:11.36,Default_JP,,0,0,0,,まあ 立派になって
Dialogue: 0,0:06:09.29,0:06:11.36,Default_CN,,0,0,0,,出落得大大方方了
Dialogue: 0,0:06:11.53,0:06:14.08,Miracle_JP,,0,0,0,,ほ...本当立派になってる
Dialogue: 0,0:06:11.53,0:06:14.08,Miracle_CN,,0,0,0,,真...真的变大了
Dialogue: 0,0:06:14.26,0:06:15.81,Magical_JP,,0,0,0,,ええ ビックリね
Dialogue: 0,0:06:14.26,0:06:15.81,Magical_CN,,0,0,0,,是的 很惊讶吧
Dialogue: 0,0:06:17.02,0:06:20.10,Default_JP,,0,0,0,,そっか ひーちゃん 帰ったんだ
Dialogue: 0,0:06:17.02,0:06:20.10,Default_CN,,0,0,0,,是吗 小菲回去了啊
Dialogue: 0,0:06:20.43,0:06:23.58,Ha_Chan_JP,,0,0,0,,うん ひーちゃんが みんなによろしくって
Dialogue: 0,0:06:20.43,0:06:23.58,Ha_Chan_CN,,0,0,0,,嗯 小菲让我代她跟大家问好
Dialogue: 0,0:06:24.24,0:06:25.81,Default_JP,,0,0,0,,帰ったの正解かも
Dialogue: 0,0:06:24.24,0:06:25.81,Default_CN,,0,0,0,,回去可能是正确选择
Dialogue: 0,0:06:26.17,0:06:29.70,Default_JP,,0,0,0,,魔法ガールっていうのが騒ぎを起こしているらしいから
Dialogue: 0,0:06:26.17,0:06:29.70,Default_CN,,0,0,0,,魔法少女什么的 好像也引起了骚动
Dialogue: 0,0:06:30.11,0:06:32.70,Miracle_JP,,0,0,0,,お父さんまで...なんで そんな事言うの？
Dialogue: 0,0:06:30.11,0:06:32.70,Miracle_CN,,0,0,0,,连爸爸都...为什么要这么说？
Dialogue: 0,0:06:32.98,0:06:35.61,Default_JP,,0,0,0,,え？ネットで話題だし
Dialogue: 0,0:06:32.98,0:06:35.61,Default_CN,,0,0,0,,怎么？因为网上都在热议啊
Dialogue: 0,0:06:35.93,0:06:36.66,Default_JP,,0,0,0,,うん
Dialogue: 0,0:06:35.93,0:06:36.66,Default_CN,,0,0,0,,嗯
Dialogue: 0,0:06:36.84,0:06:40.17,Default_JP,,0,0,0,,まあ 魔法っていうのは眉唾だけどさ
Dialogue: 0,0:06:36.84,0:06:40.17,Default_CN,,0,0,0,,不过 魔法之类的 都是骗局吧
Dialogue: 0,0:06:41.85,0:06:45.81,Miracle_JP,,0,0,0,,魔法ガールがそんな悪い事するとは思えないな
Dialogue: 0,0:06:41.85,0:06:45.81,Miracle_CN,,0,0,0,,魔法少女才不会做这种坏事
Dialogue: 0,0:06:45.95,0:06:47.48,Default_JP,,0,0,0,,なんで怒ってるの？
Dialogue: 0,0:06:45.95,0:06:47.48,Default_CN,,0,0,0,,为什么要生气？
Dialogue: 0,0:06:48.34,0:06:53.29,Default_JP,,0,0,0,,そうね 魔法つかいは そう悪い事はしないはず
Dialogue: 0,0:06:48.34,0:06:53.29,Default_CN,,0,0,0,,是啊 魔法师应该不会做这种坏事的
Dialogue: 0,0:06:56.66,0:07:00.86,Default_JP,,0,0,0,,長い間気になっていたのですが あなた 一体なんなんです？
Dialogue: 0,0:06:56.66,0:07:00.86,Default_CN,,0,0,0,,我在意很长时间了 你究竟是什么？
Dialogue: 0,0:07:01.20,0:07:02.22,Mofurun_JP,,0,0,0,,モフ？
Dialogue: 0,0:07:01.20,0:07:02.22,Mofurun_CN,,0,0,0,,mofu？
Dialogue: 0,0:07:02.78,0:07:09.30,Default_JP,,0,0,0,,主・プリキュア その家族に正体を悟られぬよう 屋根の上で待機する従順さ
Dialogue: 0,0:07:02.78,0:07:09.30,Default_CN,,0,0,0,,主人是Precure 为了不暴露 避开她的家人 乖乖地待在屋顶上
Dialogue: 0,0:07:09.61,0:07:13.16,Default_JP,,0,0,0,,その割には 主に対して横柄な言葉使い
Dialogue: 0,0:07:09.61,0:07:13.16,Default_CN,,0,0,0,,对待主人时 却会用教人做事的语气
Dialogue: 0,0:07:13.72,0:07:15.72,Default_JP,,0,0,0,,あなたの立場がさっぱりです
Dialogue: 0,0:07:13.72,0:07:15.72,Default_CN,,0,0,0,,完全搞不懂你的立场
Dialogue: 0,0:07:15.94,0:07:20.43,Mofurun_JP,,0,0,0,,じゅうじゅん？おうへいって何モフ？ちんぷんかんぷんモフ
Dialogue: 0,0:07:15.94,0:07:20.43,Mofurun_CN,,0,0,0,,那些词是什么意思？我不理解
Dialogue: 0,0:07:22.25,0:07:24.99,Default_JP,,0,0,0,,あなたにとって プリキュアとはなんです？
Dialogue: 0,0:07:22.25,0:07:24.99,Default_CN,,0,0,0,,对你而言 Precure是什么？
Dialogue: 0,0:07:25.45,0:07:28.46,Mofurun_JP,,0,0,0,,モフ みんなと仲良しモフ
Dialogue: 0,0:07:25.45,0:07:28.46,Mofurun_CN,,0,0,0,,mofu 跟大家都很要好
Dialogue: 0,0:07:28.74,0:07:31.56,Default_JP,,0,0,0,,あの 答えになってないんですけど
Dialogue: 0,0:07:28.74,0:07:31.56,Default_CN,,0,0,0,,我想 这不算是回答
Dialogue: 0,0:07:31.70,0:07:36.01,Mofurun_JP,,0,0,0,,みらいとは ずっとずーっと仲良しモフ
Dialogue: 0,0:07:31.70,0:07:36.01,Mofurun_CN,,0,0,0,,和未来是永远的好朋友
Dialogue: 0,0:07:38.18,0:07:40.60,Default_JP,,0,0,0,,それこそちんぷんかんぷんですが
Dialogue: 0,0:07:38.18,0:07:40.60,Default_CN,,0,0,0,,我才是不理解你
Dialogue: 0,0:07:41.25,0:07:47.70,Default_JP,,0,0,0,,私がドクロクシー様を敬愛しているように 彼女達を慕っているのですね
Dialogue: 0,0:07:41.25,0:07:47.70,Default_CN,,0,0,0,,就像我很敬爱毒骷髅库西大人一样 你应该也景仰着她们吧
Dialogue: 0,0:07:48.51,0:07:52.06,Mofurun_JP,,0,0,0,,モフ けいあいって何モフ？
Dialogue: 0,0:07:48.51,0:07:52.06,Mofurun_CN,,0,0,0,,mofu “敬爱”是什么？
Dialogue: 0,0:07:52.23,0:07:53.38,Default_JP,,0,0,0,,もう結構です
Dialogue: 0,0:07:52.23,0:07:53.38,Default_CN,,0,0,0,,不想聊了
Dialogue: 0,0:07:56.17,0:07:59.09,Ha_Chan_JP,,0,0,0,,はっ...はー
Dialogue: 0,0:07:56.17,0:07:59.09,Ha_Chan_CN,,0,0,0,,啊...哈
Dialogue: 0,0:07:59.87,0:08:01.40,Miracle_JP,,0,0,0,,はーちゃん 大丈夫？
Dialogue: 0,0:07:59.87,0:08:01.40,Miracle_CN,,0,0,0,,小哈 你还好吧？
Dialogue: 0,0:08:01.69,0:08:06.28,Ha_Chan_JP,,0,0,0,,頑張って身長伸ばしたから 足とか腕が痛くて
Dialogue: 0,0:08:01.69,0:08:06.28,Ha_Chan_CN,,0,0,0,,因为用劲拉长了身高 脚和手都好痛
Dialogue: 0,0:08:06.54,0:08:09.56,Miracle_CN,,0,0,0,,肌肉酸痛？就类似运动之后那种
Dialogue: 0,0:08:06.54,0:08:09.56,Miracle_JP,,0,0,0,,筋肉痛？運動の後みたいだね
Dialogue: 0,0:08:09.88,0:08:12.83,Magical_JP,,0,0,0,,ああ そういえば 5年ぶりに会って
Dialogue: 0,0:08:09.88,0:08:12.83,Magical_CN,,0,0,0,,啊 说起来隔了5年重逢那次
Dialogue: 0,0:08:13.12,0:08:18.12,Magical_JP,,0,0,0,,学生の頃に戻してもらった時も 筋肉痛で動けなくなったっけ
Dialogue: 0,0:08:13.12,0:08:18.12,Magical_CN,,0,0,0,, 变回学生时代身体后 也肌肉酸痛到动弹不得
Dialogue: 0,0:08:19.25,0:08:21.21,Miracle_JP,,0,0,0,,もう 無理するから
Dialogue: 0,0:08:19.25,0:08:21.21,Miracle_CN,,0,0,0,,不能太乱来啊
Dialogue: 0,0:08:21.46,0:08:22.77,Ha_Chan_JP,,0,0,0,,はー！
Dialogue: 0,0:08:21.46,0:08:22.77,Ha_Chan_CN,,0,0,0,,哈！
Dialogue: 0,0:08:22.79,0:08:27.04,Default_JP,,0,0,0,,なんと なんと狭くてみずぼらしいアジトなのでしょう
Dialogue: 0,0:08:22.79,0:08:27.04,Default_CN,,0,0,0,,何等 何等狭窄寒酸的基地啊
Dialogue: 0,0:08:27.64,0:08:29.73,Miracle_JP,,0,0,0,,アジトって 人聞き悪いんだけど
Dialogue: 0,0:08:27.64,0:08:29.73,Miracle_CN,,0,0,0,,基地这种说法很不中听诶
Dialogue: 0,0:08:30.10,0:08:32.88,Magical_JP,,0,0,0,,狭くてみずぼらしいも余計なお世話
Dialogue: 0,0:08:30.10,0:08:32.88,Magical_CN,,0,0,0,,狭窄寒酸也是多管闲事
Dialogue: 0,0:08:33.23,0:08:35.90,Default_JP,,0,0,0,,まあ いいでしょう 広さは関係ありません
Dialogue: 0,0:08:33.23,0:08:35.90,Default_CN,,0,0,0,,无所谓了 这与面积无关
Dialogue: 0,0:08:36.37,0:08:39.89,Default_JP,,0,0,0,,ここで深謀遠慮な作戦を立ててみせましょう
Dialogue: 0,0:08:36.37,0:08:39.89,Default_CN,,0,0,0,,就在这里制定深谋远虑的作战计划吧
Dialogue: 0,0:08:41.54,0:08:44.00,Default_JP,,0,0,0,,魔法界と津成木町
Dialogue: 0,0:08:41.54,0:08:44.00,Default_CN,,0,0,0,,这是魔法界 这是津成木镇
Dialogue: 0,0:08:44.52,0:08:50.19,Default_JP,,0,0,0,,あちこちで刻の魔獣が出没し 人々の時を奪って石像が出現している
Dialogue: 0,0:08:44.52,0:08:50.19,Default_CN,,0,0,0,,时间魔兽四处出没 夺走人们的时间 出现了石像
Dialogue: 0,0:08:50.86,0:08:54.04,Mofurun_JP,,0,0,0,,モフ お醤油とか胡椒は なんで置くモフ？
Dialogue: 0,0:08:50.86,0:08:54.04,Mofurun_CN,,0,0,0,,mofu 为什么把酱油和胡椒拿出来？
Dialogue: 0,0:08:54.35,0:08:56.52,Default_JP,,0,0,0,,分かりやすいように見立てたんです
Dialogue: 0,0:08:54.35,0:08:56.52,Default_CN,,0,0,0,,为了直观一点 拿来做比方的
Dialogue: 0,0:08:56.80,0:09:04.36,Magical_JP,,0,0,0,,ああ だったら 魔法界は胡椒の方がいいし 津成木町も塩と 対になる感じで分かりやすいから
Dialogue: 0,0:08:56.80,0:09:04.36,Magical_CN,,0,0,0,,那么的话 魔法界用胡椒比较好 津成木镇就顺带着用盐 更简单易懂
Dialogue: 0,0:09:04.51,0:09:07.80,Miracle_JP,,0,0,0,,だったら 津成木町は つなぎせんべいの方が分かりやすいよ
Dialogue: 0,0:09:04.51,0:09:07.80,Miracle_CN,,0,0,0,,那津成木镇用津成木仙贝来得更直接吧
Dialogue: 0,0:09:07.92,0:09:10.86,Mofurun_JP,,0,0,0,,街じゃないモフ おせんべいは おせんべいモフ
Dialogue: 0,0:09:07.92,0:09:10.86,Mofurun_CN,,0,0,0,,怎么是城镇呢 仙贝就是仙贝啊
Dialogue: 0,0:09:11.13,0:09:13.40,Default_JP,,0,0,0,,だから これは 分かりやすく例えで
Dialogue: 0,0:09:11.13,0:09:13.40,Default_CN,,0,0,0,,都说了是比较直观的比方
Dialogue: 0,0:09:13.45,0:09:14.70,Ha_Chan_JP,,0,0,0,,はー 美味しい！
Dialogue: 0,0:09:13.45,0:09:14.70,Ha_Chan_CN,,0,0,0,,哈 好吃！
Dialogue: 0,0:09:14.77,0:09:17.97,Default_JP,,0,0,0,,もーやめ 見立てるのやめ！
Dialogue: 0,0:09:14.77,0:09:17.97,Default_CN,,0,0,0,,不打了 不打比方了！
Dialogue: 0,0:09:18.42,0:09:25.00,Default_JP,,0,0,0,,何を言いたかったかというと 刻の魔獣の活動範囲は 魔法界か津成木町か
Dialogue: 0,0:09:18.42,0:09:25.00,Default_CN,,0,0,0,,我想说的意思是 时间魔兽的活动范围在魔法界和津成木镇
Dialogue: 0,0:09:25.56,0:09:28.84,Default_JP,,0,0,0,,ヤツは このどちらかに潜伏してるのでは
Dialogue: 0,0:09:25.56,0:09:28.84,Default_CN,,0,0,0,,他是不是就潜伏在这两者的某处
Dialogue: 0,0:09:29.45,0:09:31.12,Default_JP,,0,0,0,,という事です
Dialogue: 0,0:09:29.45,0:09:31.12,Default_CN,,0,0,0,,完毕
Dialogue: 0,0:09:31.80,0:09:33.95,Miracle_JP,,0,0,0,,普通にそう言えばいいのに
Dialogue: 0,0:09:31.80,0:09:33.95,Miracle_CN,,0,0,0,,你直接说不就行了
Dialogue: 0,0:09:34.26,0:09:35.26,Magical_JP,,0,0,0,,うん
Dialogue: 0,0:09:34.26,0:09:35.26,Ha_Chan_CN,,0,0,0,,嗯
Dialogue: 0,0:09:35.58,0:09:40.40,Magical_JP,,0,0,0,,魔法界も津成木町も お父様や校長先生が調べたはず
Dialogue: 0,0:09:35.58,0:09:40.40,Magical_CN,,0,0,0,,魔法界和津成木镇 爸爸和校长应该都调查过了
Dialogue: 0,0:09:40.80,0:09:42.85,Magical_JP,,0,0,0,,でも 何も見つかっていない
Dialogue: 0,0:09:40.80,0:09:42.85,Magical_CN,,0,0,0,,可是没有任何发现
Dialogue: 0,0:09:43.44,0:09:44.77,Magical_JP,,0,0,0,,うん...おっ！
Dialogue: 0,0:09:43.44,0:09:44.77,Magical_CN,,0,0,0,,唔...啊！
Dialogue: 0,0:09:55.39,0:09:55.71,Default_JP,,0,0,0,,あっ...
Dialogue: 0,0:09:55.39,0:09:55.71,Default_CN,,0,0,0,,啊...
Dialogue: 0,0:09:55.80,0:09:56.24,Magical_JP,,0,0,0,,あっ！
Dialogue: 0,0:09:55.80,0:09:56.24,Magical_CN,,0,0,0,,啊！
Dialogue: 0,0:09:58.09,0:09:59.80,Magical_JP,,0,0,0,,ああ すみません
Dialogue: 0,0:09:58.09,0:09:59.80,Magical_CN,,0,0,0,,啊 对不起
Dialogue: 0,0:10:00.13,0:10:01.46,Default_JP,,0,0,0,,キュアップ・ラパパ
Dialogue: 0,0:10:00.13,0:10:01.46,CUPRAPP_CN,,0,0,0,,Cure Up Rapapa
Dialogue: 0,0:10:01.60,0:10:03.50,Default_JP,,0,0,0,,答案用紙をこちらへ
Dialogue: 0,0:10:01.60,0:10:03.50,Default_CN,,0,0,0,,众卷归位
Dialogue: 0,0:10:10.06,0:10:12.10,Default_JP,,0,0,0,,お疲れのご様子ですね
Dialogue: 0,0:10:10.06,0:10:12.10,Default_CN,,0,0,0,,你似乎很劳累呢
Dialogue: 0,0:10:12.44,0:10:17.47,Magical_JP,,0,0,0,,徹夜でテストの丸付けをしてたもので すみません
Dialogue: 0,0:10:12.44,0:10:17.47,Magical_CN,,0,0,0,,我通宵批改试卷 对不起
Dialogue: 0,0:10:17.67,0:10:21.77,Default_JP,,0,0,0,,無理なさらず 困った事があれば 相談なさい
Dialogue: 0,0:10:17.67,0:10:21.77,Default_CN,,0,0,0,,不要勉强 有困难跟我们商量
Dialogue: 0,0:10:22.35,0:10:23.37,Magical_JP,,0,0,0,,はい
Dialogue: 0,0:10:22.35,0:10:23.37,Magical_CN,,0,0,0,,是
Dialogue: 0,0:10:24.80,0:10:30.14,Magical_JP,,0,0,0,,いい 生徒に飲まれちゃダメ 自信 威厳 尊厳よ リコ先生
Dialogue: 0,0:10:24.80,0:10:30.14,Magical_CN,,0,0,0,,听好 不能被学生们压一头 要自信 威严 尊严 李可老师
Dialogue: 0,0:10:33.12,0:10:33.99,Magical_JP,,0,0,0,,よし！
Dialogue: 0,0:10:33.12,0:10:33.99,Magical_CN,,0,0,0,,好！
Dialogue: 0,0:10:49.07,0:10:51.22,Magical_JP,,0,0,0,,これから 授業を始めます
Dialogue: 0,0:10:49.07,0:10:51.22,Magical_CN,,0,0,0,,现在开始上课
Dialogue: 0,0:10:52.40,0:10:53.63,Magical_JP,,0,0,0,,おっ...
Dialogue: 0,0:10:52.40,0:10:53.63,Magical_CN,,0,0,0,,啊...
Dialogue: 0,0:10:57.08,0:10:58.02,Miracle_JP,,0,0,0,,えっ！
Dialogue: 0,0:10:57.08,0:10:58.02,Miracle_CN,,0,0,0,,咦！
Dialogue: 0,0:11:01.14,0:11:01.63,Default_JP,,0,0,0,,あっ！
Dialogue: 0,0:11:01.14,0:11:01.63,Default_CN,,0,0,0,,啊！
Dialogue: 0,0:11:02.40,0:11:03.44,Default_JP,,0,0,0,,どけー！
Dialogue: 0,0:11:02.40,0:11:03.44,Default_CN,,0,0,0,,闪开！
Dialogue: 0,0:11:03.53,0:11:04.45,Default_JP,,0,0,0,,引ったくりだー！
Dialogue: 0,0:11:03.53,0:11:04.45,Default_CN,,0,0,0,,有抢包的！
Dialogue: 0,0:11:05.73,0:11:06.49,Miracle_JP,,0,0,0,,あっ！
Dialogue: 0,0:11:05.73,0:11:06.49,Miracle_CN,,0,0,0,,啊！
Dialogue: 0,0:11:06.67,0:11:07.97,Default_JP,,0,0,0,,どけー どけー！
Dialogue: 0,0:11:06.67,0:11:07.97,Default_CN,,0,0,0,,闪开 闪开！
Dialogue: 0,0:11:10.35,0:11:11.56,Miracle_JP,,0,0,0,,キュアップ・ラパパ！
Dialogue: 0,0:11:10.35,0:11:11.56,Curerpp_MR,,0,0,0,,Cure Up Rapapa !
Dialogue: 0,0:11:11.71,0:11:12.53,Miracle_JP,,0,0,0,,止まりなさい！
Dialogue: 0,0:11:11.71,0:11:12.53,Miracle_CN,,0,0,0,,给我停下！
Dialogue: 0,0:11:17.17,0:11:18.33,Default_JP,,0,0,0,,なんで？
Dialogue: 0,0:11:17.17,0:11:18.33,Default_CN,,0,0,0,,怎么回事？
Dialogue: 0,0:11:19.08,0:11:20.97,Miracle_JP,,0,0,0,,これで一件落着っと
Dialogue: 0,0:11:19.08,0:11:20.97,Miracle_CN,,0,0,0,,这样就搞定一桩
Dialogue: 0,0:11:21.38,0:11:23.94,Miracle_JP,,0,0,0,,あ 授業始まっちゃう 行こう
Dialogue: 0,0:11:21.38,0:11:23.94,Miracle_CN,,0,0,0,,啊 要上课了 走吧
Dialogue: 0,0:11:24.08,0:11:24.82,Mofurun_JP,,0,0,0,,モフ
Dialogue: 0,0:11:24.08,0:11:24.82,Mofurun_CN,,0,0,0,,mofu
Dialogue: 0,0:11:27.68,0:11:29.63,Mofurun_JP,,0,0,0,,とっても忙しいモフ
Dialogue: 0,0:11:27.68,0:11:29.63,Mofurun_CN,,0,0,0,,你好忙啊
Dialogue: 0,0:11:29.78,0:11:30.49,Miracle_JP,,0,0,0,,だね
Dialogue: 0,0:11:29.78,0:11:30.49,Miracle_CN,,0,0,0,,是啊
Dialogue: 0,0:11:30.67,0:11:33.20,Mofurun_JP,,0,0,0,,リコとも全然会えないモフ
Dialogue: 0,0:11:30.67,0:11:33.20,Mofurun_CN,,0,0,0,,也见不到李可
Dialogue: 0,0:11:34.64,0:11:38.41,Miracle_JP,,0,0,0,,仕方ないよ リコも忙しいだろうしさ
Dialogue: 0,0:11:34.64,0:11:38.41,Miracle_CN,,0,0,0,,没办法啊 李可也挺忙的吧
Dialogue: 0,0:11:39.41,0:11:40.42,Mofurun_JP,,0,0,0,,モフ...
Dialogue: 0,0:11:39.41,0:11:40.42,Mofurun_CN,,0,0,0,,mofu...
Dialogue: 0,0:11:46.26,0:11:48.28,Miracle_JP,,0,0,0,,あっ また過去
Dialogue: 0,0:11:46.26,0:11:48.28,Miracle_CN,,0,0,0,,啊 又是过去
Dialogue: 0,0:11:48.50,0:11:49.42,Magical_JP,,0,0,0,,私も
Dialogue: 0,0:11:48.50,0:11:49.42,Magical_CN,,0,0,0,,我也见到了
Dialogue: 0,0:11:49.69,0:11:52.36,Default_JP,,0,0,0,,そんなライトに過去を見ているのですか？
Dialogue: 0,0:11:49.69,0:11:52.36,Default_CN,,0,0,0,,是在那种光芒里看到过去的吗？
Dialogue: 0,0:11:52.56,0:11:53.19,Miracle_JP,,0,0,0,,まあ
Dialogue: 0,0:11:52.56,0:11:53.19,Miracle_CN,,0,0,0,,是吧
Dialogue: 0,0:11:53.63,0:11:58.60,Magical_JP,,0,0,0,,異常な事だって分かってる さすがにこれも なんとかしないと
Dialogue: 0,0:11:53.63,0:11:58.60,Magical_CN,,0,0,0,,我们知道这很异常 也该想想解决办法的
Dialogue: 0,0:12:12.17,0:12:12.62,Miracle_JP,,0,0,0,,ん？
Dialogue: 0,0:12:12.17,0:12:12.62,Miracle_CN,,0,0,0,,嗯？
Dialogue: 0,0:12:17.71,0:12:18.93,Miracle_JP,,0,0,0,,え え
Dialogue: 0,0:12:17.71,0:12:18.93,Miracle_CN,,0,0,0,,什么情况
Dialogue: 0,0:12:19.52,0:12:19.87,Miracle_JP,,0,0,0,,おっ...
Dialogue: 0,0:12:19.52,0:12:19.87,Miracle_CN,,0,0,0,,哦...
Dialogue: 0,0:12:19.93,0:12:21.64,Mofurun_JP,,0,0,0,,みんな眠れないモフ？
Dialogue: 0,0:12:19.93,0:12:21.64,Mofurun_CN,,0,0,0,,大家都睡不着？
Dialogue: 0,0:12:33.46,0:12:35.84,Ha_Chan_JP,,0,0,0,,ハッ...はー！
Dialogue: 0,0:12:33.46,0:12:35.84,Ha_Chan_CN,,0,0,0,,哈...哈！
Dialogue: 0,0:12:36.04,0:12:37.78,Magical_JP,,0,0,0,,風が気持ちいい
Dialogue: 0,0:12:36.04,0:12:37.78,Magical_CN,,0,0,0,,风好舒爽
Dialogue: 0,0:12:38.33,0:12:39.80,Mofurun_JP,,0,0,0,,モフ
Dialogue: 0,0:12:38.33,0:12:39.80,Mofurun_CN,,0,0,0,,mofu
Dialogue: 0,0:12:40.19,0:12:42.97,Miracle_JP,,0,0,0,,久しぶりだね 星空の散歩
Dialogue: 0,0:12:40.19,0:12:42.97,Miracle_CN,,0,0,0,,好久没试过在星空下散步了
Dialogue: 0,0:12:44.54,0:12:45.06,Miracle_JP,,0,0,0,,え？
Dialogue: 0,0:12:44.54,0:12:45.06,Miracle_CN,,0,0,0,,欸？
Dialogue: 0,0:12:45.22,0:12:45.82,Magical_JP,,0,0,0,,なに？
Dialogue: 0,0:12:45.22,0:12:45.82,Magical_CN,,0,0,0,,怎么了？
Dialogue: 0,0:12:47.61,0:12:49.06,Ha_Chan_JP,,0,0,0,,はー！
Dialogue: 0,0:12:47.61,0:12:49.06,Ha_Chan_CN,,0,0,0,,哈！
Dialogue: 0,0:12:58.83,0:13:00.26,Ha_Chan_JP,,0,0,0,,ハッ ハッ ハッ
Dialogue: 0,0:12:58.83,0:13:00.26,Ha_Chan_CN,,0,0,0,,哈哈哈
Dialogue: 0,0:13:00.62,0:13:02.91,Miracle_JP,,0,0,0,,今のわくわくもんだよ！
Dialogue: 0,0:13:00.62,0:13:02.91,Miracle_CN,,0,0,0,,刚才的真让人心动不已！
Dialogue: 0,0:13:03.08,0:13:05.71,Magical_JP,,0,0,0,,ハッ ハッ ハッ
Dialogue: 0,0:13:03.08,0:13:05.71,Magical_CN,,0,0,0,,哈哈哈 哈哈哈哈
Dialogue: 0,0:13:07.29,0:13:11.88,Miracle_JP,,0,0,0,,そうそう 秋の間だけ 月見イチゴメロンパンが出るんだよ
Dialogue: 0,0:13:07.29,0:13:11.88,Miracle_CN,,0,0,0,,对对 只在秋季 会出草莓蜜瓜包月饼
Dialogue: 0,0:13:12.20,0:13:13.46,Ha_Chan_JP,,0,0,0,,はー どんなの？
Dialogue: 0,0:13:12.20,0:13:13.46,Ha_Chan_CN,,0,0,0,,哈 是怎么样的？
Dialogue: 0,0:13:13.73,0:13:15.49,Miracle_JP,,0,0,0,,目玉焼きが挟んであるの
Dialogue: 0,0:13:13.73,0:13:15.49,Miracle_CN,,0,0,0,,有夹着荷包蛋的
Dialogue: 0,0:13:15.72,0:13:17.31,Magical_JP,,0,0,0,,なんか迷走してない？
Dialogue: 0,0:13:15.72,0:13:17.31,Magical_CN,,0,0,0,,是不是有点剑走偏锋啊？
Dialogue: 0,0:13:17.53,0:13:19.74,Mofurun_JP,,0,0,0,,モフ とっても美味しいモフ
Dialogue: 0,0:13:17.53,0:13:19.74,Mofurun_CN,,0,0,0,,mofu 可好吃了
Dialogue: 0,0:13:19.78,0:13:25.17,Miracle_JP,,0,0,0,,うん 騙されたと思って食べてみて 秋になったら みんなで食べよう
Dialogue: 0,0:13:19.78,0:13:25.17,Miracle_CN,,0,0,0,,嗯 就听我一次尝尝看 到秋天了 大家一起去吃吧
Dialogue: 0,0:13:25.36,0:13:27.47,Ha_Chan_JP,,0,0,0,,はー 楽しみ！
Dialogue: 0,0:13:25.36,0:13:27.47,Ha_Chan_CN,,0,0,0,,哈 好期待！
Dialogue: 0,0:13:30.57,0:13:31.37,Mofurun_JP,,0,0,0,,モフ
Dialogue: 0,0:13:30.57,0:13:31.37,Mofurun_CN,,0,0,0,,mofu
Dialogue: 0,0:13:33.01,0:13:36.03,Mofurun_JP,,0,0,0,,お月様が雲で隠れちゃったモフ
Dialogue: 0,0:13:33.01,0:13:36.03,Mofurun_CN,,0,0,0,,月亮被云遮住了
Dialogue: 0,0:13:38.67,0:13:40.62,Magical_JP,,0,0,0,,どこに隠れてるんだか
Dialogue: 0,0:13:38.67,0:13:40.62,Magical_CN,,0,0,0,,藏在某个地方啊
Dialogue: 0,0:13:44.70,0:13:45.36,Ha_Chan_JP,,0,0,0,,おっ...
Dialogue: 0,0:13:44.70,0:13:45.36,Ha_Chan_CN,,0,0,0,,啊...
Dialogue: 0,0:13:45.64,0:13:48.89,Magical_JP,,0,0,0,,魔法界にもこっちにもいないなんてね
Dialogue: 0,0:13:45.64,0:13:48.89,Magical_CN,,0,0,0,,居然不在魔法界 也不在这里
Dialogue: 0,0:13:49.07,0:13:52.15,Magical_JP,,0,0,0,,石像になったみんなが苦しんでいない
Dialogue: 0,0:13:49.07,0:13:52.15,Magical_CN,,0,0,0,,变成石像的人们 也并不痛苦
Dialogue: 0,0:13:53.25,0:13:55.49,Magical_JP,,0,0,0,,望む世界にいるんでしょ
Dialogue: 0,0:13:53.25,0:13:55.49,Magical_CN,,0,0,0,,他们都在所希望的世界里吧
Dialogue: 0,0:14:00.68,0:14:01.37,Miracle_JP,,0,0,0,,うん...
Dialogue: 0,0:14:00.68,0:14:01.37,Miracle_CN,,0,0,0,,嗯...
Dialogue: 0,0:14:01.72,0:14:03.78,Magical_JP,,0,0,0,,それが せめてもの救いね
Dialogue: 0,0:14:01.72,0:14:03.78,Magical_CN,,0,0,0,,这也算是一点慰藉吧
Dialogue: 0,0:14:04.23,0:14:11.23,Miracle_JP,,0,0,0,,でも みんなでいなくなっちゃうなんて 残された私達 寂しいじゃん
Dialogue: 0,0:14:04.23,0:14:11.23,Miracle_CN,,0,0,0,,可是大家都不在了 被留下来的我们 岂不是很孤单
Dialogue: 0,0:14:11.47,0:14:17.23,Ha_Chan_JP,,0,0,0,,うん 刻の魔獣を止めないと みんなでこうやって会えなくなっちゃうよ
Dialogue: 0,0:14:11.47,0:14:17.23,Ha_Chan_CN,,0,0,0,,嗯 不制止时间魔兽的话 就会再也见不到大家了
Dialogue: 0,0:14:17.54,0:14:20.88,Mofurun_JP,,0,0,0,,モフ みんなに会いたいモフ
Dialogue: 0,0:14:17.54,0:14:20.88,Mofurun_CN,,0,0,0,,mofu 好想念大家
Dialogue: 0,0:14:22.60,0:14:23.44,Magical_JP,,0,0,0,,おっ...
Dialogue: 0,0:14:22.60,0:14:23.44,Magical_CN,,0,0,0,,啊...
Dialogue: 0,0:14:25.40,0:14:30.77,Magical_JP,,0,0,0,,ねえ あの雲 月と重なって なんだかカタツムリニアみたい
Dialogue: 0,0:14:25.40,0:14:30.77,Magical_CN,,0,0,0,,你们看 那朵云和月亮重叠起来 是不是很像蜗牛列车啊
Dialogue: 0,0:14:31.14,0:14:31.98,Ha_Chan_JP,,0,0,0,,はー！
Dialogue: 0,0:14:31.14,0:14:31.98,Ha_Chan_CN,,0,0,0,,哈！
Dialogue: 0,0:14:32.13,0:14:33.53,Mofurun_JP,,0,0,0,,本当モフ
Dialogue: 0,0:14:32.13,0:14:33.53,Mofurun_CN,,0,0,0,,真的诶
Dialogue: 0,0:14:35.65,0:14:37.52,Ha_Chan_JP,,0,0,0,,カタツムリニア
Dialogue: 0,0:14:35.65,0:14:37.52,Ha_Chan_CN,,0,0,0,,蜗牛列车
Dialogue: 0,0:14:43.32,0:14:44.30,Miracle_JP,,0,0,0,,分かった
Dialogue: 0,0:14:43.32,0:14:44.30,Miracle_CN,,0,0,0,,我知道了
Dialogue: 0,0:14:44.59,0:14:45.31,Ha_Chan_JP,,0,0,0,,えっ？
Dialogue: 0,0:14:44.59,0:14:45.31,Ha_Chan_CN,,0,0,0,,诶？
Dialogue: 0,0:14:46.06,0:14:47.62,Miracle_JP,,0,0,0,,刻の魔獣がいる場所
Dialogue: 0,0:14:46.06,0:14:47.62,Miracle_CN,,0,0,0,,时间魔兽在哪里
Dialogue: 0,0:14:48.05,0:14:48.59,Ha_Chan_JP,,0,0,0,,え！
Dialogue: 0,0:14:48.05,0:14:48.59,Magical_CN,,0,0,0,,诶！
Dialogue: 0,0:14:49.00,0:14:50.41,Mofurun_JP,,0,0,0,,本当モフ？
Dialogue: 0,0:14:49.00,0:14:50.41,Mofurun_CN,,0,0,0,,真的吗
Dialogue: 0,0:14:50.41,0:14:52.41,Mofurun_CN,,0,0,0,,
Dialogue: 0,0:14:54.40,0:14:55.81,Default_JP,,0,0,0,,準備はいいですか？
Dialogue: 0,0:14:54.40,0:14:55.81,Default_CN,,0,0,0,,准备好了吗？
Dialogue: 0,0:14:56.06,0:14:56.82,Miracle_JP,,0,0,0,,ええ
Dialogue: 0,0:14:56.06,0:14:56.82,Miracle_CN,,0,0,0,,嗯
Dialogue: 0,0:14:57.30,0:14:58.53,Default_JP,,0,0,0,,では 行きますよ
Dialogue: 0,0:14:57.30,0:14:58.53,Default_CN,,0,0,0,,那我们出发了
Dialogue: 0,0:14:59.18,0:15:00.24,Default_JP,,0,0,0,,イードウ
Dialogue: 0,0:14:59.18,0:15:00.24,Default_CN,,0,0,0,,移动
Dialogue: 0,0:15:04.80,0:15:06.96,Default_JP,,0,0,0,,ここにいるというのですか？
Dialogue: 0,0:15:04.80,0:15:06.96,Default_CN,,0,0,0,,是在这里吗？
Dialogue: 0,0:15:07.12,0:15:11.69,Miracle_JP,,0,0,0,,うん 魔法界と津成木町の間にある ここなら
Dialogue: 0,0:15:07.12,0:15:11.69,Miracle_CN,,0,0,0,,嗯 在魔法界与津成木镇之间的这个地方
Dialogue: 0,0:15:12.24,0:15:17.24,Magical_JP,,0,0,0,,魔法界と津成木町 どちらの犯行現場にも近い 全てに説明がつく
Dialogue: 0,0:15:12.24,0:15:17.24,Magical_CN,,0,0,0,,距离魔法界和津成木镇的犯罪现场都很近 这下都说得通了
Dialogue: 0,0:15:17.44,0:15:18.70,Ha_Chan_JP,,0,0,0,,みらい 冴えてる
Dialogue: 0,0:15:17.44,0:15:18.70,Ha_Chan_CN,,0,0,0,,未来好聪明
Dialogue: 0,0:15:18.75,0:15:19.58,Mofurun_JP,,0,0,0,,モフ
Dialogue: 0,0:15:18.75,0:15:19.58,Mofurun_CN,,0,0,0,,mofu
Dialogue: 0,0:15:19.70,0:15:25.70,Default_JP,,0,0,0,,仮にいたとしてです ここ狭間の世界は広大ですよ どう探すのですか？
Dialogue: 0,0:15:19.70,0:15:25.70,Default_CN,,0,0,0,,假设是的话 这夹缝中的世界是很宽广的 该怎么搜索啊？
Dialogue: 0,0:15:26.86,0:15:28.10,Magical_JP,,0,0,0,,それは...
Dialogue: 0,0:15:26.86,0:15:28.10,Magical_CN,,0,0,0,,这个的话...
Dialogue: 0,0:15:28.72,0:15:29.47,Miracle_JP,,0,0,0,,ガッツで
Dialogue: 0,0:15:28.72,0:15:29.47,Miracle_CN,,0,0,0,,靠毅力
Dialogue: 0,0:15:29.54,0:15:30.25,Default_JP,,0,0,0,,はぁ...
Dialogue: 0,0:15:29.54,0:15:30.25,Default_CN,,0,0,0,,啊...
Dialogue: 0,0:15:30.41,0:15:32.36,Mofurun_JP,,0,0,0,,モフ なんかあるモフ！
Dialogue: 0,0:15:30.41,0:15:32.36,Mofurun_CN,,0,0,0,,mofu 那里有什么！
Dialogue: 0,0:15:32.37,0:15:33.65,Default_CN,,0,0,0,,诶！
Dialogue: 0,0:15:32.37,0:15:33.65,Default_JP,,0,0,0,,えっ！
Dialogue: 0,0:15:36.12,0:15:36.90,Miracle_JP,,0,0,0,,なにあれ？
Dialogue: 0,0:15:36.12,0:15:36.90,Miracle_CN,,0,0,0,,那是什么？
Dialogue: 0,0:15:37.01,0:15:39.69,Default_JP,,0,0,0,,ウソでしょ そう簡単に見つかるはずが
Dialogue: 0,0:15:37.01,0:15:39.69,Default_CN,,0,0,0,,不是吧 怎么可能轻而易举就找到
Dialogue: 0,0:15:40.19,0:15:41.80,Ha_Chan_JP,,0,0,0,,ねえ イードウして
Dialogue: 0,0:15:40.19,0:15:41.80,Ha_Chan_CN,,0,0,0,,哎 快用“移动”啊
Dialogue: 0,0:15:42.03,0:15:43.01,Default_JP,,0,0,0,,ああ はいはい
Dialogue: 0,0:15:42.03,0:15:43.01,Default_CN,,0,0,0,,啊 好的
Dialogue: 0,0:15:43.33,0:15:44.43,Default_JP,,0,0,0,,イードウ
Dialogue: 0,0:15:43.33,0:15:44.43,Default_CN,,0,0,0,,移动
Dialogue: 0,0:15:46.27,0:15:47.99,Miracle_JP,,0,0,0,,な...なに これ？
Dialogue: 0,0:15:46.27,0:15:47.99,Miracle_CN,,0,0,0,,这...这是什么？
Dialogue: 0,0:15:50.62,0:15:53.54,Magical_JP,,0,0,0,,ど ど どうなってるの？
Dialogue: 0,0:15:50.62,0:15:53.54,Magical_CN,,0,0,0,,究 究 究竟是什么？
Dialogue: 0,0:15:56.89,0:15:58.06,Default_JP,,0,0,0,,まさか...
Dialogue: 0,0:15:56.89,0:15:58.06,Default_CN,,0,0,0,,难不成...
