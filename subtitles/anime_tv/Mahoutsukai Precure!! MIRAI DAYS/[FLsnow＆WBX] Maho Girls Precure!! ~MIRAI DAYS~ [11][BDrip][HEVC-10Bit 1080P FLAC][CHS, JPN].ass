Dialogue: 0,0:02:42.72,0:02:43.85,Default_JP,,0,0,0,,なに？
Dialogue: 0,0:02:42.72,0:02:43.85,Default_CN,,0,0,0,,那是什么？
Dialogue: 0,0:03:18.16,0:03:20.49,DarkMHS_JP,,0,0,0,,いくぞ プリキュア
Dialogue: 0,0:03:18.16,0:03:20.49,DarkMHS_CN,,0,0,0,,接招 Precure
Dialogue: 0,0:03:24.39,0:03:25.53,Magical_JP,,0,0,0,,{\fs50\b1}ムーンストーン！
Dialogue: 0,0:03:24.39,0:03:25.53,Curerpp_LK,,0,0,0,,Moonstone !
Dialogue: 0,0:03:24.39,0:03:25.53,Magical_CN,,0,0,0,,{\fs50\b1}月长石！
Dialogue: 0,0:03:26.90,0:03:28.05,Ha_Chan_JP,,0,0,0,,{\fs50\b1}ピンクトルマリン！
Dialogue: 0,0:03:26.90,0:03:28.05,Curerpp_FL,,0,0,0,,Pink Tourmaline !
Dialogue: 0,0:03:26.90,0:03:28.05,Ha_Chan_CN,,0,0,0,,{\fs50}粉红碧玺！
Dialogue: 0,0:03:33.15,0:03:34.32,Miracle_JP,,0,0,0,,{\fs50\b1}アクアマリン！
Dialogue: 0,0:03:33.15,0:03:34.32,Curerpp_MR,,0,0,0,,Aquamarine !
Dialogue: 0,0:03:33.15,0:03:34.32,Miracle_CN,,0,0,0,,{\fs50}福海石！
Dialogue: 0,0:03:49.34,0:03:51.15,DarkMHS_JP,,0,0,0,,わぁ！
Dialogue: 0,0:03:49.34,0:03:51.15,DarkMHS_CN,,0,0,0,,嗷！
Dialogue: 0,0:03:55.54,0:03:58.29,DarkMHS_JP,,0,0,0,,時と生まれし宇宙
Dialogue: 0,0:03:55.54,0:03:58.29,DarkMHS_CN,,0,0,0,,与时间一同诞生的宇宙
Dialogue: 0,0:04:09.31,0:04:11.33,DarkMHS_JP,,0,0,0,,混沌から命へ
Dialogue: 0,0:04:09.31,0:04:11.33,DarkMHS_CN,,0,0,0,,来自混沌的生命
Dialogue: 0,0:04:11.60,0:04:13.63,DarkMHS_JP,,0,0,0,,命から混沌へ
Dialogue: 0,0:04:11.60,0:04:13.63,DarkMHS_CN,,0,0,0,,回归混沌的生命
Dialogue: 0,0:04:18.64,0:04:21.66,DarkMHS_JP,,0,0,0,,全ての循環は断たれる
Dialogue: 0,0:04:18.64,0:04:21.66,DarkMHS_CN,,0,0,0,,切断所有的循环
Dialogue: 0,0:04:27.68,0:04:29.25,Miracle_JP,,0,0,0,,私達が止める...
Dialogue: 0,0:04:27.68,0:04:29.25,Miracle_CN,,0,0,0,,我们会阻止的...
Dialogue: 0,0:04:30.28,0:04:31.02,Miracle_JP,,0,0,0,,あなたを！
Dialogue: 0,0:04:30.28,0:04:31.02,Miracle_CN,,0,0,0,,阻止你！
Dialogue: 0,0:04:32.19,0:04:34.06,Miracle_JP,,0,0,0,,わあっ 止めて！
Dialogue: 0,0:04:32.19,0:04:34.06,Miracle_CN,,0,0,0,,哇 停下啊！
Dialogue: 0,0:04:36.68,0:04:37.46,Magical_JP,,0,0,0,,ミラクル...
Dialogue: 0,0:04:36.68,0:04:37.46,Magical_CN,,0,0,0,,Miracle...
Dialogue: 0,0:04:54.90,0:04:57.59,DarkMHS_JP,,0,0,0,,永劫の命のラパーパよ
Dialogue: 0,0:04:54.90,0:04:57.59,DarkMHS_CN,,0,0,0,,永劫生命的拉帕帕啊
Dialogue: 0,0:04:58.42,0:05:02.87,DarkMHS_JP,,0,0,0,,太陽が枯れ 月の輝きが失せ
Dialogue: 0,0:04:58.42,0:05:02.87,DarkMHS_CN,,0,0,0,,即使 太阳枯竭 月光不再
Dialogue: 0,0:05:03.35,0:05:07.08,DarkMHS_JP,,0,0,0,,馴染みの銀河が役目を終えても
Dialogue: 0,0:05:03.35,0:05:07.08,DarkMHS_CN,,0,0,0,,习以为常的银河结束使命
Dialogue: 0,0:05:07.98,0:05:13.03,DarkMHS_JP,,0,0,0,,一人残る 数多を見守り続ける
Dialogue: 0,0:05:07.98,0:05:13.03,DarkMHS_CN,,0,0,0,,你也会独自留下 继续守护着一切
Dialogue: 0,0:05:13.81,0:05:15.95,DarkMHS_JP,,0,0,0,,寂しき定め
Dialogue: 0,0:05:13.81,0:05:15.95,DarkMHS_CN,,0,0,0,,孤寂的宿命
Dialogue: 0,0:05:23.44,0:05:26.36,Mofurun_JP,,0,0,0,,ミラクル！マジカル！
Dialogue: 0,0:05:23.44,0:05:26.36,Mofurun_CN,,0,0,0,,Miracle！Magical！
Dialogue: 0,0:05:29.99,0:05:32.40,DarkMHS_JP,,0,0,0,,皆と永遠にいられる
Dialogue: 0,0:05:29.99,0:05:32.40,DarkMHS_CN,,0,0,0,,能与众人一同留在永远
Dialogue: 0,0:05:33.64,0:05:35.94,DarkMHS_JP,,0,0,0,,皆とどまれるぞ
Dialogue: 0,0:05:33.64,0:05:35.94,DarkMHS_CN,,0,0,0,,众人都能停留
Dialogue: 0,0:05:39.15,0:05:44.05,DarkMHS_JP,,0,0,0,,望む過去 望む時間に
Dialogue: 0,0:05:39.15,0:05:44.05,DarkMHS_CN,,0,0,0,,留在渴望的过去 停在渴望的时间
Dialogue: 0,0:00:00.00,0:00:00.00,Default_CN,,0,0,0,,
Dialogue: 0,0:05:47.57,0:05:52.49,Default_CN,,0,0,300,,{\fad(500,0)}未来的决断
Dialogue: 0,0:00:00.00,0:00:00.00,Default_CN,,0,0,0,,
Dialogue: 0,0:06:08.90,0:06:12.35,Miracle_JP,,0,0,0,,楽しい過去に閉じこもるとか どうでもいい！
Dialogue: 0,0:06:08.90,0:06:12.35,Miracle_CN,,0,0,0,,是否能待在快乐的过去 我不在乎！
Dialogue: 0,0:06:20.44,0:06:21.71,Miracle_JP,,0,0,0,,私は会いたい
Dialogue: 0,0:06:20.44,0:06:21.71,Miracle_CN,,0,0,0,,我想要见到
Dialogue: 0,0:06:22.06,0:06:23.59,Miracle_JP,,0,0,0,,会いたいから会うんだ！
Dialogue: 0,0:06:22.06,0:06:23.59,Miracle_CN,,0,0,0,,因为想见 所以能够见到！
Dialogue: 0,0:06:25.92,0:06:28.72,Miracle_JP,,0,0,0,,ジュン ケイ エミリー
Dialogue: 0,0:06:25.92,0:06:28.72,Miracle_CN,,0,0,0,,见到俊 凯 艾米丽
Dialogue: 0,0:06:29.13,0:06:30.15,Miracle_JP,,0,0,0,,みんなに！
Dialogue: 0,0:06:29.13,0:06:30.15,Miracle_CN,,0,0,0,,见到大家！
Dialogue: 0,0:06:39.64,0:06:40.76,Magical_JP,,0,0,0,,{\fs50\b1}アクアマリン！
Dialogue: 0,0:06:39.64,0:06:40.76,Curerpp_LK,,0,0,0,,Aquamarine !
Dialogue: 0,0:06:39.64,0:06:40.76,Magical_CN,,0,0,0,,{\fs50\b1}福海石！
Dialogue: 0,0:07:07.78,0:07:09.88,Miracle_JP,,0,0,0,,待ってた 奇跡を
Dialogue: 0,0:07:07.78,0:07:09.88,Miracle_CN,,0,0,0,,等待着奇迹
Dialogue: 0,0:07:12.45,0:07:15.91,Default_CN,,30,0,30,,{\an1}{\fs50}《魔法师萩萩的大冒险》
Dialogue: 0,0:07:12.88,0:07:15.79,Miracle_CN,,0,0,0,,好想见到魔法师啊！
Dialogue: 0,0:07:12.88,0:07:15.79,Miracle_JP,,0,0,0,,魔法使い 会ってみたいな！
Dialogue: 0,0:07:18.08,0:07:20.91,Miracle_JP,,0,0,0,,私はずっと 奇跡を待ってた
Dialogue: 0,0:07:18.08,0:07:20.91,Miracle_CN,,0,0,0,,我一直都等待着奇迹
Dialogue: 0,0:07:22.13,0:07:23.56,Miracle_JP,,0,0,0,,でも違った
Dialogue: 0,0:07:22.13,0:07:23.56,Miracle_CN,,0,0,0,,可我错了
Dialogue: 0,0:07:24.20,0:07:27.43,Miracle_JP,,0,0,0,,あの時は奇跡を起こそうとしたんだ！
Dialogue: 0,0:07:24.20,0:07:27.43,Miracle_CN,,0,0,0,,那时候 是我引发了奇迹！
Dialogue: 0,0:07:28.81,0:07:29.62,Miracle_JP,,0,0,0,,だから...
Dialogue: 0,0:07:28.81,0:07:29.62,Miracle_CN,,0,0,0,,所以...
Dialogue: 0,0:07:30.98,0:07:32.46,Miracle_JP,,0,0,0,,みんなに会えた！
Dialogue: 0,0:07:30.98,0:07:32.46,Miracle_CN,,0,0,0,,{\3c&HE479A1&}见到{\r}了{\3c&H9FA430&}大家！
Dialogue: 0,0:07:36.94,0:07:41.46,Miracle_JP,,0,0,0,,それを忘れてた
Dialogue: 0,0:07:36.94,0:07:41.46,Miracle_CN,,0,0,0,,我一度忘记了
Dialogue: 0,0:07:46.32,0:07:48.62,Miracle_JP,,0,0,0,,沢山私に過去を見せたから
Dialogue: 0,0:07:46.32,0:07:48.62,Miracle_CN,,0,0,0,,因为你让我见到了很多的过去
Dialogue: 0,0:07:49.03,0:07:50.32,Miracle_JP,,0,0,0,,思い出せたよ
Dialogue: 0,0:07:49.03,0:07:50.32,Miracle_CN,,0,0,0,,才让我想了起来
Dialogue: 0,0:07:52.00,0:07:54.13,Miracle_JP,,0,0,0,,もう 待ったりはしない
Dialogue: 0,0:07:52.00,0:07:54.13,Miracle_CN,,0,0,0,,我不会再等待了
Dialogue: 0,0:07:54.78,0:07:56.72,Ha_Chan_JP,,0,0,0,,ええ 奇跡を起こしましょう
Dialogue: 0,0:07:54.78,0:07:56.72,Ha_Chan_CN,,0,0,0,,嗯 一起引发奇迹吧
Dialogue: 0,0:07:57.06,0:07:57.89,Miracle_JP,,0,0,0,,フェリーチェ
Dialogue: 0,0:07:57.06,0:07:57.89,Miracle_CN,,0,0,0,,Felice
Dialogue: 0,0:07:58.24,0:08:01.98,Magical_JP,,0,0,0,,っていうか 再会できたの あなたの奇跡だけじゃないし
Dialogue: 0,0:07:58.24,0:08:01.98,Magical_CN,,0,0,0,,话说 之所以能重逢 不仅仅是你的奇迹
Dialogue: 0,0:08:02.84,0:08:09.51,Magical_JP,,0,0,0,,研究を重ねて 2つの世界を繋いだ 私の努力と根性もお忘れなく
Dialogue: 0,0:08:02.84,0:08:09.51,Magical_CN,,0,0,0,,也别忘了 融汇研究成果 连通起两个世界的 我的努力和毅力啊
Dialogue: 0,0:08:10.04,0:08:12.71,Miracle_JP,,0,0,0,,フフッ 分かってるって
Dialogue: 0,0:08:10.04,0:08:12.71,Miracle_CN,,0,0,0,,哈哈 我知道
Dialogue: 0,0:08:12.91,0:08:15.90,Miracle_JP,,0,0,0,,勢いで調子に乗って言っちゃいました
Dialogue: 0,0:08:12.91,0:08:15.90,Miracle_CN,,0,0,0,,情绪到位了 就自然而然喊出来了
Dialogue: 0,0:08:17.23,0:08:21.01,Magical_JP,,0,0,0,,まあ あなたと何度も奇跡を見てきたから
Dialogue: 0,0:08:17.23,0:08:21.01,Magical_CN,,0,0,0,,我理解 都和你见到了无数次的奇迹了
Dialogue: 0,0:08:21.69,0:08:26.38,Magical_JP,,0,0,0,,奇跡を信じられたから 頑張れたのは確かだけど
Dialogue: 0,0:08:21.69,0:08:26.38,Magical_CN,,0,0,0,,因为我相信奇迹 可也努力了哦
Dialogue: 0,0:08:35.46,0:08:36.09,Miracle_JP,,0,0,0,,うん
Dialogue: 0,0:08:35.46,0:08:36.09,Miracle_CN,,0,0,0,,嗯
Dialogue: 0,0:08:36.90,0:08:42.25,Miracle_JP,,0,0,0,,出会いが 出会いのおかげで みんなが...
Dialogue: 0,0:08:36.90,0:08:42.25,Miracle_CN,,0,0,0,,因为相逢 感谢相逢 让大家...
Dialogue: 0,0:08:43.61,0:08:45.06,Miracle_JP,,0,0,0,,繋がる！
Dialogue: 0,0:08:43.61,0:08:45.06,Miracle_CN,,0,0,0,,{\3c&HE479A1&}连系{\r}在{\3c&H9FA430&}一起！
Dialogue: 0,0:08:47.05,0:08:48.99,Mofurun_JP,,0,0,0,,甘い匂いがするモフ
Dialogue: 0,0:08:47.05,0:08:48.99,Mofurun_CN,,0,0,0,,有股香甜的味道
Dialogue: 0,0:08:49.74,0:08:51.28,Default_JP,,0,0,0,,甘い匂いって？
