Dialogue: 0,0:06:40.40,0:06:41.47,Curerpp_MR,,0,0,0,,Tanzanite
Dialogue: 0,0:06:40.40,0:06:41.47,Miracle_CN,,0,0,0,,{\fs50\b1}坦桑石
Dialogue: 0,0:06:45.93,0:06:48.06,DarkMHS_JP,,0,0,0,,目くらましなんて小賢しい
Dialogue: 0,0:06:45.93,0:06:48.06,DarkMHS_CN,,0,0,0,,用佯攻这种小伎俩
Dialogue: 0,0:06:50.06,0:06:51.08,Magical_JP,,0,0,0,,{\fs50\b1}ガーネット
Dialogue: 0,0:06:50.06,0:06:51.08,Curerpp_LK,,0,0,0,,Garnet
Dialogue: 0,0:06:50.06,0:06:51.08,Magical_CN,,0,0,0,,{\fs50\b1}石榴石
Dialogue: 0,0:06:57.12,0:06:59.90,DarkMHS_JP,,0,0,0,,いいぞ その調子だ プリキュア
Dialogue: 0,0:06:57.12,0:06:59.90,DarkMHS_CN,,0,0,0,,很好 就这样继续吧 Precure
Dialogue: 0,0:07:00.16,0:07:02.02,DarkMHS_JP,,0,0,0,,ボクが見た未来そのものだ
Dialogue: 0,0:07:00.16,0:07:02.02,DarkMHS_CN,,0,0,0,,这就是我所见到的未来
Dialogue: 0,0:07:15.05,0:07:16.06,Mofurun_JP,,0,0,0,,モフ！
Dialogue: 0,0:07:15.05,0:07:16.06,Mofurun_CN,,0,0,0,,mofu！
Dialogue: 0,0:07:22.25,0:07:24.67,DarkMHS_JP,,0,0,0,,そろそろ眷属が燃え尽きる
Dialogue: 0,0:07:22.25,0:07:24.67,DarkMHS_CN,,0,0,0,,眷属就要燃尽了
Dialogue: 0,0:07:25.66,0:07:30.42,DarkMHS_JP,,0,0,0,,ここから始まる 現れるぞ ボクのしもべが
Dialogue: 0,0:07:25.66,0:07:30.42,DarkMHS_CN,,0,0,0,,从此刻开始 现身吧 我的奴仆
Dialogue: 0,0:07:32.69,0:07:36.78,DarkMHS_JP,,0,0,0,,ハハハハハハハハ！
Dialogue: 0,0:07:32.69,0:07:36.78,DarkMHS_CN,,0,0,0,,哈哈哈哈哈哈哈哈！
Dialogue: 0,0:07:37.92,0:07:38.76,MagiMiraJP,,0,0,0,,あっ...
Dialogue: 0,0:07:37.92,0:07:38.76,MagiMiraCN,,0,0,0,,啊...
Dialogue: 0,0:07:39.48,0:07:40.69,Mofurun_JP,,0,0,0,,モフ！
Dialogue: 0,0:07:39.48,0:07:40.69,Mofurun_CN,,0,0,0,,mofu！
Dialogue: 0,0:07:46.11,0:07:47.45,Miracle_JP,,0,0,0,,魔法学校！
Dialogue: 0,0:07:46.11,0:07:47.45,Miracle_CN,,0,0,0,,魔法学校！
Dialogue: 0,0:07:49.80,0:07:51.02,Default_JP,,0,0,0,,校長先生！
Dialogue: 0,0:07:49.80,0:07:51.02,Default_CN,,0,0,0,,校长！
Dialogue: 0,0:07:51.20,0:07:51.71,Default_JP,,0,0,0,,うん
Dialogue: 0,0:07:51.20,0:07:51.71,Default_CN,,0,0,0,,什么事
Dialogue: 0,0:07:52.42,0:07:56.11,Default_JP,,0,0,0,,リコ先生達はカタツムリニアに乗ってないようです
Dialogue: 0,0:07:52.42,0:07:56.11,Default_CN,,0,0,0,,李可老师她们 似乎没有坐上蜗牛列车
Dialogue: 0,0:07:56.27,0:07:57.08,Default_JP,,0,0,0,,なんと
Dialogue: 0,0:07:56.27,0:07:57.08,Default_CN,,0,0,0,,什么
Dialogue: 0,0:07:57.34,0:07:59.47,Default_JP,,0,0,0,,ではまだナシマホウ界に
Dialogue: 0,0:07:57.34,0:07:59.47,Default_CN,,0,0,0,,这么说 她们还在无魔界吗
Dialogue: 0,0:08:00.41,0:08:01.72,Default_JP,,0,0,0,,どういうことだ
Dialogue: 0,0:08:00.41,0:08:01.72,Default_CN,,0,0,0,,怎么回事
Dialogue: 0,0:08:02.41,0:08:04.44,Magical_JP,,0,0,0,,どうして 魔法学校が
Dialogue: 0,0:08:02.41,0:08:04.44,Magical_CN,,0,0,0,,魔法学校怎么会在这里
Dialogue: 0,0:08:06.34,0:08:12.12,DarkMHS_JP,,0,0,0,,実際の魔法学校ではない ボクの思い出さ
Dialogue: 0,0:08:06.34,0:08:12.12,DarkMHS_CN,,0,0,0,,这不是真的魔法学校 而是我的回忆
Dialogue: 0,0:08:13.42,0:08:14.91,Miracle_JP,,0,0,0,,思い出って...
Dialogue: 0,0:08:13.42,0:08:14.91,Miracle_CN,,0,0,0,,回忆...
Dialogue: 0,0:08:15.18,0:08:18.69,DarkMHS_JP,,0,0,0,,しもべは ボクの思い出から現れるんだよ
Dialogue: 0,0:08:15.18,0:08:18.69,DarkMHS_CN,,0,0,0,,奴仆是从我的回忆中诞生的
Dialogue: 0,0:08:22.36,0:08:24.09,Magical_JP,,0,0,0,,{\fs50\b1}ムーンストーン
Dialogue: 0,0:08:22.36,0:08:24.09,Curerpp_LK,,0,0,0,,Moonstone
Dialogue: 0,0:08:22.36,0:08:24.09,Magical_CN,,0,0,0,,{\fs50\b1}月光石
Dialogue: 0,0:08:30.84,0:08:32.26,MagiMiraJP,,0,0,0,,ああ！
Dialogue: 0,0:08:30.84,0:08:32.26,MagiMiraCN,,0,0,0,,啊！
Dialogue: 0,0:08:33.42,0:08:35.11,DarkMHS_JP,,0,0,0,,いいぞ もうすぐだ
Dialogue: 0,0:08:33.42,0:08:35.11,DarkMHS_CN,,0,0,0,,很好 快了
Dialogue: 0,0:08:35.29,0:08:36.64,DarkMHS_JP,,0,0,0,,そこまで来ている
Dialogue: 0,0:08:35.29,0:08:36.64,DarkMHS_CN,,0,0,0,,已经到这个地步了
Dialogue: 0,0:08:37.52,0:08:39.78,DarkMHS_JP,,0,0,0,,ボクの望みが叶う時が
Dialogue: 0,0:08:37.52,0:08:39.78,DarkMHS_CN,,0,0,0,,快到我愿望实现的时刻了
Dialogue: 0,0:08:40.17,0:08:41.82,Miracle_JP,,0,0,0,,あなたの望みって...
Dialogue: 0,0:08:40.17,0:08:41.82,Miracle_CN,,0,0,0,,你的愿望...
Dialogue: 0,0:08:42.08,0:08:43.07,Magical_JP,,0,0,0,,なんなの？
Dialogue: 0,0:08:42.08,0:08:43.07,Magical_CN,,0,0,0,,究竟是什么？
Dialogue: 0,0:08:43.36,0:08:46.82,DarkMHS_JP,,0,0,0,,好きな時間へと自由に飛べる力
Dialogue: 0,0:08:43.36,0:08:46.82,DarkMHS_CN,,0,0,0,,获得自由穿梭任意时间的力量
Dialogue: 0,0:08:48.98,0:08:51.20,DarkMHS_JP,,0,0,0,,それが ボクの望み
Dialogue: 0,0:08:48.98,0:08:51.20,DarkMHS_CN,,0,0,0,,这就是我的愿望
Dialogue: 0,0:08:52.68,0:08:55.33,DarkMHS_JP,,0,0,0,,それには ひすいが必要なんだ
Dialogue: 0,0:08:52.68,0:08:55.33,DarkMHS_CN,,0,0,0,,为此 我需要翡翠
Dialogue: 0,0:08:56.01,0:08:58.21,Miracle_JP,,0,0,0,,ひーちゃんは 守る
Dialogue: 0,0:08:56.01,0:08:58.21,Miracle_CN,,0,0,0,,我们会保护小菲的
Dialogue: 0,0:08:58.98,0:09:02.06,DarkMHS_JP,,0,0,0,,できるかな？プリキュア
Dialogue: 0,0:08:58.98,0:09:02.06,DarkMHS_CN,,0,0,0,,能办到吗？Precure
Dialogue: 0,0:09:02.06,0:09:04.06,DarkMHS_CN,,0,0,0,,
Dialogue: 0,0:09:16.21,0:09:17.03,Default_JP,,0,0,0,,なんだ？
Dialogue: 0,0:09:16.21,0:09:17.03,Default_CN,,0,0,0,,怎么了？
Dialogue: 0,0:09:20.22,0:09:24.18,Default_JP,,0,0,0,,いいえ 校長 リコ達が魔法学校に向かったはずです
Dialogue: 0,0:09:20.22,0:09:24.18,Default_CN,,0,0,0,,不 校长 李可她们确实是去魔法学校了
Dialogue: 0,0:09:24.51,0:09:25.23,Ha_Chan_JP,,0,0,0,,はっ...
Dialogue: 0,0:09:24.51,0:09:25.23,Ha_Chan_CN,,0,0,0,,啊...
Dialogue: 0,0:09:27.62,0:09:29.01,Default_JP,,0,0,0,,あれは
Dialogue: 0,0:09:27.62,0:09:29.01,Default_CN,,0,0,0,,那是
Dialogue: 0,0:09:29.18,0:09:30.39,Default_JP,,0,0,0,,どうした リアンくん
Dialogue: 0,0:09:29.18,0:09:30.39,Default_CN,,0,0,0,,怎么了 李安
Dialogue: 0,0:09:36.68,0:09:40.59,DarkMHS_JP,,0,0,0,,しもべを落とし 街ごと消し去る
Dialogue: 0,0:09:36.68,0:09:40.59,DarkMHS_CN,,0,0,0,,我会砸下奴仆 让整座城市覆灭
Dialogue: 0,0:09:45.04,0:09:48.69,Miracle_JP,,0,0,0,,あれって ナシマホウ界なの
Dialogue: 0,0:09:45.04,0:09:48.69,Miracle_CN,,0,0,0,,那是 在无魔界的
Dialogue: 0,0:09:50.45,0:09:52.51,Miracle_JP,,0,0,0,,私の街 なの
Dialogue: 0,0:09:50.45,0:09:52.51,Miracle_CN,,0,0,0,,是我居住的城市吗
Dialogue: 0,0:10:00.86,0:10:02.65,Ha_Chan_JP,,0,0,0,,きっと みらい達だ
Dialogue: 0,0:10:00.86,0:10:02.65,Ha_Chan_CN,,0,0,0,,肯定是未来她们
Dialogue: 0,0:10:05.38,0:10:07.77,Default_JP,,0,0,0,,行ってはならない ここにいるんだ
Dialogue: 0,0:10:05.38,0:10:07.77,Default_CN,,0,0,0,,不能去 你要留在这里
Dialogue: 0,0:10:08.40,0:10:09.38,Ha_Chan_JP,,0,0,0,,離して！
Dialogue: 0,0:10:08.40,0:10:09.38,Ha_Chan_CN,,0,0,0,,放开！
Dialogue: 0,0:10:14.32,0:10:15.56,Ha_Chan_JP,,0,0,0,,みんなを...
Dialogue: 0,0:10:14.32,0:10:15.56,Ha_Chan_CN,,0,0,0,,一定要...
Dialogue: 0,0:10:18.89,0:10:21.21,Ha_Chan_JP,,0,0,0,,みんなを助けるんだ！
Dialogue: 0,0:10:18.89,0:10:21.21,Ha_Chan_CN,,0,0,0,,一定要救大家！
Dialogue: 0,0:10:23.84,0:10:24.66,Default_JP,,0,0,0,,待ちなさい！
Dialogue: 0,0:10:23.84,0:10:24.66,Default_CN,,0,0,0,,等等！
Dialogue: 0,0:10:29.12,0:10:31.27,DarkMHS_JP,,0,0,0,,行け しもべよ
Dialogue: 0,0:10:29.12,0:10:31.27,DarkMHS_CN,,0,0,0,,上吧 奴仆
Dialogue: 0,0:10:36.97,0:10:39.26,DarkMHS_JP,,0,0,0,,止めてみせろ プリキュア！
Dialogue: 0,0:10:36.97,0:10:39.26,DarkMHS_CN,,0,0,0,,来挡挡看啊 Precure！
Dialogue: 0,0:10:46.66,0:10:48.88,Miracle_JP,,0,0,0,,あの怪物を押し返さないと
Dialogue: 0,0:10:46.66,0:10:48.88,Miracle_CN,,0,0,0,,要把那怪物推回去
Dialogue: 0,0:10:49.25,0:10:50.76,Magical_JP,,0,0,0,,でも 高過ぎる
Dialogue: 0,0:10:49.25,0:10:50.76,Magical_CN,,0,0,0,,但是 太高了
Dialogue: 0,0:10:51.10,0:10:52.44,Miracle_JP,,0,0,0,,こうなったら
Dialogue: 0,0:10:51.10,0:10:52.44,Miracle_CN,,0,0,0,,这样的话
Dialogue: 0,0:10:52.61,0:10:53.25,Magical_JP,,0,0,0,,ええ
Dialogue: 0,0:10:52.61,0:10:53.25,Magical_CN,,0,0,0,,嗯
Dialogue: 0,0:10:54.06,0:10:54.77,Mofurun_JP,,0,0,0,,モフ！
Dialogue: 0,0:10:54.06,0:10:54.77,Mofurun_CN,,0,0,0,,mofu！
Dialogue: 0,0:00:00.00,0:00:00.00,Default_CN,,0,0,0,,
Dialogue: 0,0:10:56.90,0:10:58.26,MagiMiraJP,,0,0,0,,{\fs50\b1}キュアップ・ラパパ！
Dialogue: 0,0:10:56.90,0:10:58.26,Curerpp_ML,,0,0,0,,CURE UP{\fnCalibri}↗{\r}RA{\fnSegoe UI}♥{\r}PA{\fnSegoe UI}★{\r}PA !
Dialogue: 0,0:11:00.26,0:11:01.28,MagiMiraJP,,0,0,0,,{\fs50\b1}サファイア！
Dialogue: 0,0:11:00.26,0:11:01.28,Curerpp_ML,,0,0,0,,Sapphire !
Dialogue: 0,0:11:00.26,0:11:01.28,MagiMiraCN,,0,0,0,,{\fs50\b1}蓝宝石！
Dialogue: 0,0:11:26.36,0:11:27.70,Miracle_JP,,0,0,0,,ふたりの奇跡！
Dialogue: 0,0:11:26.36,0:11:27.70,Miracle_CN,,0,0,0,,两个人的奇迹！
Dialogue: 0,0:11:27.73,0:11:29.47,Miracle_JP,,0,0,0,,{\fs50\b1}キュアミラクル！
Dialogue: 0,0:11:27.73,0:11:29.47,Curerpp_MR,,0,0,0,,Cure Miracle !
Dialogue: 0,0:11:27.73,0:11:29.47,Miracle_CN,,0,0,0,,{\fs50\b1}奇迹愈！
Dialogue: 0,0:11:30.50,0:11:31.85,Magical_JP,,0,0,0,,ふたりの魔法！
Dialogue: 0,0:11:30.50,0:11:31.85,Magical_CN,,0,0,0,,两个人的魔法！
Dialogue: 0,0:11:32.25,0:11:33.71,Magical_JP,,0,0,0,,{\fs50\b1}キュアマジカル！
Dialogue: 0,0:11:32.25,0:11:33.71,Curerpp_LK,,0,0,0,,Cure Magical !
Dialogue: 0,0:11:32.25,0:11:33.71,Magical_CN,,0,0,0,,{\fs50\b1}魔法愈！
Dialogue: 0,0:11:36.46,0:11:39.53,Miracle_JP,,0,0,0,,{\fs50\b1}魔法つかい{\3c&HE479A1&\4c&H823651&}プリキュア！
Dialogue: 0,0:11:36.46,0:11:39.53,Curerpp_MR,,0,0,0,,Maho Girls {\3c&HE479A1&\4c&H823651&}Precure !
Dialogue: 0,0:11:36.46,0:11:39.53,Miracle_CN,,0,0,0,,{\fs50\b1}魔法少女 {\3c&HE479A1&\4c&H823651&}光之美少女！
Dialogue: 0,0:00:00.00,0:00:00.00,Default_CN,,0,0,0,,
Dialogue: 0,0:11:40.28,0:11:43.36,DarkMHS_JP,,0,0,0,,待ってたぞ サファイア！
Dialogue: 0,0:11:40.28,0:11:43.36,DarkMHS_CN,,0,0,0,,就等着呢 蓝宝石！
Dialogue: 0,0:11:53.68,0:11:56.89,Magical_JP,,0,0,0,,ハァ...！
Dialogue: 0,0:11:53.68,0:11:56.89,MagiMiraCN,,0,0,0,,喝...！
Dialogue: 0,0:12:01.34,0:12:02.58,Default_JP,,0,0,0,,リアンくん どうした？
Dialogue: 0,0:12:01.34,0:12:02.58,Default_CN,,0,0,0,,李安 怎么了？
Dialogue: 0,0:12:03.80,0:12:05.86,Default_JP,,0,0,0,,ひ...ひすいくんが！
Dialogue: 0,0:12:03.80,0:12:05.86,Default_CN,,0,0,0,,翡...翡翠她！
Dialogue: 0,0:12:08.91,0:12:10.74,Default_JP,,0,0,0,,落ち着いて ここで離れて
Dialogue: 0,0:12:08.91,0:12:10.74,Default_CN,,0,0,0,,不要慌张 尽快撤离
Dialogue: 0,0:12:15.07,0:12:20.74,DarkMHS_JP,,0,0,0,,キミ達が見た未来に 刻々と近付いている
Dialogue: 0,0:12:15.07,0:12:20.74,DarkMHS_CN,,0,0,0,,正在逐渐接近 你们所见到的未来
Dialogue: 0,0:12:22.18,0:12:24.14,Miracle_JP,,0,0,0,,あんな未来 変えてみせる！
Dialogue: 0,0:12:22.18,0:12:24.14,Miracle_CN,,0,0,0,,我们会改变那种未来！
Dialogue: 0,0:12:25.28,0:12:27.20,DarkMHS_JP,,0,0,0,,変わらないよ 未来は
Dialogue: 0,0:12:25.28,0:12:27.20,DarkMHS_CN,,0,0,0,,未来是无法改变的
Dialogue: 0,0:12:27.77,0:12:31.67,DarkMHS_JP,,0,0,0,,言ったはずだ 時間は本に似ていると
Dialogue: 0,0:12:27.77,0:12:31.67,DarkMHS_CN,,0,0,0,,我说过 时间就像书本
Dialogue: 0,0:12:32.53,0:12:34.77,DarkMHS_JP,,0,0,0,,本の結末は決まっている
Dialogue: 0,0:12:32.53,0:12:34.77,DarkMHS_CN,,0,0,0,,书的结局是既定的
Dialogue: 0,0:12:32.27,0:12:37.79,Default_CN,,30,0,30,,{\an7}{\fs50\bord2\fad(500,500)}梗概：续上一集，男主（卡伊鲁）与服装店员（爱丽丝）经过交流\N涌现出寻找所要之物的动力\N爱丽丝为卡伊鲁泡了茶...\N亦有提及与本作相近的四种属性，异世界等设定。
Dialogue: 0,0:12:35.14,0:12:37.15,DarkMHS_JP,,0,0,0,,決して変える事はできない
Dialogue: 0,0:12:35.14,0:12:37.15,DarkMHS_CN,,0,0,0,,绝对无法改变
Dialogue: 0,0:12:37.78,0:12:42.56,DarkMHS_JP,,0,0,0,,本同様に 起こる出来事は全て変えられないんだ
Dialogue: 0,0:12:37.78,0:12:42.56,DarkMHS_CN,,0,0,0,,时间也和书一样 将要发生什么事情 全都无法改变
Dialogue: 0,0:12:43.41,0:12:44.75,Miracle_JP,,0,0,0,,そんなはずない！
Dialogue: 0,0:12:43.41,0:12:44.75,Miracle_CN,,0,0,0,,没有这种道理！
Dialogue: 0,0:12:45.21,0:12:46.33,DarkMHS_JP,,0,0,0,,事実さ
Dialogue: 0,0:12:45.21,0:12:46.33,DarkMHS_CN,,0,0,0,,我说的是事实
Dialogue: 0,0:12:48.14,0:12:49.44,DarkMHS_JP,,0,0,0,,幻滅するよね
Dialogue: 0,0:12:48.14,0:12:49.44,DarkMHS_CN,,0,0,0,,幻灭了吧
Dialogue: 0,0:12:51.04,0:12:53.28,DarkMHS_JP,,0,0,0,,未来なんて残酷なものさ
Dialogue: 0,0:12:51.04,0:12:53.28,DarkMHS_CN,,0,0,0,,未来是很残酷的
Dialogue: 0,0:12:53.78,0:12:56.60,DarkMHS_JP,,0,0,0,,未来はただ滅亡へと進むだけ
Dialogue: 0,0:12:53.78,0:12:56.60,DarkMHS_CN,,0,0,0,,它只会通往毁灭
Dialogue: 0,0:12:59.24,0:13:01.86,DarkMHS_JP,,0,0,0,,ただただ老いていく
Dialogue: 0,0:12:59.24,0:13:01.86,DarkMHS_CN,,0,0,0,,只会不断地 不断地老去
Dialogue: 0,0:13:05.32,0:13:08.01,DarkMHS_JP,,0,0,0,,最終的には死が待ち受ける
Dialogue: 0,0:13:05.32,0:13:08.01,DarkMHS_CN,,0,0,0,,最终迎来死亡
Dialogue: 0,0:13:09.65,0:13:11.16,Miracle_JP,,0,0,0,,そんなの詭弁だ！
Dialogue: 0,0:13:09.65,0:13:11.16,Miracle_CN,,0,0,0,,你那是诡辩！
Dialogue: 0,0:13:12.44,0:13:13.90,DarkMHS_JP,,0,0,0,,昔に戻りたい
Dialogue: 0,0:13:12.44,0:13:13.90,DarkMHS_CN,,0,0,0,,想回到过去
Dialogue: 0,0:13:14.41,0:13:15.16,MagiMiraJP,,0,0,0,,はっ...
Dialogue: 0,0:13:14.41,0:13:15.16,MagiMiraCN,,0,0,0,,啊...
Dialogue: 0,0:13:15.60,0:13:17.40,DarkMHS_JP,,0,0,0,,一度は思った事があるだろう？
Dialogue: 0,0:13:15.60,0:13:17.40,DarkMHS_CN,,0,0,0,,你也曾有过一次这种念头吧？
Dialogue: 0,0:13:18.43,0:13:20.16,Miracle_JP,,0,0,0,,あっ...
Dialogue: 0,0:13:18.43,0:13:20.16,Miracle_CN,,0,0,0,,啊...
Dialogue: 0,0:13:33.28,0:13:36.29,Miracle_JP,,0,0,0,,戻りたいな この頃に
Dialogue: 0,0:13:33.28,0:13:36.29,Miracle_CN,,0,0,0,,好想回去啊 回到这时候
Dialogue: 0,0:13:37.92,0:13:39.12,Miracle_JP,,0,0,0,,あっ...
Dialogue: 0,0:13:37.92,0:13:39.12,Miracle_CN,,0,0,0,,啊...
Dialogue: 0,0:13:42.25,0:13:43.06,Magical_JP,,0,0,0,,ミラクル！
Dialogue: 0,0:13:42.25,0:13:43.06,Magical_CN,,0,0,0,,Miracle！
Dialogue: 0,0:13:45.19,0:13:49.77,DarkMHS_JP,,0,0,0,,その動揺 この瞬間を作るために
Dialogue: 0,0:13:45.19,0:13:49.77,DarkMHS_CN,,0,0,0,,就是为了制造这一刻的动摇
Dialogue: 0,0:13:50.14,0:13:53.88,DarkMHS_JP,,0,0,0,,キミ達に未来と過去が見える力を授けたんだ
Dialogue: 0,0:13:50.14,0:13:53.88,DarkMHS_CN,,0,0,0,,我才给予了你们能看到过去与未来的力量
Dialogue: 0,0:13:56.74,0:13:59.79,DarkMHS_JP,,0,0,0,,ボクは人々に与えようとしているんだ...
Dialogue: 0,0:13:56.74,0:13:59.79,DarkMHS_CN,,0,0,0,,我要赐予人们...
Dialogue: 0,0:14:00.98,0:14:05.68,DarkMHS_JP,,0,0,0,,人生という物語の 好きなページを来る力を
Dialogue: 0,0:14:00.98,0:14:05.68,DarkMHS_CN,,0,0,0,,在名为人生的故事里 自由翻开任意页数的力量
Dialogue: 0,0:14:06.46,0:14:09.76,DarkMHS_JP,,0,0,0,,キミ達だって ことはと再び会えるんだろう？
Dialogue: 0,0:14:06.46,0:14:09.76,DarkMHS_CN,,0,0,0,,你们也想再见到言叶吧？
Dialogue: 0,0:14:09.84,0:14:10.82,MagiMiraJP,,0,0,0,,あっ...
Dialogue: 0,0:14:09.84,0:14:10.82,MagiMiraCN,,0,0,0,,啊...
Dialogue: 0,0:14:12.22,0:14:15.95,DarkMHS_JP,,0,0,0,,ことははね ひすいに力を与え
Dialogue: 0,0:14:12.22,0:14:15.95,DarkMHS_CN,,0,0,0,,言叶她啊 把力量给了翡翠
Dialogue: 0,0:14:21.85,0:14:24.17,DarkMHS_JP,,0,0,0,,その役目を終えたんだ
Dialogue: 0,0:14:21.85,0:14:24.17,DarkMHS_CN,,0,0,0,,完成了她的使命
Dialogue: 0,0:14:25.62,0:14:26.44,Miracle_JP,,0,0,0,,ウソだ！
Dialogue: 0,0:14:25.62,0:14:26.44,Miracle_CN,,0,0,0,,你胡说！
Dialogue: 0,0:14:26.55,0:14:27.60,Magical_JP,,0,0,0,,ありえない！
Dialogue: 0,0:14:26.55,0:14:27.60,Magical_CN,,0,0,0,,不可能的！
Dialogue: 0,0:14:28.66,0:14:31.39,DarkMHS_JP,,0,0,0,,見ろよ もうすぐ終わる！
Dialogue: 0,0:14:28.66,0:14:31.39,DarkMHS_CN,,0,0,0,,看吧 就快结束了！
Dialogue: 0,0:14:32.70,0:14:35.20,DarkMHS_JP,,0,0,0,,全てのピースは揃った！
Dialogue: 0,0:14:32.70,0:14:35.20,DarkMHS_CN,,0,0,0,,全部的书页已经集齐！
Dialogue: 0,0:14:49.25,0:14:50.01,DarkMHS_JP,,0,0,0,,フッ
Dialogue: 0,0:14:49.25,0:14:50.01,DarkMHS_CN,,0,0,0,,哼
Dialogue: 0,0:14:50.32,0:14:51.08,MagiMiraJP,,0,0,0,,はっ...
Dialogue: 0,0:14:50.32,0:14:51.08,MagiMiraCN,,0,0,0,,啊...
Dialogue: 0,0:14:51.40,0:14:52.24,Miracle_JP,,0,0,0,,ひーちゃん！
Dialogue: 0,0:14:51.40,0:14:52.24,Miracle_CN,,0,0,0,,小菲！
Dialogue: 0,0:14:52.49,0:14:53.32,Magical_JP,,0,0,0,,なんで？
Dialogue: 0,0:14:52.49,0:14:53.32,Magical_CN,,0,0,0,,为什么？
Dialogue: 0,0:14:53.61,0:14:55.35,Mofurun_JP,,0,0,0,,ひーちゃん 危ないモフ！
Dialogue: 0,0:14:53.61,0:14:55.35,Mofurun_CN,,0,0,0,,小菲 很危险的！
Dialogue: 0,0:14:57.46,0:14:58.30,Default_JP,,0,0,0,,ワン...
Dialogue: 0,0:14:57.46,0:14:58.30,Default_CN,,0,0,0,,汪...
Dialogue: 0,0:15:00.08,0:15:00.84,Mofurun_JP,,0,0,0,,モフ
Dialogue: 0,0:15:00.08,0:15:00.84,Mofurun_CN,,0,0,0,,mofu
Dialogue: 0,0:15:03.46,0:15:04.10,Mofurun_JP,,0,0,0,,はっ...
Dialogue: 0,0:15:03.46,0:15:04.10,Mofurun_CN,,0,0,0,,啊...
Dialogue: 0,0:15:06.57,0:15:08.33,Ha_Chan_JP,,0,0,0,,みらい リコ！
Dialogue: 0,0:15:06.57,0:15:08.33,Ha_Chan_CN,,0,0,0,,未来 李可！
Dialogue: 0,0:15:19.81,0:15:22.61,MagiMiraJP,,0,0,0,,ハァ！
Dialogue: 0,0:15:19.81,0:15:22.61,MagiMiraCN,,0,0,0,,喝！
Dialogue: 0,0:15:47.21,0:15:49.49,Mofurun_JP,,0,0,0,,ミラクル しっかりするモフ
Dialogue: 0,0:15:47.21,0:15:49.49,Mofurun_CN,,0,0,0,,Miracle 振作啊
Dialogue: 0,0:15:50.24,0:15:53.65,DarkMHS_JP,,0,0,0,,さあ キミ達が見た未来だ
Dialogue: 0,0:15:50.24,0:15:53.65,DarkMHS_CN,,0,0,0,,好了 这就是你们所见到的未来
Dialogue: 0,0:16:06.17,0:16:09.48,DarkMHS_JP,,0,0,0,,ことはは倒れ ひすいに命を託した
Dialogue: 0,0:16:06.17,0:16:09.48,DarkMHS_CN,,0,0,0,,言叶已经倒下 并将生命托付给了翡翠
Dialogue: 0,0:16:10.38,0:16:13.28,DarkMHS_JP,,0,0,0,,かつてマザー・ラパーパがことはにしたように
Dialogue: 0,0:16:10.38,0:16:13.28,DarkMHS_CN,,0,0,0,,就像过去妈祖·拉帕帕为言叶所做的一样
Dialogue: 0,0:16:13.86,0:16:16.30,DarkMHS_JP,,0,0,0,,その意思を受け継がせたようだね
Dialogue: 0,0:16:13.86,0:16:16.30,DarkMHS_CN,,0,0,0,,这种意志也得到了传承呢
Dialogue: 0,0:16:17.24,0:16:23.49,DarkMHS_JP,,0,0,0,,ラパーパの力の覚醒には時間がかかり過ぎる ことはがそうであったように
Dialogue: 0,0:16:17.24,0:16:23.49,DarkMHS_CN,,0,0,0,,沿用言叶那种模式 让拉帕帕力量的觉醒 太费时间了
Dialogue: 0,0:16:27.92,0:16:30.09,DarkMHS_JP,,0,0,0,,キミは特別な存在
Dialogue: 0,0:16:27.92,0:16:30.09,DarkMHS_CN,,0,0,0,,你是特别的人
Dialogue: 0,0:16:33.34,0:16:35.23,DarkMHS_JP,,0,0,0,,杖など必要ない
Dialogue: 0,0:16:33.34,0:16:35.23,DarkMHS_CN,,0,0,0,,不需要这种魔杖
Dialogue: 0,0:16:41.49,0:16:42.51,MagiMiraJP,,0,0,0,,ひーちゃん！
Dialogue: 0,0:16:41.49,0:16:42.51,MagiMiraCN,,0,0,0,,小菲！
Dialogue: 0,0:16:47.30,0:16:49.01,Mofurun_JP,,0,0,0,,モフ...
Dialogue: 0,0:16:47.30,0:16:49.01,Mofurun_CN,,0,0,0,,mofu...
Dialogue: 0,0:16:53.97,0:16:59.94,DarkMHS_JP,,0,0,0,,ラパーパの力 ことはを蘇らせるために その身体を使わせてもらうよ
Dialogue: 0,0:16:53.97,0:16:59.94,DarkMHS_CN,,0,0,0,,为了唤醒拉帕帕的力量 也就是言叶 我要借你身体一用
Dialogue: 0,0:17:03.83,0:17:10.42,DarkMHS_JP,,0,0,0,,スマホンは かつて 赤子のことはを長き年月の間守り 眠らせていた
Dialogue: 0,0:17:03.83,0:17:10.42,DarkMHS_CN,,0,0,0,,智慧书曾经长时间保护着婴儿言叶 让她在书中安眠
Dialogue: 0,0:17:11.52,0:17:19.32,DarkMHS_JP,,0,0,0,,使いようによっては ことはを眠らせ 封印する事もできる
Dialogue: 0,0:17:11.52,0:17:19.32,DarkMHS_CN,,0,0,0,,活用这个功能 也能让她睡去 封印她
Dialogue: 0,0:17:21.85,0:17:25.21,Miracle_JP,,0,0,0,,あの中に...はーちゃんが！
Dialogue: 0,0:17:21.85,0:17:25.21,Miracle_CN,,0,0,0,,小哈...在那里面！
Dialogue: 0,0:17:26.89,0:17:31.37,DarkMHS_JP,,0,0,0,,ことはの力...意思というところかな
Dialogue: 0,0:17:26.89,0:17:31.37,DarkMHS_CN,,0,0,0,,言叶的力量...是在意志之中吧
Dialogue: 0,0:17:32.94,0:17:36.53,DarkMHS_JP,,0,0,0,,さあ おいで ひすい
Dialogue: 0,0:17:32.94,0:17:36.53,DarkMHS_CN,,0,0,0,,好了 来吧 翡翠
Dialogue: 0,0:17:42.45,0:17:46.41,Ha_Chan_JP,,0,0,0,,みらい リコ モフルン
Dialogue: 0,0:17:42.45,0:17:46.41,Ha_Chan_CN,,0,0,0,,未来 李可 莫夫伦
Dialogue: 0,0:17:52.88,0:17:53.71,Ha_Chan_JP,,0,0,0,,あっ...
Dialogue: 0,0:17:52.88,0:17:53.71,Ha_Chan_CN,,0,0,0,,啊...
Dialogue: 0,0:18:02.41,0:18:07.59,DarkMHS_JP,,0,0,0,,風の力を利用して舞うとは さすがサファイアの力
Dialogue: 0,0:18:02.41,0:18:07.59,DarkMHS_CN,,0,0,0,,利用风的力量飞舞 不愧是蓝宝石的力量
Dialogue: 0,0:18:09.60,0:18:10.46,Magical_JP,,0,0,0,,させない
Dialogue: 0,0:18:09.60,0:18:10.46,Magical_CN,,0,0,0,,你休想得逞
Dialogue: 0,0:18:10.76,0:18:12.33,Miracle_JP,,0,0,0,,ひーちゃんを返して！
Dialogue: 0,0:18:10.76,0:18:12.33,Miracle_CN,,0,0,0,,快放了小菲！
Dialogue: 0,0:18:17.85,0:18:18.85,DarkMHS_JP,,0,0,0,,ハッ！
Dialogue: 0,0:18:17.85,0:18:18.85,DarkMHS_CN,,0,0,0,,哼！
Dialogue: 0,0:18:19.31,0:18:20.03,Magical_JP,,0,0,0,,おっ...
Dialogue: 0,0:18:19.31,0:18:20.03,Magical_CN,,0,0,0,,啊...
Dialogue: 0,0:18:20.44,0:18:21.16,Miracle_JP,,0,0,0,,おっ...
Dialogue: 0,0:18:20.44,0:18:21.16,Miracle_CN,,0,0,0,,啊...
Dialogue: 0,0:18:28.28,0:18:31.37,Default_JP,,0,0,0,,昔 通ってた魔法学校だよ
Dialogue: 0,0:18:28.28,0:18:31.37,Default_CN,,0,0,0,,这是妈妈以前上过的魔法学校
Dialogue: 0,0:18:32.27,0:18:33.30,Default_JP,,0,0,0,,ボクも行ける？
Dialogue: 0,0:18:32.27,0:18:33.30,Default_CN,,0,0,0,,我也能去吗？
Dialogue: 0,0:18:33.63,0:18:38.97,Default_JP,,0,0,0,,アイルは 生まれも育ちもナシマホウ界だし 杖もないからな
Dialogue: 0,0:18:33.63,0:18:38.97,Default_CN,,0,0,0,,埃路是在无魔界出生和长大的 没有魔杖呢
Dialogue: 0,0:18:40.28,0:18:46.51,Default_JP,,0,0,0,,でも アイルの傍にいてあげる 私が代わりに魔法を使ってあげる
Dialogue: 0,0:18:40.28,0:18:46.51,Default_CN,,0,0,0,,但是 妈妈会陪在埃路身边 代替你使用魔法
Dialogue: 0,0:18:52.25,0:18:53.20,Default_JP,,0,0,0,,ママ...
Dialogue: 0,0:18:52.25,0:18:53.20,Default_CN,,0,0,0,,妈妈...
Dialogue: 0,0:18:57.57,0:18:58.69,Miracle_JP,,0,0,0,,今のは...
Dialogue: 0,0:18:57.57,0:18:58.69,Miracle_CN,,0,0,0,,刚才的是...
Dialogue: 0,0:18:59.79,0:19:01.50,Magical_JP,,0,0,0,,この人の過去
Dialogue: 0,0:18:59.79,0:19:01.50,Magical_CN,,0,0,0,,他的过去
Dialogue: 0,0:19:04.62,0:19:07.26,DarkMHS_JP,,0,0,0,,眷属の力も尽きた
Dialogue: 0,0:19:04.62,0:19:07.26,DarkMHS_CN,,0,0,0,,眷属的力量也燃尽了
Dialogue: 0,0:19:07.93,0:19:09.39,Ha_Chan_JP,,0,0,0,,あっ...
Dialogue: 0,0:19:07.93,0:19:09.39,Ha_Chan_CN,,0,0,0,,啊...
Dialogue: 0,0:19:09.71,0:19:11.79,Ha_Chan_JP,,0,0,0,,ミラクル マジカル！
Dialogue: 0,0:19:09.71,0:19:11.79,Ha_Chan_CN,,0,0,0,,Miracle Magical！
Dialogue: 0,0:19:12.20,0:19:12.98,Miracle_JP,,0,0,0,,はーちゃん！
Dialogue: 0,0:19:12.20,0:19:12.98,Miracle_CN,,0,0,0,,小哈！
Dialogue: 0,0:19:13.39,0:19:14.20,Ha_Chan_JP,,0,0,0,,違う！
Dialogue: 0,0:19:13.39,0:19:14.20,Ha_Chan_CN,,0,0,0,,不对！
Dialogue: 0,0:19:15.33,0:19:17.05,Ha_Chan_JP,,0,0,0,,止めるのは彼じゃない！
Dialogue: 0,0:19:15.33,0:19:17.05,Ha_Chan_CN,,0,0,0,,我们该阻止的不是他！
Dialogue: 0,0:19:17.16,0:19:17.88,MagiMiraJP,,0,0,0,,へぇ？
Dialogue: 0,0:19:17.16,0:19:17.88,MagiMiraCN,,0,0,0,,诶？
Dialogue: 0,0:19:18.58,0:19:19.14,Ha_Chan_JP,,0,0,0,,はっ...
Dialogue: 0,0:19:18.58,0:19:19.14,Ha_Chan_CN,,0,0,0,,啊...
Dialogue: 0,0:19:23.38,0:19:24.34,Mofurun_JP,,0,0,0,,ん...？
Dialogue: 0,0:19:23.38,0:19:24.34,Mofurun_CN,,0,0,0,,嗯...？
Dialogue: 0,0:19:26.19,0:19:27.45,Mofurun_JP,,0,0,0,,モフ！
Dialogue: 0,0:19:26.19,0:19:27.45,Mofurun_CN,,0,0,0,,mofu！
Dialogue: 0,0:19:39.98,0:19:41.23,MagiMiraJP,,0,0,0,,はーちゃん！
Dialogue: 0,0:19:39.98,0:19:41.23,MagiMiraCN,,0,0,0,,小哈！
Dialogue: 0,0:19:41.87,0:19:44.74,DarkMHS_JP,,0,0,0,,刻の魔獣・クロノウストよ
Dialogue: 0,0:19:41.87,0:19:44.74,DarkMHS_CN,,0,0,0,,时间魔兽·柯罗诺斯特啊
Dialogue: 0,0:19:45.80,0:19:47.13,DarkMHS_JP,,0,0,0,,解き放たれよ！
Dialogue: 0,0:19:45.80,0:19:47.13,DarkMHS_CN,,0,0,0,,解放吧！
Dialogue: 0,0:19:41.87,0:19:44.45,Default_CN,,30,0,30,,{\an7}{\fs50}词源是{\fnArial}Χρόνος{\r}{\fs50}/Chronos/Khronos\N希腊语时间 亦是原始神·柯罗诺斯\N易与宙斯之父·克洛诺斯/{\fnArial}Κρόνος{\r}{\fs50}/Kronos混淆
Dialogue: 0,0:19:47.52,0:19:50.69,DarkMHS_JP,,0,0,0,,ボクに力を 過去へといざなえ！
Dialogue: 0,0:19:47.52,0:19:50.69,DarkMHS_CN,,0,0,0,,赐予我力量 引导我前往过去吧！
Dialogue: 0,0:20:21.04,0:20:22.02,Mofurun_JP,,0,0,0,,モフ...
Dialogue: 0,0:20:21.04,0:20:22.02,Mofurun_CN,,0,0,0,,mofu...
Dialogue: 0,0:20:26.71,0:20:27.58,MagiMiraJP,,0,0,0,,あっ...
Dialogue: 0,0:20:26.71,0:20:27.58,MagiMiraCN,,0,0,0,,啊...
Dialogue: 0,0:20:29.16,0:20:30.16,Ha_Chan_JP,,0,0,0,,始まる
Dialogue: 0,0:20:29.16,0:20:30.16,Ha_Chan_CN,,0,0,0,,开始了
Dialogue: 0,0:20:40.11,0:20:42.43,Default_JP,,0,0,0,,なんだ あれは
Dialogue: 0,0:20:40.11,0:20:42.43,Default_CN,,0,0,0,,那是什么
Dialogue: 0,0:21:03.68,0:21:07.85,Miracle_JP,,0,0,0,,はーちゃん...ねえ ひーちゃんは...
Dialogue: 0,0:21:03.68,0:21:07.85,Miracle_CN,,0,0,0,,小哈...小菲她...
Dialogue: 0,0:21:14.30,0:21:14.98,Miracle_JP,,0,0,0,,へぇ...
Dialogue: 0,0:21:14.30,0:21:14.98,Miracle_CN,,0,0,0,,诶...
Dialogue: 0,0:21:16.37,0:21:17.14,Magical_JP,,0,0,0,,ウソ
Dialogue: 0,0:21:16.37,0:21:17.14,Magical_CN,,0,0,0,,不会吧
Dialogue: 0,0:21:18.78,0:21:19.74,Mofurun_JP,,0,0,0,,モフ...
Dialogue: 0,0:21:18.78,0:21:19.74,Mofurun_CN,,0,0,0,,mofu...
Dialogue: 0,0:21:20.15,0:21:22.15,Mofurun_CN,,0,0,0,,
Dialogue: 0,0:23:09.87,0:23:11.66,Magical_JP,,0,0,0,,はーちゃんが戻ってきてくれたわ
Dialogue: 0,0:23:09.87,0:23:11.66,Magical_CN,,0,0,0,,小哈回来了
Dialogue: 0,0:23:12.04,0:23:13.90,Magical_JP,,0,0,0,,でも ひーちゃんはどこに行っちゃったの？
Dialogue: 0,0:23:12.04,0:23:13.90,Magical_CN,,0,0,0,,但是 小菲去哪了？
Comment: 0,0:23:14.76,0:23:17.04,Magical_CN,,0,0,0,,Maho Girls Precure!! ~MIRAI DAYS~
Dialogue: 0,0:23:14.76,0:23:17.04,Magical_JP,,0,0,0,,魔法つかいプリキュア！！～MIRAI DAYS～
Dialogue: 0,0:23:14.76,0:23:17.04,Magical_CN,,0,0,0,,下一集 魔法少女 光之美少女!! ~未来的日子~
Dialogue: 0,0:23:17.46,0:23:18.97,Magical_CN,,0,0,0,,掌管时间者
Dialogue: 0,0:23:19.71,0:23:20.85,Magical_JP,,0,0,0,,キュアップ・ラパパ！
Dialogue: 0,0:23:19.71,0:23:20.85,Curerpp_LK,,0,0,0,,CURE UP·RAPAPA !
Dialogue: 0,0:23:21.02,0:23:23.05,Magical_JP,,0,0,0,,今日もいい日にな～れ！
Dialogue: 0,0:23:21.02,0:23:23.05,Magical_CN,,0,0,0,,今天会是个好日子！
