Dialogue: 0,0:00:03.74,0:00:06.40,JP,,0,0,0,,何で　いつも
Dialogue: 0,0:00:16.10,0:00:18.44,JP,,0,0,0,,何でいつも私ばっかり
Dialogue: 0,0:00:20.96,0:00:23.22,JP,,0,0,0,,テっちゃんの前で泣けばよかった
Dialogue: 0,0:00:34.38,0:00:36.62,JP,,0,0,0,,焦っちゃダメ
Dialogue: 0,0:00:39.14,0:00:43.74,JP,,0,0,0,,焦っちゃダメって　分かってるんだけどなあ
Dialogue: 0,0:00:51.66,0:00:53.94,JP,,0,0,0,,雪　珍しいね
Dialogue: 0,0:00:55.06,0:00:55.62,JP,,0,0,0,,うん
Dialogue: 0,0:00:58.78,0:00:59.30,JP,,0,0,0,,はい
Dialogue: 0,0:01:09.30,0:01:10.28,JP,,0,0,0,,頼ってよ
Dialogue: 0,0:01:12.54,0:01:13.82,JP,,0,0,0,,頼りないかもだけど
Dialogue: 0,0:01:18.78,0:01:19.34,JP,,0,0,0,,うん
Dialogue: 0,0:01:21.06,0:01:21.84,JP,,0,0,0,,あと…
Dialogue: 0,0:01:23.34,0:01:24.20,JP,,0,0,0,,あと？
Dialogue: 0,0:01:25.50,0:01:28.10,JP,,0,0,0,,もっと思ってることも言って
Dialogue: 0,0:01:29.48,0:01:32.96,JP,,0,0,0,,ミワコのこと　誰よりも知りたいから
Dialogue: 0,0:01:36.22,0:01:38.78,JP,,0,0,0,,じゃあ　そっち
Dialogue: 0,0:01:39.60,0:01:39.96,JP,,0,0,0,,うん？
Dialogue: 0,0:01:41.02,0:01:42.42,JP,,0,0,0,,そっち飲みたい
Dialogue: 0,0:01:43.58,0:01:45.10,JP,,0,0,0,,これ？こっち？
Dialogue: 0,0:01:45.76,0:01:46.44,JP,,0,0,0,,いいよ
Dialogue: 0,0:01:47.80,0:01:50.64,JP,,0,0,0,,あっ　かなり飲んじゃったけど
Dialogue: 0,0:02:04.38,0:02:06.68,JP,,0,0,0,,ねえ　帰ろうか
Dialogue: 0,0:02:10.28,0:02:12.50,JP,,0,0,0,,雪　積もるかなあ
Dialogue: 0,0:02:12.80,0:02:14.14,JP,,0,0,0,,積もんないよ
Dialogue: 0,0:02:14.14,0:02:16.34,JP,,0,0,0,,え　積もるよ
Dialogue: 0,0:02:16.34,0:02:17.46,JP,,0,0,0,,積もんない
Dialogue: 0,0:02:17.46,0:02:18.78,JP,,0,0,0,,いいや　積もる
Dialogue: 0,0:02:18.90,0:02:19.66,JP,,0,0,0,,積もんない
Dialogue: 0,0:02:19.66,0:02:20.94,JP,,0,0,0,,積もるよ
Dialogue: 0,0:02:21.06,0:02:22.50,JP,,0,0,0,,積もんないよ
Dialogue: 0,0:02:22.94,0:02:24.36,JP,,0,0,0,,ああ　もう
Dialogue: 0,0:02:25.10,0:02:26.56,JP,,0,0,0,,積もればいいのに
Dialogue: 0,0:02:27.18,0:02:29.64,JP,,0,0,0,,うん　積もるといいね
Dialogue: 0,0:00:00.00,0:00:05.00,Default,,0,0,0,,
