Dialogue: 0,0:00:03.00,0:00:09.01,Default1,,0,0,0,,（手を洗う音）
Dialogue: 0,0:00:48.50,0:00:54.51,Default1,,0,0,0,,（呪霊）ぐおぉ… ぐおぉ…
Dialogue: 0,0:00:56.09,0:01:02.10,Default1,,0,0,0,,ぐおぉ… ぐおぉ…
Dialogue: 0,0:01:05.81,0:01:11.82,Default1,,0,0,0,,ぐおっ… ぐおぉ…
Dialogue: 0,0:01:15.74,0:01:17.91,Default1,,0,0,0,,（窓ガラスが割れる音）
Dialogue: 0,0:01:25.83,0:01:28.96,Default1,,0,0,0,,（足音）
Dialogue: 0,0:01:33.30,0:01:36.55,Default1,,0,0,0,,（呪霊）ぐおぉ～！
Dialogue: 0,0:01:44.81,0:01:46.19,Default1,,0,0,0,,（虎杖(いたどり)悠仁(ゆうじ)）っ…！
Dialogue: 0,0:01:47.77,0:01:50.65,Default1,,0,0,0,,（呪霊）ぐおぉ～…
Dialogue: 0,0:01:50.73,0:01:52.65,Default1,,0,0,0,,（足音）
Dialogue: 0,0:02:00.16,0:02:02.08,Default1,,0,0,0,,（足音）
Dialogue: 0,0:02:11.04,0:02:15.55,Default1,,0,0,0,,（呪霊）ぐあぁ～！
Dialogue: 0,0:02:24.93,0:02:28.64,Default1,,0,0,0,,（壁を突き破る音）
Dialogue: 0,0:02:36.24,0:02:38.28,Default1,,0,0,0,,（斬る音）
Dialogue: 0,0:02:39.16,0:02:42.16,Default1,,0,0,0,,（呪霊）ぐあぁ～…
Dialogue: 0,0:02:45.83,0:02:48.21,Default1,,0,0,0,,（衝撃音）
Dialogue: 0,0:02:49.83,0:02:52.21,Default1,,0,0,0,,（衝撃音）
Dialogue: 0,0:02:54.67,0:02:58.17,Default1,,0,0,0,,（虎杖）はぁ… はぁ…
Dialogue: 0,0:02:59.01,0:03:03.55,Default1,,0,0,0,,くっ… はぁ…
Dialogue: 0,0:03:05.14,0:03:10.19,Default1,,0,0,0,,はぁ… はぁ…
Dialogue: 0,0:03:18.19,0:03:24.20,Default1,,0,0,0,,ふぅ… ふぅ…
Dialogue: 0,0:03:31.83,0:03:34.08,Default1,,0,0,0,,（血が噴き出す音）
Dialogue: 0,0:03:34.96,0:03:39.97,Default1,,0,0,0,,♪～
Dialogue: 0,0:05:08.01,0:05:13.14,Default1,,0,0,0,,{\an8}～♪
Dialogue: 0,0:05:15.89,0:05:19.57,Default1,,0,0,0,,（直哉(なおや)）\Nで 死んだん？　真依(まい)ちゃん
Dialogue: 0,0:05:19.65,0:05:23.24,Default1,,0,0,0,,（真希(まき)と真依の母）\N…今は当主の心配を
Dialogue: 0,0:05:23.32,0:05:25.78,Default1,,0,0,0,,それに\N死にかけているのは真希です
Dialogue: 0,0:05:25.86,0:05:28.78,Default1,,0,0,0,,（直哉）そうなん？　ほな ええわ
Dialogue: 0,0:05:28.87,0:05:31.58,Default1,,0,0,0,,べっぴんさんやけど\N真希ちゃんは アカン
Dialogue: 0,0:05:31.66,0:05:33.75,Default1,,0,0,0,,アレは 男を立てられへん
Dialogue: 0,0:05:33.83,0:05:37.96,Default1,,0,0,0,,三歩 後ろを歩かれへん女は\N背中 刺されて死んだらええ
Dialogue: 0,0:05:38.79,0:05:41.67,Default1,,0,0,0,,{\an8}その点 真依ちゃんは\N立派やね
Dialogue: 0,0:05:44.34,0:05:47.63,Default1,,0,0,0,,（直哉）真希ちゃんとおんなじ顔\Nおんなじ乳
Dialogue: 0,0:05:47.72,0:05:51.89,Default1,,0,0,0,,強がっとるけど\N自分が女やと 心底 理解しとる
Dialogue: 0,0:05:52.47,0:05:55.81,Default1,,0,0,0,,（扇(おうぎ)）遅いぞ　何をしていた？
Dialogue: 0,0:05:55.89,0:05:59.44,Default1,,0,0,0,,実の父親が\N峠をさまよっているときに
Dialogue: 0,0:05:59.52,0:06:02.36,Default1,,0,0,0,,（直哉）ごめんちゃい♡\Nでも 別にええやろ
Dialogue: 0,0:06:02.44,0:06:04.57,Default1,,0,0,0,,俺が来ても 来やんでも
Dialogue: 0,0:06:04.65,0:06:07.70,Default1,,0,0,0,,次の禪院(ぜんいん)家当主は\N俺なんやから
Dialogue: 0,0:06:08.78,0:06:12.03,Default1,,0,0,0,,俺の兄さん方は\Nみんな ポンコツやし
Dialogue: 0,0:06:12.74,0:06:16.08,Default1,,0,0,0,,叔父…\N弟のアンタも パッとせぇへん
Dialogue: 0,0:06:16.16,0:06:18.37,Default1,,0,0,0,,その娘は論外
Dialogue: 0,0:06:18.46,0:06:20.38,Default1,,0,0,0,,甚壱(じんいち)君はなぁ…
Dialogue: 0,0:06:22.92,0:06:24.92,Default1,,0,0,0,,顔がアカンわ
Dialogue: 0,0:06:25.01,0:06:28.09,Default1,,0,0,0,,甚爾(とうじ)君と逆やったら\Nよかったのにな
Dialogue: 0,0:06:28.18,0:06:29.55,Default1,,0,0,0,,（衝撃音）
Dialogue: 0,0:06:35.39,0:06:38.02,Default1,,0,0,0,,{\an8}（直哉）パパが\N峠をさまよってんねんで
Dialogue: 0,0:06:38.10,0:06:40.40,Default1,,0,0,0,,{\an8}堪忍したってや
Dialogue: 0,0:06:41.02,0:06:43.19,Default1,,0,0,0,,（フルダテ）皆さん おそろいで
Dialogue: 0,0:06:45.36,0:06:49.49,Default1,,0,0,0,,（フルダテ）たった今\N禪院家当主 禪院直毘人(なおびと)様が
Dialogue: 0,0:06:49.57,0:06:51.95,Default1,,0,0,0,,お亡くなりになられました
Dialogue: 0,0:06:55.49,0:06:57.00,Default1,,0,0,0,,（フルダテ）ご遺言状は
Dialogue: 0,0:06:57.08,0:07:00.08,Default1,,0,0,0,,このフルダテが\Nお預かりいたしております
Dialogue: 0,0:07:00.17,0:07:03.75,Default1,,0,0,0,,ご遺言状は\N直毘人様のご遺志によって
Dialogue: 0,0:07:03.84,0:07:05.96,Default1,,0,0,0,,禪院 扇様
Dialogue: 0,0:07:06.05,0:07:08.59,Default1,,0,0,0,,禪院甚壱様
Dialogue: 0,0:07:08.67,0:07:10.93,Default1,,0,0,0,,禪院直哉様
Dialogue: 0,0:07:11.01,0:07:13.43,Default1,,0,0,0,,三名がそろわれたとき
Dialogue: 0,0:07:13.51,0:07:16.93,Default1,,0,0,0,,私から お伝えすることに\Nなっております
Dialogue: 0,0:07:18.06,0:07:21.94,Default1,,0,0,0,,相違なければ\Nご遺言状を読み上げます
Dialogue: 0,0:07:28.53,0:07:32.20,Default1,,0,0,0,,（フルダテ）\N“一つ 禪院家27代目当主を”
Dialogue: 0,0:07:32.28,0:07:34.45,Default1,,0,0,0,,“禪院直哉とす”
Dialogue: 0,0:07:35.03,0:07:37.95,Default1,,0,0,0,,“一つ 高専忌庫(こうせんきこ) および”
Dialogue: 0,0:07:38.04,0:07:42.71,Default1,,0,0,0,,“禪院家忌庫に保管されている\N呪具を含めた全財産を”
Dialogue: 0,0:07:42.79,0:07:44.84,Default1,,0,0,0,,“直哉が相続し”
Dialogue: 0,0:07:44.92,0:07:50.88,Default1,,0,0,0,,“禪院 扇 禪院甚壱の\Nいずれかの承認を得たうえで”
Dialogue: 0,0:07:51.51,0:07:53.55,Default1,,0,0,0,,“直哉が運用することとす”
Dialogue: 0,0:07:53.55,0:07:54.76,Default1,,0,0,0,,“直哉が運用することとす”
Dialogue: 0,0:07:53.55,0:07:54.76,Default1,,0,0,0,,{\an8}（直哉）チッ
Dialogue: 0,0:07:56.14,0:07:57.64,Default1,,0,0,0,,まあええか
Dialogue: 0,0:07:57.72,0:07:59.18,Default1,,0,0,0,,（フルダテ）“ただし”
Dialogue: 0,0:07:59.27,0:08:02.60,Default1,,0,0,0,,“なんらかの理由で\N五条(ごじょう)悟(さとる)が死亡”
Dialogue: 0,0:08:02.69,0:08:06.40,Default1,,0,0,0,,“または\N意思能力を喪失した場合”
Dialogue: 0,0:08:06.48,0:08:10.11,Default1,,0,0,0,,“伏黒(ふしぐろ)甚爾との誓約状を履行し”
Dialogue: 0,0:08:10.19,0:08:16.37,Default1,,0,0,0,,“伏黒 恵(めぐみ)を禪院家に迎え\N同人を禪院家当主とし”
Dialogue: 0,0:08:16.45,0:08:19.95,Default1,,0,0,0,,“全財産を譲るものとする”
Dialogue: 0,0:08:21.96,0:08:24.46,Default1,,0,0,0,,あっ？　やっぱ あかんわ
Dialogue: 0,0:08:24.54,0:08:26.46,Default1,,0,0,0,,タマなしや あの二人
Dialogue: 0,0:08:26.54,0:08:28.67,Default1,,0,0,0,,よう知らんガキが当主になっても
Dialogue: 0,0:08:28.75,0:08:30.88,Default1,,0,0,0,,俺よりはマシやと\Nなんもせん気や
Dialogue: 0,0:08:32.67,0:08:35.26,Default1,,0,0,0,,恵君は 今 どこで何してるん？
Dialogue: 0,0:08:35.34,0:08:37.01,Default1,,0,0,0,,（真希と真依の母）詳しくは…
Dialogue: 0,0:08:37.10,0:08:40.77,Default1,,0,0,0,,ただ 東京で 虎杖悠仁捜索の任に\N当たっているそうです
Dialogue: 0,0:08:40.85,0:08:42.39,Default1,,0,0,0,,誰やねん？
Dialogue: 0,0:08:42.48,0:08:44.14,Default1,,0,0,0,,（真希と真依の母）\N例の 宿儺(すくな)の器です
Dialogue: 0,0:08:44.73,0:08:46.90,Default1,,0,0,0,,（直哉）じゃあ 上の人に伝えとき
Dialogue: 0,0:08:46.98,0:08:49.48,Default1,,0,0,0,,禪院直哉が 宿儺の器 殺したるて
Dialogue: 0,0:08:49.57,0:08:50.40,Default1,,0,0,0,,（真希と真依の母）えっ…
Dialogue: 0,0:08:50.48,0:08:53.74,Default1,,0,0,0,,（直哉）恵君は 宿儺の器のとこ\Nおるんやろ？
Dialogue: 0,0:08:53.82,0:08:55.53,Default1,,0,0,0,,二人まとめて殺したる
Dialogue: 0,0:08:56.70,0:08:58.41,Default1,,0,0,0,,今の東京は 魔境や
Dialogue: 0,0:08:59.16,0:09:01.79,Default1,,0,0,0,,人が いつ\Nどう死んでも関係あらへん
Dialogue: 0,0:09:02.83,0:09:06.12,Default1,,0,0,0,,殺してしまえば\Nあとのことは どうとでもなる
Dialogue: 0,0:09:09.42,0:09:12.05,Default1,,0,0,0,,禪院家当主は 俺や
Dialogue: 0,0:09:19.89,0:09:22.64,Default1,,0,0,0,,（虎杖）ううっ…　死ねよ
Dialogue: 0,0:09:23.35,0:09:25.14,Default1,,0,0,0,,-（虎杖）自分だけ！\N-（七海(ななみ)）後は頼みます
Dialogue: 0,0:09:25.23,0:09:27.44,Default1,,0,0,0,,-（釘崎(くぎさき)）虎杖…\N-（七海）虎杖君
Dialogue: 0,0:09:27.52,0:09:28.48,Default1,,0,0,0,,（九十九(つくも)）君は どうする？
Dialogue: 0,0:09:53.67,0:09:54.80,Default1,,0,0,0,,（脹相(ちょうそう)）悠仁
Dialogue: 0,0:09:55.76,0:09:58.01,Default1,,0,0,0,,ケガの具合はどうだ？
Dialogue: 0,0:09:58.89,0:10:01.39,Default1,,0,0,0,,{\an8}“黒閃(こくせん)”を\Nくらったとこ以外は
Dialogue: 0,0:10:01.47,0:10:03.06,Default1,,0,0,0,,{\an8}まあ 平気
Dialogue: 0,0:10:04.27,0:10:06.31,Default1,,0,0,0,,たぶん 宿儺の影響だ
Dialogue: 0,0:10:06.89,0:10:09.61,Default1,,0,0,0,,アイツの力が\N大きくなってるのを感じる
Dialogue: 0,0:10:10.90,0:10:13.98,Default1,,0,0,0,,（脹相）悠仁 俺に気を遣うな
Dialogue: 0,0:10:14.07,0:10:15.90,Default1,,0,0,0,,高専に戻っていいんだぞ
Dialogue: 0,0:10:16.61,0:10:19.74,Default1,,0,0,0,,俺も 焼相(しょうそう)たちの亡骸(なきがら)を\N回収したいしな
Dialogue: 0,0:10:21.33,0:10:23.24,Default1,,0,0,0,,（虎杖）つかってねぇよ
Dialogue: 0,0:10:23.33,0:10:25.95,Default1,,0,0,0,,俺が戻りたいかどうかの\N問題じゃねぇんだ
Dialogue: 0,0:10:26.66,0:10:29.79,Default1,,0,0,0,,宿儺が伏黒を使って\N何か たくらんでる
Dialogue: 0,0:10:30.50,0:10:33.84,Default1,,0,0,0,,それに 俺は 人をいっぱい殺した
Dialogue: 0,0:10:34.84,0:10:38.88,Default1,,0,0,0,,（伏黒 恵）自分が助けた人間が\N将来 人を殺したらどうする？
Dialogue: 0,0:10:40.43,0:10:43.31,Default1,,0,0,0,,（虎杖）俺は\Nもう 皆(みんな)と一緒にはいられない
Dialogue: 0,0:10:44.10,0:10:45.52,Default1,,0,0,0,,脹相こそ いいのか？
Dialogue: 0,0:10:45.60,0:10:48.14,Default1,,0,0,0,,俺は お前の弟も殺したんだぞ
Dialogue: 0,0:10:48.23,0:10:50.81,Default1,,0,0,0,,（脹相）いい　あれは事故だ
Dialogue: 0,0:10:50.90,0:10:55.23,Default1,,0,0,0,,壊相(えそう)も血塗(けちず)も 俺の立場なら\N同じようにしたはずだ
Dialogue: 0,0:10:55.32,0:10:57.65,Default1,,0,0,0,,赦(ゆる)す赦さないじゃない
Dialogue: 0,0:10:57.74,0:10:59.95,Default1,,0,0,0,,兄弟とは そういうものだ
Dialogue: 0,0:11:03.28,0:11:04.70,Default1,,0,0,0,,（虎杖）……行こう
Dialogue: 0,0:11:04.79,0:11:07.00,Default1,,0,0,0,,今は とにかく 呪霊を減らさないと
Dialogue: 0,0:11:07.08,0:11:09.87,Default1,,0,0,0,,（手をたたく音）
Dialogue: 0,0:11:12.33,0:11:14.67,Default1,,0,0,0,,（呪霊たち）ぐおぉ～…
Dialogue: 0,0:11:17.17,0:11:21.18,Default1,,0,0,0,,（虎杖）はぁ はぁ はぁ はぁ…
Dialogue: 0,0:11:21.26,0:11:22.09,Default1,,0,0,0,,あっ
Dialogue: 0,0:11:24.43,0:11:25.60,Default1,,0,0,0,,んっ！
Dialogue: 0,0:11:33.90,0:11:36.32,Default1,,0,0,0,,はぁ はぁ はぁ はぁ…
Dialogue: 0,0:11:39.07,0:11:40.24,Default1,,0,0,0,,んっ！
Dialogue: 0,0:11:43.12,0:11:44.53,Default1,,0,0,0,,（蹴る音）
Dialogue: 0,0:11:49.83,0:11:50.66,Default1,,0,0,0,,（呪霊）ぐあっ！
Dialogue: 0,0:11:54.79,0:11:56.75,Default1,,0,0,0,,（虎杖）ふんっ！\N（ガラスが割れる音）
Dialogue: 0,0:11:57.88,0:11:58.96,Default1,,0,0,0,,（呪霊）ぐあ～！
Dialogue: 0,0:12:02.01,0:12:02.97,Default1,,0,0,0,,（息を吸う音）
Dialogue: 0,0:12:14.19,0:12:15.36,Default1,,0,0,0,,（手すりがきしむ音）
Dialogue: 0,0:12:18.48,0:12:20.36,Default1,,0,0,0,,（呪霊）ぐお～！\N（蹴破る音）
Dialogue: 0,0:12:25.12,0:12:26.12,Default1,,0,0,0,,（虎杖）んっ！
Dialogue: 0,0:12:30.25,0:12:33.46,Default1,,0,0,0,,（呪霊たち）ぐおぉ～…
Dialogue: 0,0:12:36.54,0:12:38.59,Default1,,0,0,0,,（呪霊たち）ぐおぉ～…
Dialogue: 0,0:12:38.67,0:12:40.59,Default1,,0,0,0,,（虎杖）はぁ はぁ はぁ…
Dialogue: 0,0:12:40.67,0:12:43.63,Default1,,0,0,0,,（呪霊たち）ぐおぉ～…
Dialogue: 0,0:12:43.72,0:12:50.02,Default1,,0,0,0,,（虎杖）はぁ はぁ はぁ はぁ…
Dialogue: 0,0:12:50.10,0:12:53.39,Default1,,0,0,0,,（呪霊たち）ぐおぉ～…
Dialogue: 0,0:12:57.40,0:12:59.32,Default1,,0,0,0,,（虎杖）はぁ はぁ はぁ はぁ…
Dialogue: 0,0:12:59.40,0:13:00.82,Default1,,0,0,0,,脹相！
Dialogue: 0,0:13:04.36,0:13:05.78,Default1,,0,0,0,,（呪霊）ぐおっ…
Dialogue: 0,0:13:07.91,0:13:08.78,Default1,,0,0,0,,悠仁
Dialogue: 0,0:13:13.87,0:13:15.12,Default1,,0,0,0,,（殴打音）
Dialogue: 0,0:13:21.30,0:13:23.30,Default1,,0,0,0,,（脹相）すさまじいな
Dialogue: 0,0:13:23.38,0:13:25.93,Default1,,0,0,0,,俺と戦ったときは\Nパワフルな印象だった
Dialogue: 0,0:13:26.76,0:13:29.39,Default1,,0,0,0,,今は そこに繊細さが加わっている
Dialogue: 0,0:13:29.47,0:13:33.31,Default1,,0,0,0,,よどみない呪力操作\N桁違いの膂力(りょりょく)
Dialogue: 0,0:13:36.06,0:13:37.94,Default1,,0,0,0,,まさに鬼神!!
Dialogue: 0,0:13:38.02,0:13:40.94,Default1,,0,0,0,,これで まだ\N全快ではないというのだからな
Dialogue: 0,0:13:42.65,0:13:45.07,Default1,,0,0,0,,（脹相）さすが 俺の弟だ
Dialogue: 0,0:13:45.15,0:13:46.91,Default1,,0,0,0,,まだ言ってんの？
Dialogue: 0,0:13:47.99,0:13:49.78,Default1,,0,0,0,,（脹相）何度でも言うさ
Dialogue: 0,0:13:49.87,0:13:52.79,Default1,,0,0,0,,思い出せ　あったはずだ
Dialogue: 0,0:13:56.08,0:13:59.33,Default1,,0,0,0,,オマエの父の額にも 縫い目が
Dialogue: 0,0:14:01.88,0:14:04.05,Default1,,0,0,0,,（直哉）恵君 おらんやん
Dialogue: 0,0:14:04.13,0:14:06.63,Default1,,0,0,0,,俺が一番乗り？\Nそんなことあんの？
Dialogue: 0,0:14:06.72,0:14:08.43,Default1,,0,0,0,,トロすぎひん？
Dialogue: 0,0:14:08.51,0:14:12.43,Default1,,0,0,0,,（虎杖）誰だ？　コイツ……\N今 伏黒の話 したか？
Dialogue: 0,0:14:12.51,0:14:15.98,Default1,,0,0,0,,（直哉）君らも何してん？\N目立ち過ぎやで
Dialogue: 0,0:14:16.06,0:14:17.94,Default1,,0,0,0,,逃げる気ないん？
Dialogue: 0,0:14:18.02,0:14:19.19,Default1,,0,0,0,,（虎杖）“逃げる”？
Dialogue: 0,0:14:19.27,0:14:23.53,Default1,,0,0,0,,（直哉）なんや 知らんのか\N君 死刑やって
Dialogue: 0,0:14:23.61,0:14:26.32,Default1,,0,0,0,,悟君の後ろだてが\Nのうなったから
Dialogue: 0,0:14:26.40,0:14:27.32,Default1,,0,0,0,,ああっ？
Dialogue: 0,0:14:27.40,0:14:28.57,Default1,,0,0,0,,あっ
Dialogue: 0,0:14:29.24,0:14:30.70,Default1,,0,0,0,,（猪野(いの)）五条さんが\N利かせていた—
Dialogue: 0,0:14:30.78,0:14:34.41,Default1,,0,0,0,,融通（(かっこ)わがまま）で\N救われていた術師が数多くいる
Dialogue: 0,0:14:34.49,0:14:37.04,Default1,,0,0,0,,（直哉）\N俺が用あんのは恵君やから
Dialogue: 0,0:14:37.12,0:14:40.17,Default1,,0,0,0,,ぶっちゃけ\N君は 生死は どうでもええねん
Dialogue: 0,0:14:40.25,0:14:42.25,Default1,,0,0,0,,でも チョコマカされんのも\Nあれやし
Dialogue: 0,0:14:42.34,0:14:45.05,Default1,,0,0,0,,とりあえず\N足でも折っといたろかな
Dialogue: 0,0:14:45.13,0:14:47.51,Default1,,0,0,0,,伏黒になんの用だよ
Dialogue: 0,0:14:47.59,0:14:49.76,Default1,,0,0,0,,（直哉）死んでもらお思て
Dialogue: 0,0:14:49.84,0:14:53.47,Default1,,0,0,0,,その前に 一筆 書いてくれると\N助かるねんけどな
Dialogue: 0,0:14:53.56,0:14:55.81,Default1,,0,0,0,,恵君 君を捜してるんやって
Dialogue: 0,0:14:57.06,0:14:58.06,Default1,,0,0,0,,-（直哉）ふっ\N-（虎杖）かはっ！
Dialogue: 0,0:14:59.06,0:15:00.27,Default1,,0,0,0,,うっ！
Dialogue: 0,0:15:01.98,0:15:04.11,Default1,,0,0,0,,（脹相）はっ… うっ！
Dialogue: 0,0:15:08.28,0:15:09.61,Default1,,0,0,0,,-（脹相）ふんっ！\N-（直哉）あっ？
Dialogue: 0,0:15:09.70,0:15:11.03,Default1,,0,0,0,,（脹相）ぐっ！
Dialogue: 0,0:15:16.41,0:15:19.58,Default1,,0,0,0,,速いっちゃ速いんだけど\Nなんか変だな
Dialogue: 0,0:15:19.66,0:15:21.63,Default1,,0,0,0,,術式だろうな
Dialogue: 0,0:15:21.71,0:15:23.96,Default1,,0,0,0,,（直哉）\N思たより やりよるんやね
Dialogue: 0,0:15:24.04,0:15:25.96,Default1,,0,0,0,,正直 ナメてたわ
Dialogue: 0,0:15:26.84,0:15:30.47,Default1,,0,0,0,,器は まあ 分かるとして\N隣のは何もんや？
Dialogue: 0,0:15:30.55,0:15:33.35,Default1,,0,0,0,,もうちょい速(はよ)うしてみるか
Dialogue: 0,0:15:35.56,0:15:36.97,Default1,,0,0,0,,（３人）はっ！
Dialogue: 0,0:15:39.52,0:15:41.06,Default1,,0,0,0,,（虎杖）五条先生!?
Dialogue: 0,0:15:41.14,0:15:43.90,Default1,,0,0,0,,いや もっと不気味な……!!
Dialogue: 0,0:15:51.03,0:15:53.87,Default1,,0,0,0,,（乙骨(おっこつ)）あれ？　一人じゃないんだ
Dialogue: 0,0:15:59.66,0:16:00.50,Default1,,0,0,0,,……誰だ？
Dialogue: 0,0:16:00.58,0:16:02.75,Default1,,0,0,0,,（脹相）誰であろうと 目的は…
Dialogue: 0,0:16:02.83,0:16:05.75,Default1,,0,0,0,,（乙骨）誰が 虎杖君の… 何？
Dialogue: 0,0:16:06.84,0:16:09.51,Default1,,0,0,0,,（脹相）\Nやはり 悠仁の死刑執行人か
Dialogue: 0,0:16:09.59,0:16:13.26,Default1,,0,0,0,,（衝撃音）
Dialogue: 0,0:16:17.72,0:16:20.14,Default1,,0,0,0,,（直哉）ちょい待って　味方やで
Dialogue: 0,0:16:20.89,0:16:22.52,Default1,,0,0,0,,君 乙骨君やろ？
Dialogue: 0,0:16:22.60,0:16:26.36,Default1,,0,0,0,,（虎杖）乙骨…\N伏黒が言ってた二年の…
Dialogue: 0,0:16:26.44,0:16:29.53,Default1,,0,0,0,,五条先生と同じ特級術師
Dialogue: 0,0:16:29.61,0:16:30.78,Default1,,0,0,0,,アナタは？
Dialogue: 0,0:16:30.86,0:16:34.24,Default1,,0,0,0,,禪院直哉\N真希ちゃんのいとこや
Dialogue: 0,0:16:34.32,0:16:36.99,Default1,,0,0,0,,君とおんなじで\N虎杖君 殺せって言われとる
Dialogue: 0,0:16:36.99,0:16:37.99,Default1,,0,0,0,,君とおんなじで\N虎杖君 殺せって言われとる
Dialogue: 0,0:16:36.99,0:16:37.99,Default1,,0,0,0,,{\an8}（脹相）\N逃げるぞ 悠仁
Dialogue: 0,0:16:37.99,0:16:38.08,Default1,,0,0,0,,{\an8}（脹相）\N逃げるぞ 悠仁
Dialogue: 0,0:16:38.08,0:16:38.79,Default1,,0,0,0,,{\an8}（脹相）\N逃げるぞ 悠仁
Dialogue: 0,0:16:38.08,0:16:38.79,Default1,,0,0,0,,安心しぃ\N君の邪魔はせぇへん
Dialogue: 0,0:16:38.79,0:16:38.87,Default1,,0,0,0,,安心しぃ\N君の邪魔はせぇへん
Dialogue: 0,0:16:38.87,0:16:40.12,Default1,,0,0,0,,安心しぃ\N君の邪魔はせぇへん
Dialogue: 0,0:16:38.87,0:16:40.12,Default1,,0,0,0,,{\an8}（虎杖）あっ？
Dialogue: 0,0:16:40.12,0:16:41.16,Default1,,0,0,0,,安心しぃ\N君の邪魔はせぇへん
Dialogue: 0,0:16:41.25,0:16:44.00,Default1,,0,0,0,,金髪は 種のあるスピードタイプ
Dialogue: 0,0:16:44.08,0:16:46.50,Default1,,0,0,0,,あいつと追いかけっこは\N美味(うま)くない
Dialogue: 0,0:16:46.58,0:16:47.92,Default1,,0,0,0,,俺が足止めする
Dialogue: 0,0:16:48.00,0:16:49.30,Default1,,0,0,0,,大丈夫かよ
Dialogue: 0,0:16:49.38,0:16:52.13,Default1,,0,0,0,,そのかわり 虎杖君を殺しても
Dialogue: 0,0:16:52.22,0:16:55.18,Default1,,0,0,0,,そのことを 上に\Nしばらく黙っててくれへん？
Dialogue: 0,0:16:55.26,0:16:57.30,Default1,,0,0,0,,彼を餌に会いたい人がおんねん
Dialogue: 0,0:16:57.39,0:16:59.06,Default1,,0,0,0,,俺はな
Dialogue: 0,0:16:59.14,0:17:01.89,Default1,,0,0,0,,狙われてるのは お前だぞ 悠仁
Dialogue: 0,0:17:01.98,0:17:06.44,Default1,,0,0,0,,黒髪… 乙骨から\N逃げきることだけを考えろ
Dialogue: 0,0:17:06.52,0:17:10.44,Default1,,0,0,0,,五条 悟と同じタイプとみた\N戦ったら死ぬぞ
Dialogue: 0,0:17:10.53,0:17:13.49,Default1,,0,0,0,,（直哉）恵君のこと\N黙っといたらよかったな
Dialogue: 0,0:17:13.57,0:17:14.70,Default1,,0,0,0,,肝 冷えるわ
Dialogue: 0,0:17:14.78,0:17:17.20,Default1,,0,0,0,,（脹相）悠仁と術師(にんげん)を戦わせず
Dialogue: 0,0:17:17.28,0:17:20.54,Default1,,0,0,0,,かつ\N俺に引け目を感じさせない提案
Dialogue: 0,0:17:20.62,0:17:23.33,Default1,,0,0,0,,フッ 世話が焼ける
Dialogue: 0,0:17:23.41,0:17:25.33,Default1,,0,0,0,,昨日の地点で落ち合うぞ
Dialogue: 0,0:17:25.42,0:17:28.46,Default1,,0,0,0,,いいですよ\Nじゃあ そっちは任せます
Dialogue: 0,0:17:28.54,0:17:30.34,Default1,,0,0,0,,応!!　っ！
Dialogue: 0,0:17:31.92,0:17:34.72,Default1,,0,0,0,,（虎杖）速い!!\N抜き身の刀を持って これかよ!!
Dialogue: 0,0:17:36.43,0:17:39.97,Default1,,0,0,0,,（乙骨）速いな　走りだしで\N潰すつもりだったのに
Dialogue: 0,0:17:40.05,0:17:43.27,Default1,,0,0,0,,（脹相）チッ\N乙骨の進路を妨害するつもりが
Dialogue: 0,0:17:43.35,0:17:44.56,Default1,,0,0,0,,読まれていたか!!
Dialogue: 0,0:17:44.64,0:17:46.81,Default1,,0,0,0,,（直哉）見てたで さっき
Dialogue: 0,0:17:46.90,0:17:49.02,Default1,,0,0,0,,“赤血操術(せっけつそうじゅつ)”やろ
Dialogue: 0,0:17:49.11,0:17:52.32,Default1,,0,0,0,,なんで 君が それを\N持っとんのかは知らんけど
Dialogue: 0,0:17:52.40,0:17:55.07,Default1,,0,0,0,,“穿血(せんけつ)”以外は そんな怖ない
Dialogue: 0,0:17:55.15,0:17:59.28,Default1,,0,0,0,,ほんで“穿血”を出すには“百斂(びゃくれん)”\Nデカいタメがいる
Dialogue: 0,0:17:59.37,0:18:01.70,Default1,,0,0,0,,後は言わんでも分かるやろ
Dialogue: 0,0:18:01.79,0:18:04.04,Default1,,0,0,0,,詰みや　死ぬで 君
Dialogue: 0,0:18:04.12,0:18:08.67,Default1,,0,0,0,,（脹相）オマエこそ\N俺の弟に手を出して
Dialogue: 0,0:18:08.75,0:18:11.50,Default1,,0,0,0,,生きて帰れると思っているのか？
Dialogue: 0,0:18:12.75,0:18:17.05,Default1,,0,0,0,,（呪霊）ぐおぉ～…
Dialogue: 0,0:18:21.51,0:18:24.06,Default1,,0,0,0,,（虎杖）っ… うっ…
Dialogue: 0,0:18:24.60,0:18:25.68,Default1,,0,0,0,,ふっ！
Dialogue: 0,0:18:28.98,0:18:30.69,Default1,,0,0,0,,あっ！
Dialogue: 0,0:18:32.52,0:18:35.07,Default1,,0,0,0,,（乙骨）絶対 斬ったと思ったのに
Dialogue: 0,0:18:35.15,0:18:36.61,Default1,,0,0,0,,真希さんみたいだ
Dialogue: 0,0:18:42.28,0:18:46.08,Default1,,0,0,0,,（虎杖）ふっ… っ！　くっ… っ！
Dialogue: 0,0:18:46.16,0:18:47.33,Default1,,0,0,0,,くっ！　っ！
Dialogue: 0,0:18:50.54,0:18:52.96,Default1,,0,0,0,,（衝撃音）
Dialogue: 0,0:18:53.63,0:18:54.88,Default1,,0,0,0,,（虎杖）うっ…
Dialogue: 0,0:18:58.47,0:19:02.22,Default1,,0,0,0,,（乙骨）驚いた？\Nパワータイプに見えないもんね
Dialogue: 0,0:19:02.30,0:19:04.22,Default1,,0,0,0,,（虎杖）パワーがなくても
Dialogue: 0,0:19:04.31,0:19:06.68,Default1,,0,0,0,,とんでもねぇ呪力量だ
Dialogue: 0,0:19:06.77,0:19:08.85,Default1,,0,0,0,,（乙骨）実際 非力な方だしね
Dialogue: 0,0:19:08.94,0:19:12.19,Default1,,0,0,0,,（虎杖）パワー不足を\N呪力強化で補ってる
Dialogue: 0,0:19:12.27,0:19:15.36,Default1,,0,0,0,,皆 やってることだけど\Nこの人がやると…
Dialogue: 0,0:19:15.44,0:19:16.86,Default1,,0,0,0,,俺と真逆だな
Dialogue: 0,0:19:19.78,0:19:24.28,Default1,,0,0,0,,（乙骨）気づいた？\N五条先生より多いんだよ 呪力量
Dialogue: 0,0:19:24.37,0:19:25.20,Default1,,0,0,0,,（虎杖）いっ！
Dialogue: 0,0:19:25.29,0:19:28.25,Default1,,0,0,0,,（乙骨）でも 先生には\N“六眼(りくがん)”があるから
Dialogue: 0,0:19:28.33,0:19:30.92,Default1,,0,0,0,,術式を発動したときの\Nエネルギーのロスが
Dialogue: 0,0:19:31.00,0:19:32.92,Default1,,0,0,0,,限りなくゼロなんだ
Dialogue: 0,0:19:33.71,0:19:36.71,Default1,,0,0,0,,パフォーマンスでは\Nやっぱり 先生が１番だよ
Dialogue: 0,0:19:36.80,0:19:40.63,Default1,,0,0,0,,僕に 呪力切れはあっても\N先生にはないしね
Dialogue: 0,0:19:42.05,0:19:43.76,Default1,,0,0,0,,話は終わり
Dialogue: 0,0:19:45.35,0:19:47.18,Default1,,0,0,0,,（虎杖）くっ… っ！
Dialogue: 0,0:19:49.18,0:19:50.19,Default1,,0,0,0,,くそっ!!
Dialogue: 0,0:19:50.27,0:19:54.23,Default1,,0,0,0,,（東堂(とうどう)）一流の術師ほど\N呪力の流れが読みづらいものだ
Dialogue: 0,0:19:54.31,0:19:56.11,Default1,,0,0,0,,オマエとは違う理由でな
Dialogue: 0,0:19:56.19,0:19:57.73,Default1,,0,0,0,,{\an8}（虎杖）\Nあれは 一流ほど
Dialogue: 0,0:19:57.82,0:19:59.61,Default1,,0,0,0,,{\an8}呪力操作の精度が\N高いから
Dialogue: 0,0:19:59.69,0:20:01.11,Default1,,0,0,0,,{\an8}直前まで 攻撃が
Dialogue: 0,0:20:01.20,0:20:02.86,Default1,,0,0,0,,{\an8}予測できない\Nという意味だ
Dialogue: 0,0:20:02.95,0:20:04.82,Default1,,0,0,0,,（虎杖）ふっ！\N（殴打音）
Dialogue: 0,0:20:04.91,0:20:06.12,Default1,,0,0,0,,（虎杖）でも この人は
Dialogue: 0,0:20:06.20,0:20:10.37,Default1,,0,0,0,,刀を含め 全身から\N常に呪力が立ち上ってる
Dialogue: 0,0:20:10.46,0:20:13.54,Default1,,0,0,0,,動きを読む 読まない以前の問題!!
Dialogue: 0,0:20:13.63,0:20:16.13,Default1,,0,0,0,,全ての攻撃が決定打になりえるし
Dialogue: 0,0:20:16.21,0:20:19.38,Default1,,0,0,0,,全てのダメージを\N最小限に抑えられる
Dialogue: 0,0:20:19.46,0:20:21.13,Default1,,0,0,0,,（七海）後は頼みます
Dialogue: 0,0:20:21.84,0:20:25.64,Default1,,0,0,0,,悪いけど\Nまだ死ぬわけにはいかねぇんだわ
Dialogue: 0,0:20:26.85,0:20:28.56,Default1,,0,0,0,,（虎杖）ふっ！\N（斬る音）
Dialogue: 0,0:20:29.60,0:20:31.02,Default1,,0,0,0,,（虎杖）くっ！
Dialogue: 0,0:20:33.44,0:20:34.69,Default1,,0,0,0,,（五条）タイプによっては
Dialogue: 0,0:20:34.77,0:20:37.48,Default1,,0,0,0,,得物の扱いを軸に\N修行を進めるんだけど
Dialogue: 0,0:20:38.57,0:20:43.32,Default1,,0,0,0,,呪具頼りとかになって\N呪力操作が疎(おろそ)かになっても嫌だし
Dialogue: 0,0:20:43.40,0:20:45.82,Default1,,0,0,0,,悠仁に\Nこういうのは まだ先かな
Dialogue: 0,0:20:46.16,0:20:46.91,Default1,,0,0,0,,（虎杖）っ…！
Dialogue: 0,0:20:46.99,0:20:48.74,Default1,,0,0,0,,（五条）屠坐魔(とざま)は応急処置
Dialogue: 0,0:20:49.29,0:20:51.70,Default1,,0,0,0,,（刀とナイフのぶつかり合う音）\N（虎杖）習ってねぇんだよ！
Dialogue: 0,0:20:53.71,0:20:56.04,Default1,,0,0,0,,（乙骨）意識が 刀にいきすぎ
Dialogue: 0,0:20:56.13,0:20:58.00,Default1,,0,0,0,,（蹴る音）\N（虎杖）がはっ！
Dialogue: 0,0:20:58.09,0:21:00.09,Default1,,0,0,0,,うらぁ！
Dialogue: 0,0:21:00.17,0:21:01.05,Default1,,0,0,0,,（刀とナイフが折れる音）
Dialogue: 0,0:21:04.05,0:21:04.88,Default1,,0,0,0,,（乙骨）折られた……
Dialogue: 0,0:21:05.59,0:21:08.81,Default1,,0,0,0,,まあ そうだよね\N五条先生の教え子だもん
Dialogue: 0,0:21:08.89,0:21:11.06,Default1,,0,0,0,,{\an8}一筋縄じゃいかないか
Dialogue: 0,0:21:11.77,0:21:14.23,Default1,,0,0,0,,（虎杖）傷は深い……\Nけど 内臓 出てねぇ!!
Dialogue: 0,0:21:14.31,0:21:17.06,Default1,,0,0,0,,これで お互い 丸腰だ!!\Nいける!!
Dialogue: 0,0:21:22.65,0:21:25.61,Default1,,0,0,0,,（リカ）なにしてるのォ？
Dialogue: 0,0:21:26.66,0:21:28.74,Default1,,0,0,0,,（虎杖）くっ… うっ…
Dialogue: 0,0:21:28.83,0:21:31.62,Default1,,0,0,0,,（乙骨）\N遊んでるだけだよ リカちゃん
Dialogue: 0,0:21:31.70,0:21:32.58,Default1,,0,0,0,,（リカ）へへっ…
Dialogue: 0,0:21:32.66,0:21:34.79,Default1,,0,0,0,,（虎杖）リカ!?　なんだ こいつ!!
Dialogue: 0,0:21:34.87,0:21:37.58,Default1,,0,0,0,,式神!?　どっから出てきた!?
Dialogue: 0,0:21:37.67,0:21:39.17,Default1,,0,0,0,,ぐっ… はぁ はぁ…
Dialogue: 0,0:21:39.25,0:21:40.46,Default1,,0,0,0,,（乙骨）抑えててね
Dialogue: 0,0:21:41.30,0:21:42.21,Default1,,0,0,0,,（虎杖）動けねぇ!!
Dialogue: 0,0:21:44.30,0:21:46.47,Default1,,0,0,0,,なんつぅ力だ!!
Dialogue: 0,0:21:53.93,0:21:55.23,Default1,,0,0,0,,（乙骨）ごめんね—
Dialogue: 0,0:22:01.90,0:22:03.40,Default1,,0,0,0,,虎杖君
Dialogue: 0,0:22:10.49,0:22:15.50,Default1,,0,0,0,,♪～
Dialogue: 0,0:23:34.91,0:23:39.91,Default1,,0,0,0,,～♪
Dialogue: 0,0:23:40.00,0:23:42.88,Default1,,0,0,0,,（直哉）弟よりデキの悪い兄なんか\Nおる意味ないやろ
Dialogue: 0,0:23:42.96,0:23:45.63,Default1,,0,0,0,,（脹相）兄弟を愛せなかった\Nオマエの気持ちは分からん
Dialogue: 0,0:23:45.71,0:23:47.71,Default1,,0,0,0,,-（乙骨）虎杖君の死は…\N-（九十九）全ての歪(ひず)みは—
Dialogue: 0,0:23:47.80,0:23:49.38,Default1,,0,0,0,,あのとき\N始まったのかもしれない
Dialogue: 0,0:23:49.47,0:23:50.38,Default1,,0,0,0,,（直哉）見下ろすなや!!
